#!/usr/bin/env ssc
---
name: actors-bounded-mailbox
description: v1.6.x bounded mailboxes — DropOldest / DropNewest / Block overflow strategies
backends: [jvm]
---

# Bounded Mailbox

```scalascript
import actors.Overflow

runActors {
  // ── DropOldest: capacity=2, 3 sends → first message dropped ──────────────
  val dropOldest = spawnBounded(2, Overflow.DropOldest, () => {
    receive { case s: String => println("drop-oldest: " + s) }
    receive { case s: String => println("drop-oldest: " + s) }
  })
  dropOldest ! "a"  // mailbox=[a]
  dropOldest ! "b"  // mailbox=[a,b] (full)
  dropOldest ! "c"  // overflow → drop "a", mailbox=[b,c]

  // ── DropNewest: capacity=2, 3rd send is silently discarded ───────────────
  val dropNewest = spawnBounded(2, Overflow.DropNewest, () => {
    receive { case s: String => println("drop-newest: " + s) }
    receive { case s: String => println("drop-newest: " + s) }
  })
  dropNewest ! "x"  // mailbox=[x]
  dropNewest ! "y"  // mailbox=[x,y] (full)
  dropNewest ! "z"  // dropped

  // ── Block: capacity=1 — sender suspends until receiver drains ─────────────
  val blockTarget = spawnBounded(1, Overflow.Block, () => {
    receive { case s: String => println("block: " + s) }
    receive { case s: String => println("block: " + s) }
  })
  blockTarget ! "first"   // fits (mailbox=[first])
  blockTarget ! "second"  // blocks root until "first" is consumed
  println("block-done")
}
```
