#!/usr/bin/env bash
# sscc — ScalaScript compiler: compiles .ssc → Scala 3 → JVM
# Usage: sscc file.ssc [file2.ssc ...]
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SSC="$SCRIPT_DIR/ssc"
# The bare `compile` subcommand was split into `compile-jvm` / `compile-js` /
# `compile-runtime`; `sscc` is the JVM compiler, so it maps to `compile-jvm`.
exec "$SSC" compile-jvm "$@"
