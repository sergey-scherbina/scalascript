      |fn _tui_table(frame: &mut Frame, area: Rect, attrs: &[(String, String)]) {
      |    use ratatui::widgets::{Table, Row};
      |    let sig = _tui_attr(attrs, "data-ssc-rows-sig").unwrap_or("");
      |    let path = _tui_attr(attrs, "data-ssc-rows-path").unwrap_or("");
      |    let row_key_path = _tui_attr(attrs, "data-ssc-row-key").unwrap_or("id");
      |    let cols = _tui_decode_cols(_tui_attr(attrs, "data-ssc-cols").unwrap_or(""));
      |    let json = crate::value::ssc_signals().lock().unwrap().get(sig).cloned().unwrap_or_default();
      |    let rows = _tui_rows_of(&json, path, row_key_path, &cols);
      |    let n = cols.len().max(1) as u32;
      |    let widths: Vec<Constraint> = (0..n).map(|_| Constraint::Ratio(1, n)).collect();
      |    let header = Row::new(cols.iter().map(|(t, _)| t.clone()).collect::<Vec<_>>())
      |        .style(Style::default().add_modifier(Modifier::BOLD));
      |    let trows: Vec<Row> = match rows {
      |        Ok(values) => values.into_iter().map(Row::new).collect(),
      |        Err(message) => vec![Row::new(vec![format!("Error: {}", message)])],
      |    };
      |    frame.render_widget(Table::new(trows, widths).header(header), area);
      |}
