-- ssc1-front.ssc0 — KC2+KC3: lexer + functional-subset parser for ScalaScript v1.0 (K61).
-- Written in ssc0 (avoids HM-unifier stack overflow; matches pattern of mira-md.ssc0).
--
-- Public API:
--   lex(src)        : String -> [Token]
--   parse(src)      : String -> [Stmt]
--   showStmts(ss)   : [Stmt] -> String
-- Token = Pair(kind, value).  Kinds: "kw" "id" "uid" "op" "int" "str"
--   "(" ")" "[" "]" "{" "}" "," ";" "." ":" "=" "=>" "->" "::" "@" "#" "EOF"
-- Stmt = Pair(tag, data).  Tags: "def" "val" "expr"
-- Expr = Pair(tag, data).  Tags: "int" "str" "bool" "var" "uid" "app" "sel" "if" "inf" "pre" "tup"

import "../lib/list.ssc0"

-- ── List helper ───────────────────────────────────────────────────────────────
-- lenLF: flat-tuple pattern lowering (Tuple${lenLF(subs)}) needs a list-length here.
-- The front is imported ALONGSIDE ssc1-lower (which also defines `lenL`), so a plain
-- `lenL` here collides ("duplicate top-level def across imported files"); a bare `lenL`
-- reference (as the sibling first wrote it) is instead UNBOUND when the front runs
-- standalone (kc3). A front-local uniquely-named helper resolves both.
def lenLF = (xs) => match xs { case Nil => 0 case Cons(h, t) => #i.add(1, lenLF(t)) }

-- ── Token helpers ─────────────────────────────────────────────────────────────
def mkTok  = (kind, val) => Pair(kind, val)
def tokKind = (t) => match t { case Pair(k, v) => k }
def tokVal  = (t) => match t { case Pair(k, v) => v }

-- ── Char predicates ───────────────────────────────────────────────────────────
def isDigit    = (c) => if #i.lt(c, 48) then false else #i.le(c, 57)
-- hex literal support (0xFF): digit-code → value (0-9/a-f/A-F), else -1
def hexDigVal = (code) =>
  if #i.ge(code, 48) then
    (if #i.le(code, 57) then #i.sub(code, 48)
     else if #i.ge(code, 97) then (if #i.le(code, 102) then #i.sub(code, 87) else #i.neg(1))
     else if #i.ge(code, 65) then (if #i.le(code, 70) then #i.sub(code, 55) else #i.neg(1))
     else #i.neg(1))
  else #i.neg(1)
def scanHexVal = (s, i, acc) =>
  if #i.ge(i, slen(s)) then Pair(acc, i)
  else let v = hexDigVal(sget(s, i)) in
    if #i.lt(v, 0) then Pair(acc, i)
    else scanHexVal(s, #i.add(i, 1), #i.add(#i.mul(acc, 16), v))
-- `0x` / `0X` prefix at position i
def isHexStart = (s, i) =>
  if #i.eq(sget(s, i), 48) then
    (let nx = nget(s, #i.add(i, 1)) in if #i.eq(nx, 120) then true else #i.eq(nx, 88))
  else false
def isLower    = (c) => if #i.lt(c, 97) then false else #i.le(c, 122)
def isUpper    = (c) => if #i.lt(c, 65) then false else #i.le(c, 90)
def isAlpha    = (c) => if isLower(c) then true else isUpper(c)
def isAlphaNum = (c) => if isAlpha(c) then true else if isDigit(c) then true else #i.eq(c, 95)
-- K62.6c-indent: newline (10) / CR (13) are NO LONGER whitespace — the lexer emits
-- an `NL <indent>` token at each line break so the layout pass can reconstruct
-- brace-less indented blocks. Only space (32) / tab (9) are inline whitespace.
def isWS       = (c) => if #i.eq(c, 32) then true else #i.eq(c, 9)

def slen = (s) => #slen(s)
def sget = (s, i) => #scodeAt(s, i)
def nget = (s, i) => if #i.ge(i, slen(s)) then #i.neg(1) else sget(s, i)
def scat = (a, b) => #sconcat(a, b)

-- ── Keyword test ──────────────────────────────────────────────────────────────
def isKwA = (s) =>
  if #seq(s, "def") then true else if #seq(s, "val") then true
  else if #seq(s, "var") then true else if #seq(s, "class") then true
  else if #seq(s, "trait") then true else if #seq(s, "object") then true
  else if #seq(s, "case") then true else if #seq(s, "given") then true else false
def isKwB = (s) =>
  if #seq(s, "using") then true else if #seq(s, "import") then true
  else if #seq(s, "match") then true else if #seq(s, "if") then true
  else if #seq(s, "else") then true else if #seq(s, "for") then true
  else if #seq(s, "yield") then true else if #seq(s, "return") then true else false
def isKwC = (s) =>
  if #seq(s, "sealed") then true else if #seq(s, "abstract") then true
  else if #seq(s, "override") then true else if #seq(s, "extends") then true
  else if #seq(s, "with") then true else if #seq(s, "new") then true
  else if #seq(s, "then") then true else if #seq(s, "do") then true else false
def isKwD = (s) =>
  if #seq(s, "true") then true else if #seq(s, "false") then true
  else if #seq(s, "null") then true else if #seq(s, "this") then true
  else if #seq(s, "type") then true else if #seq(s, "while") then true
  else if #seq(s, "effect") then true else false
def isKw = (s) =>
  if isKwA(s) then true else if isKwB(s) then true
  else if isKwC(s) then true else isKwD(s)

-- ── String utilities ──────────────────────────────────────────────────────────
def scanEnd = (pred, s, i) =>
  if #i.ge(i, slen(s)) then i
  else if pred(sget(s, i)) then scanEnd(pred, s, #i.add(i, 1))
  else i

-- Decimal separators are part of a numeric token only between digits. Starting
-- at a digit, consume digits plus `_` followed by a digit; invalid/trailing
-- underscores stay outside the token and are rejected by ordinary parsing.
def scanDecEnd = (s, i) =>
  if #i.ge(i, slen(s)) then i
  else let c = sget(s, i) in
    if isDigit(c) then scanDecEnd(s, #i.add(i, 1))
    else if #i.eq(c, 95) then
      let next = nget(s, #i.add(i, 1)) in
      if isDigit(next) then scanDecEnd(s, #i.add(i, 1)) else i
    else i

-- Scientific exponent: `i` points AT an `e`/`E`. If a valid `e[+-]?digits` follows, return its end;
-- otherwise return `i` (so `1.0e` / `1.0eX` keep the `e` as a separate identifier). Enables `1.0e100`.
def scanExponent = (s, i) =>
  if #i.ge(i, slen(s)) then i
  else
    let c = sget(s, i) in
    if if #i.eq(c, 101) then true else #i.eq(c, 69) then
      let afterE = #i.add(i, 1) in
      let afterSign =
        if #i.lt(afterE, slen(s)) then
          let sc = sget(s, afterE) in
          if #i.eq(sc, 43) then #i.add(afterE, 1)
          else if #i.eq(sc, 45) then #i.add(afterE, 1)
          else afterE
        else afterE in
      if #i.lt(afterSign, slen(s)) then
        (if isDigit(sget(s, afterSign)) then scanDecEnd(s, afterSign) else i)
      else i
    else i

def stripNumericSeparators = (s) =>
  let rec go = (i, acc) =>
    if #i.ge(i, slen(s)) then acc
    else let c = sget(s, i) in
      if #i.eq(c, 95) then go(#i.add(i, 1), acc)
      else go(#i.add(i, 1), scat(acc, #sfromCodes(Cons(c, Nil)))) in
  go(0, "")
-- Skip a quoted string nested inside a `${...}` expression. `i` is the first
-- character after its opening quote and the result is just after the closing
-- quote (or EOF). This keeps inner delimiters from terminating the outer
-- interpolated string.
def scanNestedStr = (s, i) =>
  if #i.ge(i, slen(s)) then i
  else let c = sget(s, i) in
    if #i.eq(c, 34) then #i.add(i, 1)
    else if #i.eq(c, 92) then scanNestedStr(s, #i.add(i, 2))
    else scanNestedStr(s, #i.add(i, 1))

-- Find the byte just after the matching `}` for an interpolation body. Nested
-- braces and string literals are balanced; malformed input returns EOF and is
-- subsequently rejected by the ordinary expression/parser checks.
def scanInterpEnd = (s, i, depth) =>
  if #i.ge(i, slen(s)) then i
  else let c = sget(s, i) in
    if #i.eq(c, 34) then scanInterpEnd(s, scanNestedStr(s, #i.add(i, 1)), depth)
    else if #i.eq(c, 123) then scanInterpEnd(s, #i.add(i, 1), #i.add(depth, 1))
    else if #i.eq(c, 125) then
      if #i.eq(depth, 1) then #i.add(i, 1)
      else scanInterpEnd(s, #i.add(i, 1), #i.sub(depth, 1))
    else scanInterpEnd(s, #i.add(i, 1), depth)

def scanStr = (s, i) =>
  if #i.ge(i, slen(s)) then i
  else let c = sget(s, i) in
    if #i.eq(c, 34) then i
    else if #i.eq(c, 92) then scanStr(s, #i.add(i, 2))
    else if #i.eq(c, 36) then
      if #i.eq(nget(s, #i.add(i, 1)), 123) then
        scanStr(s, scanInterpEnd(s, #i.add(i, 2), 1))
      else scanStr(s, #i.add(i, 1))
    else scanStr(s, #i.add(i, 1))

-- Triple-quoted strings are raw: find the first closing `"""` and preserve
-- every byte in between (including newlines, quotes, and backslashes).
def scanTripleEnd = (s, i) =>
  if #i.ge(i, slen(s)) then i
  else if #i.eq(sget(s, i), 34) then
    if #i.eq(nget(s, #i.add(i, 1)), 34) then
      if #i.eq(nget(s, #i.add(i, 2)), 34) then i
      else scanTripleEnd(s, #i.add(i, 1))
    else scanTripleEnd(s, #i.add(i, 1))
  else scanTripleEnd(s, #i.add(i, 1))

-- Hex-digit value (0-9 A-F a-f); non-hex → 0. Used to decode `\uXXXX` escapes.
def hexDigit = (c) =>
  if #i.ge(c, 48) then
    (if #i.le(c, 57) then #i.sub(c, 48)
     else if #i.ge(c, 65) then (if #i.le(c, 70) then #i.sub(c, 55)
       else if #i.ge(c, 97) then (if #i.le(c, 102) then #i.sub(c, 87) else 0) else 0)
     else 0)
  else 0
-- Decode 4 hex digits at `i` → code point (d0*4096 + d1*256 + d2*16 + d3).
def hex4 = (s, i) =>
  #i.add(#i.mul(hexDigit(sget(s, i)), 4096),
    #i.add(#i.mul(hexDigit(sget(s, #i.add(i, 1))), 256),
      #i.add(#i.mul(hexDigit(sget(s, #i.add(i, 2))), 16),
        hexDigit(sget(s, #i.add(i, 3))))))

def buildStr = (s, i, end, acc) =>
  if #i.ge(i, end) then acc
  else let c = sget(s, i) in
    if #i.eq(c, 92) then
      let e = nget(s, #i.add(i, 1)) in
      -- `\uXXXX` → the code-point char (advance past the 6-char escape).
      if #i.eq(e, 117) then
        buildStr(s, #i.add(i, 6), end, scat(acc, #sfromCodes(Cons(hex4(s, #i.add(i, 2)), Nil))))
      else
      -- Control-char escapes: \n \t \r \b \f. Others (\" \\ \' \/) fall to the
      -- else branch, which yields the literal char — correct for those. \r/\b/\f
      -- were missing, so `"\r"` decoded to the letter "r" (e.g. isWhitespace("\r")
      -- wrongly matched a bare "r"). Use #sfromCodes so this doesn't depend on the
      -- host lexer decoding \r/\b/\f in its own literals.
      let ec = if #i.eq(e, 110) then "\n" else if #i.eq(e, 116) then "\t"
               else if #i.eq(e, 114) then #sfromCodes(Cons(13, Nil))
               else if #i.eq(e, 98) then #sfromCodes(Cons(8, Nil))
               else if #i.eq(e, 102) then #sfromCodes(Cons(12, Nil))
               else #sfromCodes(Cons(e, Nil)) in
      buildStr(s, #i.add(i, 2), end, scat(acc, ec))
    else buildStr(s, #i.add(i, 1), end, scat(acc, #sfromCodes(Cons(c, Nil))))

-- ── Lexer ─────────────────────────────────────────────────────────────────────
-- K62.6c-indent: from `i` at a line start, count leading spaces/tabs → (indent, pos).
def countIndent = (s, i, acc) =>
  if #i.ge(i, slen(s)) then Pair(acc, i)
  else let c = sget(s, i) in
    if #i.eq(c, 32) then countIndent(s, #i.add(i, 1), #i.add(acc, 1))
    else if #i.eq(c, 9) then countIndent(s, #i.add(i, 1), #i.add(acc, 1))
    else Pair(acc, i)

-- K62.8: skip a `/* … */` block comment; `i` points at the opening `/`.
-- Returns the position just after the closing `*/` (or EOF). Nesting not handled
-- (Scala doc/block comments in the stdlib modules are non-nested).
def skipBlockComment = (s, i) =>
  let rec go = (j) =>
    if #i.ge(j, slen(s)) then j
    else if #i.eq(sget(s, j), 42) then
      if #i.eq(nget(s, #i.add(j, 1)), 47) then #i.add(j, 2)
      else go(#i.add(j, 1))
    else go(#i.add(j, 1)) in
  go(#i.add(i, 2))

-- from `i` pointing AT a newline char, skip newline(s), blank lines and comment
-- lines, and return (indent, pos) of the next real code token (or (0, EOF)).
def skipToCode = (s, i) =>
  let i1 = #i.add(i, 1) in
  match countIndent(s, i1, 0) {
    case Pair(ind, pos) =>
      if #i.ge(pos, slen(s)) then Pair(0, pos)
      else let c = sget(s, pos) in
        if #i.eq(c, 10) then skipToCode(s, pos)
        else if #i.eq(c, 13) then skipToCode(s, pos)
        else if #i.eq(c, 47) then
          if #i.eq(nget(s, #i.add(pos, 1)), 47) then
            let e = scanEnd((c2) => if #i.eq(c2, 10) then false else true, s, #i.add(pos, 2)) in
            if #i.ge(e, slen(s)) then Pair(0, e) else skipToCode(s, e)
          else if #i.eq(nget(s, #i.add(pos, 1)), 42) then
            -- `/* … */` block comment line: skip it, keep looking for code
            let e = skipBlockComment(s, pos) in
            if #i.ge(e, slen(s)) then Pair(0, e)
            else if #i.eq(sget(s, e), 10) then skipToCode(s, e)
            else Pair(ind, e)
          else Pair(ind, pos)
        else Pair(ind, pos)
  }

def skipWS = (s, i) =>
  if #i.ge(i, slen(s)) then i
  else let c = sget(s, i) in
    if isWS(c) then skipWS(s, #i.add(i, 1))
    else if #i.eq(c, 47) then
      if #i.eq(nget(s, #i.add(i, 1)), 47) then
        let j = scanEnd((c2) => if #i.eq(c2, 10) then false else true, s, #i.add(i, 2)) in
        skipWS(s, j)
      else if #i.eq(nget(s, #i.add(i, 1)), 42) then
        -- `/* … */` block comment (may span lines): skip and continue
        skipWS(s, skipBlockComment(s, i))
      else i
    else i

def lexFrom = (s, i) =>
  let i2 = skipWS(s, i) in
  if #i.ge(i2, slen(s)) then Cons(mkTok("EOF", ""), Nil)
  else let c = sget(s, i2) in
    let n = nget(s, #i.add(i2, 1)) in
    if #i.eq(c, 10) then
      match skipToCode(s, i2) {
        case Pair(ind, pos) =>
          if #i.ge(pos, slen(s)) then Cons(mkTok("EOF", ""), Nil)
          else Cons(mkTok("NL", ind), lexFrom(s, pos))
      }
    else if #i.eq(c, 13) then
      match skipToCode(s, i2) {
        case Pair(ind, pos) =>
          if #i.ge(pos, slen(s)) then Cons(mkTok("EOF", ""), Nil)
          else Cons(mkTok("NL", ind), lexFrom(s, pos))
      }
    else if isAlpha(c) then
      let e = scanEnd(isAlphaNum, s, #i.add(i2, 1)) in
      let w = #sslice(s, i2, e) in
      let kind = if isKw(w) then "kw" else if isUpper(c) then "uid" else "id" in
      Cons(mkTok(kind, w), lexFrom(s, e))
    else if #i.eq(c, 95) then
      let e = scanEnd(isAlphaNum, s, #i.add(i2, 1)) in
      Cons(mkTok("id", #sslice(s, i2, e)), lexFrom(s, e))
    else if isHexStart(s, i2) then
      -- hex literal 0xFF: scan hex digits after `0x`, emit the decimal value token
      (match scanHexVal(s, #i.add(i2, 2), 0) {
         case Pair(hv, hend) =>
           -- strip a trailing Long suffix L/l (e.g. 0x10FFFFL) just like the decimal
           -- path; without this the `L` lexed as a separate id → `unbound global: L`.
           let hL = if #i.lt(hend, slen(s)) then
             let lc = sget(s, hend) in
             if #i.eq(lc, 76) then #i.add(hend, 1)
             else if #i.eq(lc, 108) then #i.add(hend, 1)
             else hend
           else hend in
           Cons(mkTok("int", #i->str(hv)), lexFrom(s, hL))
       })
    else if isDigit(c) then
      let e = scanDecEnd(s, i2) in
      -- float: digit '.' digit (e.g. 3.14159, 0.5, 1.0)
      let nextIsDot = if #i.lt(e, slen(s)) then #i.eq(sget(s, e), 46) else false in
      let nextDotIsFloat = if nextIsDot then
        if #i.lt(#i.add(e, 1), slen(s)) then isDigit(sget(s, #i.add(e, 1)))
        else false
      else false in
      if nextDotIsFloat then
        let e2 = scanDecEnd(s, #i.add(e, 1)) in
        let e3 = scanExponent(s, e2) in       -- optional scientific exponent (`1.0e100`)
        Cons(mkTok("float", stripNumericSeparators(#sslice(s, i2, e3))), lexFrom(s, e3))
      else
      -- `1e10` (no decimal point) is still a float in Scala.
      let eExp = scanExponent(s, e) in
      if #i.gt(eExp, e) then
        Cons(mkTok("float", stripNumericSeparators(#sslice(s, i2, eExp))), lexFrom(s, eExp))
      else
      -- strip Long suffix L/l (e.g. 0L, 2862933555777941757L)
      let eL = if #i.lt(e, slen(s)) then
        let lc = sget(s, e) in
        if #i.eq(lc, 76) then #i.add(e, 1)
        else if #i.eq(lc, 108) then #i.add(e, 1)
        else e
      else e in
      Cons(mkTok("int", stripNumericSeparators(#sslice(s, i2, e))), lexFrom(s, eL))
    else if #i.eq(c, 34) then
      if #i.eq(n, 34) then
        if #i.eq(nget(s, #i.add(i2, 2)), 34) then
          let start = #i.add(i2, 3) in
          let e = scanTripleEnd(s, start) in
          Cons(mkTok("str", #sslice(s, start, e)), lexFrom(s, #i.add(e, 3)))
        else
          let e = scanStr(s, #i.add(i2, 1)) in
          Cons(mkTok("str", buildStr(s, #i.add(i2, 1), e, "")), lexFrom(s, #i.add(e, 1)))
      else
        let e = scanStr(s, #i.add(i2, 1)) in
        Cons(mkTok("str", buildStr(s, #i.add(i2, 1), e, "")), lexFrom(s, #i.add(e, 1)))
    else if #i.eq(c, 40)  then Cons(mkTok("(", ""),   lexFrom(s, #i.add(i2, 1)))
    else if #i.eq(c, 41)  then Cons(mkTok(")", ""),   lexFrom(s, #i.add(i2, 1)))
    else if #i.eq(c, 91)  then Cons(mkTok("[", ""),   lexFrom(s, #i.add(i2, 1)))
    else if #i.eq(c, 93)  then Cons(mkTok("]", ""),   lexFrom(s, #i.add(i2, 1)))
    else if #i.eq(c, 123) then Cons(mkTok("{", ""),   lexFrom(s, #i.add(i2, 1)))
    else if #i.eq(c, 125) then Cons(mkTok("}", ""),   lexFrom(s, #i.add(i2, 1)))
    else if #i.eq(c, 44)  then Cons(mkTok(",", ""),   lexFrom(s, #i.add(i2, 1)))
    else if #i.eq(c, 59)  then Cons(mkTok(";", ""),   lexFrom(s, #i.add(i2, 1)))
    else if #i.eq(c, 64)  then Cons(mkTok("@", ""),   lexFrom(s, #i.add(i2, 1)))
    else if #i.eq(c, 35)  then Cons(mkTok("#", ""),   lexFrom(s, #i.add(i2, 1)))
    else if #i.eq(c, 39)  then
      -- K62.6c: char literal 'x' or '\n' → int token (its code); the VM treats
      -- chars as codes (scodeAt, comparisons), so 'a' == c works.
      if #i.eq(sget(s, #i.add(i2, 1)), 92) then
        let e = sget(s, #i.add(i2, 2)) in
        -- '\uXXXX' → code point; the literal is 8 chars ('\uXXXX' + closing quote).
        if #i.eq(e, 117) then
          Cons(mkTok("int", #i->str(hex4(s, #i.add(i2, 3)))), lexFrom(s, #i.add(i2, 8)))
        else
        let code = if #i.eq(e, 110) then 10 else if #i.eq(e, 116) then 9
                   else if #i.eq(e, 114) then 13 else if #i.eq(e, 48) then 0 else e in
        Cons(mkTok("int", #i->str(code)), lexFrom(s, #i.add(i2, 4)))
      else
        Cons(mkTok("int", #i->str(sget(s, #i.add(i2, 1)))), lexFrom(s, #i.add(i2, 3)))
    -- two-char operators that get own kind
    else if #i.eq(c, 61) then
      if #i.eq(n, 62) then Cons(mkTok("=>", ""), lexFrom(s, #i.add(i2, 2)))    -- =>
      else if #i.eq(n, 61) then Cons(mkTok("op", "=="), lexFrom(s, #i.add(i2, 2))) -- ==
      else Cons(mkTok("=", ""), lexFrom(s, #i.add(i2, 1)))                       -- =
    else if #i.eq(c, 58) then
      -- `:::` list concat. In v2 every Seq is a Cons-list, so `xs ::: ys` is exactly
      -- `xs ++ ys` (concatenation; the result is identical regardless of associativity).
      -- Reuse the `++` op lowering. (Was lexed as `::` + a bare `:` → `_err`.)
      if #i.eq(n, 58) then
        (if #i.eq(nget(s, #i.add(i2, 2)), 58) then Cons(mkTok("op", "++"), lexFrom(s, #i.add(i2, 3)))  -- :::
         else Cons(mkTok("::", ""), lexFrom(s, #i.add(i2, 2))))     -- ::
      else if #i.eq(n, 43) then Cons(mkTok("op", ":+"), lexFrom(s, #i.add(i2, 2))) -- :+
      else if #i.eq(n, 61) then Cons(mkTok("op", ":="), lexFrom(s, #i.add(i2, 2))) -- := (DSL op)
      else Cons(mkTok(":", ""), lexFrom(s, #i.add(i2, 1)))                       -- :
    else if #i.eq(c, 46) then
      if #i.eq(n, 46) then Cons(mkTok("op", ".."), lexFrom(s, #i.add(i2, 2)))   -- ..
      else Cons(mkTok(".", ""), lexFrom(s, #i.add(i2, 1)))                       -- .
    else if #i.eq(c, 45) then
      if #i.eq(n, 62) then Cons(mkTok("->", ""), lexFrom(s, #i.add(i2, 2)))     -- ->
      else if #i.eq(n, 61) then Cons(mkTok("op", "-="), lexFrom(s, #i.add(i2, 2))) -- -=
      else Cons(mkTok("op", "-"), lexFrom(s, #i.add(i2, 1)))
    else if #i.eq(c, 60) then
      if #i.eq(n, 126) then Cons(mkTok("op", "<~"), lexFrom(s, #i.add(i2, 2)))
      else if #i.eq(n, 61) then Cons(mkTok("op", "<="), lexFrom(s, #i.add(i2, 2)))
      else if #i.eq(n, 45) then Cons(mkTok("<-", ""), lexFrom(s, #i.add(i2, 2)))       -- K62.6c: for-generator arrow
      else if #i.eq(n, 62) then Cons(mkTok("op", "<>"), lexFrom(s, #i.add(i2, 2)))
      else if #i.eq(n, 60) then Cons(mkTok("op", "<<"), lexFrom(s, #i.add(i2, 2)))  -- K62.6c: shift-left
      else Cons(mkTok("op", "<"), lexFrom(s, #i.add(i2, 1)))
    else if #i.eq(c, 62) then
      if #i.eq(n, 61) then Cons(mkTok("op", ">="), lexFrom(s, #i.add(i2, 2)))
      else if #i.eq(n, 62) then
        if #i.eq(sget(s, #i.add(i2, 2)), 62) then Cons(mkTok("op", ">>>"), lexFrom(s, #i.add(i2, 3)))  -- unsigned shift-right
        else Cons(mkTok("op", ">>"), lexFrom(s, #i.add(i2, 2)))   -- K62.6c: shift-right
      else Cons(mkTok("op", ">"), lexFrom(s, #i.add(i2, 1)))
    else if #i.eq(c, 33) then
      if #i.eq(n, 61) then Cons(mkTok("op", "!="), lexFrom(s, #i.add(i2, 2)))
      else Cons(mkTok("op", "!"), lexFrom(s, #i.add(i2, 1)))
    else if #i.eq(c, 38) then
      if #i.eq(n, 38) then
        (if #i.eq(nget(s, #i.add(i2, 2)), 61) then Cons(mkTok("op", "&&="), lexFrom(s, #i.add(i2, 3)))
         else Cons(mkTok("op", "&&"), lexFrom(s, #i.add(i2, 2))))
      else Cons(mkTok("op", "&"), lexFrom(s, #i.add(i2, 1)))
    else if #i.eq(c, 124) then
      if #i.eq(n, 124) then
        (if #i.eq(nget(s, #i.add(i2, 2)), 61) then Cons(mkTok("op", "||="), lexFrom(s, #i.add(i2, 3)))
         else Cons(mkTok("op", "||"), lexFrom(s, #i.add(i2, 2))))
      else Cons(mkTok("op", "|"), lexFrom(s, #i.add(i2, 1)))
    else if #i.eq(c, 43) then
      if #i.eq(n, 43) then Cons(mkTok("op", "++"), lexFrom(s, #i.add(i2, 2)))
      else if #i.eq(n, 61) then Cons(mkTok("op", "+="), lexFrom(s, #i.add(i2, 2)))
      -- `+:` prepend. In v2 every Seq is a Cons-list, so `x +: xs` is exactly
      -- `x :: xs`; reuse the `::` token's right-associativity and Cons lowering.
      -- (Was unlexed → parsed as a bare `+` then `:` → `_err` unbound global.)
      else if #i.eq(n, 58) then Cons(mkTok("::", ""), lexFrom(s, #i.add(i2, 2)))
      else Cons(mkTok("op", "+"), lexFrom(s, #i.add(i2, 1)))
    else if #i.eq(c, 42) then
      if #i.eq(n, 42) then Cons(mkTok("op", "**"), lexFrom(s, #i.add(i2, 2)))
      else if #i.eq(n, 61) then Cons(mkTok("op", "*="), lexFrom(s, #i.add(i2, 2))) -- *=
      else Cons(mkTok("op", "*"), lexFrom(s, #i.add(i2, 1)))
    else if #i.eq(c, 126) then
      if #i.eq(n, 62) then Cons(mkTok("op", "~>"), lexFrom(s, #i.add(i2, 2)))
      else Cons(mkTok("op", "~"), lexFrom(s, #i.add(i2, 1)))
    else if #i.eq(c, 63) then
      -- ??? = notImplemented (Scala Predef). Only the triple form is meaningful.
      if #i.eq(n, 63) then
        if #i.eq(nget(s, #i.add(i2, 2)), 63) then Cons(mkTok("id", "???"), lexFrom(s, #i.add(i2, 3)))
        else Cons(mkTok("op", "?"), lexFrom(s, #i.add(i2, 1)))
      else Cons(mkTok("op", "?"), lexFrom(s, #i.add(i2, 1)))
    else
      Cons(mkTok("op", #sslice(s, i2, #i.add(i2, 1))), lexFrom(s, #i.add(i2, 1)))

def lex = (src) => lexFrom(src, 0)

-- ── AST (tag-based encoding) ──────────────────────────────────────────────────
def mkInt   = (n)        => Pair("int",   n)
def mkFloat = (n)        => Pair("float", n)
def mkStr  = (s)        => Pair("str",  s)
def mkBool = (b)        => Pair("bool", b)
def mkVar  = (n)        => Pair("var",  n)
def mkUVar = (n)        => Pair("uid",  n)
def mkSel  = (e, n)     => Pair("sel",  Pair(e, n))
def mkApp  = (f, args)  => Pair("app",  Pair(f, args))
def mkNArg = (label, e) => Pair("narg", Pair(label, e))
def mkLam  = (ps, e)    => Pair("lam",  Pair(ps, e))
def mkIf   = (c, t, el) => Pair("if",   Pair(c, Pair(t, el)))
def mkInf  = (op, l, r) => Pair("inf",  Pair(op, Pair(l, r)))
def mkPre  = (op, e)    => Pair("pre",  Pair(op, e))
def mkTup  = (es)       => Pair("tup",  es)
def mkDef  = (n, ps, e) => Pair("def",  Pair(n, Pair(ps, e)))
-- Preserve whether a zero-parameter declaration omitted the parameter clause.
-- `def value: T = rhs` auto-applies on bare reference; `def value(): T = rhs`
-- remains an explicit-empty-parens method. CoreIR arity alone cannot recover
-- this source distinction, so keep a transparent AST marker around the body.
def mkParameterlessBody = (e) => Pair("parameterless", e)
def mkVal  = (n, e)     => Pair("val",  Pair(n, e))
def mkSExpr = (e)       => Pair("expr", e)

-- ParseResult helpers
def pr     = (v, ts)    => Pair(v, ts)
def prV    = (r)        => match r { case Pair(v, t) => v }
def prT    = (r)        => match r { case Pair(v, t) => t }

-- ── Parser utilities ──────────────────────────────────────────────────────────
def peek = (toks) =>
  match toks { case Nil => mkTok("EOF", "") case Cons(t, r) => t }
def advance = (toks) =>
  match toks { case Nil => Nil case Cons(t, r) => r }
def kindIs  = (k, toks) => #seq(tokKind(peek(toks)), k)
def kwIs    = (kw, toks) =>
  if #seq(tokKind(peek(toks)), "kw") then #seq(tokVal(peek(toks)), kw) else false
def opIs    = (op, toks) =>
  if #seq(tokKind(peek(toks)), "op") then #seq(tokVal(peek(toks)), op) else false
def skipKind = (k, toks) => if kindIs(k, toks) then advance(toks) else toks
def skipKw   = (kw, toks) => if kwIs(kw, toks) then advance(toks) else toks

-- Skip type annotation  ': Type'  (stop at '=' ')' ',' '{' 'EOF')
-- skipType: skip a type expression, respecting nested [...] and (...)
-- delimiters. Function types such as `() => String` appear inside an outer
-- parameter list; their inner `)` must not terminate that outer list.
-- Stops at = ) , { EOF at depth 0; continues through nested delimiters.
def skipTypeAt = (depth, toks) =>
  let t = peek(toks) in
  let k = tokKind(t) in
  if #seq(k, "EOF") then toks
  else if #seq(k, "[") then skipTypeAt(#i.add(depth, 1), advance(toks))
  else if #seq(k, "(") then skipTypeAt(#i.add(depth, 1), advance(toks))
  else if #seq(k, "]") then
    if #i.eq(depth, 0) then toks
    else skipTypeAt(#i.sub(depth, 1), advance(toks))
  else if #seq(k, ")") then
    if #i.eq(depth, 0) then toks
    else skipTypeAt(#i.sub(depth, 1), advance(toks))
  else if #i.gt(depth, 0) then skipTypeAt(depth, advance(toks))
  else if #seq(k, "=") then toks
  else if #seq(k, ",") then toks
  else if #seq(k, ";") then toks
  else if #seq(k, "{") then toks
  else if #seq(k, "}") then toks
  else skipTypeAt(depth, advance(toks))

def skipType = (toks) => skipTypeAt(0, toks)

def skipTypeAnnot = (toks) =>
  if kindIs(":", toks) then skipType(advance(toks)) else toks

-- A match-pattern annotation has two additional depth-zero terminators that
-- cannot be added to skipTypeAt: `=>` and guard `if` delimit the arm, while a
-- general type may itself contain an unwrapped function arrow. Keep the same
-- nested []/() discipline and specialize only the arm boundary.
def skipPatternTypeAt = (depth, toks) =>
  let t = peek(toks) in
  let k = tokKind(t) in
  if #seq(k, "EOF") then toks
  else if #seq(k, "[") then skipPatternTypeAt(#i.add(depth, 1), advance(toks))
  else if #seq(k, "(") then skipPatternTypeAt(#i.add(depth, 1), advance(toks))
  else if #seq(k, "]") then
    if #i.eq(depth, 0) then toks
    else skipPatternTypeAt(#i.sub(depth, 1), advance(toks))
  else if #seq(k, ")") then
    if #i.eq(depth, 0) then toks
    else skipPatternTypeAt(#i.sub(depth, 1), advance(toks))
  else if #i.gt(depth, 0) then skipPatternTypeAt(depth, advance(toks))
  else if #seq(k, "=>") then toks
  else if kwIs("if", toks) then toks
  else if #seq(k, "=") then toks
  else if #seq(k, ",") then toks
  else if #seq(k, "{") then toks
  else if #seq(k, "}") then toks
  else skipPatternTypeAt(depth, advance(toks))

def skipPatternTypeAnnot = (toks) =>
  if kindIs(":", toks) then skipPatternTypeAt(0, advance(toks)) else toks

-- Retain the outer portable nominal head of a typed match binder. Nested type
-- arguments remain syntax-only after their balanced boundary is consumed;
-- platform/reflection types are not introduced by this structural tag.
def patternTypeHead = (toks) =>
  if kindIs(":", toks) then
    let ts = advance(toks) in
    let t = peek(ts) in
    let k = tokKind(t) in
    if #seq(k, "uid") then tokVal(t)
    else if #seq(k, "id") then tokVal(t)
    else ""
  else ""

-- ── K62.17: default-parameter registry (call-site default synthesis) ──────────
-- ssc1-lower `import`s ssc1-front and both run in ONE ssc0 process, so these
-- top-level cells are SHARED: the front populates them during parse; lowerProg
-- reads funcDefaultsCell for call-site synthesis. paramDefaultsCell accumulates
-- the current param list's defaults [Pair(name, dfltExpr)]; parseDef snapshots it
-- into funcDefaultsCell as Pair(funcName, Pair(paramNames, positionalDefaults))
-- — one entry per param, either the default expr AST or the
-- Pair("__nodflt__", "") sentinel. Constructors share the same registry.
def paramDefaultsCell = #cell.new(Nil)
def funcDefaultsCell  = #cell.new(Nil)
-- Names of defs whose LAST parameter is a repeated (vararg) `T*` param. ssc1-lower
-- reads it (same self-hosted process) to PACK a call's trailing arguments into a
-- single Cons-list, since the def body binds that param as one list value
-- (`children.toList`). Without packing, `card(a, b)` / `vstack(g)(a, b)` reach the
-- def as N unpacked args and fail the CoreIR arity check ("N expected, M given").
def varargDefsCell = #cell.new(Nil)
-- Set by parseParam to the varargness of the parameter it just parsed; parseDef
-- reads it after the whole (possibly multi-clause) parameter list to learn whether
-- the trailing param was a vararg (Scala requires a vararg to be last).
def lastParamVarargCell = #cell.new(false)
-- Nominal subtype registry: [Pair(parentType, childTag)] captured from a case
-- class's `extends Parent`. ssc1-lower reads it (same self-hosted process) to
-- EXPAND a `case _: Parent` type-ascription into an OR over the child tags
-- (the VM's __isTag__ is an exact tag test; sealed-trait membership must be
-- expanded at lower time, mirroring the scalameta bridge).
def subtypeRegCell = #cell.new(Nil)
-- Typeclass/trait nominal hierarchy: [Pair(childTC, parentTC)] from `trait Child extends Parent`.
-- ssc1-lower reads it (shared process) so a `given X: Child[T]` also satisfies `Parent[T]` lookups
-- (e.g. a Monoid[Int] given resolves a Semigroup[Int] context bound).
def tcExtendsCell = #cell.new(Nil)
-- Case-class BODY methods: [Pair(tag, Pair(fields, defs))] where defs are the
-- captured `def` nodes (e.g. `override def toString`). ssc1-lower emits each as a
-- `Tag_method(self, …)` global (fields bound from self) + registers it so the VM's
-- __method__ dispatch calls it instead of the default DataV rendering/no-op.
-- --mutable compiler flag: enables mutable `var` fields in classes. Set from argv
-- by the tower mains (ssc1-run / ssc1-check-run). `mutableViolationCell` records a
-- `var` field seen while the flag is OFF, so parseCaseClass can emit the specific
-- `_err_mutable_fields` sentinel. `mutableFieldsCell` records, per class tag, the
-- names of `var` fields (flag ON) so the lowerer can cell-back them.
def mutableFlagCell      = #cell.new(false)
def mutableViolationCell = #cell.new(false)
def mutableFieldsCell    = #cell.new(Nil)
def pendingVarFieldsCell = #cell.new(Nil)
-- Body-declared `var`/`lazy val` fields of a class (a body `val` is desugared to a
-- nullary method instead). classBodyFieldsCell = [Pair(className, [Pair(name, Pair(init, kind))])],
-- kind ∈ {"var","lazy"}. The lowerer synthesizes a constructor that computes them.
def classBodyFieldsCell   = #cell.new(Nil)
def pendingBodyFieldsCell = #cell.new(Nil)

def caseMethodsCell = #cell.new(Nil)
def registerCaseMethods = (name, fields, defs) =>
  match defs {
    case Nil => 0
    case Cons(h, t) =>
      #cell.set(caseMethodsCell,
        Cons(Pair(name, Pair(fields, defs)), #cell.get(caseMethodsCell)))
  }
-- Active top-level extension group and the unique method names it declares.
-- ssc1-lower reads extensionMethodsCell in the same self-hosted process.
def extensionParamsCell  = #cell.new(Nil)
def extensionMethodsCell = #cell.new(Nil)
-- Named `using` param resolution: `def f(a)(using s: Show[A])` needs the Show given auto-injected at
-- the call site (like a context bound, but the given goes at the END, after regular args, and the
-- param keeps its name `s`). usingSigCell maps defName → Pair([usingTypeStr], fullArgCount); ssc1-lower
-- reads it in injectGivens (shared process). pendingUsingTypesCell is transient per parseUsingParams.
def usingSigCell = #cell.new(Nil)
def pendingUsingTypesCell = #cell.new(Nil)
def dfltLookup = (nm, dflts) =>
  match dflts {
    case Nil => Pair("__nodflt__", "")
    case Cons(h, t) =>
      match h { case Pair(pn, pe) => if #seq(pn, nm) then pe else dfltLookup(nm, t) }
  }
def dfltIsNone = (d) =>
  match d { case Pair(tg, e) => #seq(tg, "__nodflt__") }
def anyDflt = (params, dflts) =>
  match params {
    case Nil => false
    case Cons(p, rest) =>
      if dfltIsNone(dfltLookup(p, dflts)) then anyDflt(rest, dflts) else true
  }
def positionalDflts = (params, dflts) =>
  match params {
    case Nil => Nil
    case Cons(p, rest) => Cons(dfltLookup(p, dflts), positionalDflts(rest, dflts))
  }
def registerParamDflts = (name, params) =>
  let dflts = #cell.get(paramDefaultsCell) in
  if anyDflt(params, dflts) then
    #cell.set(funcDefaultsCell,
      Cons(Pair(name, Pair(params, positionalDflts(params, dflts))),
        #cell.get(funcDefaultsCell)))
  else 0

-- ── Parameter list parser ─────────────────────────────────────────────────────
-- Whether a `: T*` type annotation ends in a bare `*` (repeated/vararg marker).
-- Mirrors skipTypeAt's nesting/terminator discipline; `lastStar` tracks whether the
-- most recent depth-0 type token was `*`, so nested `List[A]*` etc. report correctly.
def typeStarScan = (depth, toks, lastStar) =>
  let t = peek(toks) in
  let k = tokKind(t) in
  if #seq(k, "EOF") then lastStar
  else if #seq(k, "[") then typeStarScan(#i.add(depth, 1), advance(toks), false)
  else if #seq(k, "(") then typeStarScan(#i.add(depth, 1), advance(toks), false)
  else if #seq(k, "]") then
    if #i.eq(depth, 0) then lastStar else typeStarScan(#i.sub(depth, 1), advance(toks), false)
  else if #seq(k, ")") then
    if #i.eq(depth, 0) then lastStar else typeStarScan(#i.sub(depth, 1), advance(toks), false)
  else if #i.gt(depth, 0) then typeStarScan(depth, advance(toks), false)
  else if #seq(k, "=") then lastStar
  else if #seq(k, ",") then lastStar
  else if #seq(k, ";") then lastStar
  else if #seq(k, "{") then lastStar
  else if #seq(k, "}") then lastStar
  else typeStarScan(depth, advance(toks),
    if #seq(k, "op") then #seq(tokVal(t), "*") else false)
def paramTypeIsVararg = (toks) =>
  if kindIs(":", toks) then typeStarScan(0, advance(toks), false) else false

def parseParam = (toks) =>
  if #seq(tokKind(peek(toks)), "id") then
    let name = tokVal(peek(toks)) in
    let _vararg = #cell.set(lastParamVarargCell, paramTypeIsVararg(advance(toks))) in
    let ts1 = skipTypeAnnot(advance(toks)) in
    -- K62.6g/K62.17: default value `param: T = expr` — parse the default AND record it
    -- in paramDefaultsCell so parseDef can register it for call-site synthesis.
    if kindIs("=", ts1) then
      let rd = parseExpr(advance(ts1)) in
      let _rec = #cell.set(paramDefaultsCell,
                   Cons(Pair(name, prV(rd)), #cell.get(paramDefaultsCell))) in
      pr(name, prT(rd))
    else pr(name, ts1)
  else
    let _nv = #cell.set(lastParamVarargCell, false) in
    pr("_", toks)

def parseParamList = (toks) =>
  if kindIs("(", toks) then
    let toks2 = advance(toks) in
    if kindIs(")", toks2) then pr(Nil, advance(toks2))
    else
      let rec goParams = (ts, acc) =>
        let r = parseParam(ts) in
        let acc2 = Cons(prV(r), acc) in
        let ts2 = prT(r) in
        if kindIs(",", ts2) then
          -- Trailing comma before `)` in a multi-line `def` param list must NOT start
          -- another param (parseParam on `)` falls to its `_` fallback → phantom param
          -- → def lowered at arity N+1, so a full call fails "arity N+1 expected, N given").
          let tsAfterComma = advance(ts2) in
          if kindIs(")", tsAfterComma) then pr(reverse(acc2), tsAfterComma)
          else goParams(tsAfterComma, acc2)
        else pr(reverse(acc2), ts2) in
      let r = goParams(toks2, Nil) in
      pr(prV(r), skipKind(")", prT(r)))
  else pr(Nil, toks)

-- ── KC12: string interpolation helpers ───────────────────────────────────────
-- Walk string raw from i, return index of first non-alphanumeric-or-underscore
def readInterpId = (raw, i) =>
  if #i.ge(i, slen(raw)) then i
  else if isAlphaNum(sget(raw, i)) then readInterpId(raw, #i.add(i, 1))
  else i

-- Split interpolated string into list of Pair("str",literal)|Pair("var",name)
def interpParts = (raw) =>
  let len = slen(raw) in
  let rec go = (i, litStart, acc) =>
    if #i.ge(i, len) then
      let lit = #sslice(raw, litStart, len) in
      let acc2 = if #i.eq(slen(lit), 0) then acc else Cons(Pair("str", lit), acc) in
      reverse(acc2)
    else
      let c = sget(raw, i) in
      if #i.eq(c, 36) then
        let i1 = #i.add(i, 1) in
        if #i.ge(i1, len) then go(#i.add(i, 1), litStart, acc)
        else
          let c2 = sget(raw, i1) in
          if #i.eq(c2, 123) then
            -- ${expr}: balance nested braces/strings, parse the complete inner
            -- expression, and splice its AST into the concatenation.
            let i2 = #i.add(i1, 1) in
            let iAfter = scanInterpEnd(raw, i2, 1) in
            let exprEnd = if #i.gt(iAfter, i2) then
              if #i.eq(sget(raw, #i.sub(iAfter, 1)), 125) then #i.sub(iAfter, 1)
              else len
            else len in
            let lit = #sslice(raw, litStart, i) in
            let acc2 = if #i.eq(slen(lit), 0) then acc else Cons(Pair("str", lit), acc) in
            let exprSrc = #sslice(raw, i2, exprEnd) in
            go(iAfter, iAfter, Cons(Pair("expr", exprSrc), acc2))
          else if isAlpha(c2) then
            -- $name: flush literal, extract identifier
            let lit = #sslice(raw, litStart, i) in
            let acc2 = if #i.eq(slen(lit), 0) then acc else Cons(Pair("str", lit), acc) in
            let endId = readInterpId(raw, i1) in
            let name = #sslice(raw, i1, endId) in
            go(endId, endId, Cons(Pair("var", name), acc2))
          else go(#i.add(i, 1), litStart, acc)
      else go(#i.add(i, 1), litStart, acc) in
  go(0, 0, Nil)

-- Build ++ concatenation AST from parts list
def partsToExpr = (parts) =>
  match parts {
    case Nil => mkStr("")
    case Cons(p, rest) =>
      let pexpr = match p {
        case Pair(pkind, pval) =>
          if #seq(pkind, "str") then mkStr(pval)
          else if #seq(pkind, "expr") then prV(parseExpr(lex(pval)))
          else mkVar(pval)
      } in
      match rest {
        case Nil => pexpr
        case _ => Pair("inf", Pair("++", Pair(pexpr, partsToExpr(rest))))
      }
  }

def buildSInterp = (raw) => partsToExpr(interpParts(raw))

-- `md"..."` is the normative language interpolator from SPEC.md §5.7. Reuse
-- the complete s-interpolation parser, then route the resulting String through
-- the portable indent-strip primitive. Emitting the prim here keeps `md` out
-- of runtime/global resolution and needs no host parser or provider.
def buildMdInterp = (raw) =>
  Pair("prim", Pair("__mdStrip__", Cons(buildSInterp(raw), Nil)))

-- K62.26b: f"" format specifiers. In an f-string a ${expr} may be followed by a printf
-- spec  %[-#+ 0,(<]*[width][.prec]<letter>  at the front of the NEXT literal (f"$x%-4s").
-- splitFFormatPrefix peels that spec off (default "%s" when absent). buildFInterp emits
-- app(var("__fInterpolate__"), [head, spec,arg,rest, …]); the lowerer routes it to the
-- __fInterpolate__ prim (runtime String.format). Char codes: %=37 .=46 flags -#+ 0,(< .
def isFmtFlag = (c) =>
  if #i.eq(c, 45) then true else if #i.eq(c, 35) then true
  else if #i.eq(c, 43) then true else if #i.eq(c, 32) then true
  else if #i.eq(c, 48) then true else if #i.eq(c, 44) then true
  else if #i.eq(c, 40) then true else #i.eq(c, 60)

def splitFFormatPrefix = (part) =>
  let len = slen(part) in
  if #i.eq(len, 0) then Pair("%s", part)
  else if #i.eq(sget(part, 0), 37) then
    let rec scanFlags = (i) =>
      if #i.ge(i, len) then i
      else if isFmtFlag(sget(part, i)) then scanFlags(#i.add(i, 1)) else i in
    let rec scanDigits = (i) =>
      if #i.ge(i, len) then i
      else if isDigit(sget(part, i)) then scanDigits(#i.add(i, 1)) else i in
    let i1 = scanFlags(1) in
    let i2 = scanDigits(i1) in
    let i3 = if #i.lt(i2, len) then
               (if #i.eq(sget(part, i2), 46) then scanDigits(#i.add(i2, 1)) else i2)
             else i2 in
    if #i.lt(i3, len) then
      (if isAlpha(sget(part, i3)) then
         let specEnd = #i.add(i3, 1) in
         Pair(#sslice(part, 0, specEnd), #sslice(part, specEnd, len))
       else Pair("%s", part))
    else Pair("%s", part)
  else Pair("%s", part)

def mkFInterpCall = (args) => Pair("app", Pair(Pair("var", "__fInterpolate__"), args))

def fArgExpr = (part) =>
  match part { case Pair(ak, av) =>
    if #seq(ak, "expr") then prV(parseExpr(lex(av))) else mkVar(av) }

def goFArgs = (parts) =>
  match parts {
    case Nil => Nil
    case Cons(arg, rest) =>
      let ae = fArgExpr(arg) in
      match rest {
        case Nil => Cons(mkStr("%s"), Cons(ae, Cons(mkStr(""), Nil)))
        case Cons(nxt, rest2) =>
          match nxt { case Pair(nk, nv) =>
            if #seq(nk, "str") then
              match splitFFormatPrefix(nv) {
                case Pair(spec, r) =>
                  Cons(mkStr(spec), Cons(ae, Cons(mkStr(r), goFArgs(rest2))))
              }
            else Cons(mkStr("%s"), Cons(ae, Cons(mkStr(""), goFArgs(rest)))) }
      }
  }

def buildFInterp = (raw) =>
  let parts = interpParts(raw) in
  match parts {
    case Nil => mkStr("")
    case Cons(p0, rest0) =>
      match p0 { case Pair(pk, pv) =>
        if #seq(pk, "str") then mkFInterpCall(Cons(mkStr(pv), goFArgs(rest0)))
        else mkFInterpCall(Cons(mkStr(""), goFArgs(parts))) }
  }

-- K62.6c: underscore-placeholder support. An argument expression that CONTAINS a
-- `_` (ph) but isn't a bare `_` becomes `x => <expr with ph→x>` — e.g.
-- filter(_ % 2 == 0) → filter(x => x % 2 == 0). Bare f(_) is left as-is (rarer).
def exprHasPh = (e) =>
  match e {
    case Pair(t, d) =>
      if #seq(t, "ph") then true
      else if #seq(t, "inf") then
        match d { case Pair(op, lr) => match lr { case Pair(l, r) =>
          if exprHasPh(l) then true else exprHasPh(r) } }
      else if #seq(t, "pre") then match d { case Pair(op, s) => exprHasPh(s) }
      else if #seq(t, "app") then
        match d { case Pair(f, args) =>
          if exprHasPh(f) then true else phInArgs(args) }
      else if #seq(t, "sel") then match d { case Pair(o, fld) => exprHasPh(o) }
      else false
  }
def phInArgs = (args) =>
  match args { case Nil => false case Cons(a, r) => if exprHasPh(a) then true else phInArgs(r) }

def replacePh = (e, vn) =>
  match e {
    case Pair(t, d) =>
      if #seq(t, "ph") then Pair("var", vn)
      else if #seq(t, "inf") then
        match d { case Pair(op, lr) => match lr { case Pair(l, r) =>
          Pair("inf", Pair(op, Pair(replacePh(l, vn), replacePh(r, vn)))) } }
      else if #seq(t, "pre") then
        match d { case Pair(op, s) => Pair("pre", Pair(op, replacePh(s, vn))) }
      else if #seq(t, "app") then
        match d { case Pair(f, args) => Pair("app", Pair(replacePh(f, vn), replacePhArgs(args, vn))) }
      else if #seq(t, "sel") then
        match d { case Pair(o, fld) => Pair("sel", Pair(replacePh(o, vn), fld)) }
      else e
  }
def replacePhArgs = (args, vn) =>
  match args { case Nil => Nil case Cons(a, r) => Cons(replacePh(a, vn), replacePhArgs(r, vn)) }

-- K62.29: each `_` in a placeholder expression is a DISTINCT parameter left-to-right, so
-- `_ + _` is `(a, b) => a + b` (arity 2), not `__u => __u + __u` (arity 1, which crashed
-- foldLeft/reduce with "arity: 1 expected, 2 given"). Count placeholders, bind each to __u<i>
-- in traversal order, and emit an N-arg lambda.
def countPh = (e) =>
  match e {
    case Pair(t, d) =>
      if #seq(t, "ph") then 1
      else if #seq(t, "inf") then
        match d { case Pair(op, lr) => match lr { case Pair(l, r) =>
          #i.add(countPh(l), countPh(r)) } }
      else if #seq(t, "pre") then match d { case Pair(op, s) => countPh(s) }
      else if #seq(t, "app") then
        match d { case Pair(f, args) => #i.add(countPh(f), countPhArgs(args)) }
      else if #seq(t, "sel") then match d { case Pair(o, fld) => countPh(o) }
      else 0
  }
def countPhArgs = (args) =>
  match args { case Nil => 0 case Cons(a, r) => #i.add(countPh(a), countPhArgs(r)) }

-- replace placeholders left-to-right with __u<idx>; returns Pair(newExpr, nextIdx)
def replacePhSeq = (e, idx) =>
  match e {
    case Pair(t, d) =>
      if #seq(t, "ph") then Pair(Pair("var", #sconcat("__u", #i->str(idx))), #i.add(idx, 1))
      else if #seq(t, "inf") then
        match d { case Pair(op, lr) => match lr { case Pair(l, r) =>
          match replacePhSeq(l, idx) { case Pair(nl, i1) =>
            match replacePhSeq(r, i1) { case Pair(nr, i2) =>
              Pair(Pair("inf", Pair(op, Pair(nl, nr))), i2) } } } }
      else if #seq(t, "pre") then
        match d { case Pair(op, s) =>
          match replacePhSeq(s, idx) { case Pair(ns, i1) =>
            Pair(Pair("pre", Pair(op, ns)), i1) } }
      else if #seq(t, "app") then
        match d { case Pair(f, args) =>
          match replacePhSeq(f, idx) { case Pair(nf, i1) =>
            match replacePhSeqArgs(args, i1) { case Pair(nargs, i2) =>
              Pair(Pair("app", Pair(nf, nargs)), i2) } } }
      else if #seq(t, "sel") then
        match d { case Pair(o, fld) =>
          match replacePhSeq(o, idx) { case Pair(no, i1) =>
            Pair(Pair("sel", Pair(no, fld)), i1) } }
      else Pair(e, idx)
  }
def replacePhSeqArgs = (args, idx) =>
  match args {
    case Nil => Pair(Nil, idx)
    case Cons(a, r) =>
      match replacePhSeq(a, idx) { case Pair(na, i1) =>
        match replacePhSeqArgs(r, i1) { case Pair(nr, i2) =>
          Pair(Cons(na, nr), i2) } }
  }
def phParams = (i, n) =>
  if #i.ge(i, n) then Nil
  else Cons(#sconcat("__u", #i->str(i)), phParams(#i.add(i, 1), n))

-- wrap an argument expression in x => … if it holds a placeholder (but isn't a bare _)
def wrapPhArg = (e) =>
  match e {
    case Pair(t, d) =>
      if #seq(t, "ph") then e
      else if exprHasPh(e) then
        match replacePhSeq(e, 0) {
          case Pair(newE, nIdx) => Pair("lam", Pair(phParams(0, countPh(e)), newE))
        }
      else e
  }

-- K62.6c: for-comprehension (single generator + optional guard) desugared to
-- map / foreach / filter. `for x <- xs [if g] yield e` → xs[.filter(x=>g)].map(x=>e);
-- `for x <- xs [if g] do e` (or braceless body) → …foreach(x=>e).
-- K62.6c: a generator binder is either `name` or a tuple `(a, b, …)`. For a tuple
-- the lambda takes `__fp` and binds each name via `val a = __fp._1; …` before the
-- body (native tuppat surfaces only the first name, so bind explicitly by _N).
def bindTupleNames = (names, i) =>
  match names {
    case Nil => Nil
    case Cons(nm, rest) =>
      Cons(Pair("val", Pair(nm, mkSel(Pair("var", "__fp"), #sconcat("_", #i->str(i))))),
           bindTupleNames(rest, #i.add(i, 1)))
  }
def mkBinderLam = (names, isTuple, body) =>
  if isTuple then
    mkLam(Cons("__fp", Nil),
      Pair("block", append(bindTupleNames(names, 1), Cons(Pair("expr", body), Nil))))
  else mkLam(names, body)

def parseForFrom = (toks) =>
  let name0 = tokVal(peek(toks)) in
  let tsAfter = advance(toks) in
  let rBinder = if kindIs(",", tsAfter) then
                  let rec more = (ts, acc) =>
                    let nm = tokVal(peek(ts)) in
                    let ts2 = advance(ts) in
                    if kindIs(",", ts2) then more(advance(ts2), Cons(nm, acc))
                    else pr(reverse(Cons(nm, acc)), ts2) in
                  let rm = more(advance(tsAfter), Cons(name0, Nil)) in
                  pr(Pair(true, prV(rm)), skipKind(")", prT(rm)))
                else pr(Pair(false, Cons(name0, Nil)), tsAfter) in
  let isTuple = match prV(rBinder) { case Pair(it, ns) => it } in
  let names = match prV(rBinder) { case Pair(it, ns) => ns } in
  let ts1 = skipKind("<-", prT(rBinder)) in
  let rGen = parseExpr(ts1) in
  let ts3 = prT(rGen) in
  let rGuard = if kwIs("if", ts3) then
                 let rg = parseExpr(advance(ts3)) in
                 pr(mkApp(mkSel(prV(rGen), "filter"), Cons(mkBinderLam(names, isTuple, prV(rg)), Nil)), prT(rg))
               else pr(prV(rGen), ts3) in
  let genE = prV(rGuard) in
  let ts4 = prT(rGuard) in
  if kindIs(";", ts4) then
    let rRest = parseForFrom(advance(ts4)) in
    pr(mkApp(mkSel(genE, "flatMap"), Cons(mkBinderLam(names, isTuple, prV(rRest)), Nil)), prT(rRest))
  else
    let ts5 = if kindIs(")", ts4) then advance(ts4)
              else if kindIs("}", ts4) then advance(ts4) else ts4 in
    if kwIs("yield", ts5) then
      let rB = parseExpr(advance(ts5)) in
      pr(mkApp(mkSel(genE, "map"), Cons(mkBinderLam(names, isTuple, prV(rB)), Nil)), prT(rB))
    else
      let ts6 = if kwIs("do", ts5) then advance(ts5) else ts5 in
      let rB = parseExpr(ts6) in
      pr(mkApp(mkSel(genE, "foreach"), Cons(mkBinderLam(names, isTuple, prV(rB)), Nil)), prT(rB))

def parseFor = (toks) =>
  let ts0 = if kindIs("(", toks) then advance(toks)
            else if kindIs("{", toks) then advance(toks) else toks in
  parseForFrom(ts0)

-- ── Expression parser ─────────────────────────────────────────────────────────
-- parseAtom: handles literals, variables, parenthesized, if, prefix
def parseAtom = (toks) =>
  let t = peek(toks) in
  let k = tokKind(t) in
  let v = tokVal(t) in
  if #seq(k, "int") then pr(mkInt(v), advance(toks))
  else if #seq(k, "float") then pr(mkFloat(v), advance(toks))
  else if #seq(k, "str") then pr(mkStr(v), advance(toks))
  else if #seq(k, "id")  then
    -- KC12: detect built-in s"..." / f"..." / raw"..." / md"..." interpolation
    if #seq(v, "s") then
      let ts2 = advance(toks) in
      if kindIs("str", ts2) then pr(buildSInterp(tokVal(peek(ts2))), advance(ts2))
      else pr(mkVar(v), ts2)
    else if #seq(v, "f") then
      let ts2 = advance(toks) in
      if kindIs("str", ts2) then pr(buildFInterp(tokVal(peek(ts2))), advance(ts2))
      else pr(mkVar(v), ts2)
    else if #seq(v, "raw") then
      let ts2 = advance(toks) in
      if kindIs("str", ts2) then pr(buildSInterp(tokVal(peek(ts2))), advance(ts2))
      else pr(mkVar(v), ts2)
    else if #seq(v, "md") then
      let ts2 = advance(toks) in
      if kindIs("str", ts2) then pr(buildMdInterp(tokVal(peek(ts2))), advance(ts2))
      else pr(mkVar(v), ts2)
    else if #seq(v, "???") then pr(Pair("prim", Pair("__notImplemented__", Nil)), advance(toks))  -- Scala Predef.??? → notImplemented prim
    else if #seq(v, "_") then pr(Pair("ph", ""), advance(toks))   -- K62.6c: underscore placeholder
    else if #seq(v, "throw") then
      -- `throw e` → prim __throw__(e). A PRIM (not a plugin global) so it resolves on the native lane
      -- (Prims.resolve) as well as the bridge lane; the runtime raises an SscThrow carrying the value.
      let r = parseExpr(advance(toks)) in
      pr(Pair("prim", Pair("__throw__", Cons(prV(r), Nil))), prT(r))
    else if #seq(v, "try") then
      -- `try BODY catch { case … } [finally F]` → prim __tryCatch__(() => BODY, {case…}) [/ …Finally].
      -- BODY and F are 0-arg thunks so the runtime controls evaluation order; the catch is a partial
      -- function over the caught value (thrown value, or a RuntimeException DataV for host errors).
      let rBody = parseExpr(advance(toks)) in
      let bodyThunk = mkLam(Nil, prV(rBody)) in
      let ts2 = prT(rBody) in
      if #seq(tokVal(peek(ts2)), "catch") then
        let ts3 = advance(ts2) in
        let rPf = if kindIs("{", ts3) then parseBlockArg(advance(ts3)) else parseExpr(ts3) in
        let catchPf = prV(rPf) in
        let ts4 = prT(rPf) in
        if #seq(tokVal(peek(ts4)), "finally") then
          let rFin = parseExpr(advance(ts4)) in
          pr(Pair("prim", Pair("__tryCatchFinally__",
               Cons(bodyThunk, Cons(catchPf, Cons(mkLam(Nil, prV(rFin)), Nil))))), prT(rFin))
        else
          pr(Pair("prim", Pair("__tryCatch__", Cons(bodyThunk, Cons(catchPf, Nil)))), ts4)
      else if #seq(tokVal(peek(ts2)), "finally") then
        let rFin = parseExpr(advance(ts2)) in
        pr(Pair("prim", Pair("__tryFinally__", Cons(bodyThunk, Cons(mkLam(Nil, prV(rFin)), Nil)))), prT(rFin))
      else
        pr(prV(rBody), ts2)
    else pr(mkVar(v), advance(toks))
  else if #seq(k, "uid") then pr(mkUVar(v), advance(toks))
  else if #seq(k, "kw") then
    if #seq(v, "true")  then pr(mkBool("true"),  advance(toks))
    else if #seq(v, "false") then pr(mkBool("false"), advance(toks))
    else if #seq(v, "if")    then parseIfExpr(advance(toks))
    else if #seq(v, "for")   then parseFor(advance(toks))
    else if #seq(v, "new")   then parseAtom(advance(toks))   -- K62.6c: new Foo(x) == Foo(x)
    else if #seq(v, "match") then parseMatchExpr(advance(toks))
    else if #seq(v, "return") then
      let r = parseExpr(advance(toks)) in
      pr(Pair("return", prV(r)), prT(r))
    -- K62.18: `null` → None (mirrors the scalameta bridge Lit.Null → Ctor("None")).
    else if #seq(v, "null") then pr(mkUVar("None"), advance(toks))
    else pr(mkVar(v), advance(toks))
  else if #seq(k, "(") then
    let toks2 = advance(toks) in
    if kindIs(")", toks2) then pr(mkTup(Nil), advance(toks2))
    else
      let r = parseExpr(toks2) in
      let e = prV(r) in
      let ts = prT(r) in
      if kindIs(",", ts) then
        -- tuple
        let rec moreTup = (ts2, acc) =>
          let r2 = parseExpr(ts2) in
          let acc2 = Cons(prV(r2), acc) in
          let ts3 = prT(r2) in
          if kindIs(",", ts3) then moreTup(advance(ts3), acc2)
          else pr(reverse(acc2), ts3) in
        let r2 = moreTup(advance(ts), Cons(e, Nil)) in
        pr(mkTup(prV(r2)), skipKind(")", prT(r2)))
      else pr(e, skipKind(")", ts))
  else if #seq(k, "[") then
    -- K62.6f: list literal [e1, e2, …, en]  →  List(e1, …, en) (ssc bracket sugar).
    -- Only reached in expression position; statement-level [names](path) link-imports
    -- are handled in parseOneStmt.
    let toks2 = advance(toks) in
    if kindIs("]", toks2) then pr(mkApp(mkUVar("List"), Nil), advance(toks2))
    else
      let rec moreEls = (ts, acc) =>
        let r = parseExpr(ts) in
        let acc2 = Cons(prV(r), acc) in
        let ts2 = prT(r) in
        if kindIs(",", ts2) then moreEls(advance(ts2), acc2)
        else pr(reverse(acc2), ts2) in
      let re = moreEls(toks2, Nil) in
      pr(mkApp(mkUVar("List"), prV(re)), skipKind("]", prT(re)))
  else if #seq(k, "{") then parseBlock(advance(toks))
  else if #seq(k, "op") then
    if #seq(v, "-") then
      let r0 = parseAtom(advance(toks)) in
      let r = buildPostfix(prV(r0), prT(r0)) in
      pr(mkPre("-", prV(r)), prT(r))
    else if #seq(v, "!") then
      let r0 = parseAtom(advance(toks)) in
      let r = buildPostfix(prV(r0), prT(r0)) in
      pr(mkPre("!", prV(r)), prT(r))
    else if #seq(v, "~") then
      let r0 = parseAtom(advance(toks)) in
      let r = buildPostfix(prV(r0), prT(r0)) in
      pr(mkPre("~", prV(r)), prT(r))  -- K62.6c: bitwise not
    else pr(mkVar("_err"), advance(toks))
  else pr(mkVar("_err"), advance(toks))

-- KC9+KC10: parseBlock — `{` already consumed; parse stmts until `}`
-- Handles: val/var/def/while/assignment(id=)/expr stmts
def parseBlock = (toks) =>
  let rec go = (ts, acc) =>
    let ts2 = skipSemis(ts) in
    if kindIs("}", ts2) then
      pr(Pair("block", reverse(acc)), advance(ts2))
    else if kindIs("EOF", ts2) then
      pr(Pair("block", reverse(acc)), ts2)
    else if kwIs("val", ts2) then
      let r = parseVal(advance(ts2)) in
      -- val name = fn(args) { block } → val name = fn(args)(() => block)
      if kindIs("{", prT(r)) then
        let rbArg = parseBlockArg(advance(prT(r))) in
        let valStmt = match prV(r) {
          case Pair(vtag, vdata) =>
            match vdata {
              case Pair(vname, vrhs) =>
                let newRhs = mkApp(vrhs, Cons(prV(rbArg), Nil)) in
                Pair("val", Pair(vname, newRhs))
            }
        } in
        go(prT(rbArg), Cons(valStmt, acc))
      else
        go(prT(r), Cons(prV(r), acc))
    else if kwIs("var", ts2) then
      -- var x [: T] = expr  →  ("var", (name, expr))
      let r = parseVal(advance(ts2)) in
      let valStmt = prV(r) in
      let varStmt = match valStmt {
        case Pair(tag, data) => Pair("var", data)
      } in
      go(prT(r), Cons(varStmt, acc))
    else if kwIs("def", ts2) then
      let r = parseDef(advance(ts2)) in
      go(prT(r), Cons(prV(r), acc))
    else if kwIs("while", ts2) then
      -- while (cond) body
      let ts3 = advance(ts2) in
      let rCond = if kindIs("(", ts3) then
        let r = parseExpr(advance(ts3)) in
        pr(prV(r), skipKind(")", prT(r)))
      else parseExpr(ts3) in
      let cond = prV(rCond) in
      let ts4 = if kwIs("do", prT(rCond)) then advance(prT(rCond)) else prT(rCond) in  -- K62.6c: skip `do`
      let rBody = if kindIs("{", ts4) then parseBlock(advance(ts4))
                  else parseExpr(ts4) in
      go(prT(rBody), Cons(Pair("while", Pair(cond, prV(rBody))), acc))
    else if kwIs("return", ts2) then
      -- return expr  →  ("return", expr)
      let r = parseExpr(advance(ts2)) in
      go(prT(r), Cons(Pair("return", prV(r)), acc))
    else if kindIs("id", ts2) then
      -- look ahead: id = expr is assignment; id { block } is call-with-thunk; else expr
      let name = tokVal(peek(ts2)) in
      let ts3 = advance(ts2) in
      if kindIs("=", ts3) then
        let r = parseExpr(advance(ts3)) in
        go(prT(r), Cons(Pair("assign", Pair(name, prV(r))), acc))
      else if kindIs("{", ts3) then
        -- name { body }  →  name(arg): lambda-block or 0-arity thunk (T5.7)
        let rbArg = parseBlockArg(advance(ts3)) in
        let call = mkApp(Pair("var", name), Cons(prV(rbArg), Nil)) in
        -- Effect handler: `handle { body } { case Op(a,resume)=>… }` carries a SECOND
        -- brace block (the `{ case … }` handler). The def-body `=` opens a layout block,
        -- so this reaches the statement parser: consume block2 as a curried arg →
        -- handle(bodyThunk)(handlerλ). parseBlockArg turns `{ case … }` into
        -- `__pf => __pf match { arms }` (the VM handler shape); without this the handler
        -- block leaked as statements (`case` → unbound global).
        if #seq(name, "handle") then
          let afterB1 = skipSemis(prT(rbArg)) in
          if kindIs("{", afterB1) then
            let rbH = parseBlockArg(advance(afterB1)) in
            let call2 = mkApp(call, Cons(prV(rbH), Nil)) in
            go(prT(rbH), Cons(Pair("expr", call2), acc))
          else go(prT(rbArg), Cons(Pair("expr", call), acc))
        else go(prT(rbArg), Cons(Pair("expr", call), acc))
      else
        let r = parseExpr(ts2) in
        -- Check for a(idx) = rhs  →  idx_assign
        if kindIs("=", prT(r)) then
          let r2 = parseExpr(advance(prT(r))) in
          go(prT(r2), Cons(Pair("idx_assign", Pair(prV(r), prV(r2))), acc))
        -- handle(expr) { handler } — consume trailing { block } as thunk arg
        else if kindIs("{", prT(r)) then
          let rbArg = parseBlockArg(advance(prT(r))) in
          let call = mkApp(prV(r), Cons(prV(rbArg), Nil)) in
          go(prT(rbArg), Cons(Pair("expr", call), acc))
        else
          go(prT(r), Cons(Pair("expr", prV(r)), acc))
    else
      let r = parseExpr(ts2) in
      go(prT(r), Cons(Pair("expr", prV(r)), acc)) in
  go(toks, Nil)

-- parseStmtOrExpr: parse assignment (id = expr) or a regular expression
-- Used for if-then/else branches which can be assignments in Scala 3 style
def parseStmtOrExpr = (toks) =>
  if kindIs("id", toks) then
    let name = tokVal(peek(toks)) in
    let ts2 = advance(toks) in
    if kindIs("=", ts2) then
      let r = parseExpr(advance(ts2)) in
      pr(Pair("assign", Pair(name, prV(r))), prT(r))
    else parseExpr(toks)
  else parseExpr(toks)

-- parseIfExpr: toks has consumed 'if'
def parseIfExpr = (toks) =>
  -- accept both 'if (cond) e1 else e2'  and  'if cond then e1 else e2'
  -- A leading parenthesis groups the first term but does not end a following
  -- infix tail. Resume at infix parsing directly so a legacy `{ branch }`
  -- cannot be mistaken for a block argument applied to the condition.
  let r0 = if kindIs("(", toks) then
    let rInner = parseExpr(advance(toks)) in
    parseInfix(1, prV(rInner), skipKind(")", prT(rInner)))
  else parseExpr(toks) in
  let rCond = pr(prV(r0), skipKw("then", prT(r0))) in
  let cond = prV(rCond) in
  -- then-branch may be an assignment (Scala 3: if cond then x = expr)
  let rt = parseStmtOrExpr(prT(rCond)) in
  let thenE = prV(rt) in
  let ts2 = prT(rt) in
  -- else is optional: if missing, emit Unit as else branch
  if kwIs("else", ts2) then
    let re = parseStmtOrExpr(advance(ts2)) in
    pr(mkIf(cond, thenE, prV(re)), prT(re))
  else
    pr(mkIf(cond, thenE, mkTup(Nil)), ts2)

-- Read one bracketed type application (opening `[` already consumed) while
-- retaining nested brackets as source text. Ordinary type applications remain
-- erased; summon uses the payload for exact named-given lookup.
def readTypeApply = (toks, depth, acc) =>
  let t = peek(toks) in
  let k = tokKind(t) in
  let v = tokVal(t) in
  if #seq(k, "EOF") then pr(joinStrs(reverse(acc)), toks)
  else if #seq(k, "[") then
    readTypeApply(advance(toks), #i.add(depth, 1), Cons("[", acc))
  else if #seq(k, "]") then
    if #i.le(depth, 1) then pr(joinStrs(reverse(acc)), advance(toks))
    else readTypeApply(advance(toks), #i.sub(depth, 1), Cons("]", acc))
  else
    let sv = if #seq(v, "") then k else v in
    readTypeApply(advance(toks), depth, Cons(sv, acc))

def isDbQuerySelection = (e) =>
  match e {
    case Pair(tag, data) =>
      if #seq(tag, "sel") then
        match data {
          case Pair(obj, method) =>
            if #seq(method, "query") then
              match obj {
                case Pair(objTag, objName) =>
                  if #seq(objTag, "uid") then #seq(objName, "Db") else false
              }
            else false
        }
      else false
  }

-- buildPostfix: e . name | e (args)  (left-recursive, iterative)
def buildPostfix = (e, toks) =>
  let t = peek(toks) in
  let k = tokKind(t) in
  if #seq(k, ".") then
    let toks2 = advance(toks) in
    let ft = peek(toks2) in
    let fk = tokKind(ft) in
    if #seq(fk, "id") then buildPostfix(mkSel(e, tokVal(ft)), advance(toks2))
    else if #seq(fk, "uid") then buildPostfix(mkSel(e, tokVal(ft)), advance(toks2))
    else pr(e, toks)
  else if #seq(k, "(") then
    let toks2 = advance(toks) in
    -- KC8: detect `(using args)` call sites — strip `using`, merge args into caller
    let wasUsing = kwIs("using", toks2) in
    let toks2b = if wasUsing then advance(toks2) else toks2 in
    -- KC8: merge `(using args)` into the preceding call's arg list (avoid curried apply)
    let mergeWithE = (newArgs) =>
      if wasUsing then
        match e {
          case Pair(etag, edata) =>
            if #seq(etag, "app") then
              match edata {
                case Pair(ef, eargs) => mkApp(ef, append(eargs, newArgs))
              }
            else mkApp(e, newArgs)
        }
      else mkApp(e, newArgs) in
    if kindIs(")", toks2b) then buildPostfix(mergeWithE(Nil), advance(toks2b))
    else
      let rec moreArgs = (ts, acc) =>
        -- named argument `label = value`: `id` followed by a single `=` (lexer makes
        -- `==` an `op` token and `=` its own `"="` kind, so this never eats a `==`).
        -- Emit an `narg` node; the lowerer reorders by declared case-class field order.
        let isNamed = if #seq(tokKind(peek(ts)), "id") then kindIs("=", advance(ts)) else false in
        let vts = if isNamed then advance(advance(ts)) else ts in
        let r = parseExpr(vts) in
        let node = if isNamed then mkNArg(tokVal(peek(ts)), wrapPhArg(prV(r)))
                   else wrapPhArg(prV(r)) in                 -- K62.6c: filter(_ % 2 == 0) → filter(x => …)
        let acc2 = Cons(node, acc) in
        let ts2 = prT(r) in
        if kindIs(",", ts2) then
          -- tolerate a trailing comma before `)` (idiomatic in multi-line calls);
          -- without this the parser feeds `)` to parseExpr → a spurious `_err` arg.
          let ts3 = advance(ts2) in
          if kindIs(")", ts3) then pr(reverse(acc2), ts3)
          else moreArgs(ts3, acc2)
        else pr(reverse(acc2), ts2) in
      let ra = moreArgs(toks2b, Nil) in
      buildPostfix(mergeWithE(prV(ra)), skipKind(")", prT(ra)))
  else if #seq(k, "[") then
    let rt = readTypeApply(advance(toks), 1, Nil) in
    let typed = match e {
      case Pair(etag, edata) =>
        if #seq(etag, "var") then
          if #seq(edata, "summon") then Pair("summon", prV(rt))
          else if #seq(edata, "direct") then Pair("direct_marker", prV(rt))
          else e
        else if #seq(etag, "uid") then
          if #seq(edata, "Focus") then Pair("focus_marker", prV(rt))
          else if #seq(edata, "Prism") then Pair("prism", prV(rt))
          else e
        else if #seq(etag, "sel") then
          if isDbQuerySelection(e) then Pair("typed_db_query", prV(rt)) else e
        else e
    } in
    buildPostfix(typed, prT(rt))
  else if #seq(k, "{") then
    match e {
      case Pair(etag, edata) =>
        if #seq(etag, "direct_marker") then
          -- Preserve fresh assignment statements before ordinary block
          -- lowering can reinterpret them as mutable stores.
          let rb = parseBlock(advance(toks)) in
          buildPostfix(Pair("direct", Pair(edata, prV(rb))), prT(rb))
        else
          -- trailing block argument: e { body }  →  e(body)  (T5.7 / KC-postfix)
          -- lambda-aware: parseBlockArg strips a `param =>` header.
          let rbArg = parseBlockArg(advance(toks)) in
          buildPostfix(mkApp(e, Cons(prV(rbArg), Nil)), prT(rbArg))
    }
  else if #seq(k, "kw") then
    if kwIs("match", toks) then
      let ts2 = skipKind("{", advance(toks)) in
      let rArms = parseMatchArms(ts2) in
      buildPostfix(mkMatch(e, prV(rArms)), prT(rArms))
    else pr(e, toks)
  else pr(e, toks)

def parsePostfix = (toks) =>
  let r = parseAtom(toks) in buildPostfix(prV(r), prT(r))

-- operator precedence: 0 = not an infix op
def opPrec = (op) =>
  if #seq(op, "~") then 9 else if #seq(op, "~>") then 9
  else if #seq(op, "*") then 8 else if #seq(op, "/") then 8 else if #seq(op, "%") then 8
  else if #seq(op, "+") then 7 else if #seq(op, "-") then 7
  else if #seq(op, "++") then 6 else if #seq(op, ":+") then 6
  else if #seq(op, "==") then 5 else if #seq(op, "!=") then 5
  else if #seq(op, "<")  then 5 else if #seq(op, "<~") then 5 else if #seq(op, ">")  then 5
  else if #seq(op, "<=") then 5 else if #seq(op, ">=") then 5
  else if #seq(op, "&&") then 4
  else if #seq(op, "||") then 3
  else if #seq(op, "!") then 2       -- actor send: receiver ! message
  else if #seq(op, "&") then 5      -- K62.6c: bitwise
  else if #seq(op, "^") then 4
  else if #seq(op, "|") then 4
  else if #seq(op, "<<") then 6     -- shifts
  else if #seq(op, ">>") then 6
  else if #seq(op, ">>>") then 6
  else if #seq(op, ":=") then 1     -- DSL assign operator (attr.x := v; SBT-style setting)
  else 0

def isInfixOp = (toks) =>
  if #seq(tokKind(peek(toks)), "op") then #i.gt(opPrec(tokVal(peek(toks))), 0)
  else false

def parseInfix = (minPrec, lhs, toks) =>
  if isInfixOp(toks) then
    let op = tokVal(peek(toks)) in
    let prec = opPrec(op) in
    if #i.lt(prec, minPrec) then pr(lhs, toks)
    else
      let r = parsePostfix(advance(toks)) in
      let r2 = parseInfix(#i.add(prec, 1), prV(r), prT(r)) in
      parseInfix(minPrec, mkInf(op, lhs, prV(r2)), prT(r2))
  else if kindIs("::", toks) then
    -- K62.6c: cons `a :: b` — right-associative, prec 5 (own token kind, not "op")
    if #i.lt(5, minPrec) then pr(lhs, toks)
    else
      let r = parsePostfix(advance(toks)) in
      let r2 = parseInfix(5, prV(r), prT(r)) in
      parseInfix(minPrec, mkInf("::", lhs, prV(r2)), prT(r2))
  else if kindIs("->", toks) then
    -- K62.6c: pair `a -> b` — prec 1 (binds loosest), lowers to a 2-tuple
    if #i.lt(1, minPrec) then pr(lhs, toks)
    else
      let r = parsePostfix(advance(toks)) in
      let r2 = parseInfix(2, prV(r), prT(r)) in
      parseInfix(minPrec, mkInf("->", lhs, prV(r2)), prT(r2))
  else if kindIs("id", toks) then
    let name = tokVal(peek(toks)) in
    if #seq(name, "until") then
      let r = parsePostfix(advance(toks)) in
      parseInfix(minPrec, mkApp(mkSel(lhs, "until"), Cons(prV(r), Nil)), prT(r))
    else if #seq(name, "to") then
      let r = parsePostfix(advance(toks)) in
      parseInfix(minPrec, mkApp(mkSel(lhs, "to"), Cons(prV(r), Nil)), prT(r))
    else pr(lhs, toks)
  else pr(lhs, toks)

-- KC11: try to parse a lambda param list after `(` — returns pr(Some(names), rest-after-)) or pr(None, toks-before-()
-- Stops (fails) if it sees anything other than id [: T] (, id [: T])* )
def tryLamParamsMore = (toks, acc) =>
  if kindIs("id", toks) then
    let name = tokVal(peek(toks)) in
    let ts2 = skipTypeAnnot(advance(toks)) in
    if kindIs(",", ts2) then tryLamParamsMore(advance(ts2), Cons(name, acc))
    else if kindIs(")", ts2) then pr(Some(reverse(Cons(name, acc))), advance(ts2))
    else pr(None, Nil)
  else pr(None, Nil)

def tryLamParams = (toksAfterParen) =>
  if kindIs(")", toksAfterParen) then pr(Some(Nil), advance(toksAfterParen))
  else tryLamParamsMore(toksAfterParen, Nil)

-- The base infix operator of a compound-assignment token, or "" if the head is
-- not one. `x += e` desugars to `x = x + e` (K62: loop var mutation `i += 1`).
def compoundBaseOp = (toks) =>
  if opIs("+=", toks) then "+"
  else if opIs("-=", toks) then "-"
  else if opIs("*=", toks) then "*"
  else if opIs("||=", toks) then "||"
  else if opIs("&&=", toks) then "&&"
  else ""

def finishAssignment = (r) =>
  if kindIs("=", prT(r)) then
    match prV(r) { case Pair(tag, data) =>
      if #seq(tag, "var") then
        let rr = parseExpr(advance(prT(r))) in
        pr(Pair("assign", Pair(data, prV(rr))), prT(rr))
      else if #seq(tag, "sel") then
        -- `obj.field = rhs` — a field write. The lowerer routes a mutable `var`
        -- field to cell.set; a non-var field is an error there.
        match data { case Pair(objE, fieldN) =>
          let rr = parseExpr(advance(prT(r))) in
          pr(Pair("sel_assign", Pair(objE, Pair(fieldN, prV(rr)))), prT(rr))
        }
      else r
    }
  else
    let baseOp = compoundBaseOp(prT(r)) in
    if #seq(baseOp, "") then r
    else match prV(r) { case Pair(tag, data) =>
      if #seq(tag, "var") then
        let rr = parseExpr(advance(prT(r))) in
        pr(Pair("assign", Pair(data, mkInf(baseOp, mkVar(data), prV(rr)))), prT(rr))
      else r
    }

-- KC11: parse expression, with lambda short-circuit before infix parsing.
-- A single `=` tail on a bare variable is an assignment expression; named
-- call arguments are consumed by parseArgs before reaching this path.
def parseExprCore = (toks) =>
  if kindIs("id", toks) then
    -- peek: id => body  →  lambda with one param
    let name = tokVal(peek(toks)) in
    let ts2 = advance(toks) in
    if kindIs("=>", ts2) then
      let rBody = parseExpr(advance(ts2)) in
      pr(Pair("lam", Pair(Cons(name, Nil), prV(rBody))), prT(rBody))
    else
      let r = parsePostfix(toks) in parseInfix(1, prV(r), prT(r))
  else if kindIs("(", toks) then
    -- peek: (params) => body  vs  (expr)
    let rTry = tryLamParams(advance(toks)) in
    match prV(rTry) {
      case Some(params) =>
        if kindIs("=>", prT(rTry)) then
          let rBody = parseExpr(advance(prT(rTry))) in
          pr(Pair("lam", Pair(params, prV(rBody))), prT(rBody))
        else
          let r = parsePostfix(toks) in parseInfix(1, prV(r), prT(r))
      case None =>
        let r = parsePostfix(toks) in parseInfix(1, prV(r), prT(r))
    }
  else
    let r = parsePostfix(toks) in parseInfix(1, prV(r), prT(r))

def parseExpr = (toks) => finishAssignment(parseExprCore(toks))

-- ── Statement parser ──────────────────────────────────────────────────────────
-- Skip type params [A, B, ...]
def skipTypeParams = (toks) =>
  if kindIs("[", toks) then
    let rec skip = (ts) =>
      if kindIs("]", ts) then advance(ts)
      else if kindIs("EOF", ts) then ts
      else skip(advance(ts)) in
    skip(advance(toks))
  else toks

-- KC5: skip a single [T] type argument list after a TC name
def skipTypeArgs = (ts) =>
  if kindIs("[", ts) then
    let rec skipBr = (tss, depth) =>
      if kindIs("EOF", tss) then tss
      else if kindIs("[", tss) then skipBr(advance(tss), #i.add(depth, 1))
      else if kindIs("]", tss) then
        if #i.le(depth, 1) then advance(tss)
        else skipBr(advance(tss), #i.sub(depth, 1))
      else skipBr(advance(tss), depth) in
    skipBr(advance(ts), 1)
  else ts

-- KC5: make a context dict param name from a bound: (tv, TC) → "__tc_TC"
def mkCtxParam = (bound) =>
  match bound { case Pair(tv, tc) => #sconcat("__tc_", tc) }

-- KC5: parse [A: Show, B: Eq, C] → List of Pair(tv, TC) for bounded type vars
-- Unbounded type vars (no `:`) are silently skipped.
def parseTypeParams = (toks) =>
  if kindIs("[", toks) then
    let rec go = (ts, acc) =>
      if kindIs("]", ts) then pr(reverse(acc), advance(ts))
      else if kindIs("EOF", ts) then pr(reverse(acc), ts)
      else
        let tv = tokVal(peek(ts)) in
        -- Skip a higher-kinded type param's own params (`F[_]`, `G[_, _]`) before the bound/comma —
        -- otherwise `[F[_]]` stops at the INNER `]`, misaligning the whole signature.
        let ts2 = skipTypeArgs(advance(ts)) in
        if kindIs(":", ts2) then
          -- bounded: read one OR MORE chained TC bounds for this tv (`A: Monoid: Pretty`).
          -- Each `: TC[optArg]` yields a Pair(tv, TC); loop while another `:` follows.
          let rec readBounds = (bts, bacc) =>
            -- bts points AT a `:`
            let bts1 = advance(bts) in
            let btc = tokVal(peek(bts1)) in
            let bts2 = advance(bts1) in
            let bts3 = skipTypeArgs(bts2) in
            let bacc2 = Cons(Pair(tv, btc), bacc) in
            if kindIs(":", bts3) then readBounds(bts3, bacc2)
            else pr(bacc2, bts3) in
          match readBounds(ts2, acc) {
            case Pair(acc2, ts5) =>
              if kindIs(",", ts5) then go(advance(ts5), acc2)
              else go(ts5, acc2)
          }
        else
          -- unbounded type var: skip
          if kindIs(",", ts2) then go(advance(ts2), acc)
          else go(ts2, acc) in
    go(advance(toks), Nil)
  else pr(Nil, toks)

-- KC5: join a list of strings into one string (no separator)
def joinStrs = (ss) =>
  match ss {
    case Nil => ""
    case Cons(s, rest) => #sconcat(s, joinStrs(rest))
  }

-- KC5: collect type annotation tokens into a string, stopping at '=' ';' or EOF
-- Punctuation tokens have tokVal="" so we use tokKind as their string representation.
def readTypeStr = (toks) =>
  let rec go = (ts, acc) =>
    let t = peek(ts) in
    let k = tokKind(t) in
    let v = tokVal(t) in
    if #seq(k, "=") then pr(joinStrs(reverse(acc)), ts)
    else if #seq(k, ";") then pr(joinStrs(reverse(acc)), ts)
    else if #seq(k, "EOF") then pr(joinStrs(reverse(acc)), ts)
    else if #seq(k, "{") then pr(joinStrs(reverse(acc)), ts)
    else if #seq(k, "kw") then
      if #seq(v, "with") then pr(joinStrs(reverse(acc)), ts)
      else
        let sv = v in
        go(advance(ts), Cons(sv, acc))
    else
      -- punctuation tokens have empty val; use the kind char itself
      let sv = if #seq(v, "") then k else v in
      go(advance(ts), Cons(sv, acc)) in
  go(toks, Nil)

-- KC8: parse `using p: T, q: U)` (after the `using` keyword; closing `)` consumed)
def parseUsingParams = (toks) =>
  -- Capture the param NAMES (kept, for body reference) and each type's TC HEAD (first token after `:`,
  -- e.g. `Show` from `Show[A]`) for auto-injection. Use skipTypeAnnot for advancement — it respects
  -- nested []/() and stops at the depth-0 `,`/`)` (readTypeStr would over-read past the comma).
  let rec goU = (ts, nacc, tacc) =>
    if kindIs(")", ts) then Pair(Pair(reverse(nacc), reverse(tacc)), advance(ts))
    else if kindIs("EOF", ts) then Pair(Pair(reverse(nacc), reverse(tacc)), ts)
    else
      let name = tokVal(peek(ts)) in
      let tsColon = advance(ts) in
      let tcHead = if kindIs(":", tsColon) then tokVal(peek(advance(tsColon))) else "" in
      let ts2 = skipTypeAnnot(tsColon) in
      let nacc2 = Cons(name, nacc) in
      let tacc2 = Cons(tcHead, tacc) in
      if kindIs(",", ts2) then goU(advance(ts2), nacc2, tacc2)
      else if kindIs(")", ts2) then Pair(Pair(reverse(nacc2), reverse(tacc2)), advance(ts2))
      else Pair(Pair(reverse(nacc2), reverse(tacc2)), ts2) in
  match goU(toks, Nil, Nil) {
    case Pair(nt, toksAfter) =>
      match nt {
        case Pair(names, tcHeads) =>
          let _set = #cell.set(pendingUsingTypesCell, tcHeads) in
          pr(names, toksAfter)
      }
  }

def parseDef = (toks) =>
  -- name
  let name = tokVal(peek(toks)) in
  let toks2 = advance(toks) in
  let extensionParams = #cell.get(extensionParamsCell) in
  -- KC5: parse type params → extract context bounds [A: TC, ...]
  let rCtx = parseTypeParams(toks2) in
  let ctxBounds = prV(rCtx) in
  let toks3 = prT(rCtx) in
  -- context dict params: prepend "__tc_TC" for each (tv, TC) bound
  let ctxParams = map(mkCtxParam, ctxBounds) in
  -- K62.17: reset the per-def default accumulator before parsing THIS def's params
  -- (a nested def in the body clears it again before the outer def reads the body,
  -- so outer/inner never interfere).
  let _clr = #cell.set(paramDefaultsCell, Nil) in
  -- Reset the transient using-types accumulator; only parseUsingParams sets it, so a def with no
  -- `using` clause leaves it Nil (won't inherit a previous def's types).
  let _clru = #cell.set(pendingUsingTypesCell, Nil) in
  -- Reset the trailing-vararg flag before parsing this def's clauses; parseParam
  -- overwrites it per param, so after the whole list it reflects the LAST param.
  let _clrv = #cell.set(lastParamVarargCell, false) in
  -- first parameter list. Remember whether a source clause was present before
  -- parseParamList erases both an absent clause and explicit `()` to Nil.
  let hasSourceParamClause = kindIs("(", toks3) in
  let rp = parseParamList(toks3) in
  let params = prV(rp) in
  let toks4 = prT(rp) in
  -- KC8: handle (using p: T, ...) or a second regular param list
  let rp2 =
    if kindIs("(", toks4) then
      let ts4b = advance(toks4) in
      if kwIs("using", ts4b) then parseUsingParams(advance(ts4b))
      else parseParamList(toks4)
    else pr(Nil, toks4) in
  -- ctxParams first, then regular params, then using params
  let allParams = append(ctxParams, append(extensionParams, append(params, prV(rp2)))) in
  -- Register named `using` params for call-site auto-injection: (defName → ([usingTypeStr], fullCount)).
  -- fullCount = regular + using count (the arg count when using is passed EXPLICITLY); ssc1-lower's
  -- injectGivens appends the using givens only when the call has fewer args than that.
  let _regUsing = match #cell.get(pendingUsingTypesCell) {
    case Nil => 0
    case Cons(ut, uts) =>
      let usingTypes = Cons(ut, uts) in
      let fullCount = #i.add(lenLF(params), lenLF(prV(rp2))) in
      #cell.set(usingSigCell, Cons(Pair(name, Pair(usingTypes, fullCount)), #cell.get(usingSigCell)))
  } in
  -- K62.17: snapshot source-call defaults so the lower can synthesize omitted
  -- trailing args at call sites.
  -- Context dictionaries are injected separately by the lowerer and therefore
  -- are not part of the source-call arity/default registry.
  let callParams = append(params, prV(rp2)) in
  let _reg = registerParamDflts(name, callParams) in
  -- Register a trailing-vararg def so the lowerer packs its call-site trailing args.
  let _vreg = if #cell.get(lastParamVarargCell) then
                #cell.set(varargDefsCell, Cons(name, #cell.get(varargDefsCell)))
              else 0 in
  let _extReg = match extensionParams {
    case Nil => 0
    case Cons(h, t) =>
      #cell.set(extensionMethodsCell, Cons(name, #cell.get(extensionMethodsCell)))
  } in
  let toks5 = prT(rp2) in
  -- optional return type
  let toks6 = skipTypeAnnot(toks5) in
  -- '=' is optional: abstract defs (in traits/effects) have no body
  if kindIs("=", toks6) then
    let re = parseExpr(advance(toks6)) in
    let body =
      if hasSourceParamClause then prV(re)
      else if #i.eq(lenLF(allParams), 0) then mkParameterlessBody(prV(re))
      else prV(re) in
    pr(mkDef(name, allParams, body), prT(re))
  else
    let body =
      if hasSourceParamClause then mkTup(Nil)
      else if #i.eq(lenLF(allParams), 0) then mkParameterlessBody(mkTup(Nil))
      else mkTup(Nil) in
    pr(mkDef(name, allParams, body), toks6)

-- consumeBlockArg: if next token is '{', parse it as a 0-arg thunk and apply to expr
-- T5.7: parse a `{ … }` call argument, lambda-header-FIRST.
-- `{ (a, b) => stmts… }` / `{ x => stmts… }` is the LAMBDA argument itself
-- (Scala block-lambda syntax): parse the header, then the whole remaining
-- block as the lambda body (so `val`/`def` stmts in the body work). A block
-- with no lambda header stays a 0-arity thunk (runStream { … } style).
-- toks = tokens AFTER the '{'. Returns pr(argExpr, toksAfterBlock).
def parseBlockArg = (toks0) =>
  -- Skip layout separators after `{` (a newline lexes to NL→`;`) so a multi-line
  -- `{ \n case … }` partial-function / effect-handler block is still recognised.
  let toks = skipSemis(toks0) in
  -- K62.9: partial-function literal `{ case P => B; … }` (the `{` already consumed) →
  -- `__pf => __pf match { arms }`. parseMatchArms consumes the closing `}`.
  if kwIs("case", toks) then
    let rArms = parseMatchArms(toks) in
    pr(mkLam(Cons("__pf", Nil), mkMatch(mkVar("__pf"), prV(rArms))), prT(rArms))
  else
  let single =
    if kindIs("id", toks) then
      let name = tokVal(peek(toks)) in
      let ts2 = advance(toks) in
      if kindIs("=>", ts2) then Some(pr(Cons(name, Nil), advance(ts2)))
      else None
    else None in
  match single {
    case Some(hdr) =>
      let rb = parseBlock(prT(hdr)) in
      pr(mkLam(prV(hdr), prV(rb)), prT(rb))
    case None =>
      if kindIs("(", toks) then
        let rTry = tryLamParams(advance(toks)) in
        match prV(rTry) {
          case Some(params) =>
            if kindIs("=>", prT(rTry)) then
              let rb = parseBlock(advance(prT(rTry))) in
              pr(mkLam(params, prV(rb)), prT(rb))
            else
              let rb = parseBlock(toks) in
              pr(mkLam(Nil, prV(rb)), prT(rb))
          case None =>
            let rb = parseBlock(toks) in
            pr(mkLam(Nil, prV(rb)), prT(rb))
        }
      else
        let rb = parseBlock(toks) in
        pr(mkLam(Nil, prV(rb)), prT(rb))
  }

def consumeBlockArg = (expr, toks) =>
  if kindIs("{", toks) then
    let ra = parseBlockArg(advance(toks)) in
    pr(mkApp(expr, Cons(prV(ra), Nil)), prT(ra))
  else pr(expr, toks)

def parseVal = (toks) =>
  -- Tuple pattern: val (a, b) = expr  →  ("tuppat", (names, expr))
  if kindIs("(", toks) then
    let ts1 = advance(toks) in
    let rec goNames = (ts, acc) =>
      let name = tokVal(peek(ts)) in
      let ts2 = advance(ts) in
      let acc2 = Cons(name, acc) in
      if kindIs(",", ts2) then goNames(advance(ts2), acc2)
      else pr(reverse(acc2), skipKind(")", ts2)) in
    let rNames = goNames(ts1, Nil) in
    let ts2 = prT(rNames) in
    let ts3 = skipTypeAnnot(ts2) in
    let ts4 = skipKind("=", ts3) in
    let re = parseExpr(ts4) in
    -- If followed by { body }, treat it as a block arg to the expr (e.g. runStream { ... })
    let reFinal = consumeBlockArg(prV(re), prT(re)) in
    pr(Pair("tuppat", Pair(prV(rNames), prV(reFinal))), prT(reFinal))
  else
    let name = tokVal(peek(toks)) in
    let toks2 = advance(toks) in
    let toks3 = skipTypeAnnot(toks2) in
    let toks4 = skipKind("=", toks3) in
    let re = parseExpr(toks4) in
    -- T5.7: `val x = xs.foldLeft(z) { (a, b) => … }` — consume the trailing block
    -- arg here too (only the tuppat path did); otherwise the block detaches into a
    -- separate top-level statement and the val holds a partial application.
    let reFinal = consumeBlockArg(prV(re), prT(re)) in
    pr(mkVal(name, prV(reFinal)), prT(reFinal))

-- ── KC7: match + case class parsing ─────────────────────────────────────────

def mkMatch   = (e, arms) => Pair("match",   Pair(e, arms))
-- Product declarations retain the source data needed by portable Mirror and
-- exact custom derives synthesis. Constructor lowering still consumes `ps`;
-- `types` and `derives` are metadata, never host reflection handles.
def mkCaseCls = (n, ps, types, derives) =>
  Pair("casecls", Pair(n, Pair(ps, Pair(types, derives))))
def mkCaseObj = (n)       => Pair("caseobj", n)

-- parsePat: single flat pattern; returns (pat, remaining-toks)
-- Supports: Ctor(v1,v2), lowercase-var, _ wildcard, kw-literal
-- K62.10: pattern fields are now SUB-PATTERNS (vpat/wpat/cpat/lpat), not bare
-- binder-name strings, so `Some(Foo(x))` / `Some((a, b))` destructure via nested
-- matches (lowered in lowerMatch). goSubPats parses a comma list of sub-patterns.
def goSubPats = (ts0) =>
  let rec go = (ts, acc, cnt) =>
    let rp = parsePat(ts) in
    let typeHead = patternTypeHead(prT(rp)) in
    let fieldPat = if #i.gt(#slen(typeHead), 0) then
      Pair("tpat", Pair(prV(rp), typeHead))
    else prV(rp) in
    let tsA = skipTypeAnnot(prT(rp)) in
    let cnt2 = #i.add(cnt, 1) in
    if kindIs(",", tsA) then go(advance(tsA), Cons(fieldPat, acc), cnt2)
    else pr(Pair(reverse(Cons(fieldPat, acc)), cnt2), tsA) in
  go(ts0, Nil, 0)

-- K62.20 tuple values use Pair for arity two and flat Tuple${N} constructors
-- for arity three or greater. Pattern tuples must use the identical shape,
-- including when nested inside another constructor such as Some((a, b, c)).
def tuplePat = (subs) =>
  match subs {
    case Nil => Pair("wpat", "")
    case Cons(first, rest) =>
      match rest {
        case Nil => first
        case Cons(second, tail) =>
          match tail {
            case Nil => Pair("cpat", Pair("Pair", Cons(first, Cons(second, Nil))))
            case Cons(third, more) =>
              Pair("cpat", Pair(#sconcat("Tuple", #i->str(lenLF(subs))), subs))
          }
      }
  }

def finishCtorPat = (tag, toks) =>
  if kindIs("(", toks) then
    let ts2 = advance(toks) in
    if kindIs(")", ts2) then pr(Pair("cpat", Pair(tag, Nil)), advance(ts2))
    else
      let rSub = goSubPats(ts2) in
      match prV(rSub) { case Pair(subs, n) =>
        pr(Pair("cpat", Pair(tag, subs)), skipKind(")", prT(rSub))) }
  else pr(Pair("cpat", Pair(tag, Nil)), toks)

def parsePatAtom = (toks) =>
  let t  = peek(toks) in
  let k  = tokKind(t) in
  let v  = tokVal(t) in
  if #seq(k, "uid") then
    let ts2 = advance(toks) in
    if kindIs(".", ts2) then
      let ts3 = advance(ts2) in
      let opName = tokVal(peek(ts3)) in
      finishCtorPat(opName, advance(ts3))
    else finishCtorPat(v, ts2)
  else if #seq(k, "id") then
    let ts2 = advance(toks) in
    if #seq(v, "_") then pr(Pair("wpat", ""), ts2)
    else pr(Pair("vpat", v), ts2)
  else if #seq(k, "kw") then
    if #seq(v, "true") then pr(Pair("lpat", Pair("bool", "true")), advance(toks))
    else if #seq(v, "false") then pr(Pair("lpat", Pair("bool", "false")), advance(toks))
    else pr(Pair("cpat", Pair(v, Nil)), advance(toks))
  else if #seq(k, "(") then
    let rSub = goSubPats(advance(toks)) in
    match prV(rSub) {
      case Pair(subs, n) => pr(tuplePat(subs), skipKind(")", prT(rSub)))
    }
  else if #seq(k, "int") then pr(Pair("lpat", Pair("int", v)), advance(toks))
  else if #seq(k, "str") then pr(Pair("lpat", Pair("str", v)), advance(toks))
  else if #seq(k, "float") then pr(Pair("lpat", Pair("float", v)), advance(toks))
  else pr(Pair("wpat", ""), advance(toks))

-- Pattern cons is right-associative, like expression `::`. In particular, a
-- tuple head retains its ordinary nested Pair pattern inside the outer Cons.
def parsePat = (toks) =>
  let rHead = parsePatAtom(toks) in
  if kindIs("::", prT(rHead)) then
    let rTail = parsePat(advance(prT(rHead))) in
    pr(Pair("cpat", Pair("Cons", Cons(prV(rHead), Cons(prV(rTail), Nil)))), prT(rTail))
  else rHead

-- A source bind pattern owns the whole successfully matched value while its
-- constructor pattern still binds fields. Keep this at the match-arm boundary:
-- nested/typed/guarded aliases are separate syntax families, and accepting
-- them partially would recreate the `_err` sentinel this node removes.
def parseArmPat = (toks) =>
  let rBase = parsePat(toks) in
  match prV(rBase) {
    case Pair(baseTag, baseData) =>
      if #seq(baseTag, "vpat") then
        if kindIs("@", prT(rBase)) then
          let rInner = parsePat(advance(prT(rBase))) in
          match prV(rInner) {
            case Pair(innerTag, innerData) =>
              if #seq(innerTag, "cpat") then
                pr(Pair("bpat", Pair(baseData, prV(rInner))), prT(rInner))
              else rBase
          }
        else rBase
      else rBase
  }

-- parseMatchArm: `case Pat => expr`  (keyword `case` already consumed)
-- K62.11: a match-arm body can be a statement SEQUENCE (`case X => val n = e; expr`),
-- not just one expression. Parse statements (via parseOneStmt) until the next arm
-- boundary (`case`/`}`/EOF). One expr-statement unwraps to the bare expr (the common
-- case, no block); anything else (a val/def, or several statements) becomes a block.
def parseArmBody = (toks) =>
  let rec go = (ts, acc) =>
    let ts2 = skipSemis(ts) in
    if kwIs("case", ts2) then pr(reverse(acc), ts)
    else if kindIs("}", ts2) then pr(reverse(acc), ts)
    else if kindIs("EOF", ts2) then pr(reverse(acc), ts)
    else
      let r = parseOneStmt(ts2) in
      go(prT(r), Cons(prV(r), acc)) in
  let r = go(toks, Nil) in
  let stmts = prV(r) in
  let endToks = prT(r) in
  match stmts {
    case Nil => pr(Pair("uid", "Unit"), endToks)
    case Cons(single, tl) =>
      match tl {
        case Nil =>
          match single { case Pair(stag, sdata) =>
            if #seq(stag, "expr") then pr(sdata, endToks)
            else pr(Pair("block", stmts), endToks) }
        case Cons(h2, t2) => pr(Pair("block", stmts), endToks)
      }
  }

-- K62.26: a field is guard-safe if it's a binder/wildcard OR a nested constructor
-- pattern whose own fields are (recursively) guard-safe. The lowerer's
-- dischargeObsOrGuard destructures the nesting before the guard, so `case (ah::at,
-- bh::_) if ah<=bh` is now honoured instead of silently dropping the guard.
def flatGuardFields = (fields) =>
  match fields {
    case Nil => true
    case Cons(field, rest) =>
      match field { case Pair(ftag, fdata) =>
        if #seq(ftag, "vpat") then flatGuardFields(rest)
        else if #seq(ftag, "wpat") then flatGuardFields(rest)
        else if #seq(ftag, "lpat") then flatGuardFields(rest)
        else if #seq(ftag, "tpat") then
          match fdata { case Pair(basePat, typeHead) =>
            if guardablePat(basePat) then flatGuardFields(rest) else false }
        else if #seq(ftag, "cpat") then
          match fdata { case Pair(cn, cf) =>
            if flatGuardFields(cf) then flatGuardFields(rest) else false }
        else false }
  }

def guardablePat = (pat) =>
  match pat { case Pair(ptag, pdata) =>
    if #seq(ptag, "vpat") then true
    else if #seq(ptag, "wpat") then true
    else if #seq(ptag, "lpat") then true   -- literal pattern binds nothing → guard-safe
    else if #seq(ptag, "tpat") then
      match pdata { case Pair(basePat, typeHead) => guardablePat(basePat) }
    else if #seq(ptag, "cpat") then
      match pdata { case Pair(ctorName, fields) => flatGuardFields(fields) }
    -- An alternation `A | B | …` binds nothing (or the SAME vars in every branch,
    -- per Scala), so a guard only reads OUTER scope → always safe. Without this,
    -- `case "]" | "}" if cond =>` left the `if …` unparsed → `_err`.
    else if #seq(ptag, "apat") then true
    else false }

-- Flat constructor alternatives: `case A(_) | B(_) => body`. The lowerer
-- expands the shared body into ordered constructor arms; the scrutinee remains
-- once-evaluated by ordinary match lowering.
def parsePatAlternatives = (ts, acc) =>
  if kindIs("op", ts) then
    if #seq(tokVal(peek(ts)), "|") then
      let rp = parsePat(advance(ts)) in
      parsePatAlternatives(prT(rp), Cons(prV(rp), acc))
    else pr(reverse(acc), ts)
  else pr(reverse(acc), ts)

def parseMatchArm = (toks) =>
  let rPat = parseArmPat(toks) in
  let rAlts = parsePatAlternatives(prT(rPat), Cons(prV(rPat), Nil)) in
  let pats = prV(rAlts) in
  let pat0 = match pats {
    case Cons(one, rest) =>
      match rest { case Nil => one case _ => Pair("apat", pats) }
    case Nil => Pair("wpat", "")
  } in
  let typeHead = patternTypeHead(prT(rAlts)) in
  let typedPat = if #i.gt(#slen(typeHead), 0) then
    Pair("tpat", Pair(pat0, typeHead))
  else pat0 in
  let ts1 = skipPatternTypeAnnot(prT(rAlts)) in
  let canGuard = guardablePat(typedPat) in
  let rGuard = if canGuard then
    if kwIs("if", ts1) then
      let rg = parseExpr(advance(ts1)) in pr(Some(prV(rg)), prT(rg))
    else pr(None, ts1)
  else pr(None, ts1) in
  let ts2 = skipKind("=>", prT(rGuard)) in
  let re   = parseArmBody(ts2) in
  let pat = match prV(rGuard) {
    case None => typedPat
    case Some(guard) => Pair("gpat", Pair(typedPat, guard))
  } in
  pr(Pair(pat, prV(re)), prT(re))

-- parseMatchArms: all arms inside `{ case ... }` (opening `{` already consumed)
def parseMatchArms = (toks) =>
  let rec go = (ts, acc) =>
    let ts2 = skipSemis(ts) in
    if kwIs("case", ts2) then
      let r = parseMatchArm(advance(ts2)) in
      go(prT(r), Cons(prV(r), acc))
    else if kindIs("}", ts2) then pr(reverse(acc), advance(ts2))
    else pr(reverse(acc), ts2) in
  go(toks, Nil)

-- parseMatchExpr: `match e { arms }`  (keyword `match` already consumed)
def parseMatchExpr = (toks) =>
  let re    = parseExpr(toks) in
  let ts1   = skipKind("{", prT(re)) in
  let rArms = parseMatchArms(ts1) in
  pr(mkMatch(prV(re), prV(rArms)), prT(rArms))

-- Read a case-class parameter type while preserving balanced source spelling.
-- This mirrors skipTypeAt's boundary but returns the collected token text.
def readCaseParamTypeAt = (depth, toks, acc) =>
  let t = peek(toks) in
  let k = tokKind(t) in
  let v = tokVal(t) in
  if #seq(k, "EOF") then pr(joinStrs(reverse(acc)), toks)
  else if #seq(k, "[") then
    readCaseParamTypeAt(#i.add(depth, 1), advance(toks), Cons("[", acc))
  else if #seq(k, "(") then
    readCaseParamTypeAt(#i.add(depth, 1), advance(toks), Cons("(", acc))
  else if #seq(k, "]") then
    if #i.eq(depth, 0) then pr(joinStrs(reverse(acc)), toks)
    else readCaseParamTypeAt(#i.sub(depth, 1), advance(toks), Cons("]", acc))
  else if #seq(k, ")") then
    if #i.eq(depth, 0) then pr(joinStrs(reverse(acc)), toks)
    else readCaseParamTypeAt(#i.sub(depth, 1), advance(toks), Cons(")", acc))
  else if #i.eq(depth, 0) then
    if #seq(k, "=") then pr(joinStrs(reverse(acc)), toks)
    else if #seq(k, ",") then pr(joinStrs(reverse(acc)), toks)
    else if #seq(k, ";") then pr(joinStrs(reverse(acc)), toks)
    else if #seq(k, "{") then pr(joinStrs(reverse(acc)), toks)
    else if #seq(k, "}") then pr(joinStrs(reverse(acc)), toks)
    else
      let sv = if #seq(v, "") then k else v in
      readCaseParamTypeAt(depth, advance(toks), Cons(sv, acc))
  else
    let sv = if #seq(v, "") then k else v in
    readCaseParamTypeAt(depth, advance(toks), Cons(sv, acc))

def parseCaseParam = (toks) =>
  -- `var`/`val` field modifiers. `val` is the default (immutable) — just skip it.
  -- `var` is a MUTABLE field: record a violation when the --mutable flag is off (so
  -- parseCaseClass emits `_err_mutable_fields`), and record the field name (flag on)
  -- for the lowerer to cell-back.
  let isVar = kwIs("var", toks) in
  let toks0 = if isVar then advance(toks)
              else if kwIs("val", toks) then advance(toks)
              else toks in
  if #seq(tokKind(peek(toks0)), "id") then
    let name = tokVal(peek(toks0)) in
    let _vrec = if isVar then
                  #cell.set(pendingVarFieldsCell, Cons(name, #cell.get(pendingVarFieldsCell)))
                else 0 in
    let ts1 = advance(toks0) in
    let rt = if kindIs(":", ts1) then
      readCaseParamTypeAt(0, advance(ts1), Nil)
    else pr("Any", ts1) in
    let fieldType = if #i.eq(#slen(prV(rt)), 0) then "Any" else prV(rt) in
    let ts2 = prT(rt) in
    if kindIs("=", ts2) then
      let rd = parseExpr(advance(ts2)) in
      let _rec = #cell.set(paramDefaultsCell,
                   Cons(Pair(name, prV(rd)), #cell.get(paramDefaultsCell))) in
      pr(Pair(name, fieldType), prT(rd))
    else pr(Pair(name, fieldType), ts2)
  else pr(Pair("_", "Any"), toks0)

def parseCaseParamList = (toks) =>
  if kindIs("(", toks) then
    let toks2 = advance(toks) in
    if kindIs(")", toks2) then pr(Nil, advance(toks2))
    else
      let rec goParams = (ts, acc) =>
        let r = parseCaseParam(ts) in
        let acc2 = Cons(prV(r), acc) in
        let ts2 = prT(r) in
        if kindIs(",", ts2) then
          -- A trailing comma before `)` (common in multi-line param lists) must NOT
          -- start another param: parseCaseParam on `)` would fall to its `_`/`Any`
          -- fallback and inject a phantom 5th field (→ ctor arity off-by-one).
          let tsAfterComma = advance(ts2) in
          if kindIs(")", tsAfterComma) then pr(reverse(acc2), tsAfterComma)
          else goParams(tsAfterComma, acc2)
        else pr(reverse(acc2), ts2) in
      let r = goParams(toks2, Nil) in
      pr(prV(r), skipKind(")", prT(r)))
  else pr(Nil, toks)

def caseParamNames = (params) =>
  match params {
    case Nil => Nil
    case Cons(p, rest) => match p { case Pair(name, fieldType) => Cons(name, caseParamNames(rest)) }
  }

def caseParamTypes = (params) =>
  match params {
    case Nil => Nil
    case Cons(p, rest) => match p { case Pair(name, fieldType) => Cons(fieldType, caseParamTypes(rest)) }
  }

def parseDeriveNames = (toks, acc) =>
  let k = tokKind(peek(toks)) in
  if #seq(k, "uid") then
    let name = tokVal(peek(toks)) in
    let ts2 = skipTypeArgs(advance(toks)) in
    if kindIs(",", ts2) then parseDeriveNames(advance(ts2), Cons(name, acc))
    else reverse(Cons(name, acc))
  else if #seq(k, "id") then
    let name = tokVal(peek(toks)) in
    let ts2 = skipTypeArgs(advance(toks)) in
    if kindIs(",", ts2) then parseDeriveNames(advance(ts2), Cons(name, acc))
    else reverse(Cons(name, acc))
  else reverse(acc)

def findCaseDerives = (toks) =>
  let k = tokKind(peek(toks)) in
  let v = tokVal(peek(toks)) in
  if #seq(k, "EOF") then Nil
  else if #seq(k, ";") then Nil
  else if #seq(k, "{") then Nil
  else if #seq(k, "id") then
    if #seq(v, "derives") then parseDeriveNames(advance(toks), Nil)
    else findCaseDerives(advance(toks))
  else findCaseDerives(advance(toks))

-- parseCaseClass: `case class Name(params) [derives TC]` (keywords consumed)
def parseCaseClass = (toks) =>
  let name = tokVal(peek(toks)) in
  let ts1  = skipTypeParams(advance(toks)) in
  let _clr = #cell.set(paramDefaultsCell, Nil) in
  let _clrv = #cell.set(pendingVarFieldsCell, Nil) in
  let _clrb = #cell.set(pendingBodyFieldsCell, Nil) in
  let rp   = parseCaseParamList(ts1) in
  let params = caseParamNames(prV(rp)) in
  let types = caseParamTypes(prV(rp)) in
  let derives = findCaseDerives(prT(rp)) in
  let _reg = registerParamDflts(name, params) in
  -- Record `extends Parent` (first named parent) so a `case _: Parent` ascription
  -- can expand to the child tags. Only an uppercase (uid) parent is nominal.
  let _regSub =
    if kwIs("extends", prT(rp)) then
      let parentTok = peek(advance(prT(rp))) in
      if #seq(tokKind(parentTok), "uid") then
        #cell.set(subtypeRegCell,
          Cons(Pair(tokVal(parentTok), name), #cell.get(subtypeRegCell)))
      else 0
    else 0 in
  let rec skipExt = (ts) =>
    let tok = peek(ts) in
    let k2  = tokKind(tok) in
    if #seq(k2, "EOF")  then ts
    else if #seq(k2, "{") then ts
    -- A `}` after the param list closes the ENCLOSING block (e.g. the object body
    -- when this case class is its LAST member) — a case class body can only START
    -- with `{` or an on-line layout member, never past a `}`. Without this stop
    -- `skipExt` walked through the object's `}` and captured the following
    -- top-level `def` as a case-class body method (`object O { case class P(..) }`
    -- then `def main` → main absorbed as `O_main`, entry never called).
    else if #seq(k2, "}") then ts
    else if #seq(k2, ";") then ts
    else if #seq(k2, "kw") then
      if kwIs("def",      ts) then ts
      else if kwIs("val",    ts) then ts
      else if kwIs("case",   ts) then ts
      else if kwIs("sealed", ts) then ts
      else if kwIs("object", ts) then ts
      else if kwIs("class",  ts) then ts
      else skipExt(advance(ts))
    else skipExt(advance(ts)) in
  let ts2 = skipExt(prT(rp)) in
  -- Capture body `def`s (methods like `override def toString`). Two body shapes:
  --  • braced `{ … }` — skip non-defs to the closing `}` (same reach as the old skip);
  --  • layout `case class X(…):` then indented members — skipExt already stopped at the
  --    first member `def` (it skips `override`), so consume CONSECUTIVE member defs and
  --    stop at the first non-member token (a new decl keyword / statement).
  let ts3 =
    if kindIs("{", ts2) then
      let rec captureBraced = (ts, acc) =>
        if kindIs("}", ts) then pr(reverse(acc), advance(ts))
        else if kindIs("EOF", ts) then pr(reverse(acc), ts)
        else if kwIs("override", ts) then captureBraced(advance(ts), acc)
        else if kwIs("final", ts) then captureBraced(advance(ts), acc)
        else if kwIs("private", ts) then captureBraced(advance(ts), acc)
        else if kwIs("def", ts) then
          let r = parseDef(advance(ts)) in captureBraced(prT(r), Cons(prV(r), acc))
        else if kwIs("val", ts) then
          -- A body `val y = expr` (not a ctor param) is captured as a NULLARY method
          -- `def y = expr` — a pure computed field is observationally identical, and
          -- reuses method dispatch (`c.y` external, bare `y` internal). NOTE: recomputed
          -- per access, so a val with side effects differs (rare); `lazy val` is separate.
          let r = parseVal(advance(ts)) in
          let defNode = match prV(r) { case Pair(vt, vd) =>
            match vd { case Pair(vn, vrhs) => Pair("def", Pair(vn, Pair(Nil, vrhs))) } } in
          captureBraced(prT(r), Cons(defNode, acc))
        else if (if #seq(tokKind(peek(ts)), "id") then #seq(tokVal(peek(ts)), "lazy") else false) then
          -- `lazy val z = expr` → a memoized body field (needs per-instance cell state).
          let r = parseVal(advance(advance(ts))) in
          let _bf = match prV(r) { case Pair(vt, vd) => match vd { case Pair(vn, vrhs) =>
            #cell.set(pendingBodyFieldsCell,
              Cons(Pair(vn, Pair(vrhs, "lazy")), #cell.get(pendingBodyFieldsCell))) } } in
          captureBraced(prT(r), acc)
        else if kwIs("var", ts) then
          -- Body `var y = expr` → a mutable body field (cell). Gated by --mutable.
          let r = parseVal(advance(ts)) in
          let _bf = match prV(r) { case Pair(vt, vd) => match vd { case Pair(vn, vrhs) =>
            let _pv = #cell.set(pendingVarFieldsCell, Cons(vn, #cell.get(pendingVarFieldsCell))) in
            #cell.set(pendingBodyFieldsCell,
              Cons(Pair(vn, Pair(vrhs, "var")), #cell.get(pendingBodyFieldsCell))) } } in
          captureBraced(prT(r), acc)
        else captureBraced(advance(ts), acc) in
      let rc = captureBraced(advance(ts2), Nil) in
      let _regM = registerCaseMethods(name, params, prV(rc)) in
      prT(rc)
    else if kwIs("def", ts2) then
      let rec captureLayout = (ts, acc) =>
        if kwIs("override", ts) then captureLayout(advance(ts), acc)
        else if kwIs("final", ts) then captureLayout(advance(ts), acc)
        else if kwIs("private", ts) then captureLayout(advance(ts), acc)
        else if kwIs("def", ts) then
          let r = parseDef(advance(ts)) in captureLayout(prT(r), Cons(prV(r), acc))
        else if kwIs("val", ts) then
          -- Layout body `val y = expr` → nullary `def y = expr` (see captureBraced).
          let r = parseVal(advance(ts)) in
          let defNode = match prV(r) { case Pair(vt, vd) =>
            match vd { case Pair(vn, vrhs) => Pair("def", Pair(vn, Pair(Nil, vrhs))) } } in
          captureLayout(prT(r), Cons(defNode, acc))
        else if (if #seq(tokKind(peek(ts)), "id") then #seq(tokVal(peek(ts)), "lazy") else false) then
          let r = parseVal(advance(advance(ts))) in
          let _bf = match prV(r) { case Pair(vt, vd) => match vd { case Pair(vn, vrhs) =>
            #cell.set(pendingBodyFieldsCell,
              Cons(Pair(vn, Pair(vrhs, "lazy")), #cell.get(pendingBodyFieldsCell))) } } in
          captureLayout(prT(r), acc)
        else if kwIs("var", ts) then
          let r = parseVal(advance(ts)) in
          let _bf = match prV(r) { case Pair(vt, vd) => match vd { case Pair(vn, vrhs) =>
            let _pv = #cell.set(pendingVarFieldsCell, Cons(vn, #cell.get(pendingVarFieldsCell))) in
            #cell.set(pendingBodyFieldsCell,
              Cons(Pair(vn, Pair(vrhs, "var")), #cell.get(pendingBodyFieldsCell))) } } in
          captureLayout(prT(r), acc)
        else pr(reverse(acc), ts) in
      let rc = captureLayout(ts2, Nil) in
      let _regM = registerCaseMethods(name, params, prV(rc)) in
      prT(rc)
    else ts2 in
  -- Mutable `var` field gate: any recorded var field in this class requires the
  -- --mutable flag. Off → emit the `_err_mutable_fields` sentinel (CLI surfaces a
  -- specific message). On → register the var fields under this class tag so the
  -- lowerer can cell-back them.
  -- Register this class's body-declared var/lazy fields (declaration order) so the
  -- lowerer can synthesize a constructor that computes them.
  let _regBody = match #cell.get(pendingBodyFieldsCell) {
    case Nil => 0
    case Cons(bh, bt) => #cell.set(classBodyFieldsCell,
                 Cons(Pair(name, reverse(Cons(bh, bt))), #cell.get(classBodyFieldsCell)))
  } in
  let thisVars = #cell.get(pendingVarFieldsCell) in
  match thisVars {
    case Nil => pr(mkCaseCls(name, params, types, derives), ts3)
    case Cons(vh, vt) =>
      if #cell.get(mutableFlagCell) then
        let _reg = #cell.set(mutableFieldsCell,
                     Cons(Pair(name, thisVars), #cell.get(mutableFieldsCell))) in
        pr(mkCaseCls(name, params, types, derives), ts3)
      else
        let _v = #cell.set(mutableViolationCell, true) in
        pr(mkSExpr(mkVar("_err_mutable_fields")), ts3)
  }

-- parseCaseObject: `case object Name [extends ...]` (keywords consumed).
-- The native route represents the declaration as one stable nullary value.
-- Member-bearing bodies are deliberately skipped by this slice, matching the
-- bounded contract in specs/v2.1-native-case-objects.md.
def parseCaseObject = (toks) =>
  let name = tokVal(peek(toks)) in
  let rec skipTail = (ts) =>
    if kindIs("EOF", ts) then ts
    else if kindIs(";", ts) then ts
    else if kindIs("{", ts) then ts
    else if kindIs("kw", ts) then
      if kwIs("def", ts) then ts
      else if kwIs("val", ts) then ts
      else if kwIs("var", ts) then ts
      else if kwIs("case", ts) then ts
      else if kwIs("sealed", ts) then ts
      else if kwIs("trait", ts) then ts
      else if kwIs("given", ts) then ts
      else if kwIs("object", ts) then ts
      else if kwIs("class", ts) then ts
      else if kwIs("abstract", ts) then ts
      else skipTail(advance(ts))
    else skipTail(advance(ts)) in
  let ts1 = skipTail(advance(toks)) in
  let ts2 = if kindIs("{", ts1) then
    let rec skipBody = (ts) =>
      if kindIs("}", ts) then advance(ts)
      else if kindIs("EOF", ts) then ts
      else skipBody(advance(ts)) in
    skipBody(advance(ts1))
  else ts1 in
  pr(mkCaseObj(name), ts2)

-- skipToBrace: advance past extends/with clauses until `{` or EOF/;
def skipToBrace = (ts) =>
  if kindIs("{",   ts) then ts
  else if kindIs("EOF", ts) then ts
  else if kindIs(";",   ts) then ts
  else skipToBrace(advance(ts))

-- skipBraceBlock: skip a balanced {…} block (ts must start at `{`)
def skipBraceBlock = (ts) =>
  let rec go = (t, depth) =>
    if kindIs("EOF", t) then t
    else if kindIs("{", t) then go(advance(t), #i.add(depth, 1))
    else if kindIs("}", t) then
      if #i.le(depth, 1) then advance(t)
      else go(advance(t), #i.sub(depth, 1))
    else go(advance(t), depth) in
  if kindIs("{", ts) then go(advance(ts), 1)
  else ts

-- skipToStmt: advance until next top-level statement keyword
def skipToStmt = (ts) =>
  let tok = peek(ts) in
  let k2  = tokKind(tok) in
  let v2  = tokVal(tok) in
  if #seq(k2, "EOF") then ts
  else if #seq(k2, ";") then ts
  else if #seq(k2, "kw") then
    if kwIs("def",      ts) then ts
    else if kwIs("val",    ts) then ts
    else if kwIs("case",   ts) then ts
    else if kwIs("sealed", ts) then ts
    else if kwIs("trait",  ts) then ts
    else if kwIs("given",  ts) then ts
    else if kwIs("object", ts) then ts
    else if kwIs("abstract", ts) then ts
    -- K62.8: `type X = Y` alias starts a new statement (top-level has no `;`
    -- separators, so a body-skip must halt at the next declaration keyword).
    else if kwIs("type",   ts) then ts
    else skipToStmt(advance(ts))
  else if #seq(k2, "id") then
    -- K62.8: declaration-starting identifiers (not real keywords) also bound a skip
    if #seq(v2, "extern") then ts
    else if #seq(v2, "opaque") then ts
    else if #seq(v2, "enum") then ts
    else skipToStmt(advance(ts))
  else skipToStmt(advance(ts))

-- K62.13: skip an enum header (`extends S with T` / stray tokens) up to the body
-- opener `:` (layout) or `{` (braced), or the first `case`, `;`, EOF.
def skipEnumHead = (ts) =>
  if kindIs(":", ts) then ts
  else if kindIs("{", ts) then ts
  else if kindIs(";", ts) then ts
  else if kindIs("EOF", ts) then ts
  else if kwIs("case", ts) then ts
  else skipEnumHead(advance(ts))

-- K62.13: from INSIDE a `{`-block (depth 1), skip to and past the matching `}`
-- (used to consume any post-case methods in a braced enum body).
def skipRestBrace = (ts) =>
  let rec go = (t, depth) =>
    if kindIs("EOF", t) then t
    else if kindIs("{", t) then go(advance(t), #i.add(depth, 1))
    else if kindIs("}", t) then
      (if #i.le(depth, 1) then advance(t) else go(advance(t), #i.sub(depth, 1)))
    else go(advance(t), depth) in
  go(ts, 1)

-- K62.6b: a top-level statement that is either an expression or a `name = expr`
-- assignment (only a bare-identifier lhs is treated as assignment; anything else
-- stays an expression statement).
def parseExprOrAssign = (toks) =>
  let re = parseExpr(toks) in
  if kindIs("=", prT(re)) then
    match prV(re) {
      case Pair(ltag, ldata) =>
        if #seq(ltag, "var") then
          let rrhs = parseExpr(advance(prT(re))) in
          pr(Pair("assign", Pair(ldata, prV(rrhs))), prT(rrhs))
        else pr(mkSExpr(prV(re)), prT(re))
    }
  else pr(mkSExpr(prV(re)), prT(re))

-- `final`/`private` are not lexer keywords (they lex as `id`), so a leading
-- `final case class …` / `private object …` would fall through to parseExpr as
-- a bare variable (→ "unbound global: final"). Recognize them as no-op leading
-- modifiers: consume one and re-dispatch on the underlying declaration. Chains
-- (`private final case class`) fold through the recursion. Unlike `sealed`/
-- `abstract`, we must NOT skip the declaration — the class/object is real.
def isLeadModTok = (k, v) =>
  if #seq(k, "id") then
    (if #seq(v, "final") then true else if #seq(v, "private") then true else false)
  else false

def parseOneStmt = (toks) =>
  let t = peek(toks) in
  let k = tokKind(t) in
  let v = tokVal(t) in
  -- Receiver lifetime is owned by the extension layout/brace frame. Nested
  -- member bodies also call parseOneStmt, so statement kind cannot safely
  -- clear the shared receiver cell.
  if isLeadModTok(k, v) then parseOneStmt(advance(toks))
  else if #seq(k, "@") then
    -- annotation(s): @Name / @Name("args") before a def/class/val — no runtime
    -- effect in the native path, so skip them and parse the annotated statement.
    let rec skipAnn = (ts) =>
      let ts1 = advance(ts) in
      let ts2 = if kindIs("id", ts1) then advance(ts1)
                else if kindIs("uid", ts1) then advance(ts1) else ts1 in
      let ts3 = if kindIs("(", ts2) then
                  let rec skipP = (t2) =>
                    if kindIs(")", t2) then advance(t2)
                    else if kindIs("EOF", t2) then t2
                    else skipP(advance(t2)) in
                  skipP(advance(ts2))
                else ts2 in
      if kindIs("@", ts3) then skipAnn(ts3) else ts3 in
    parseOneStmt(skipAnn(toks))
  else if #seq(k, "[") then
    -- Markdown-link import  [a, b, c](path)  — the imported names resolve via
    -- the plugin registry / globals, so the declaration is a parse-only no-op.
    let rec skipTo = (ts, closer) =>
      if kindIs(closer, ts) then advance(ts)
      else if kindIs("EOF", ts) then ts
      else skipTo(advance(ts), closer) in
    let ts1 = skipTo(advance(toks), "]") in
    let ts2 = if kindIs("(", ts1) then skipTo(advance(ts1), ")") else ts1 in
    pr(Pair("sealed", ""), ts2)
  else if #seq(k, "kw") then
    if #seq(v, "import") then
      -- Scala-style `import a.b.c` / `import a.b.{x, y}` — names resolve via the
      -- registry / globals; consume exactly the dotted path (+ optional {…} group).
      let rec skipPath = (ts) =>
        if kindIs("id", ts) then
          let ts2 = advance(ts) in
          if kindIs(".", ts2) then skipPath(advance(ts2))
          else ts2
        else if kindIs("uid", ts) then
          let ts2 = advance(ts) in
          if kindIs(".", ts2) then skipPath(advance(ts2))
          else ts2
        else if kindIs("{", ts) then
          let rec skipGrp = (t2) =>
            if kindIs("}", t2) then advance(t2)
            else if kindIs("EOF", t2) then t2
            else skipGrp(advance(t2)) in
          skipGrp(advance(ts))
        else if #seq(tokVal(peek(ts)), "*") then advance(ts)   -- wildcard: import a.b.*
        else ts in
      pr(Pair("sealed", ""), skipPath(advance(toks)))
    else if #seq(v, "def") then parseDef(advance(toks))
    else if #seq(v, "val") then parseVal(advance(toks))
    else if #seq(v, "var") then
      -- K62.6b: top-level mutable var (parseBlock handled var; parseOneStmt did not)
      let r = parseVal(advance(toks)) in
      match prV(r) { case Pair(vtag, vdata) => pr(Pair("var", vdata), prT(r)) }
    else if #seq(v, "while") then
      -- K62.19: document-level while reuses the block statement shape.
      let ts1 = advance(toks) in
      let rCond = if kindIs("(", ts1) then
        let r = parseExpr(advance(ts1)) in
        pr(prV(r), skipKind(")", prT(r)))
      else parseExpr(ts1) in
      let ts2 = if kwIs("do", prT(rCond)) then advance(prT(rCond)) else prT(rCond) in
      let rBody = if kindIs("{", ts2) then parseBlock(advance(ts2))
                  else parseExpr(ts2) in
      pr(Pair("while", Pair(prV(rCond), prV(rBody))), prT(rBody))
    else if #seq(v, "case") then
      let ts2 = advance(toks) in
      if kwIs("class", ts2) then parseCaseClass(advance(ts2))
      else if kwIs("object", ts2) then parseCaseObject(advance(ts2))
      else let re = parseExpr(toks) in pr(mkSExpr(prV(re)), prT(re))
    else if #seq(v, "sealed") then
      pr(Pair("sealed", ""), skipToStmt(advance(toks)))
    else if #seq(v, "abstract") then
      pr(Pair("sealed", ""), skipToStmt(advance(toks)))
    else if #seq(v, "trait") then
      -- Capture `trait Child extends Parent` into the TC hierarchy before skipping (givens under a
      -- child TC must satisfy a parent-TC context bound). Scan from the trait name to the first
      -- `extends <UID>` (stop at the body `{`/`:`/EOF).
      let tsAfterKw = advance(toks) in
      let childTC = if kindIs("uid", tsAfterKw) then tokVal(peek(tsAfterKw)) else "" in
      -- Stop at the trait-header boundary (body `{`, `:`, `;`, EOF, or a following stmt keyword) so a
      -- bodyless `trait Foo` never captures a later statement's `extends`.
      let rec scanExtends = (ts) =>
        if kindIs("EOF", ts) then Pair("sealed", "")
        else if kindIs("{", ts) then Pair("sealed", "")
        else if kindIs(":", ts) then Pair("sealed", "")
        else if kindIs(";", ts) then Pair("sealed", "")
        else if kwIs("extends", ts) then
          let pt = peek(advance(ts)) in
          if #seq(tokKind(pt), "uid") then Pair("uid", tokVal(pt)) else Pair("sealed", "")
        else if kindIs("kw", ts) then
          if kwIs("def", ts) then Pair("sealed", "")
          else if kwIs("val", ts) then Pair("sealed", "")
          else if kwIs("var", ts) then Pair("sealed", "")
          else if kwIs("case", ts) then Pair("sealed", "")
          else if kwIs("sealed", ts) then Pair("sealed", "")
          else if kwIs("trait", ts) then Pair("sealed", "")
          else if kwIs("given", ts) then Pair("sealed", "")
          else if kwIs("object", ts) then Pair("sealed", "")
          else if kwIs("abstract", ts) then Pair("sealed", "")
          else if kwIs("class", ts) then Pair("sealed", "")
          else if kwIs("enum", ts) then Pair("sealed", "")
          else if kwIs("type", ts) then Pair("sealed", "")
          else scanExtends(advance(ts))
        else scanExtends(advance(ts)) in
      let _regExt = match scanExtends(tsAfterKw) {
        case Pair(ptag, parent) =>
          if #seq(ptag, "uid") then
            (if #seq(childTC, "") then 0
             else #cell.set(tcExtendsCell, Cons(Pair(childTC, parent), #cell.get(tcExtendsCell))))
          else 0
      } in
      -- Skip trait declarations entirely (abstract, no impl to lower).
      -- Use a stmt-keyword-aware skip so we don't eat following case class declarations.
      -- If a body `{...}` is encountered, skip it; otherwise stop at the next statement.
      let rec skipTrait = (ts) =>
        if kindIs("EOF", ts) then ts
        else if kindIs(";",  ts) then ts
        else if kindIs("{",  ts) then skipBraceBlock(ts)
        else if kindIs("kw", ts) then
          if kwIs("def",      ts) then ts
          else if kwIs("val",    ts) then ts
          else if kwIs("var",    ts) then ts
          else if kwIs("case",   ts) then ts
          else if kwIs("sealed", ts) then ts
          else if kwIs("trait",  ts) then ts
          else if kwIs("given",  ts) then ts
          else if kwIs("object", ts) then ts
          else if kwIs("abstract", ts) then ts
          else skipTrait(advance(ts))
        else skipTrait(advance(ts)) in
      pr(Pair("sealed", ""), skipTrait(advance(toks)))
    else if #seq(v, "given") then
      -- KC5+KC8: `given name: T = body` → ("given", (name, typeStr, body)) for KC5 injection
      let ts1 = advance(toks) in
      if kindIs("id", ts1) then
        let gname = tokVal(peek(ts1)) in
        let ts2 = advance(ts1) in
        if kindIs(":", ts2) then
          -- KC5: capture type annotation as a string for the given table
          let rTyp = readTypeStr(advance(ts2)) in
          let typeStr = prV(rTyp) in
          let ts3 = prT(rTyp) in
          if kindIs("=", ts3) then
            let re = parseExpr(advance(ts3)) in
            pr(Pair("given", Pair(gname, Pair(typeStr, prV(re)))), prT(re))
          else if kwIs("with", ts3) then
            -- given name: T with { defs } → ("given_obj", (name, typeStr, stmts))
            let ts4 = skipToBrace(advance(ts3)) in
            let rec parseObj = (ts, acc) =>
              let ts5 = skipSemis(ts) in
              if kindIs("}", ts5) then
                -- An `extension` group inside the body closes as `} extension_end` (a virtual E frame);
                -- that ends the EXTENSION, not the given. Consume both, reset the extension params (so a
                -- following regular `def` isn't given the receiver), keep the extension_end marker (so
                -- ssc1-lower's extension tracking stops here), and continue the body.
                let tsE = advance(ts5) in
                if kindIs("extension_end", tsE) then
                  let _clrExt = #cell.set(extensionParamsCell, Nil) in
                  parseObj(advance(tsE), Cons(Pair("extension_end", ""), acc))
                else pr(Pair("given_obj", Pair(gname, Pair(typeStr, reverse(acc)))), tsE)
              else if kindIs("EOF", ts5) then pr(Pair("given_obj", Pair(gname, Pair(typeStr, reverse(acc)))), ts5)
              else
                let r = parseOneStmt(ts5) in
                parseObj(prT(r), Cons(prV(r), acc)) in
            if kindIs("{", ts4) then parseObj(advance(ts4), Nil)
            else pr(Pair("given_obj", Pair(gname, Pair(typeStr, Nil))), ts4)
          else pr(Pair("sealed", ""), skipToStmt(ts3))
        else if kindIs("=", ts2) then
          -- `given name = body` (no type annotation) → treat as val
          let re = parseExpr(advance(ts2)) in
          pr(mkVal(gname, prV(re)), prT(re))
        else
          pr(Pair("sealed", ""), skipToStmt(ts1))
      else
        -- Anonymous given (starts with uppercase type) — skip
        pr(Pair("sealed", ""), skipToStmt(ts1))
    else if #seq(v, "effect") then
      let ts1 = advance(toks) in
      if kindIs("{", ts1) then
        -- `effect { body }` is the reactive global call with a thunk argument.
        -- `effect` is also a declaration keyword, so this call form must be
        -- separated before the declaration-only erasure below.
        parseExprOrAssign(toks)
      else
        -- A declared effect owns its abstract member body. Retain the operation
        -- signatures so imports and the portable lowerer can materialize
        -- E_op closures; erasing/skipping here used to swallow later defs.
        let ename = tokVal(peek(ts1)) in
        let ts2 = skipToBrace(advance(ts1)) in
        let rec parseEffect = (ts, acc) =>
          let ts3 = skipSemis(ts) in
          if kindIs("}", ts3) then
            pr(Pair("effect_decl", Pair(ename, Pair(false, reverse(acc)))), advance(ts3))
          else if kindIs("EOF", ts3) then
            pr(Pair("effect_decl", Pair(ename, Pair(false, reverse(acc)))), ts3)
          else
            let r = parseOneStmt(ts3) in
            parseEffect(prT(r), Cons(prV(r), acc)) in
        if kindIs("{", ts2) then parseEffect(advance(ts2), Nil)
        else pr(Pair("effect_decl", Pair(ename, Pair(false, Nil))), ts2)
    else if #seq(v, "class") then
      -- A plain (non-`case`) class reuses the case-class pipeline: same DataV
      -- representation, positional field accessors, method dispatch (defs in the
      -- body), and `new X(a)` == `X(a)` construction (the `new` atom is elided).
      -- Mutable `var` fields are a separate gap (v2-class-var-fields).
      parseCaseClass(advance(toks))
    else if #seq(v, "object") then
      -- KC7b: parse object body into ("object", (name, [stmts]))
      let ts1 = advance(toks) in
      let name = tokVal(peek(ts1)) in
      let ts2 = skipToBrace(advance(ts1)) in
      if kindIs("{", ts2) then
        let rec parseObj = (ts, acc) =>
          let ts5 = skipSemis(ts) in
          if kindIs("}", ts5) then pr(Pair("object", Pair(name, reverse(acc))), advance(ts5))
          else if kindIs("EOF", ts5) then pr(Pair("object", Pair(name, reverse(acc))), ts5)
          else
            let r = parseOneStmt(ts5) in
            parseObj(prT(r), Cons(prV(r), acc)) in
        parseObj(advance(ts2), Nil)
      else pr(Pair("object", Pair(name, Nil)), ts2)
    else if #seq(v, "type") then
      -- K62.8: `type X = Y` / `type X[..] = Y` alias — erased, skip to next stmt.
      pr(Pair("sealed", ""), skipToStmt(advance(toks)))
    else let re = parseExpr(toks) in pr(mkSExpr(prV(re)), prT(re))
  else
    -- KV9: check for "multi effect E { ... }" multi-shot effect declaration
    if #seq(k, "id") then
      if #seq(v, "extension") then
        -- K62.18: retain receiver names through the virtual layout body. The
        -- top-level parse loop clears them when it consumes the matching `}`.
        let ts1 = skipTypeParams(advance(toks)) in
        let rp = if kindIs("(", ts1) then parseParamList(ts1) else pr(Nil, ts1) in
        let _ext = #cell.set(extensionParamsCell, prV(rp)) in
        let ts2 = prT(rp) in
        let ts3 = if kindIs("{", ts2) then advance(ts2) else ts2 in
        pr(Pair("extension_start", ""), ts3)
      else if #seq(v, "multi") then
        let ts1 = advance(toks) in
        if kindIs("kw", ts1) then
          if #seq(tokVal(peek(ts1)), "effect") then
            let ts2 = advance(ts1) in
            let ename = tokVal(peek(ts2)) in
            let ts3 = skipToBrace(advance(ts2)) in
            let rec parseEffect = (ts, acc) =>
              let ts4 = skipSemis(ts) in
              if kindIs("}", ts4) then
                pr(Pair("effect_decl", Pair(ename, Pair(true, reverse(acc)))), advance(ts4))
              else if kindIs("EOF", ts4) then
                pr(Pair("effect_decl", Pair(ename, Pair(true, reverse(acc)))), ts4)
              else
                let r = parseOneStmt(ts4) in
                parseEffect(prT(r), Cons(prV(r), acc)) in
            if kindIs("{", ts3) then parseEffect(advance(ts3), Nil)
            else pr(Pair("effect_decl", Pair(ename, Pair(true, Nil))), ts3)
          else let re = parseExpr(toks) in pr(mkSExpr(prV(re)), prT(re))
        else let re = parseExpr(toks) in pr(mkSExpr(prV(re)), prT(re))
      else if #seq(v, "extern") then
        -- K62.8: extern defs are signatures; extern classes additionally own a
        -- layout/braced abstract-member body. Consume that body atomically so
        -- its `val`/`def` members cannot escape as top-level parser sentinels.
        let ts1 = advance(toks) in
        if kwIs("class", ts1) then
          let ts2 = skipToBrace(advance(ts1)) in
          let ts3 = if kindIs("{", ts2) then skipBraceBlock(ts2) else skipToStmt(ts2) in
          pr(Pair("sealed", ""), ts3)
        else
          let ts2 = if kindIs("kw", ts1) then advance(ts1) else ts1 in
          pr(Pair("sealed", ""), skipToStmt(ts2))
      else if #seq(v, "opaque") then
        -- K62.8: `opaque type X = Y` — erased alias, skip to next stmt.
        pr(Pair("sealed", ""), skipToStmt(advance(toks)))
      else if #seq(v, "enum") then
        -- K62.13: real enum parsing. `enum E[T](p) extends S:` (layout) or `{ … }` (braced),
        -- then `case X` (nullary) / `case X(p1: T, …)` (parametrized) entries. Layout inserts
        -- `;` between case lines. Emits ("enum", Pair(name, [Pair(caseName, params)…])); the
        -- lower turns each case into a ctor (nullary = value, parametrized = case-class ctor).
        let ts1 = advance(toks) in
        let ename = tokVal(peek(ts1)) in
        let ts2 = skipTypeParams(advance(ts1)) in
        let ts3 = if kindIs("(", ts2) then prT(parseParamList(ts2)) else ts2 in
        let ts4 = skipEnumHead(ts3) in
        let brace = kindIs("{", ts4) in
        let ts5 = if kindIs(":", ts4) then advance(ts4)
                  else if brace then advance(ts4) else ts4 in
        let rec goCases = (ts, acc) =>
          let tsA = skipSemis(ts) in
          if kwIs("case", tsA) then
            let tsB = advance(tsA) in
            -- A following top-level `case class` is a new declaration, not an
            -- enum case named `class` (layout newlines are otherwise erased).
            if kwIs("class", tsB) then pr(reverse(acc), tsA)
            else
              let cname = tokVal(peek(tsB)) in
              let tsC = advance(tsB) in
              let _clr = #cell.set(paramDefaultsCell, Nil) in
              let rp = if kindIs("(", tsC) then parseParamList(tsC) else pr(Nil, tsC) in
              let _reg = registerParamDflts(cname, prV(rp)) in
              let acc1 = Cons(Pair(cname, prV(rp)), acc) in
              -- `case Red, Green, …`: additional comma-separated NULLARY cases on one
              -- line (Scala enum sugar). Without this the comma tail leaked as
              -- statements (`, Green` → `case`/`Green` unbound globals).
              let rec goComma = (tsK, accK) =>
                if kindIs(",", tsK) then
                  let nm = tokVal(peek(advance(tsK))) in
                  goComma(advance(advance(tsK)), Cons(Pair(nm, Nil), accK))
                else pr(accK, tsK) in
              let rComma = goComma(prT(rp), acc1) in
              goCases(prT(rComma), prV(rComma))
          else pr(reverse(acc), tsA) in
        let rc = goCases(ts5, Nil) in
        let ts6 = if brace then skipRestBrace(prT(rc)) else prT(rc) in
        pr(Pair("enum", Pair(ename, prV(rc))), ts6)
      else parseExprOrAssign(toks)
    else parseExprOrAssign(toks)

def skipSemis = (toks) =>
  if kindIs(";", toks) then skipSemis(advance(toks)) else toks

def parseStmts = (toks) =>
  let rec go = (ts, acc) =>
    let ts2 = skipSemis(ts) in
    if kindIs("EOF", ts2) then reverse(acc)
    else if kindIs("extension_end", ts2) then
      -- Only the close of the owning extension frame ends receiver scope.
      -- Ordinary residual `}` tokens may belong to nested member layout.
      let _closeExtension = #cell.set(extensionParamsCell, Nil) in
      go(advance(ts2), Cons(Pair("extension_end", ""), acc))
    else if kindIs("}", ts2) then go(advance(ts2), acc)
    else
      let r = parseOneStmt(ts2) in
      go(prT(r), Cons(prV(r), acc)) in
  go(toks, Nil)

-- ── K62.6c-indent: layout (offside → virtual braces) ─────────────────────────
-- Convert NL <indent> tokens into virtual { ; } for brace-less indented blocks.
-- A layout block ("L") opens after an opener token (= => then else do yield) that is
-- immediately followed by a newline; its statements sit at the block's indent.
-- Explicit braces are tracked as "B" so dedent/close stay correctly nested. NLs
-- outside any L block (top level, or directly inside a `{}`) are consumed — that
-- preserves the pre-indent behaviour (newlines were whitespace).
def isLayoutOpener = (t) =>
  match t { case Pair(k, v) =>
    if #seq(k, "=") then true
    else if #seq(k, "=>") then true
    else if #seq(k, "kw") then
      (if #seq(v, "then") then true else if #seq(v, "else") then true
       else if #seq(v, "do") then true else if #seq(v, "yield") then true
       else if #seq(v, "with") then true
       -- K62.13: brace-less `x match` ⏎ <indented case arms> opens a layout block so the
       -- arms close at dedent (a top-level `def f = e match` ⏎ arms no longer swallows the
       -- following statements). Braced `match { … }` is unaffected (match is followed by `{`,
       -- not NL, so no L block opens).
       else if #seq(v, "match") then true
       else false)
    else false }

def prependLayoutClose = (tag, closes) =>
  if #seq(tag, "E") then
    Cons(mkTok("}", ""), Cons(mkTok("extension_end", ""), closes))
  else Cons(mkTok("}", ""), closes)

def isLayoutFrame = (tag) =>
  if #seq(tag, "L") then true else #seq(tag, "E")

-- close L/E blocks whose indent > v (stop at a brace or shallow-enough frame)
def dedentL = (v, stack) =>
  match stack {
    case Nil => Pair(Nil, Nil)
    case Cons(top, srest) =>
      match top { case Pair(tag, ind) =>
        if isLayoutFrame(tag) then
          (if #i.lt(v, ind) then
             match dedentL(v, srest) { case Pair(cs, ns) => Pair(prependLayoutClose(tag, cs), ns) }
           else Pair(Nil, stack))
        else Pair(Nil, stack) } }

def nearestBraceIsExtension = (stack) =>
  match stack {
    case Nil => false
    case Cons(top, srest) =>
      match top { case Pair(tag, ind) =>
        if #seq(tag, "EB") then true
        else if #seq(tag, "B") then false
        else nearestBraceIsExtension(srest) }
  }

-- on `}`: emit a virtual } for each open layout frame above the nearest
-- B/EB, then pop that explicit brace frame.
def closeToBrace = (stack) =>
  match stack {
    case Nil => Pair(Nil, Nil)
    case Cons(top, srest) =>
      match top { case Pair(tag, ind) =>
        if #seq(tag, "B") then Pair(Nil, srest)
        else if #seq(tag, "EB") then Pair(Nil, srest)
        else match closeToBrace(srest) {
          case Pair(cs, ns) => Pair(prependLayoutClose(tag, cs), ns)
        } } }

-- On `)` / `]`, close only virtual layout blocks opened inside the matching
-- explicit delimiter. A different explicit delimiter is a hard boundary.
def closeToDelim = (wanted, stack) =>
  match stack {
    case Nil => Pair(Nil, Nil)
    case Cons(top, srest) =>
      match top { case Pair(tag, ind) =>
        if #seq(tag, wanted) then Pair(Nil, srest)
        else if isLayoutFrame(tag) then
          match closeToDelim(wanted, srest) {
            case Pair(cs, ns) => Pair(prependLayoutClose(tag, cs), ns)
          }
        else Pair(Nil, stack) } }

-- at EOF: close all still-open L/E blocks.
def closeAllL = (stack) =>
  match stack {
    case Nil => Nil
    case Cons(top, srest) =>
      match top { case Pair(tag, ind) =>
        if isLayoutFrame(tag) then prependLayoutClose(tag, closeAllL(srest))
        else closeAllL(srest) } }

-- after a dedent to stack `ns`, does `v` land at a same-level L (→ a `;`)?
def sepAfter = (v, ns) =>
  match ns {
    case Nil => Nil
    case Cons(nt, nsr) =>
      match nt { case Pair(ntag, nind) =>
        if isLayoutFrame(ntag) then (if #i.eq(v, nind) then Cons(mkTok(";", ""), Nil) else Nil)
        else Nil } }

-- a line that STARTS with one of these continues the previous expression rather
-- than starting a new statement (Scala offside: else / infix op / . / :: / ->).
def isCont = (ts) =>
  match ts {
    case Nil => false
    case Cons(t, r) =>
      match t { case Pair(k, v) =>
        if #seq(k, "kw") then
          (if #seq(v, "else") then true else if #seq(v, "match") then true
           else if #seq(v, "yield") then true
           -- A class/object/trait header may wrap before its `extends`/`with`
           -- clause (`case class X(…)` NL `extends T[…]:`). Treat a line that
           -- STARTS with `extends`/`with` as a continuation of the declaration,
           -- else the NL splits the header and `extends` parses as a bare stmt.
           else if #seq(v, "extends") then true
           else if #seq(v, "with") then true else false)
        else if #seq(k, "id") then
          (if #seq(v, "catch") then true else if #seq(v, "finally") then true
           -- `case class X(…)` NL `derives TC` — same continuation case.
           else if #seq(v, "derives") then true else false)
        -- `!` is BOTH prefix unary-not and infix actor-send. A line that STARTS with
        -- `!` (after a completable previous line) is a new unary-not statement, never a
        -- wrapped `receiver ! msg` (actor sends stay on one line). Treating it as a
        -- continuation glued `val t = e` NL `!f(t)` into `val t = (e ! f(t))`, so `t`
        -- referenced its own not-yet-bound name → `unbound global: t`.
        else if #seq(k, "op") then
          (if #seq(v, "!") then false else #i.gt(opPrec(v), 0))
        else if #seq(k, ".") then true
        else if #seq(k, "::") then true
        else if #seq(k, "->") then true
        else false } }

-- Scala-style semicolon inference for physical newlines.  The original layout
-- pass discarded every NL at top level and directly inside explicit braces.
-- That made a following parenthesized statement attach to the previous
-- expression (`val x = f { ... }` newline `(x, y)` became one application).
-- Keep newlines invisible while an expression is syntactically incomplete,
-- but emit a separator when the token before NL can end a statement and the
-- token after it can start one.
def canEndLine = (t) =>
  match t { case Pair(k, v) =>
    if #seq(k, "id") then true
    else if #seq(k, "uid") then true
    else if #seq(k, "int") then true
    else if #seq(k, "float") then true
    else if #seq(k, "str") then true
    else if #seq(k, ")") then true
    else if #seq(k, "]") then true
    else if #seq(k, "}") then true
    else if #seq(k, "kw") then
      (if #seq(v, "true") then true else if #seq(v, "false") then true
       else if #seq(v, "null") then true else #seq(v, "this"))
    else false }

def canStartLine = (ts) =>
  match ts {
    case Nil => false
    case Cons(t, rest) =>
      match t { case Pair(k, v) =>
        if #seq(k, "EOF") then false
        else if #seq(k, ")") then false
        else if #seq(k, "]") then false
        else if #seq(k, "}") then false
        else if #seq(k, ",") then false
        else if #seq(k, ";") then false
        else if #seq(k, ".") then false
        else if #seq(k, ":") then false
        else if #seq(k, "=") then false
        else if #seq(k, "=>") then false
        else if #seq(k, "->") then false
        else if #seq(k, "::") then false
        else if #seq(k, "kw") then
          (if #seq(v, "else") then false else if #seq(v, "match") then false
           else if #seq(v, "yield") then false else true)
        -- `catch`/`finally` continue a `try` on the next line; they never START a statement.
        else if #seq(k, "id") then
          (if #seq(v, "catch") then false else if #seq(v, "finally") then false else true)
        else true }
  }

-- a non-opener NL <v>: returns Pair(emittedTokens, newStack). `cont` = the next
-- line is a continuation, so suppress the `;` (but still close dedented blocks).
def nlStep = (v, stack, cont) =>
  match stack {
    case Nil => Pair(if cont then Nil else Cons(mkTok(";", ""), Nil), stack)
    case Cons(top, srest) =>
      match top { case Pair(tag, ind) =>
        if #seq(tag, "B") then Pair(if cont then Nil else Cons(mkTok(";", ""), Nil), stack)
        else if #seq(tag, "P") then Pair(if cont then Nil else Cons(mkTok(";", ""), Nil), stack)
        else if #seq(tag, "S") then Pair(if cont then Nil else Cons(mkTok(";", ""), Nil), stack)
        else if #i.gt(v, ind) then Pair(Nil, stack)
        else if #i.eq(v, ind) then (if cont then Pair(Nil, stack) else Pair(Cons(mkTok(";", ""), Nil), stack))
        else
          match dedentL(v, stack) {
            case Pair(closeToks, ns) => Pair(append(closeToks, (if cont then Nil else sepAfter(v, ns))), ns)
          } } }

def topStackIs = (wanted, stack) =>
  match stack {
    case Nil => false
    case Cons(top, rest) =>
      match top { case Pair(tag, ind) => #seq(tag, wanted) }
  }

def extensionReceiverParen = (extensionHead, stack) =>
  if extensionHead then
    if topStackIs("P", stack) then false
    else if topStackIs("S", stack) then false
    else if topStackIs("X", stack) then false
    else true
  else false

def layout = (toks) =>
  -- A trailing `:` opens layout only while scanning a trait/object declaration
  -- header. Treating every colon as an opener would misclassify split type
  -- annotations; keeping this one bit of header context gives declaration
  -- bodies real virtual braces without changing expression/type colons.
  -- `extension [A](receiver)` uses its outer receiver parentheses as a
  -- contextual layout opener. X distinguishes that delimiter from nested
  -- parentheses in receiver/function types.
  let rec go = (ts, stack, prevOpener, prevCanEnd, declHead, extensionHead, extensionOpener) =>
    match ts {
      case Nil => Nil
      case Cons(t, rest) =>
        match t { case Pair(k, v) =>
          if #seq(k, "EOF") then append(closeAllL(stack), Cons(t, Nil))
          else if #seq(k, "NL") then
            if prevOpener then
              let frameTag = if extensionOpener then "E" else "L" in
              Cons(mkTok("{", ""), go(rest, Cons(Pair(frameTag, v), stack), false, false, false, false, false))
            else
              let suppressSep =
                if prevCanEnd then
                  if canStartLine(rest) then isCont(rest) else true
                else true in
              match nlStep(v, stack, suppressSep) {
                -- A continuation NL (suppressSep) must PRESERVE declHead: a class/
                -- object/trait header may wrap before its `extends`/`with` clause
                -- (`case class X(…)` NL `extends T[…]:`), and the body `:` sits on the
                -- continuation line. Resetting declHead here left that `:` unframed, so
                -- the body leaked as top-level defs and only the first member was
                -- captured (the rest → Stub), same failure the inParenLike fix guards.
                case Pair(emitted, ns) =>
                  append(emitted, go(rest, ns, false, false,
                    (if suppressSep then declHead else false), false, false))
              }
          else if #seq(k, "(") then
            if extensionReceiverParen(extensionHead, stack) then
              Cons(t, go(rest, Cons(Pair("X", 0), stack), false, false, declHead, false, false))
            else
              Cons(t, go(rest, Cons(Pair("P", 0), stack), false, false, declHead, extensionHead, false))
          else if #seq(k, "[") then
            Cons(t, go(rest, Cons(Pair("S", 0), stack), false, false, declHead, extensionHead, false))
          else if #seq(k, ")") then
            if topStackIs("X", stack) then
              match closeToDelim("X", stack) {
                case Pair(cs, ns) => append(cs, Cons(t, go(rest, ns, true, true, declHead, false, true)))
              }
            else
              match closeToDelim("P", stack) {
                case Pair(cs, ns) => append(cs, Cons(t, go(rest, ns, false, true, declHead, extensionHead, false)))
              }
          else if #seq(k, "]") then
            match closeToDelim("S", stack) {
              case Pair(cs, ns) => append(cs, Cons(t, go(rest, ns, false, true, declHead, extensionHead, false)))
            }
          else if #seq(k, "{") then
            let braceTag = if extensionOpener then "EB" else "B" in
            Cons(t, go(rest, Cons(Pair(braceTag, 0), stack), false, false, false, false, false))
          else if #seq(k, "}") then
            let extensionClose = nearestBraceIsExtension(stack) in
            match closeToBrace(stack) {
              case Pair(cs, ns) =>
                let closeTail = if extensionClose then Cons(mkTok("extension_end", ""), Nil) else Nil in
                append(cs, Cons(t, append(closeTail, go(rest, ns, false, true, false, false, false))))
            }
          else
            let inDeclHead =
              if #seq(k, "kw") then
                (if #seq(v, "trait") then true
                 else if #seq(v, "object") then true
                 else if #seq(v, "class") then true
                 else if #seq(v, "effect") then true
                 else declHead)
              else declHead in
            -- A `:` INSIDE a paren/bracket/ext-receiver frame (P/S/X) is a type
            -- annotation (`x: Int`, `[A: TC]`, `(self: X)`), NOT a declaration-body
            -- opener — it must not consume the declHead bit, so the OUTER body colon
            -- after `)`/`]` still opens the virtual `{ … }` block. Without this,
            -- `case class X(f: T):` leaves declHead=false at the body colon → the
            -- body is unframed and its member defs leak as top-level `;`-separated
            -- defs (only the first is captured; the rest never dispatch → Stub).
            let inParenLike =
              if topStackIs("P", stack) then true
              else if topStackIs("S", stack) then true
              else topStackIs("X", stack) in
            let declColon = if #seq(k, ":") then (if inParenLike then false else inDeclHead) else false in
            let nextDeclHead = if #seq(k, ":") then (if inParenLike then inDeclHead else false) else inDeclHead in
            let nextExtensionHead =
              if #seq(k, "id") then (if #seq(v, "extension") then true else extensionHead)
              else extensionHead in
            Cons(t, go(rest, stack,
              (if declColon then true else isLayoutOpener(t)),
              canEndLine(t), nextDeclHead, nextExtensionHead, false))
        }
    } in
  go(toks, Nil, false, false, false, false, false)

def parse = (src) =>
  let _ep = #cell.set(extensionParamsCell, Nil) in
  let _em = #cell.set(extensionMethodsCell, Nil) in
  parseStmts(layout(lex(src)))

-- ── Pretty-print ──────────────────────────────────────────────────────────────
-- ssc0 does NOT support nested constructor patterns (case Cons(x, Nil) not allowed).
-- Use nested match instead.
def showList = (f, xs) =>
  let rec go = (xs2, acc) =>
    match xs2 {
      case Nil => acc
      case Cons(x, rest) =>
        match rest {
          case Nil => scat(acc, f(x))
          case _ => go(rest, scat(acc, scat(f(x), ",")))
        }
    } in
  scat("[", scat(go(xs, ""), "]"))

def showExpr = (e) =>
  match e {
    case Pair(tag, data) =>
      if #seq(tag, "int") then scat("EInt(", scat(data, ")"))
      else if #seq(tag, "str") then scat("EStr(\"", scat(data, "\")"))
      else if #seq(tag, "bool") then scat("EBool(", scat(data, ")"))
      else if #seq(tag, "var")  then scat("EVar(", scat(data, ")"))
      else if #seq(tag, "uid")  then scat("EUVar(", scat(data, ")"))
      else if #seq(tag, "inf") then
        match data {
          case Pair(op, lr) =>
            match lr {
              case Pair(l, r) =>
                scat("EInfix(\"", scat(op, scat("\",", scat(showExpr(l), scat(",", scat(showExpr(r), ")"))))))
            }
        }
      else if #seq(tag, "app") then
        match data {
          case Pair(f, args) =>
            scat("EApp(", scat(showExpr(f), scat(",", scat(showList(showExpr, args), ")"))))
        }
      else if #seq(tag, "sel") then
        match data {
          case Pair(e2, n) => scat("ESel(", scat(showExpr(e2), scat(".", scat(n, ")"))))
        }
      else if #seq(tag, "if") then
        match data {
          case Pair(c, tel) =>
            match tel {
              case Pair(t, el) =>
                scat("EIf(", scat(showExpr(c), scat(",", scat(showExpr(t), scat(",", scat(showExpr(el), ")"))))))
            }
        }
      else if #seq(tag, "tup") then scat("ETuple(", scat(showList(showExpr, data), ")"))
      else if #seq(tag, "pre") then
        match data {
          case Pair(op, e2) => scat("EPre(", scat(op, scat(",", scat(showExpr(e2), ")"))))
        }
      else scat("E?(", scat(tag, ")"))
  }

def showStmt = (s) =>
  match s {
    case Pair(tag, data) =>
      if #seq(tag, "def") then
        match data {
          case Pair(name, psb) =>
            match psb {
              case Pair(params, body) =>
                scat("SDef(\"", scat(name, scat("\",", scat(showList((p) => p, params), scat(",", scat(showExpr(body), ")"))))))
            }
        }
      else if #seq(tag, "val") then
        match data {
          case Pair(name, body) =>
            scat("SVal(\"", scat(name, scat("\",", scat(showExpr(body), ")"))))
        }
      else if #seq(tag, "expr") then scat("SExpr(", scat(showExpr(data), ")"))
      else scat("S?(", scat(tag, ")"))
  }

def showStmts = (ss) =>
  let rec go = (xs, acc) =>
    match xs {
      case Nil => acc
      case Cons(x, rest) =>
        match rest {
          case Nil => scat(acc, showStmt(x))
          case _ => go(rest, scat(acc, scat(showStmt(x), "\n")))
        }
    } in
  go(ss, "")
