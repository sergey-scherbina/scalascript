#!/usr/bin/env bash
# Join the native-front and standard VM/ASM corpus reports into the reviewed
# ScalaScript 2.1 parser-sentinel taxonomy. Unknown/category-growing rows fail.
set -euo pipefail
export LC_ALL=C

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
ROOT=$(git -C "$SCRIPT_DIR" rev-parse --show-toplevel 2>/dev/null) || {
  echo 'v21-sentinel-taxonomy: cannot locate repository root' >&2
  exit 2
}

native_report="$ROOT/target/v21-native-front-current.tsv"
parity_report="$ROOT/target/v21-standard-bc-parity-current.tsv"
manifest="$ROOT/tests/fixtures/v21-sentinel-taxonomy/overrides.tsv"
limits="$ROOT/tests/fixtures/v21-sentinel-taxonomy/category-limits.tsv"
report="$ROOT/target/v21-sentinel-taxonomy-current.tsv"

usage() {
  echo 'usage: scripts/v21-sentinel-taxonomy [--native-report PATH] [--parity-report PATH] [--manifest PATH] [--limits PATH] [--report PATH]'
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --native-report) native_report=$2; shift 2 ;;
    --parity-report) parity_report=$2; shift 2 ;;
    --manifest) manifest=$2; shift 2 ;;
    --limits) limits=$2; shift 2 ;;
    --report) report=$2; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) echo "v21-sentinel-taxonomy: unknown option: $1" >&2; usage >&2; exit 2 ;;
  esac
done

for input in "$native_report" "$parity_report" "$manifest" "$limits"; do
  [[ -f "$input" ]] || { echo "v21-sentinel-taxonomy: missing input: $input" >&2; exit 2; }
done

mkdir -p "$(dirname -- "$report")"
summary=$(mktemp "${TMPDIR:-/tmp}/v21-sentinel-taxonomy.XXXXXX")
rows=$(mktemp "${TMPDIR:-/tmp}/v21-sentinel-taxonomy-rows.XXXXXX")
trap 'rm -f "$summary" "$rows"' EXIT HUP INT TERM

awk -F '\t' -v OFS='\t' -v summary="$summary" '
  FILENAME == ARGV[1] {
    if (FNR > 1 && $1 != "") {
      if ($1 in overrideCat) { print "duplicate override row: " $1 > "/dev/stderr"; bad=1 }
      overrideCat[$1]=$2
      overrideReason[$1]=$3
    }
    next
  }
  FILENAME == ARGV[2] {
    if (FNR > 1 && $1 != "") {
      if ($1 in parity) { print "duplicate parity row: " $1 > "/dev/stderr"; bad=1 }
      parity[$1]=$2
    }
    next
  }
  FILENAME == ARGV[3] {
    if (FNR == 1 || $3 != "PRESENT") next
    file=$1
    p=parity[file]
    category=""
    reason=""
    if (p == "skipped-server") {
      category="server"; reason="existing server/tui classification"
    } else if (p == "skipped-backend") {
      category="backend"; reason="existing target/backend/frontend classification"
    } else if (p == "skipped-nondeterministic") {
      category="nondeterministic"; reason="existing nondeterministic classification"
    } else if ((p == "both-fail" || p == "identical") && (file in overrideCat)) {
      category=overrideCat[file]
      reason=overrideReason[file]
      if (category != "server" && category != "backend" &&
          category != "nondeterministic" && category != "tools-backend") {
        print "invalid override category: " file "=" category > "/dev/stderr"
        bad=1
        next
      }
      seenOverride[file]=1
    } else if (p == "both-fail" || p == "identical") {
      category="standard-gap"; reason="standard deterministic parser gap"
    } else {
      print "unclassified sentinel: " file " (parity=" p ")" > "/dev/stderr"
      bad=1
      next
    }
    count[category]++
    total++
    print file, category, p, reason
    next
  }
  FILENAME == ARGV[4] {
    if (FNR > 1 && $1 != "") limit[$1]=$2 + 0
    next
  }
  END {
    for (file in overrideCat) {
      if (!(file in seenOverride)) {
        print "stale or reclassified override row: " file > "/dev/stderr"
        bad=1
      }
    }
    split("backend nondeterministic server tools-backend standard-gap", cats, " ")
    for (i=1; i<=5; i++) {
      category=cats[i]
      if (!(category in limit)) {
        print "missing category limit: " category > "/dev/stderr"; bad=1
      } else if (count[category] > limit[category]) {
        print "category growth: " category "=" count[category] " > " limit[category] > "/dev/stderr"
        bad=1
      }
      print category "\t" (count[category] + 0) >> summary
    }
    if (!("total" in limit)) {
      print "missing category limit: total" > "/dev/stderr"; bad=1
    } else if (total > limit["total"]) {
      print "category growth: total=" total " > " limit["total"] > "/dev/stderr"
      bad=1
    }
    print "total\t" total >> summary
    if (bad) exit 1
  }
' "$manifest" "$parity_report" "$native_report" "$limits" > "$rows"

{
  printf 'file\treadiness_category\tparity_category\treason\n'
  cat "$rows"
} > "$report"

cat "$summary"
echo "REPORT: $report"
