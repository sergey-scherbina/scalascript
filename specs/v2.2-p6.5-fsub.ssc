def collectGivenReg1(gname, t2, ts) = if isTok(hd(t2), 2, 34) then collectGivenReg2(gname, skipTypeRef(tl(t2)), ts) else collectObjReg(tl(ts))
def collectGivenReg2(gname, t3, ts) = if isWord(hd(t3), "with") then collectGivenObj(gname, objBodyToks(t3)) else collectObjReg(tl(ts))
