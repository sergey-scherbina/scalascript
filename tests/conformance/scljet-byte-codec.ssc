#!/usr/bin/env ssc
---
name: scljet-byte-codec
description: SclJet immutable byte slices, endian codecs, and exact SQLite varints
backends: [int]
---

# SclJet bytes and codec M1

[ByteSlice, ByteRead, VarintRead, byteSliceToList, byteSliceGet, byteSliceUpdated, byteSliceSlice, byteSliceConcat, byteSliceCopyTo, byteSliceZeroExtend, readU16Be, readU32Be, readU64Be, readU32Le, readI16Be, readI24Be, readI32Be, writeU32Be, writeU32Le, encodeVarint, decodeVarint](std/scljet/index.ssc)

```scalascript
def mustBytes(values: List[Int]): ByteSlice = ByteSlice.fromList(values) match
  case Right(bytes) => bytes
  case Left(_) => ByteSlice.empty

def readValue(result: Any): Long = result match
  case Right(ByteRead(value, _)) => value
  case Right(VarintRead(value, _, _)) => value
  case _ => -999L

val base = mustBytes(List(0, 1, 127, 128, 255))
println(base.length)
println(byteSliceGet(base, 4))
println(byteSliceGet(base, 5).isLeft)
println(ByteSlice.fromList(List(0, 256)).isLeft)

val middle = byteSliceSlice(base, 1, 3) match
  case Right(bytes) => bytes
  case Left(_) => ByteSlice.empty
println(byteSliceToList(middle))

val copied = byteSliceCopyTo(middle, mustBytes(List(9, 9, 9, 9, 9)), 1) match
  case Right(bytes) => bytes
  case Left(_) => ByteSlice.empty
println(byteSliceToList(copied))

val zeros = ByteSlice.zeros(3) match
  case Right(bytes) => bytes
  case Left(_) => ByteSlice.empty
println(byteSliceToList(zeros))

val changed = byteSliceUpdated(base, 2, 42) match
  case Right(bytes) => bytes
  case Left(_) => ByteSlice.empty
println(byteSliceToList(changed))
println(byteSliceToList(byteSliceConcat(middle, mustBytes(List(9)))))

val extended = byteSliceZeroExtend(middle, 5) match
  case Right(bytes) => bytes
  case Left(_) => ByteSlice.empty
println(byteSliceToList(extended))
println(byteSliceUpdated(base, 0, 256).isLeft)
println(byteSliceSlice(base, 4, 2).isLeft)
println(byteSliceZeroExtend(middle, 2).isLeft)
println(readU32Be(middle, 0).isLeft)

val chunked0 = ByteSlice.zeros(65) match
  case Right(bytes) => bytes
  case Left(_) => ByteSlice.empty
val chunked1 = byteSliceUpdated(chunked0, 63, 7) match
  case Right(bytes) => bytes
  case Left(_) => ByteSlice.empty
val chunked2 = byteSliceUpdated(chunked1, 64, 8) match
  case Right(bytes) => bytes
  case Left(_) => ByteSlice.empty
val boundary = byteSliceSlice(chunked2, 62, 3) match
  case Right(bytes) => bytes
  case Left(_) => ByteSlice.empty
println(byteSliceToList(boundary))
println(byteSliceGet(chunked2, 64))

val fixed = mustBytes(List(0x12, 0x34, 0x56, 0x78, 0x9a, 0xbc, 0xde, 0xf0))
println(readValue(readU16Be(fixed, 0)))
println(readValue(readU32Be(fixed, 0)))
println(readValue(readU64Be(fixed, 0)))
println(readValue(readU32Le(fixed, 0)))
println(byteSliceToList(writeU32Be(305419896L)))
println(byteSliceToList(writeU32Le(305419896L)))

println(readValue(readI16Be(mustBytes(List(0xff, 0xfe)), 0)))
println(readValue(readI24Be(mustBytes(List(0xff, 0xff, 0xfe)), 0)))
println(readValue(readI32Be(mustBytes(List(0xff, 0xff, 0xff, 0xfe)), 0)))

val varints = List(0L, 1L, 127L, 128L, 16383L, 16384L,
  1048576L, 1099511627776L, 9223372036854775807L, -1L,
  -9223372036854775807L - 1L)

def verify(values: List[Long], ok: Boolean): Boolean = values match
  case Nil => ok
  case Cons(value, tail) =>
    val encoded = encodeVarint(value)
    decodeVarint(encoded, 0) match
      case Right(VarintRead(decoded, length, next)) =>
        verify(tail, ok && decoded == value && length == encoded.length && next == encoded.length)
      case _ => false

println(byteSliceToList(encodeVarint(0L)))
println(byteSliceToList(encodeVarint(128L)))
println(byteSliceToList(encodeVarint(16384L)))
println(encodeVarint(-1L).length)
println(verify(varints, true))
println(decodeVarint(mustBytes(List(0x81)), 0).isLeft)
```
