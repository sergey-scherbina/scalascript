def skipTraitDecl(ts) = skipTraitBody(skipTraitColon(skipExtends(skipTypeRef(skipTraitKw(ts)))))
// A trait body may be layout-braced after a `:` (`trait X:` ⏎ <indented members>) — the `:` sits before
// the virtual `{`, so skip it too — or explicitly `{`-braced, or absent (a pure marker trait).
def skipTraitColon(ts) = if isTok(hd(ts), 2, 34) then tl(ts) else ts
def skipTraitBody(ts) = if isTok(hd(ts), 2, 28) then skipBrace(tl(ts), 1) else ts
def skipBrace(ts, d) = if d == 0 then ts else (if isEmpty(ts) then ts else (if isTok(hd(ts), 2, 28) then skipBrace(tl(ts), d + 1) else (if isTok(hd(ts), 2, 29) then skipBrace(tl(ts), d - 1) else skipBrace(tl(ts), d))))
// skip one type reference (name token + optional [generics]); skip a trailing `extends T [with T]*`.
def skipGen(ts) = if isTok(hd(ts), 2, 50) then skipBrk(tl(ts), 1) else ts
def skipBrk(ts, d) = if d == 0 then ts else (if isEmpty(ts) then ts else (if isTok(hd(ts), 2, 50) then skipBrk(tl(ts), d + 1) else (if isTok(hd(ts), 2, 51) then skipBrk(tl(ts), d - 1) else skipBrk(tl(ts), d))))
def skipTypeRef(ts) = skipGen(tl(ts))
// DA15: a case class may be GENERIC — `case class Box[A](value: A)` — so between the class NAME and its
// `(fields)` sits an optional `[typeparams]`. Every field-collection pre-pass assumed `Name (` and read
// the type params AS fields (`Box[A]` → a field `A`; `View[S]` → `_sel_S`). skipGenParen (ts already AFTER
// the name) skips the optional `[gen]` then the `(`; skipNameGenParen (ts AT the name) also skips the name.
// The type-param NAMES are erased by the reference (measured), so this is byte-faithful.
def ccOpenSkip(ts) = if isTok(hd(ts), 2, 21) then tl(ts) else ts
def skipGenParen(ts) = ccOpenSkip(skipGen(ts))
def skipNameGenParen(ts) = skipGenParen(tl(ts))
def skipExtends(ts) = if isWord(hd(ts), "extends") then skipWithChain(skipTypeRef(tl(ts))) else ts
def skipWithChain(ts) = if isWord(hd(ts), "with") then skipWithChain(skipTypeRef(tl(ts))) else ts
// -- enums (P6.5 E1) ----------------------------------------------------------------------------
// `enum Name [tparams] [(..)] [extends ..]:` then `;`-separated `case` lines. The oracle does NOT make
// enum a layout declHead — it reads the `;`-separated cases directly (ssc1-front goCases :2810-2834), and
// F's ported layout already emits those `;`. enumCasesFrom (ts = the `enum` keyword) returns
// ([Pair(caseName, fields)..], rest); a nullary case has fields = Nil, a parametrized one reuses
// collectFields (identical to a case class). `case Red, Green` comma-sugar expands to extra nullary cases.
def isEnumHead(ts) = isWord(hd(ts), "enum")
def enumSkipToBody(ts) = if isEmpty(ts) then ts else enumSkipToBody1(hd(ts), ts)
def enumSkipToBody1(t, ts) = if isTok(t, 2, 34) then tl(ts) else (if isTok(t, 2, 28) then tl(ts) else (if isTok(t, 2, 6) then ts else (if isTok(t, 2, 52) then ts else enumSkipToBody(tl(ts)))))
def enumCasesFrom(ts) = goCasesF(enumSkipToBody(tl(ts)))
def goCasesF(ts) = goCasesF1(skipSemisF(ts))
// DA15: an enum's `;`-separated case scan must STOP at a following `case class` (which begins the NEXT
// top-level decl, not an enum case) WITHOUT consuming its `case` — else the enum's `rest` starts at
// `class X` and every downstream walk (walkTop ctor emission, collectTypeCases sels) fails to see it as a
// case class. `case` immediately followed by `class` (code 10) ⇒ end the case list, keep ts at `case`.
def goCasesF1(ts) = if isTok(hd(ts), 2, 6) then goCasesF2(ts) else (Nil, ts)
def goCasesF2(ts) = if isTok(hd(tl(ts)), 2, 10) then (Nil, ts) else goCaseName(tl(ts))
def goCaseName(ts) = if isTok(hd(ts), 2, 10) then (Nil, ts) else goCaseName2(snd(hd(ts)), tl(ts))
def goCaseName2(cname, ts) = if isTok(hd(ts), 2, 21) then goCaseParam(cname, tl(ts)) else goCaseNullary(cname, ts)
def goCaseParam(cname, ts) = collectFields(ts, Nil) match { case (fs, r) => goCaseCons(Cons((cname, fs), Nil), r) }
def goCaseNullary(cname, ts) = goCommaF(ts) match { case (more, r) => goCaseCons(Cons((cname, Nil), more), r) }
def goCommaF(ts) = if isTok(hd(ts), 2, 27) then goCommaF1(snd(hd(tl(ts))), tl(tl(ts))) else (Nil, ts)
def goCommaF1(nm, ts) = goCommaF(ts) match { case (more, r) => (Cons((nm, Nil), more), r) }
def goCaseCons(these, r) = goCasesF(r) match { case (rest, r2) => (appEnv(these, rest), r2) }
// decl-site emission: nullary case -> `(def N (ctor N))` (a VALUE, ssc1-lower :3826); parametrized ->
// the case-class ctor + mirror (lowerCaseCls, ssc1-lower :3827). Emitted in userDefs in document order.
def enumItem(ts, cx) = enumCasesFrom(ts) match { case (cases, rest) => ((emitEnumDefs(cases, cx), ""), rest) }
def emitEnumDefs(cases, cx) = cases match { case Nil => "" case h :: t => join2(erase(emitEnumDef(h), cx), emitEnumDefs(t, cx)) }
def emitEnumDef(c) = c match { case (nm, fs) => if isEmpty(fs) then ("enumnull", nm) else emitCtorFn((nm, fs)) }
// pre-pass: unified ordered type-case list (case classes AND enum cases interleaved in declaration order)
// -> drives emitSels + regFields + fldNames, so enum-case fields/regfields land in oracle order
// (ssc1-lower collectCaseFields/collectCaseClassOrder descend into enums, :4918/4936).
def collectTypeCases(ts) = if isEmpty(ts) then Nil else collectTC1(ts)
def collectTC1(ts) = if isCCHead(ts) then collectTCcc(tl(tl(ts))) else (if isEnumHead(ts) then collectTCenum(ts) else collectTypeCases(tl(ts)))
def collectTCcc(ts) = collectFields(skipNameGenParen(ts), Nil) match { case (fs, r) => Cons((snd(hd(ts)), fs), collectTypeCases(r)) }
def collectTCenum(ts) = enumCasesFrom(ts) match { case (cases, r) => appEnv(cases, collectTypeCases(r)) }
// pre-pass: enum registries. enumReg = [Pair(enumName, [nullaryCaseName..])]; enumCaseNames = all case names.
def collectEnumReg(ts) = if isEmpty(ts) then Nil else (if isEnumHead(ts) then collectER1(ts) else collectEnumReg(tl(ts)))
def collectER1(ts) = collectER2(snd(hd(tl(ts))), enumCasesFrom(ts))
def collectER2(ename, pr) = pr match { case (cases, r) => Cons((ename, nullaryNames(cases)), collectEnumReg(r)) }
def nullaryNames(cases) = cases match { case Nil => Nil case h :: t => h match { case (nm, fs) => if isEmpty(fs) then Cons(nm, nullaryNames(t)) else nullaryNames(t) } }
def collectEnumCaseNames(ts) = if isEmpty(ts) then Nil else (if isEnumHead(ts) then collectECN1(ts) else collectEnumCaseNames(tl(ts)))
def collectECN1(ts) = enumCasesFrom(ts) match { case (cases, r) => appEnv(caseNamesL(cases), collectEnumCaseNames(r)) }
def caseNamesL(cases) = cases match { case Nil => Nil case h :: t => Cons(fst(h), caseNamesL(t)) }
// DA1 typed-pattern registries. subReg = [Pair(parent, child)] from `case class C(..) extends P`, REVERSE
// source order (ssc1-front PREPENDS per case class :2251-2258, subtypeChildren preserves cell order). Only
// the FIRST named parent; enums contribute via enumAllReg. enumAllReg = [Pair(enumName, [allCaseNames])]
// (declaration order, incl. parametrized cases) so `case _: Color` expands over every Color case.
def collectSubReg(ts) = collectSubRegAcc(ts, Nil)
def collectSubRegAcc(ts, acc) = if isEmpty(ts) then acc else (if isCCHead(ts) then collectSubRegAcc(tl(ts), collectSRadd(ts, acc)) else collectSubRegAcc(tl(ts), acc))
def collectSRadd(ts, acc) = collectFields(skipNameGenParen(tl(tl(ts))), Nil) match { case (fs, r) => collectSRext(snd(hd(tl(tl(ts)))), r, acc) }
def collectSRext(child, r, acc) = if isWord(hd(r), "extends") then Cons((snd(hd(tl(r))), child), acc) else acc
def collectEnumAllReg(ts) = if isEmpty(ts) then Nil else (if isEnumHead(ts) then collectEAR1(ts) else collectEnumAllReg(tl(ts)))
def collectEAR1(ts) = collectEAR2(snd(hd(tl(ts))), enumCasesFrom(ts))
def collectEAR2(ename, pr) = pr match { case (cases, r) => Cons((ename, caseNamesL(cases)), collectEnumAllReg(r)) }

// -- E2: call-site default-parameter registry -----------------------------------------------------
// funcDflts = [(name, [(paramName, dfltToks)])], mirroring the oracle's funcDefaultsCell (populated by
// ssc1-front registerParamDflts :653 at every `def`/`case class`/enum-case whose param list has a `= expr`).
// The default is stored as its RAW TOKEN SLICE so the call site can re-parse+emit it in the right scoped
// env (a later default sees earlier params). Linear top-level scan (like collectCC): react ONLY to a `def`/
// `case class` HEAD or the `enum` keyword, then ALWAYS advance ONE token — the construct's params get
// re-walked but nothing re-triggers (a match-arm `case Name(..)` is never a trigger, so patterns are safe).
def collectFuncDflts(ts) = if isEmpty(ts) then Nil else collectFD1(ts)
def collectFD1(ts) = if isDefHead(ts) then appEnv(defDfltEntry(ts), collectFuncDflts(tl(ts))) else (if isCCHead(ts) then appEnv(ccDfltEntry(ts), collectFuncDflts(tl(ts))) else (if isEnumHead(ts) then appEnv(enumDfltEntries(ts), collectFuncDflts(tl(ts))) else collectFuncDflts(tl(ts))))
def isDefHead(ts) = if isTok(hd(ts), 2, 1) then isNameTok(hd(tl(ts))) else false
def isNameTok(t) = if fst(t) == 1 then true else fst(t) == 3
// A `def NAME [gen] (params)` — register only when the param list actually holds a default.
def defDfltEntry(ts) = defDfltE1(snd(hd(tl(ts))), skipGen(tl(tl(ts))))
def defDfltE1(nm, afterName) = if isTok(hd(afterName), 2, 21) then dfltReg(nm, collectPD(tl(afterName), Nil)) else Nil
// A `case class NAME [gen] (fields)` — skipNameGenParen skips NAME+[gen]+`(`.
def ccDfltEntry(ts) = dfltReg(snd(hd(tl(tl(ts)))), collectPD(skipNameGenParen(tl(tl(ts))), Nil))
def dfltReg(nm, pr) = pr match { case (pd, r) => if pdAnyDflt(pd) then Cons((nm, pd), Nil) else Nil }
def pdAnyDflt(pd) = pd match { case Nil => false case h :: t => if isEmpty(snd(h)) then pdAnyDflt(t) else true }
// enum cases: mirror goCasesF's walker but capture defaults; emit a registry entry per parametrized case.
def enumDfltEntries(ts) = goCaseDf(enumSkipToBody(tl(ts)))
def goCaseDf(ts) = goCaseDf1(skipSemisF(ts))
def goCaseDf1(ts) = if isTok(hd(ts), 2, 6) then goCaseDf2(ts) else Nil
def goCaseDf2(ts) = if isTok(hd(tl(ts)), 2, 10) then Nil else goCaseDfName(tl(ts))
def goCaseDfName(ts) = if isTok(hd(ts), 2, 10) then Nil else goCaseDfName2(snd(hd(ts)), tl(ts))
def goCaseDfName2(cname, ts) = if isTok(hd(ts), 2, 21) then goCaseDfParam(cname, tl(ts)) else goCaseDfNullary(ts)
def goCaseDfParam(cname, ts) = collectPD(ts, Nil) match { case (pd, r) => goCaseDfPCons(cname, pd, r) }
def goCaseDfPCons(cname, pd, r) = if pdAnyDflt(pd) then Cons((cname, pd), goCaseDf(r)) else goCaseDf(r)
def goCaseDfNullary(ts) = goCaseDf(skipNullComma(ts))
def skipNullComma(ts) = if isTok(hd(ts), 2, 27) then skipNullComma(tl(tl(ts))) else ts
// E2b: object-method call-site defaults. `object O { def m(x, y = d) }` lowers m to a top-level
// `(def O_m ..)` (objDefE) and the call `O.m(x)` to `(app (global O_m) ..)` (emitMethodCall). Register
// each def member's default entry under the MANGLED name `O_m` (mirroring ssc1-lower's aliasFuncDefault
// :4196) so postMeth can synth omitted trailing defaults on the object-call path. Reading each member's
// OWN param list keys arity correctly, so same-named methods across objects (Tool.text/1 no-default vs
// Resource.text/2 defaulted) never share an entry. Only regular `object` (not given_obj) — matching the
// oracle, whose given prefixDefs :4268 does NOT alias defaults. Linear scan like collectObjReg.
def collectObjDflts(ts) = if isEmpty(ts) then Nil else (if isObjectHead(ts) then collectOD1(ts) else collectObjDflts(tl(ts)))
def collectOD1(ts) = collectOD2(snd(hd(tl(ts))), objBodyToks(tl(tl(ts))))
def collectOD2(name, ts) = if isTok(hd(ts), 2, 28) then appEnv(objMemDflts(name, collectObjMembers(tl(ts))), collectObjDflts(skipBrace(tl(ts), 1))) else collectObjDflts(ts)
def objMemDflts(name, ms) = ms match { case Nil => Nil case h :: t => appEnv(objMemDflt1(name, h), objMemDflts(name, t)) }
def objMemDflt1(name, m) = m match { case (kind, nt) => nt match { case (mname, toks) => if kind == "def" then objDefDflt(name ++ "_" ++ mname, skipGen(toks)) else Nil } }
def objDefDflt(pfxName, ts) = if isTok(hd(ts), 2, 21) then dfltReg(pfxName, collectPD(tl(ts), Nil)) else Nil
// E2c: object-method VARARG registry. `object O { def m(.., xs: T*) }` lowers m to a top-level
// `(def O_m (lam N ..))` whose LAST param is the whole vararg Seq (one param), so the call `O.m(a, b, ..)`
// must collapse the args past the `lead` fixed params into ONE list to match arity N. Register each
// object def member whose LAST param is a token-level trailing `*` under the MANGLED name `O_m` →
// lead = paramCount - 1. typeText ERASES the star (punctStr(25)=""), so detection is a TOKEN scan
// (star = opcode 25), NOT collectPD's stripped type. Mirrors collectObjDflts (regular `object` only);
// payload is `lead` (int), held in its OWN cx slot (objVarargsOf), never merged into funcDflts.
def collectObjVarargs(ts) = if isEmpty(ts) then Nil else (if isObjectHead(ts) then collectOV1(ts) else collectObjVarargs(tl(ts)))
def collectOV1(ts) = collectOV2(snd(hd(tl(ts))), objBodyToks(tl(tl(ts))))
def collectOV2(name, ts) = if isTok(hd(ts), 2, 28) then appEnv(objMemVarargs(name, collectObjMembers(tl(ts))), collectObjVarargs(skipBrace(tl(ts), 1))) else collectObjVarargs(ts)
def objMemVarargs(name, ms) = ms match { case Nil => Nil case h :: t => appEnv(objMemVararg1(name, h), objMemVarargs(name, t)) }
def objMemVararg1(name, m) = m match { case (kind, nt) => nt match { case (mname, toks) => if kind == "def" then objDefVararg(name ++ "_" ++ mname, skipGen(toks)) else Nil } }
def objDefVararg(pfxName, ts) = if isTok(hd(ts), 2, 21) then varargRegE(pfxName, tl(ts)) else Nil
def varargRegE(pfxName, pts) = if lastParamStar(pts, 0, (2, 0)) then Cons((pfxName, pvCount(collectPD(pts, Nil)) - 1), Nil) else Nil
def pvCount(pr) = pr match { case (pd, r) => dlen(pd) }
// TOKEN-level trailing-`*` detector: walk the param-list tokens (AFTER the `(`) tracking bracket depth
// (`(`/`[` open, `)`/`]` close) and the previous token. The vararg star (opcode 25) is the token
// immediately before the depth-0 `)`. prev seeds with a non-star sentinel so an empty `()` never crashes.
def lastParamStar(ts, d, prev) = if isEmpty(ts) then false else lastParamStar1(hd(ts), tl(ts), d, prev)
def lastParamStar1(t, rest, d, prev) = if isTok(t, 2, 22) then (if d == 0 then isTok(prev, 2, 25) else lastParamStar(rest, d - 1, t)) else (if isOpenD(t) then lastParamStar(rest, d + 1, t) else (if isTok(t, 2, 51) then lastParamStar(rest, d - 1, t) else lastParamStar(rest, d, t)))
// collectPD walks a param list (ts AFTER the `(`) -> ([(paramName, dfltToks)], restAfterClose). dfltToks
// is Nil when the param has no default. Mirrors collectField but captures the default token slice.
def collectPD(ts, acc) = if isEmpty(ts) then (revL(acc), ts) else (if isTok(hd(ts), 2, 22) then (revL(acc), tl(ts)) else collectPD1(ts, acc))
def collectPD1(ts, acc) = collectPDafterName(snd(hd(ts)), tl(ts), acc)
def collectPDafterName(nm, ts, acc) = if isTok(hd(ts), 2, 34) then collectPDdflt(nm, skipParamType(tl(ts)), acc) else collectPDdflt(nm, ts, acc)
def skipParamType(ts) = typeText(ts, 0, "") match { case (ty, r) => r }
def collectPDdflt(nm, ts, acc) = if isTok(hd(ts), 2, 20) then collectPDcap(nm, captureDflt(tl(ts), 0, Nil), acc) else collectPDend(nm, Nil, ts, acc)
def collectPDcap(nm, pr, acc) = pr match { case (dtoks, r) => collectPDend(nm, dtoks, r, acc) }
def collectPDend(nm, dtoks, ts, acc) = if isTok(hd(ts), 2, 27) then collectPD(tl(ts), Cons((nm, dtoks), acc)) else (revL(Cons((nm, dtoks), acc)), tl(ts))
// capture the default expr's tokens up to (not including) the next `,`/`)` at depth 0.
def captureDflt(ts, d, acc) = if isEmpty(ts) then (revL(acc), ts) else (if isSep0(hd(ts), d) then (revL(acc), ts) else captureDflt(tl(ts), typeDepth(hd(ts), d), Cons(hd(ts), acc)))
// subtypeChildren(T) = case-class children of T ++ enum cases of T; Nil => leaf (exact test). typedTagTest:
// leaf -> `(prim __isTag__ s (lit (str T)) (lit (int -1)))`; supertype -> OR-chain (ssc1-lower :3270-3316).
def subRegChildren(parent, reg) = reg match { case Nil => Nil case h :: t => if fst(h) == parent then Cons(snd(h), subRegChildren(parent, t)) else subRegChildren(parent, t) }
def enumAllOf(ename, reg) = reg match { case Nil => Nil case h :: t => if fst(h) == ename then snd(h) else enumAllOf(ename, t) }
def subtypeChildren(th, cx) = appEnv(subRegChildren(th, fst(subInfoOf(cx))), enumAllOf(th, snd(subInfoOf(cx))))
def isTagExact(scrut, tag, cx) = "(prim __isTag__ " ++ scrut ++ " (lit (str " ++ dqOf(cx) ++ tag ++ dqOf(cx) ++ ")) (lit (int -1)))"
def orTagTests(scrut, tags, cx) = tags match { case Nil => "(lit false)" case h :: t => t match { case Nil => isTagExact(scrut, h, cx) case _ => "(if " ++ isTagExact(scrut, h, cx) ++ " (lit true) " ++ orTagTests(scrut, t, cx) ++ ")" } }
// NB: use isEmpty/helper (NOT `case Nil/case cs`) so F self-compiles this def (a bare-var arm after a
// ctor arm mis-parses as a cons pattern in F's own parseCtorMatch).
def typedTagTest(scrut, th, cx) = typedTagTest1(scrut, subtypeChildren(th, cx), th, cx)
def typedTagTest1(scrut, cs, th, cx) = if isEmpty(cs) then isTagExact(scrut, th, cx) else orTagTests(scrut, cs, cx)
// skip a pattern type annotation `: T[..]` up to (but not consuming) the arm boundary `=>`/guard `if`
// (ssc1-front skipPatternTypeAt :525-544 — []/() balanced, stop at `=>`/`if`/depth-0).
def skipTypeToArrow(ts) = skipTTA(ts, 0)
def skipTTA(ts, d) = if isEmpty(ts) then ts else skipTTA1(hd(ts), tl(ts), ts, d)
def skipTTA1(t, r, ts, d) = if isTok(t, 2, 50) then skipTTA(r, d + 1) else (if isTok(t, 2, 21) then skipTTA(r, d + 1) else (if isTok(t, 2, 51) then skipTTAclose(r, ts, d) else (if isTok(t, 2, 22) then skipTTAclose(r, ts, d) else (if d > 0 then skipTTA(r, d) else (if isTok(t, 2, 30) then ts else (if isTok(t, 2, 2) then ts else skipTTA(r, d)))))))
def skipTTAclose(r, ts, d) = if d == 0 then ts else skipTTA(r, d - 1)
// typed match arm `case _: T => body` / `case x: T => body`. Wild -> if-test only; binder -> extra let
// binding x to the scrutinee (ssc1-lower lowerOrderedGuardArms tpat :3432-3446). rest recurses in
// parseGenArms (binder pushes a dummy scrut slot so genScrut rises by one).
def isTypedArm(ts) = if fst(hd(ts)) == 1 then isTok(hd(tl(ts)), 2, 34) else false
def parseTypedArm(ts, menv, cx) = parseTypedArm1(isWild(hd(ts)), snd(hd(ts)), snd(hd(tl(tl(ts)))), skipTypeToArrow(tl(tl(ts))), menv, cx)
def parseTypedArm1(wild, binder, th, tsA, menv, cx) = if wild then parseTypedWild(th, tl(tsA), menv, cx) else parseTypedBind(binder, th, tl(tsA), menv, cx)
def parseTypedWild(th, ts, menv, cx) = parseExpr(ts, 0, menv, cx) match { case (body, r) => parseTypedWildRest(th, erase(body, cx), r, menv, cx) }
def parseTypedWildRest(th, body, ts, menv, cx) = parseGenArms(ts, menv, cx) match { case (rest, r) => (emitIf(typedTagTest(genScrut(menv), th, cx), body, rest), r) }
def parseTypedBind(binder, th, ts, menv, cx) = parseExpr(ts, 0, binder :: menv, cx) match { case (body, r) => parseTypedBindRest(th, erase(body, cx), r, menv, cx) }
def parseTypedBindRest(th, body, ts, menv, cx) = parseGenArms(ts, "__typed_scrut__" :: menv, cx) match { case (rest, r) => ("(let (" ++ genScrut(menv) ++ ") " ++ emitIf(typedTagTest("(local 0)", th, cx), body, rest) ++ ")", r) }
// -- try / catch / finally (DA2) ------------------------------------------------------------------
// `try B catch {case e:T=>..} [finally F]` -> `(prim __tryCatch__ (lam 0 B) <pf>)`; `try B finally F` ->
// `__tryFinally__`; both -> `__tryCatchFinally__` (ssc1-front :1076-1106). B/F are 0-arg thunks. The braced
// catch handler is a case-lambda `(lam 1 (let (<scrut>) <chain>))` over TYPED patterns: each body is
// prefixed with `__handler_dispatch_selected__(pf)` and a fallback arm emits `__handler_dispatch_miss__(pf)`
// (ssc1-lower lowerHandlerMatch :3636 / handlerMarkedArms :3603). menv threads __m (scrut) + __pf (lam arg).
def parseTry(ts, env, cx) = parseExpr(ts, 0, env, cx) match { case (body, r) => parseTryAfter(erase(body, cx), r, env, cx) }
def parseTryAfter(body, ts, env, cx) = if isWord(hd(ts), "catch") then parseTryCatch(body, tl(ts), env, cx) else (if isWord(hd(ts), "finally") then parseTryFin(body, tl(ts), env, cx) else (body, ts))
def parseTryCatch(body, ts, env, cx) = parseCatchPf(ts, env, cx) match { case (pf, r) => parseTryCF(body, pf, r, env, cx) }
def parseTryCF(body, pf, ts, env, cx) = if isWord(hd(ts), "finally") then parseTryCFin(body, pf, tl(ts), env, cx) else ("(prim __tryCatch__ (lam 0 " ++ body ++ ") " ++ pf ++ ")", ts)
def parseTryFin(body, ts, env, cx) = parseExpr(ts, 0, env, cx) match { case (fin, r) => ("(prim __tryFinally__ (lam 0 " ++ body ++ ") (lam 0 " ++ erase(fin, cx) ++ "))", r) }
def parseTryCFin(body, pf, ts, env, cx) = parseExpr(ts, 0, env, cx) match { case (fin, r) => ("(prim __tryCatchFinally__ (lam 0 " ++ body ++ ") " ++ pf ++ " (lam 0 " ++ erase(fin, cx) ++ "))", r) }
def parseCatchPf(ts, env, cx) = parseHArms(hOpen(ts), "__m" :: "__pf" :: env, cx) match { case (chain, r) => ("(lam 1 (let ((local 0)) " ++ chain ++ "))", r) }
def hOpen(ts) = if isTok(hd(ts), 2, 28) then tl(ts) else ts
def hClose(ts) = if isTok(hd(ts), 2, 29) then tl(ts) else ts
def pfRef(menv) = "(local " ++ lookup("__pf", menv) ++ ")"
def hSelected(menv) = "(prim __handler_dispatch_selected__ " ++ pfRef(menv) ++ ")"
def hMiss(menv) = "(prim __handler_dispatch_miss__ " ++ pfRef(menv) ++ ")"
// fallback arm: `(let (<scrut>) (miss(pf)))` — the fallback alias binder pushes one slot before miss.
def hMissArm(menv) = "(let (" ++ genScrut(menv) ++ ") " ++ hMiss("__hfb__" :: menv) ++ ")"
def parseHArms(ts, menv, cx) = parseHArms0(skipSemisF(ts), menv, cx)
def parseHArms0(ts, menv, cx) = if isTok(hd(ts), 2, 6) then parseHArm(tl(ts), menv, cx) else (hMissArm(menv), hClose(ts))
def parseHArm(ts, menv, cx) = parseHTyped(isWild(hd(ts)), snd(hd(ts)), snd(hd(tl(tl(ts)))), skipTypeToArrow(tl(tl(ts))), menv, cx)
def parseHTyped(wild, binder, th, tsA, menv, cx) = if wild then parseHWild(th, tl(tsA), menv, cx) else parseHBind(binder, th, tl(tsA), menv, cx)
def parseHWild(th, ts, menv, cx) = parseExpr(ts, 0, "__hsel__" :: menv, cx) match { case (body, r) => parseHWildRest(th, erase(body, cx), r, menv, cx) }
def parseHWildRest(th, body, ts, menv, cx) = parseHArms(ts, menv, cx) match { case (rest, r) => (emitIf(typedTagTest(genScrut(menv), th, cx), "(let (" ++ hSelected(menv) ++ ") " ++ body ++ ")", rest), r) }
def parseHBind(binder, th, ts, menv, cx) = parseExpr(ts, 0, "__hsel__" :: binder :: menv, cx) match { case (body, r) => parseHBindRest(binder, th, erase(body, cx), r, menv, cx) }
def parseHBindRest(binder, th, body, ts, menv, cx) = parseHArms(ts, "__typed_scrut__" :: menv, cx) match { case (rest, r) => ("(let (" ++ genScrut(menv) ++ ") " ++ emitIf(typedTagTest("(local 0)", th, cx), "(let (" ++ hSelected(binder :: menv) ++ ") " ++ body ++ ")", rest) ++ ")", r) }
// -- direct{} monad desugar (DA3) ------------------------------------------------------------------
// `direct[M] { x = rhs; ...; result }` desugars to a flatMap chain (ssc1-lower directStmts :1979):
// a bare bind `x = rhs` (x not a declared var) -> `rhs.flatMap(x => rest)` (dispatch via emitMethodCall,
// so Some/List ctor -> _sel_flatMap, var recv -> __method__); `val`/`var`/mutation/expr stay as ordinary
// block let/lcell/seq statements (directThen). Reuses F's block machinery so de-Bruijn threading matches.
// Intercepted only for `direct[M] {` (marker form, ssc1-front :1400/:1414). M is validated-only (not emitted).
def isDirectHead(ts) = if isTok(hd(ts), 2, 50) then isTok(hd(skipGen(ts)), 2, 28) else false
def parseDirect(ts, env, cx) = parseDirectBlock(hOpen(skipGen(ts)), env, cx)
def parseDirectBlock(ts, env, cx) = parseDBlock0(skipSemisF(ts), env, cx)
def parseDBlock0(ts, env, cx) = if isTok(hd(ts), 2, 7) then parseDBlockVal(tl(ts), env, cx) else (if isVarHead(ts) then parseDBlockVar(tl(ts), env, cx) else (if isDirectBind(ts, env) then parseDBind(ts, env, cx) else (if isAssignHead(ts) then parseDBlockAssign(ts, env, cx) else parseDBlockExpr(ts, env, cx))))
def notEnvVar(nm, env) = if lookup("@@" ++ nm, env) >= 0 then false else (if lookup("@" ++ nm, env) >= 0 then false else true)
def isDirectBind(ts, env) = if isAssignHead(ts) then (if isTok(hd(tl(ts)), 2, 20) then notEnvVar(snd(hd(ts)), env) else false) else false
def parseDBind(ts, env, cx) = parseDBind1(snd(hd(ts)), tl(tl(ts)), env, cx)
def parseDBind1(nm, ts, env, cx) = parseExpr(ts, 0, env, cx) match { case (rhs, r) => parseDBindRest(nm, erase(rhs, cx), r, env, cx) }
def parseDBindRest(nm, rhs, ts, env, cx) = parseDirectBlock(ts, nm :: env, cx) match { case (rest, r) => (emitMethodCall("flatMap", rhs, Cons(forLam(rest), Nil), cx), r) }
def parseDBlockVal(ts, env, cx) = parseDBlockVal1(snd(hd(ts)), skipToEq(tl(ts)), env, cx)
def parseDBlockVal1(nm, ts, env, cx) = parseExpr(ts, 0, env, cx) match { case (e, r) => parseDBlockValRest(nm, erase(e, cx), r, env, cx) }
def parseDBlockValRest(nm, e, ts, env, cx) = parseDirectBlock(ts, nm :: env, cx) match { case (b, r) => ("(let (" ++ e ++ ") " ++ b ++ ")", r) }
def parseDBlockVar(ts, env, cx) = parseDBlockVarN(snd(hd(ts)), skipToEq(ts), env, cx)
def parseDBlockVarN(nm, ts, env, cx) = parseExpr(ts, 0, env, cx) match { case (init, r) => parseDBlockVarBind(nm, erase(init, cx), r, env, cx) }
def parseDBlockVarBind(nm, init, r, env, cx) = if isIntLitCode(init) then parseDBlockVarLc(nm, init, r, env, cx) else parseDBlockVarC(nm, init, r, env, cx)
def parseDBlockVarLc(nm, init, r, env, cx) = parseDirectBlock(r, ("@@" ++ nm) :: env, cx) match { case (b, rr) => ("(let ((prim lcell.new " ++ init ++ ")) " ++ b ++ ")", rr) }
def parseDBlockVarC(nm, init, r, env, cx) = parseDirectBlock(r, ("@" ++ nm) :: env, cx) match { case (b, rr) => ("(let ((prim cell.new " ++ init ++ ")) " ++ b ++ ")", rr) }
def parseDBlockAssign(ts, env, cx) = parseAssign(ts, env, cx) match { case (a, r) => parseDBlockAssignC(erase(a, cx), isTok(hd(tl(ts)), 2, 20), skipSemisF(r), env, cx) }
def parseDBlockAssignC(a, simple, ts, env, cx) = if simple then parseDBlockSeq(a, ts, env, cx) else parseDBlockCont(a, ts, env, cx)
def parseDBlockSeq(a, ts, env, cx) = if isEmpty(ts) then (a, ts) else (if isTok(hd(ts), 2, 29) then (a, tl(ts)) else parseDBlockSeqMore(a, ts, env, cx))
def parseDBlockSeqMore(a, ts, env, cx) = parseDBlock0(ts, env, cx) match { case (b, r) => ("(seq " ++ a ++ " " ++ b ++ ")", r) }
def parseDBlockExpr(ts, env, cx) = parseExpr(ts, 0, env, cx) match { case (e, r) => parseDBlockCont(erase(e, cx), skipSemisF(r), env, cx) }
def parseDBlockCont(e, ts, env, cx) = if isEmpty(ts) then (e, ts) else (if isTok(hd(ts), 2, 29) then (e, tl(ts)) else parseDBlockBare(e, ts, env, cx))
def parseDBlockBare(e, ts, env, cx) = parseDBlock0(ts, "" :: env, cx) match { case (b, r) => ("(let (" ++ e ++ ") " ++ b ++ ")", r) }
def defTopItem(ts, cx) = emitDef(ts, cx) match { case (d, rest) => ((d, ""), rest) }
def ccTopItem(ts, cx) = emitCCDecl(ts, cx) match { case (d, rest) => ((d, ccDerivedInit(ccNameAt(ts), derivesAt(tl(tl(ts))))), rest) }
// `val (a, b, ..) = e` tuple-destructuring (ssc1-lower :2522-style): bind the init to a `let`, then set
// one cell per element via its 1-based `_sel__N` tuple projection: `(let (<init>) (seq (cell.set a__cell
// (_sel__1 (local 0))) (cell.set b__cell (_sel__2 (local 0))) ..))`. Every element is a NAME (incl `_` ->
// `___cell`); flat name-tuples only (the corpus's shape). Plain `val name = e` unchanged.
def valItem(ts, cx) = if isTupleVal(ts) then tupValItem(ts, cx) else valItem1(snd(hd(tl(ts))), skipToEq(tl(ts)), cx)
def isTupleVal(ts) = isTok(hd(tl(ts)), 2, 21)
def valPatNames(ts) = if isTupleVal(ts) then tupNames(tl(tl(ts))) else Cons(snd(hd(tl(ts))), Nil)
def tupNames(ts) = Cons(snd(hd(ts)), tupNamesMore(tl(ts)))
def tupNamesMore(ts) = if isTok(hd(ts), 2, 27) then tupNames(tl(ts)) else Nil
def tupValItem(ts, cx) = tupValItem1(valPatNames(ts), skipToEq(tl(ts)), cx)
def tupValItem1(names, ts, cx) = parseExpr(ts, 0, Nil, cx) match { case (init, rest) => (("", tupValEmit(names, erase(init, cx))), rest) }
def tupValEmit(names, init) = "(let (" ++ init ++ ") (seq " ++ tupSets(names, 1) ++ "))"
def tupSets(names, i) = names match { case Nil => "" case h :: t => join2("(prim cell.set (global " ++ h ++ "__cell) (app (global _sel__" ++ i ++ ") (local 0)))", tupSets(t, i + 1)) }
def valItem1(nm, ts, cx) = parseExpr(ts, 0, Nil, cx) match { case (init, rest) => (("", "(prim cell.set (global " ++ nm ++ "__cell) " ++ erase(init, cx) ++ ")"), rest) }
def exprItem(ts, cx) = parseExpr(ts, 0, Nil, cx) match { case (e, rest) => (("", erase(e, cx)), rest) }
def walkTop(ts, cx) = walkTop0(skipSemisF(ts), cx)
def walkTop0(ts, cx) = if isEmpty(ts) then (("", ""), 0) else walkTopStep(parseTopItem(ts, cx), cx)
def walkTopStep(pr, cx) = pr match { case (parts, rest) => walkTopJoin(parts, walkTop(rest, cx)) }
def walkTopJoin(parts, acc) = parts match { case (d, e) => acc match { case (accStrs, n) => walkTopJoin2(d, e, accStrs, n) } }
def walkTopJoin2(d, e, accStrs, n) = accStrs match { case (dA, eA) => ((join2(d, dA), join2(e, eA)), if e == "" then n else n + 1) }
def emitCCDecl(ts, cx) = collectCC1(tl(tl(ts))) match { case c :: r => (emitCC(c, cx), skipCCHead(tl(tl(ts)))) case _ => ("", Nil) }
// A case class may carry `extends Shape [with T]*` after its params (measured: the oracle IGNORES it —
// `case class C(x) extends Shape` lowers identically to `case class C(x)`). Skip the clause in the walk.
// It may ALSO carry a BODY — `case class C(x): <indented defs>` (layout `{..}`) or `case class C(x) { .. }`
// — carrying method defs (T3). skipCCHead must CONSUME that body (an optional `:` then a `{..}` block) so
// it does not cascade into the entry as garbage; the methods themselves are collected by collectCaseMethods.
def skipCCHead(ts) = collectFields(skipNameGenParen(ts), Nil) match { case (fs, r) => skipCCBody(skipExtends(r)) }
def skipCCBody(ts) = skipCCBrace(skipCCColon(skipDerives(ts)))
// `derives TC1, TC2` clause (ssc1-front findCaseDerives :2228) — skip in the head walk (comes after
// params/extends, before any body). Each TC name may carry erased type args (skipGen).
def skipDerives(ts) = if isWord(hd(ts), "derives") then skipDvNames(tl(ts)) else ts
def skipDvNames(ts) = skipDvAfter(skipGen(tl(ts)))
def skipDvAfter(ts) = if isTok(hd(ts), 2, 27) then skipDvNames(tl(ts)) else ts
def skipCCColon(ts) = if isTok(hd(ts), 2, 34) then tl(ts) else ts
def skipCCBrace(ts) = if isTok(hd(ts), 2, 28) then skipBrace(tl(ts), 1) else ts
// pre-pass: top-level `val` names in source order. Same item advancement as walkTop; `rest` does not
// depend on the (not-yet-known) val names, so a base cx (empty valNames) gives the right boundaries.
def collectTopVals(ts, cx) = collectTopVals0(skipSemisF(ts), cx)
def collectTopVals0(ts, cx) = if isEmpty(ts) then Nil else (if isTok(hd(ts), 2, 7) then collectValName(ts, cx) else (if isCCHead(ts) then collectCCVals(ts, cx) else collectTopVals(sndRest(parseTopItem(ts, cx)), cx)))
// A `case class X(..) derives TC1,..` contributes a `__derived_TC_X` top-val NAME per derived TC (in
// derives order, at the class's source position) — ssc1-lower collectTopVals appends derivedValueNames
// :4976. valCells then emits `(def __derived_TC_X__cell (prim cell.new (lit unit)))` in that slot.
def collectCCVals(ts, cx) = appEnv(derivedNames(ccNameAt(ts), derivesAt(tl(tl(ts)))), collectTopVals(sndRest(parseTopItem(ts, cx)), cx))
def sndRest(pr) = pr match { case (parts, rest) => rest }
def collectValName(ts, cx) = valItem(ts, cx) match { case (parts, rest) => appEnv(valPatNames(ts), collectTopVals(rest, cx)) }
// one empty global cell per top-level val, placed between the prelude and the sels (ssc1-lower def
// order: prelude, topVarCells, topValCells, caseMethodDefs, accDefs, userDefs). Trailing space like
// emitSels; "" when there are no top-level vals -> a val-free program is byte-unchanged.
def valCells(names, dq) = names match { case Nil => "" case h :: t => "(def " ++ h ++ "__cell (prim cell.new (lit unit))) " ++ valCells(t, dq) }

// -- case classes -------------------------------------------------------------------------------
// A case class is NOT a local shape: `_sel_<field>` is ONE GLOBAL def per field NAME, merging one arm
// per class that has that field, HOISTED before all user defs -- while the ctor + mirror stay at the
// declaration site. So F takes a PRE-PASS over the token stream to collect every declaration first.
// Everything below is measured (SPRINT X1h).
//
// A collected class is (name, fields); a field is (fieldName, typeText). Nested tuples only -- the
// subset has no 3-tuples in this compiler's own style.
def ccName(c) = fst(c)
def ccFields(c) = snd(c)
def fldName(f) = fst(f)
def fldType(f) = snd(f)

// -- pre-pass: collect every `case class C(f: T, ..)` in declaration order -----------------------
def collectCC(ts) = if isEmpty(ts) then Nil else (if isCCHead(ts) then collectCC1(tl(tl(ts))) else collectCC(tl(ts)))
def isCCHead(ts) = if isTok(hd(ts), 2, 6) then isTok(hd(tl(ts)), 2, 10) else false
def collectCC1(ts) = collectCC2(snd(hd(ts)), skipNameGenParen(ts))
def collectCC2(nm, ts) = collectFields(ts, Nil) match { case (fs, r) => Cons((nm, fs), collectCC(r)) }
// fields accumulate REVERSED then flip, so declaration order is preserved.
def collectFields(ts, acc) = if isTok(hd(ts), 2, 22) then (revL(acc), tl(ts)) else collectField(ts, acc)
def collectField(ts, acc) = collectField1(snd(hd(ts)), tl(tl(ts)), acc)
def collectField1(nm, ts, acc) = typeText(ts, 0, "") match { case (ty, r) => collectFieldEnd(nm, ty, r, acc) }
// E1: a field may carry a DEFAULT `x: T = expr`. typeText stops at the `=` (code 20); the default value
// is then SKIPPED to the next `,`/`)` at depth 0 (skipDefault) so the mirror's field type is the clean `T`
// (`Int`, not `Int10`) and the rest position still lands after the field-list close. Fields with no default
// are byte-unchanged (no `=` token to stop at, and the `=` branch below is skipped).
def collectFieldEnd(nm, ty, ts, acc) = if isTok(hd(ts), 2, 20) then collectFieldEnd(nm, ty, skipDefault(tl(ts), 0), acc) else (if isTok(hd(ts), 2, 27) then collectFields(tl(ts), Cons((nm, ty), acc)) else ((revL(Cons((nm, ty), acc))), tl(ts)))
def skipDefault(ts, d) = if isEmpty(ts) then ts else (if isSep0(hd(ts), d) then ts else skipDefault(tl(ts), typeDepth(hd(ts), d)))
def isSep0(t, d) = if d > 0 then false else (if isTok(t, 2, 27) then true else isTok(t, 2, 22))
// Capture the type's SOURCE TEXT by concatenating token lexemes -- no separator, which reproduces
// the reference's whitespace-stripped rendering exactly. Stops at `,`, `)`, or `=` (default) at depth 0.
def typeText(ts, d, acc) = if isEmpty(ts) then (acc, ts) else (if isTypeEnd(hd(ts), d) then (acc, ts) else typeText(tl(ts), typeDepth(hd(ts), d), acc ++ tokStr(hd(ts))))
def isTypeEnd(t, d) = if d > 0 then false else (if isTok(t, 2, 27) then true else (if isTok(t, 2, 22) then true else isTok(t, 2, 20)))
def typeDepth(t, d) = if isOpenD(t) then d + 1 else (if isCloseD(t) then d - 1 else (if isTok(t, 2, 22) then d - 1 else d))
def revL(xs) = revL2(xs, Nil)
def revL2(xs, acc) = xs match { case Nil => acc case h :: t => revL2(t, Cons(h, acc)) }

// -- hoisted accessors: one `_sel_<f>` per distinct field name, arms merged across classes --------
def allFieldNames(cs) = revL(collectNames(cs, Nil))
def collectNames(cs, acc) = cs match { case Nil => acc case h :: t => collectNames(t, addNames(ccFields(h), acc)) }
def addNames(fs, acc) = fs match { case Nil => acc case h :: t => addNames(t, addName(fldName(h), acc)) }
def addName(n, acc) = if memL(n, acc) then acc else Cons(n, acc)
def memL(n, xs) = xs match { case Nil => false case h :: t => if h == n then true else memL(n, t) }
def emitSels(cs, cx) = emitSelList(allFieldNames(cs), cs, cx)
def emitSelList(ns, cs, cx) = ns match { case Nil => "" case h :: t => erase(emitSel(h, cs, cx), cx) ++ " " ++ emitSelList(t, cs, cx) }
// NOTE: emitSels keeps a TRAILING space (prelude ++ sels ++ defs), and is "" when there are
// no case classes -- so a case-class-free program is byte-unchanged.
// F5b: builds a `sel` node whose arms are erased `arm` nodes joined into a pre-rendered string sub-part
// (join2 spacing preserved). eraseSel/eraseArm are in the scaffold's erase dispatcher.
def emitSel(n, cs, cx) = ("sel", (n, selArms(n, cs, cx)))
// F5b: selArm1 now BUILDS an `arm` node; selArm erases it here so the sel payload stays a pre-rendered
// arm string (join2 spacing preserved). eraseArm is in the erase dispatcher.
def selArms(n, cs, cx) = cs match { case Nil => "" case h :: t => join2(selArm(n, h, cx), selArms(n, t, cx)) }
def selArm(n, c, cx) = if memL(n, fieldNamesOf(ccFields(c))) then erase(selArm1(n, c), cx) else ""
def fieldNamesOf(fs) = fs match { case Nil => Nil case h :: t => Cons(fldName(h), fieldNamesOf(t)) }
// a field's slot is (local arity-1-pos) -- the same reverse indexing params use.
def selArm1(n, c) = ("arm", (ccName(c), (dlen(ccFields(c)), (dlen(ccFields(c)) - 1 - idxOf(n, ccFields(c), 0)))))
def idxOf(n, fs, i) = fs match { case Nil => 0 case h :: t => if fldName(h) == n then i else idxOf(n, t, i + 1) }

// == F5b Stage 0: AST scaffold (parse -> AST -> erase) ============================================
// F historically FUSED parse and emit: each emit* concatenated Core-IR TEXT directly, so there was no
// tree and no place to attach types. F5b splits that fusion into parse -> AST -> erase, so a LATER
// stage can infer types over the AST and emit TYPED IR (retiring the kernel's runtime-dispatch prims).
// Stage 0 changes NOTHING observable: the converted emit* build an AST node and a trivial `erase`
// reproduces TODAY's UNTYPED IR strings BYTE-IDENTICALLY. That "no-change" is the safety net for the
// pervasive refactor, verified by specs/v2.2-p6.5-corpus.sh (IR byte-identity vs the oracle),
// specs/v2.2-p6.5-semantic.sh (output equivalence) and the `--self` fixpoint.
//
// A node is a TAGGED TUPLE (tag, payload) — F's own idiom (a token is (kind,payload); parseAtom1
// dispatches on fst). `erase(node, cx)` matches the tag and rebuilds the exact string the old emit*
// concatenated. cx carries the `"` char (dqOf) and `\` char (bsOf), threaded because F is escape-free.
// CONVERTED (Stage 0 COMPLETE): declaration cluster ctorfn/mirror/sel/arm/enumnull/extdisp, and the whole
// EXPRESSION pipeline (spine leaves thread nodes; atoms int/float/str/triple are structured; every other
// expression producer stays string-based and is bridged via wrapE / erased via erase(_,cx) at the ~55
// consumption sites). `e` = a raw already-rendered IR string. The remaining string-returning helpers
// (emitInt/emitStr/emitArith/emitBin/emitMethod/emitApp/… and the def/val/expr declaration WRAPPERS) are
// erase-time RENDERERS or wrappers around erased expression nodes — correct by design, not un-converted.
// F5b: erase takes the FULL cx (not just dq) — expression string/triple nodes need `bs` too and Stage 1
// reads the inferred type off cx/the node. dqOf(cx)==dq and bsOf(cx)==bs by construction (cx is always
// mkCx(dq,…,bs,…)), so deriving dq here is byte-identical to the old dq-threaded callers.
def erase(n, cx) = n match { case (tag, p) => eraseB(tag, p, cx) }
// Expression-node arms come FIRST (hottest): `e` = a raw already-rendered IR string (the Stage-0 default
// for the method/selection/app/ctor/match/block/lambda machinery, which inspects receiver strings); the
// atom nodes int/float/str/triple defer their rendering here (triple needs bs from cx). Stage 1 attaches
// typed rendering (i.add/f.add/… by inferred type) at THIS seam without touching the parsers.
def eraseB(tag, p, cx) = if tag == "e" then p else (if tag == "int" then emitInt(p) else (if tag == "float" then emitFloat(p) else (if tag == "str" then emitStr(p, dqOf(cx)) else (if tag == "triple" then eraseTriple(p, cx) else (if tag == "ctorfn" then eraseCtorFn(p) else (if tag == "mirror" then eraseMirror(p, dqOf(cx)) else (if tag == "sel" then eraseSel(p, dqOf(cx)) else (if tag == "enumnull" then eraseEnumNull(p) else (if tag == "arm" then eraseArm(p) else (if tag == "extdisp" then eraseExtDisp(p) else ""))))))))))
def eraseExtDisp(p) = p match { case (m, rest) => rest match { case (ar, chain) => " (def " ++ m ++ " (lam " ++ ar ++ " " ++ chain ++ "))" } }
def eNode(s) = ("e", s)
// wrap a (string, rest) pair from a string-based producer into a (node, rest) pair for the spine.
def wrapE(pr) = pr match { case (s, r) => (eNode(s), r) }
// erase the VALUE of a (node, rest) pair back to a (string, rest) pair (spine result → string producer).
def eraseP(pr, cx) = pr match { case (a, r) => (erase(a, cx), r) }
def eraseTriple(p, cx) = emitStr(escTriple(p, 0, p.length, dqOf(cx), bsOf(cx)), dqOf(cx))
def eraseArm(p) = p match { case (cn, rest) => rest match { case (ar, k) => "(arm " ++ cn ++ " " ++ ar ++ " (local " ++ k ++ "))" } }
def eraseEnumNull(nm) = "(def " ++ nm ++ " (ctor " ++ nm ++ "))"
def eraseCtorFn(p) = p match { case (name, ar) => "(def " ++ name ++ " (lam " ++ ar ++ " (ctor " ++ name ++ ctorArgs(ar, 0) ++ ")))" }
def eraseSel(p, dq) = p match { case (n, arms) => "(def _sel_" ++ n ++ " (lam 1 (match (local 0) (" ++ arms ++ ") (default (prim __method__ (lit (str " ++ dq ++ n ++ dq ++ ")) (local 0))))))" }
def eraseMirror(p, dq) = p match { case (name, rest) => rest match { case (fnames, ftypes) => "(def __mirror_" ++ name ++ " (ctor Mirror (lit (str " ++ dq ++ name ++ dq ++ ")) " ++ strList(fnames, dq) ++ " " ++ strList(ftypes, dq) ++ "))" } }

// -- ctor + mirror, emitted AT the declaration site ------------------------------------------------
// The bare constructor def `(def C (lam N (ctor C (local ..))))`. A case class pairs it with a mirror
// (emitCC); a PARAMETRIZED ENUM CASE emits ONLY this (ssc1-lower lowerCaseCls :3770 emits no mirror —
// the mirror path lowerProductMetadata runs for `casecls`, not `enum`).
// F5b: emitCtorFn/emitMirror now BUILD nodes; emitCC/emitEnumDef erase them at the string boundary.
def emitCtorFn(c) = ("ctorfn", (ccName(c), dlen(ccFields(c))))
def emitCC(c, cx) = erase(emitCtorFn(c), cx) ++ " " ++ erase(emitMirror(c, cx), cx)
def ctorArgs(ar, i) = if i >= ar then "" else " (local " ++ (ar - 1 - i) ++ ")" ++ ctorArgs(ar, i + 1)
def emitMirror(c, cx) = ("mirror", (ccName(c), (fieldNamesOf(ccFields(c)), fieldTypesOf(ccFields(c)))))
def fieldTypesOf(fs) = fs match { case Nil => Nil case h :: t => Cons(fldType(h), fieldTypesOf(t)) }
def strList(xs, dq) = xs match { case Nil => "(ctor Nil)" case h :: t => "(ctor Cons (lit (str " ++ dq ++ h ++ dq ++ ")) " ++ strList(t, dq) ++ ")" }

// -- derives TC (derived typeclass instances) ------------------------------------------------------
// `case class X(..) derives TC1, TC2` (ssc1-lower derivedInitIrs :3803 / derivedValueNames :3787):
//   • cell `(def __derived_TC_X__cell (prim cell.new (lit unit)))` via collectTopVals/valCells (above);
//   • entry init `(prim cell.set (global __derived_TC_X__cell) (app (global TC_derived) (global __mirror_X)))`
//     as the class's doc-order entry item (after all regfields). Mirror + regfields already emit for
//     EVERY case class (F matches plain cc). `TC_derived` is an imported/object global (unbound => runtime
//     supplies it). summon-based access + `object TC { def derived }` are separate (deeper) levers.
def ccNameAt(ts) = snd(hd(tl(tl(ts))))
def derivesAt(tsName) = collectFields(skipNameGenParen(tsName), Nil) match { case (fs, r) => derivesClause(skipExtends(r)) }
def derivesClause(ts) = if isWord(hd(ts), "derives") then parseDvList(tl(ts)) else Nil
def parseDvList(ts) = Cons(snd(hd(ts)), parseDvListMore(skipGen(tl(ts))))
def parseDvListMore(ts) = if isTok(hd(ts), 2, 27) then parseDvList(tl(ts)) else Nil
def derivedNames(tn, tcs) = tcs match { case Nil => Nil case h :: t => Cons("__derived_" ++ h ++ "_" ++ tn, derivedNames(tn, t)) }
def ccDerivedInit(tn, tcs) = tcs match { case Nil => "" case h :: t => join2(derivedInit1(tn, h), ccDerivedInit(tn, t)) }
def derivedInit1(tn, tc) = "(prim cell.set (global __derived_" ++ tc ++ "_" ++ tn ++ "__cell) (app (global " ++ tc ++ "_derived) (global __mirror_" ++ tn ++ ")))"

// -- T3: case-class BODY methods ------------------------------------------------------------------
// `case class C(f1..fn): def m(p1..pk): T = body` -> a hoisted `(def C_m (lam k+1 <field-lets> body))`
// PLUS a `(prim __regmethod__ "C" "m" (global C_m))` entry so `x.m(a)` (which F already emits as
// `(prim __method__ "m" x a)`) dispatches. Measured byte-exact vs ssc1-lower caseMethodDefsFor :5110 /
// lowerCaseMethodBody :5092 / caseMethodRegs :5162 on case-class-body-methods + js-scala-fenced-block.
//
// PRE-PASS: caseMethods = [ (className, (fieldNames, methodSlices)) ] in REVERSE class order — ssc1-front
// registerCaseMethods :621 PREPENDS each class as parsed, so the cross-class def/reg order is reversed
// (verified: scljet-readonly-pager-btree emits FixtureVfs's defs before FixtureFile's); methods WITHIN a
// class stay source order. methodSlice = (methodName, defToks) where defToks = the token tail right AFTER
// the method-name token (ccMParams+skipToEq re-derive params/body). A class body with NO `def` is omitted
// (registerCaseMethods skips empty defs); `override` is stripped; body val/var fields are skipped.
def collectCaseMethods(ts) = revL(collectCM(ts))
def collectCM(ts) = if isEmpty(ts) then Nil else (if isCCHead(ts) then collectCMcc(ts) else collectCM(tl(ts)))
def collectCMcc(ts) = collectCMcc2(snd(hd(tl(tl(ts)))), tl(tl(tl(ts))), ts)
def collectCMcc2(cname, afterName, ts) = collectFields(skipGenParen(afterName), Nil) match { case (fs, r) => collectCMcc3(cname, fieldNamesOf(fs), skipCCColon(skipExtends(r)), ts) }
def collectCMcc3(cname, flds, r, ts) = if isTok(hd(r), 2, 28) then collectCMcc4(cname, flds, tl(r), ts) else collectCM(tl(ts))
def collectCMcc4(cname, flds, bodyTs, ts) = collectCMreg(cname, flds, collectMethodDefs(bodyTs), ts)
def collectCMreg(cname, flds, ms, ts) = if isEmpty(ms) then collectCM(tl(ts)) else Cons((cname, (flds, ms)), collectCM(tl(ts)))
def collectMethodDefs(ts) = collectMD(skipSemisF(ts))
def collectMD(ts) = if isEmpty(ts) then Nil else (if isTok(hd(ts), 2, 29) then Nil else (if isWord(hd(ts), "override") then collectMD(tl(ts)) else (if isTok(hd(ts), 2, 1) then collectMDdef(ts) else collectMD(skipStmt(ts)))))
def collectMDdef(ts) = Cons((snd(hd(tl(ts))), tl(tl(ts))), collectMD(skipSemisF(skipStmt(tl(tl(ts))))))
// skip one statement to (and past) its top-level `;` (code 52); STOP before a top-level `}` (body close),
// tracking paren/brace/bracket nesting so an inner `;`/`}` inside the method body is not the boundary.
def skipStmt(ts) = skipStmtD(ts, 0)
def skipStmtD(ts, d) = if isEmpty(ts) then ts else skipStmtTok(hd(ts), tl(ts), d)
def skipStmtTok(t, rest, d) = if d == 0 then skipStmtZ(t, rest) else skipStmtN(t, rest, d)
def skipStmtZ(t, rest) = if isTok(t, 2, 52) then rest else (if isTok(t, 2, 29) then Cons(t, rest) else (if isOpenNest(t) then skipStmtD(rest, 1) else skipStmtD(rest, 0)))
def skipStmtN(t, rest, d) = if isOpenNest(t) then skipStmtD(rest, d + 1) else (if isCloseNest(t) then skipStmtD(rest, d - 1) else skipStmtD(rest, d))
// skipExtBody: advance past ONE extension-member def body to the NEXT member. It is skipStmt PLUS an extra
// stop-and-keep at a depth-0 `def`: a `given … with` body GLUES its `extension` members (deeper indent,
// NO `;`), so plain skipStmt runs past them all to the block-terminating `;` and only the 1st member is
// collected → `recv.m` on the rest stubs (`__method__`, not the ext dispatcher). Stopping at the glued
// `def` collects each. It ALSO stops-and-KEEPS a depth-0 `;` (and `}`): inside a given/object body an
// extension block ENDS at the first `;`-separated sibling (a dedented plain `def m` at body indent must
// NOT be glued as an extension member — else its impl is emitted receiver-prepended, arity N+1, and a bare
// `m` dispatcher is synthesised → `recv.m`/`g.m` crash `arity: N+1 expected, N given`). collectOMExtMs
// (given-body emitter/dispatcher) reads this KEPT `;` as the block boundary; collectEMs/collectTopEMs (the
// top-level ext REGISTRY, whose members ARE `;`-separated) wrap the result in `skipSemisF`, so KEEPING the
// `;` is byte-neutral for them and they keep gluing. Nesting-tracked so `(`/`[`/`{` in a body is skipped
// whole. Used by collectEMs (decides `recv.m` → ext dispatch) and collectOMExtMs (given-body emit).
def skipExtBody(ts) = skipExtBodyD(ts, 0)
def skipExtBodyD(ts, d) = if isEmpty(ts) then ts else skipExtBodyTok(hd(ts), tl(ts), d)
def skipExtBodyTok(t, rest, d) = if d == 0 then skipExtBodyZ(t, rest) else skipExtBodyN(t, rest, d)
def skipExtBodyZ(t, rest) = if isTok(t, 2, 1) then Cons(t, rest) else (if isTok(t, 2, 52) then Cons(t, rest) else (if isTok(t, 2, 29) then Cons(t, rest) else (if isOpenNest(t) then skipExtBodyD(rest, 1) else skipExtBodyD(rest, 0))))
def skipExtBodyN(t, rest, d) = if isOpenNest(t) then skipExtBodyD(rest, d + 1) else (if isCloseNest(t) then skipExtBodyD(rest, d - 1) else skipExtBodyD(rest, d))
def isOpenNest(t) = if isTok(t, 2, 21) then true else (if isTok(t, 2, 28) then true else isTok(t, 2, 50))
def isCloseNest(t) = if isTok(t, 2, 22) then true else (if isTok(t, 2, 29) then true else isTok(t, 2, 51))

// DEF emission: `(def C_m (lam k+1 <n nested field-lets> <body>))`. Method env (F, head=local0) = the k
// params (source order, pushed L->R) on top of __self — matching the oracle's revL(Cons("__self", params))
// — so arity = 1 + #params and self starts at (local k). Each field emits `(let ((app (global _sel_f)
// (local <selfIdx>))) ...)` with selfIdx = k + (# lets already emitted); the field NAME is then pushed so
// a bare field ref in the body resolves to its let-local. The body parses with the full cx (so a field
// SELECTION `o.f` still lowers to `(app (global _sel_f) <o>)`). ALL fields get a let (even unreferenced).
def caseMethodDefsStr(cms, cx) = cms match { case Nil => "" case h :: t => ccMDefsCls(h, cx) ++ caseMethodDefsStr(t, cx) }
def ccMDefsCls(reg, cx) = reg match { case (cname, fd) => fd match { case (flds, ms) => ccMDefsMs(cname, flds, ms, cx) } }
def ccMDefsMs(cname, flds, ms, cx) = ms match { case Nil => "" case h :: t => ccMDef(cname, flds, h, cx) ++ " " ++ ccMDefsMs(cname, flds, t, cx) }
def ccMDef(cname, flds, m, cx) = m match { case (mname, defToks) => ccMDefP(cname, mname, flds, ccMParams(defToks), cx) }
// params: `(p1, ..)` after the name -> parseParams (pushed onto [__self]); param-less `def m: T =` -> just __self.
def ccMParams(defToks) = if isTok(hd(defToks), 2, 21) then parseParams(tl(defToks), Cons("__self", Nil)) else (Cons("__self", Nil), defToks)
def ccMDefP(cname, mname, flds, pr, cx) = pr match { case (env, rest) => ccMDefBody(cname, mname, flds, env, skipToEq(rest), cx) }
def ccMDefBody(cname, mname, flds, env, bodyToks, cx) = "(def " ++ cname ++ "_" ++ mname ++ " (lam " ++ dlen(env) ++ " " ++ ccMLets(flds, env, bodyToks, cx) ++ "))"
def ccMLets(flds, env, bodyToks, cx) = flds match { case Nil => ccMBodyE(bodyToks, env, cx) case h :: t => ccMLet(h, t, env, bodyToks, cx) }
def ccMLet(h, t, env, bodyToks, cx) = "(let (" ++ ccMSelInit(h, lookup("__self", env)) ++ ") " ++ ccMLets(t, Cons(h, env), bodyToks, cx) ++ ")"
def ccMSelInit(h, idx) = "(app (global _sel_" ++ h ++ ") (local " ++ idx ++ "))"
def ccMBodyE(bodyToks, env, cx) = parseExpr(bodyToks, 0, env, cx) match { case (b, r) => erase(b, cx) }

// ENTRY: `(prim __regmethod__ (lit (str "C")) (lit (str "m")) (global C_m))` per method, emitted AFTER
// all regfields and BEFORE the doc-order entry items (ssc1-lower :5648). join2 (space-joined, no trailing).
def regMethods(cms, dq) = cms match { case Nil => "" case h :: t => join2(regMethodsCls(h, dq), regMethods(t, dq)) }
def regMethodsCls(reg, dq) = reg match { case (cname, fd) => fd match { case (flds, ms) => regMethodsMs(cname, ms, dq) } }
def regMethodsMs(cname, ms, dq) = ms match { case Nil => "" case h :: t => join2(regMethod1(cname, h, dq), regMethodsMs(cname, t, dq)) }
def regMethod1(cname, m, dq) = m match { case (mname, defToks) => "(prim __regmethod__ (lit (str " ++ dq ++ cname ++ dq ++ ")) (lit (str " ++ dq ++ mname ++ dq ++ ")) (global " ++ cname ++ "_" ++ mname ++ "))" }
def countMethods(cms) = cms match { case Nil => 0 case h :: t => countMethodsCls(h) + countMethods(t) }
def countMethodsCls(reg) = reg match { case (cname, fd) => fd match { case (flds, ms) => dlen(ms) } }

// -- the entry -------------------------------------------------------------------------------------
// items = one __regfields__ per case class (declaration order), then the main call if there is one.
// MEASURED: 0 items -> (lit unit); exactly 1 -> that item BARE (no seq); >1 -> (seq i1 i2 ..).
def regFields(cs, dq) = cs match { case Nil => "" case h :: t => join2(regField(h, dq), regFields(t, dq)) }
def regField(c, dq) = "(prim __regfields__ (lit (str " ++ dq ++ ccName(c) ++ dq ++ ")) " ++ strList(fieldNamesOf(ccFields(c)), dq) ++ ")"
// entry = caseFieldRegs (ALL case classes first) ++ caseMethodRegs ++ doc-order val-sets/exprs ++ main
// call (if any). ssc1-lower :5648 order: regfields (all classes), THEN regmethods (all classes), THEN docExprs.
def mainItem(ts) = if hasMain(ts) then "(app (global main))" else ""
def entryItems3(ts, cs, docEntry, dq, cms) = join2(regFields(cs, dq), join2(regMethods(cms, dq), join2(docEntry, mainItem(ts))))
def nItems3(ts, cs, nDoc, cms) = dlen(cs) + countMethods(cms) + nDoc + (if hasMain(ts) then 1 else 0)
def entryBody3(ts, cs, docEntry, nDoc, dq, cms) = entryWrap(entryItems3(ts, cs, docEntry, dq, cms), nItems3(ts, cs, nDoc, cms))
def entryWrap(items, n) = if n == 0 then "(lit unit)" else (if n == 1 then items else "(seq " ++ items ++ ")")

// The entry clause depends on whether the program HAS a `main` (measured: a main-less program gets
// `(entry (lit unit))`). F's OWN source is main-less -- it defines `compile`, and the ssc0 driver
// supplies the file-reading main -- so this is the last shape X1 needs.
def hasMain(ts) = if isEmpty(ts) then false else (if isTok(hd(ts), 2, 1) then hasMain1(hd(tl(ts)), tl(ts)) else hasMain(tl(ts)))
def hasMain1(t, ts) = if fst(t) == 1 then hasMainN(snd(t), ts) else hasMain(ts)
def hasMainN(nm, ts) = if nm == "main" then true else hasMain(ts)
def entryOf3(ts, cs, docEntry, nDoc, dq, cms) = ") (entry " ++ entryBody3(ts, cs, docEntry, nDoc, dq, cms) ++ "))"
def compile(src, dq, bs) = compile1(layout(lex(src, 0, src.length)), dq, bs)
def compile1(ts, dq, bs) = compile2(ts, collectCC(ts), collectTypeCases(ts), dq, bs)
// The pre-pass results become the parse CONTEXT: case-class names (cs, cc-only, for isCC) + the UNIFIED
// type-case field names (tcs, cc + enum cases) + top-level val names + the enum registries. Top-level vals
// are collected with a base cx first (their `rest` boundaries do not depend on val-name resolution).
def mkCxE(cs, tcs, ts, dq, vals, vars, bs, pless) = mkCx(dq, ccNamesL(cs), allFieldNames(tcs), vals, collectEnumCaseNames(ts), collectEnumReg(ts), vars, bs, pless, (collectSubReg(ts), collectEnumAllReg(ts)), collectObjReg(ts), appEnv(collectFuncDflts(ts), collectObjDflts(ts)), (collectGivenTable(ts), (collectUsingSig(ts), (collectExtMethods(ts), (mangleExtMethods(ts), collectObjVarargs(ts))))))
def compile2(ts, cs, tcs, dq, bs) = compile2b(ts, cs, tcs, dq, bs, mkCxE(cs, tcs, ts, dq, Nil, Nil, bs, Nil))
def compile2b(ts, cs, tcs, dq, bs, base) = compile3(ts, cs, tcs, dq, mkCxE(cs, tcs, ts, dq, collectTopVals(ts, base), collectTopVars(ts, base), bs, collectPlessDefs(ts, base)))
def compile3(ts, cs, tcs, dq, cx) = walkTop(ts, cx) match { case (strs, nDoc) => compile4(strs, nDoc, ts, tcs, dq, cx) }
// def order: prelude, topValCells, sels(accessors), userDefs; then the entry. prelude/valCells/sels
// each carry a trailing space as their separator; when userDefs is empty that space would sit right
// before the defs-closing `)` (spurious). rtrim1 drops exactly one trailing space -- a no-op when
// userDefs is non-empty (it ends with `)`), so every def-bearing program stays byte-identical.
def rtrim1(s) = if s.length > 0 then (if s.charAt(s.length - 1) == 32 then s.substring(0, s.length - 1) else s) else s
// def order (ssc1-lower :5570-5573): prelude, topVarCells, topValCells, sels(accessors), userDefs. varCells
// reuses valCells (identical `(def n__cell (prim cell.new (lit unit)))` render); "" when there are no vars.
// caseMethodDefs sit BETWEEN topValCells and sels (ssc1-lower :5570-5573); each carries a trailing space
// like valCells/emitSels ("" when there are no body methods → a method-free program stays byte-identical).
def compile4(strs, nDoc, ts, tcs, dq, cx) = compile4b(strs, nDoc, ts, tcs, dq, cx, collectCaseMethods(ts))
def compile4b(strs, nDoc, ts, tcs, dq, cx, cms) = strs match { case (userDefs, docEntry) => rtrim1(prelude(dq) ++ valCells(varNamesOf(cx), dq) ++ valCells(valNamesOf(cx), dq) ++ caseMethodDefsStr(cms, cx) ++ emitSels(tcs, cx) ++ userDefs ++ emitExtDispatchers(ts, cx)) ++ entryOf3(ts, tcs, docEntry, nDoc, dq, cms) }
def ccNamesL(cs) = cs match { case Nil => Nil case h :: t => Cons(ccName(h), ccNamesL(t)) }
// The CONSTANT 7258-byte prelude `ssc1-lower` emits (measured identical across programs).
// It is fixed OUTPUT, so F carries it as a string constant; byte-identity stays the oracle.
// Split at the 24 `"` sites, spliced with dq -- so this source has no `"`-inside-a-string.
// The quote that sits ON a group boundary is the leading `dq` of the next def (X1a bug: it was
// dropped, costing exactly 4 bytes -- one per boundary).
def pre1(dq) = "(program (defs (def println (lam 1 (prim io.println (local 0)))) (def print (lam 1 (prim io.print (local 0)))) (def math (prim __math_obj__)) (def RuntimeException (lam 1 (ctor RuntimeException (local 0)))) (def Exception (lam 1 (ctor Exception (local 0)))) (def IllegalArgumentException (lam 1 (ctor IllegalArgumentException (local 0)))) (def IllegalStateException (lam 1 (ctor IllegalStateException (local 0)))) (def NoSuchElementException (lam 1 (ctor NoSuchElementException (local 0)))) (def UnsupportedOperationException (lam 1 (ctor UnsupportedOperationException (local 0)))) (def Bump_tick_cell (prim cell.new (lam 0 (lit (int 1))))) (def Bump_tick (lam 0 (app (prim cell.get (global Bump_tick_cell))))) (def _sel_map (lam 2 (letrec ((lam 1 (match (local 0) ((arm Nil 0 (ctor Nil)) (arm Cons 2 (ctor Cons (app (local 4) (local 1)) (app (local 3) (local 0)))) (arm LazyCons 2 (ctor LazyCons (app (local 4) (local 1)) (lam 0 (app (local 3) (app (local 0)))))) (arm LazyNil 0 (ctor LazyNil)) (arm Some 1 (ctor Some (app (local 3) (local 0)))) (arm None 0 (ctor None)) (arm Right 1 (ctor Right (app (local 3) (local 0)))) (arm Left 1 (ctor Left (local 0)))) (default (prim __method__ (lit (str "
def pre2(dq) = dq ++ "map" ++ dq ++ ")) (local 0) (local 2)))))) (app (local 0) (local 2))))) (def _sel_foreach (lam 2 (letrec ((lam 1 (match (local 0) ((arm Nil 0 (lit unit)) (arm Cons 2 (let ((app (local 4) (local 1))) (app (local 4) (local 1))))) (default (prim __method__ (lit (str " ++ dq ++ "foreach" ++ dq ++ ")) (local 0) (local 2)))))) (app (local 0) (local 2))))) (def _sel_filter (lam 2 (letrec ((lam 1 (match (local 0) ((arm Nil 0 (ctor Nil)) (arm Cons 2 (if (app (local 4) (local 1)) (ctor Cons (local 1) (app (local 3) (local 0))) (app (local 3) (local 0))))) (default (prim __method__ (lit (str " ++ dq ++ "filter" ++ dq ++ ")) (local 0) (local 2)))))) (app (local 0) (local 2))))) (def _sel_foldLeft (lam 2 (lam 1 (letrec ((lam 2 (match (local 1) ((arm Nil 0 (local 0)) (arm Cons 2 (app (local 4) (local 0) (app (local 5) (local 2) (local 1)))))))) (app (local 0) (local 3) (local 2)))))) (def _sel_flatMap (lam 2 (match (local 1) ((arm Some 1 (app (local 1) (local 0))) (arm None 0 (ctor None)) (arm Right 1 (app (local 1) (local 0))) (arm Left 1 (ctor Left (local 0)))) (default (prim __method__ (lit (str "
def pre3(dq) = dq ++ "flatMap" ++ dq ++ ")) (local 1) (local 0)))))) (def _sel_fold (lam 3 (match (local 2) ((arm Left 1 (app (local 2) (local 0))) (arm Right 1 (app (local 1) (local 0)))) (default (prim __method__ (lit (str " ++ dq ++ "fold" ++ dq ++ ")) (local 2) (local 1) (local 0)))))) (def _sel_getOrElse (lam 2 (match (local 1) ((arm Some 1 (local 0))) (default (local 0))))) (def __list_head (lam 1 (match (local 0) ((arm Cons 2 (local 1))) (default (prim __method__ (lit (str " ++ dq ++ "head" ++ dq ++ ")) (local 0)))))) (def __list_tail (lam 1 (match (local 0) ((arm Cons 2 (local 0))) (default (prim __method__ (lit (str " ++ dq ++ "tail" ++ dq ++ ")) (local 0)))))) (def __list_isEmpty (lam 1 (match (local 0) ((arm Nil 0 (lit true)) (arm None 0 (lit true))) (default (prim __method__ (lit (str " ++ dq ++ "isEmpty" ++ dq ++ ")) (local 0)))))) (def __list_nonEmpty (lam 1 (match (local 0) ((arm Nil 0 (lit false)) (arm None 0 (lit false))) (default (if (prim __method__ (lit (str "
def pre4(dq) = dq ++ "isEmpty" ++ dq ++ ")) (local 0)) (lit false) (lit true)))))) (def __str_toInt (lam 1 (match (prim str->i (local 0)) ((arm Some 1 (local 0))) (default (lit (int 0)))))) (def _sel__1 (lam 1 (match (local 0) ((arm Pair 2 (local 1)) (arm Tuple2 2 (local 1)) (arm Tuple3 3 (local 2)) (arm Tuple4 4 (local 3)))))) (def _sel__2 (lam 1 (match (local 0) ((arm Pair 2 (local 0)) (arm Tuple2 2 (local 0)) (arm Tuple3 3 (local 1)) (arm Tuple4 4 (local 2)))))) (def _sel__3 (lam 1 (match (local 0) ((arm Tuple3 3 (local 0)) (arm Tuple4 4 (local 1)))))) (def _sel__4 (lam 1 (match (local 0) ((arm Tuple4 4 (local 0)))))) (def _sel_split (lam 2 (prim str.split (local 1) (local 0)))) (def _sel_trim (lam 1 (prim str.trim (local 0)))) (def _sel_replace (lam 3 (prim str.replace (local 2) (local 1) (local 0)))) (def _sel_mkString (lam 2 (letrec ((lam 1 (match (local 0) ((arm Nil 0 (lit (str "
