      |/// Drill the fetched JSON to the row array (`rows_path` dotted, or common
      |/// envelope keys when empty) and project each row onto the column field paths.
      |fn _tui_rows_of(json: &str, rows_path: &str, row_key_path: &str, cols: &[(String, String)]) -> Result<Vec<Vec<String>>, String> {
      |    use std::collections::HashSet;
      |    let v: serde_json::Value = serde_json::from_str(json).map_err(|_| "table response is not JSON".to_string())?;
      |    let arr = match _tui_drill(&v, rows_path).and_then(|x| x.as_array()) {
      |        Some(a) => a, None => return Err("table rows are not an array".to_string()),
      |    };
      |    let mut seen = HashSet::new();
      |    let mut projected = Vec::with_capacity(arr.len());
      |    for (index, row) in arr.iter().enumerate() {
      |        let identity = _tui_row_identity(row, row_key_path)
      |            .map_err(|e| format!("row {}: {}", index, e))?;
      |        if !seen.insert(identity.clone()) { return Err(format!("duplicate row key {}", identity)); }
      |        projected.push(cols.iter().map(|(_, f)| _tui_json_field(row, f)).collect());
      |    }
      |    Ok(projected)
      |}
      |
      |fn _tui_row_identity(row: &serde_json::Value, path: &str) -> Result<String, String> {
      |    if path.is_empty() || path.split('.').any(|part| part.is_empty()) {
      |        return Err("rowKeyPath must be a non-empty dotted path".to_string());
      |    }
      |    let mut cur = row;
      |    for part in path.split('.') { cur = cur.get(part).ok_or_else(|| format!("missing key at {}", path))?; }
      |    match cur {
      |        serde_json::Value::String(value) if !value.is_empty() => Ok(format!("string:{}", value)),
      |        serde_json::Value::Number(value) if value.as_i64().is_some() || value.as_u64().is_some() => Ok(format!("int:{}", value)),
      |        _ => Err(format!("key at {} must be a non-empty String or integral number", path)),
      |    }
      |}
