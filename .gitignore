# Hidden files and directories — catch-all; only .github/ is whitelisted
.*
.*/
!.github/
!.gitignore
!.gitattributes
!.work/


# Build outputs
target/
out/
dist/
build/

# Repo-local bin/ is generated by `install.sh` / `sbt cli/stage`.
# bin/lib/ holds staged JARs; bin/lib/compiler/plugins/ holds .sscpkg files.
# Sources for bin/ wrappers live in scripts/launchers/.
/bin/
/lib/
# Compiled JVM artifacts produced by compile-jvm / package
*.scjvm

# Scala CLI
.scala-build/

# Claude Code
.claude/

# IDE
.idea/
.vscode/
*.iml
.project
.classpath
.settings/

# Scala
*.class
*.log
.bloop/
.metals/
.bsp/
project/target/
project/project/

# Node (for JS backend tooling)
node_modules/
npm-debug.log
yarn-error.log

# OS
.DS_Store
Thumbs.db

# Temporary files
*.swp
*.swo
*~
.cache/

# ScalaScript compiled artifacts
*.ssc.js
*.ssc.class
.scalascript/

# SQLite databases generated by ssc scripts at runtime
todos.db
*.db
