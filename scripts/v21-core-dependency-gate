#!/usr/bin/env bash
# Classify the ScalaScript 2.1 standard v2 runtime roots and reject parser/codec
# dependencies from the permanent Scala 3 seed and pure core. Feature plugins
# may declare their own external codecs, but those implementation JARs are not
# part of the closed standard layout unless a separately packaged plugin owns
# them. The final cutover runs with --strict-parsers as an extra root-reference
# check after all migration parser JARs have left that layout.
set -euo pipefail
export LC_ALL=C

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
ROOT=$(git -C "$SCRIPT_DIR" rev-parse --show-toplevel 2>/dev/null) || {
  echo 'v21-core-dependency-gate: cannot locate repository root' >&2
  exit 2
}

jars_dir=${SSC_STANDARD_JARS:-}
report=${V21_CORE_DEP_REPORT:-"${TMPDIR:-/tmp}/scalascript-v21-core-deps-$$.tsv"}
strict_parsers=0
require_closed_layout=0
self_test=0

usage() {
  cat <<'EOF'
usage: scripts/v21-core-dependency-gate [options]
  --jars DIR          staged standard JAR directory
  --report PATH       write stable TSV report (default: temporary file)
  --strict-parsers    reject parser/codec references in staged plugin roots too
  --require-closed-layout
                      reject every staged JAR outside declared standard ownership
                      (roots, jdeps closure, and named reflective plugin deps;
                      automatic for */standard/jars)
  --self-test         prove the forbidden-reference detector rejects a fixture

Default JAR lookup prefers bin/lib/standard/jars (the 2.1 slim layout), then
falls back to bin/lib/jars during migration. Run scripts/sbtc "installBin"
first when neither directory exists.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --jars) jars_dir=$2; shift 2 ;;
    --report) report=$2; shift 2 ;;
    --strict-parsers) strict_parsers=1; shift ;;
    --require-closed-layout) require_closed_layout=1; shift ;;
    --self-test) self_test=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) echo "v21-core-dependency-gate: unknown option: $1" >&2; usage >&2; exit 2 ;;
  esac
done

# Package spellings occur both in jdeps output (dots) and JVM constant pools
# (slashes). Keep this list narrow and explicit: it is the standard seed/core
# parser and codec denylist, not a ban on feature-plugin implementation choices.
forbidden_re='(^|[^[:alnum:]_])(ujson|upickle|org[./]commonmark|com[./]vladsch[./]flexmark|org[./]yaml[./]snakeyaml|com[./]fasterxml[./]jackson|io[./]circe|io[./]bullet[./]borer|scala[./]meta)([^[:alnum:]_]|$)'

archive_has_forbidden_reference() {
  local archive=$1
  local entry
  while IFS= read -r entry; do
    [[ $entry == *.class ]] || continue
    if unzip -p "$archive" "$entry" 2>/dev/null | grep -aE "$forbidden_re" >/dev/null; then
      return 0
    fi
  done < <(jar tf "$archive")
  return 1
}

if [[ $self_test -eq 1 ]]; then
  tmp=$(mktemp -d "${TMPDIR:-/tmp}/ssc-v21-core-dep-selftest.XXXXXX")
  trap 'rm -rf "$tmp"' EXIT HUP INT TERM
  mkdir -p "$tmp/classes"
  printf 'synthetic constant pool: ujson/Value\n' >"$tmp/classes/Forbidden.class"
  (cd "$tmp/classes" && jar --create --file "$tmp/scalascript-v2-core_3-selftest.jar" Forbidden.class)
  if ! archive_has_forbidden_reference "$tmp/scalascript-v2-core_3-selftest.jar"; then
    echo 'v21-core-dependency-gate: self-test failed to detect ujson/Value' >&2
    exit 1
  fi
  echo 'PASS v21-core-dependency-gate self-test'
  exit 0
fi

if [[ -z $jars_dir ]]; then
  if [[ -d "$ROOT/bin/lib/standard/jars" ]]; then
    jars_dir="$ROOT/bin/lib/standard/jars"
  else
    jars_dir="$ROOT/bin/lib/jars"
  fi
fi
if [[ ! -d $jars_dir ]]; then
  echo "v21-core-dependency-gate: staged JAR directory missing: $jars_dir" >&2
  echo 'run scripts/sbtc "installBin" first' >&2
  exit 2
fi
case "$jars_dir" in
  */standard/jars) require_closed_layout=1 ;;
esac

jdeps_cmd=$(command -v jdeps || true)
if [[ -z $jdeps_cmd ]]; then
  echo 'v21-core-dependency-gate: jdeps not found' >&2
  exit 2
fi
for cmd in jar unzip; do
  command -v "$cmd" >/dev/null || {
    echo "v21-core-dependency-gate: required command not found: $cmd" >&2
    exit 2
  }
done

declare -a root_specs=(
  'seed|scalascript-v2-core_*.jar'
  'seed|scala3-library_3-*.jar'
  'pure-core|scalascript-v2-native-plugin-spi_*.jar'
  'backend-plugin|scalascript-v2-jvm-bytecode_*.jar'
  'feature-plugin|scalascript-v2-native-host-plugin_*.jar'
  'feature-plugin|scalascript-v2-native-crypto-plugin_*.jar'
  'feature-plugin|scalascript-v2-native-os-plugin_*.jar'
  'feature-plugin|scalascript-v2-native-fs-plugin_*.jar'
  'feature-plugin|scalascript-scljet-vfs-host_*.jar'
  'feature-plugin|scalascript-v2-native-scljet-vfs-plugin_*.jar'
  'feature-plugin|scalascript-v2-native-json-plugin_*.jar'
  'feature-plugin|scalascript-v2-native-http-fast-plugin_*.jar'
  'feature-plugin|scalascript-http-fast-engine_*.jar'
  'feature-plugin|scalascript-v2-native-sql-plugin_*.jar'
  'feature-plugin|scalascript-v2-native-ui-plugin_*.jar'
  'feature-plugin|scalascript-v2-native-state-effect-plugin_*.jar'
  'feature-plugin|scalascript-v2-native-effect-runners-plugin_*.jar'
  'feature-plugin|scalascript-v2-native-storage-effect-plugin_*.jar'
  'feature-plugin|scalascript-v2-native-reactive-plugin_*.jar'
  'feature-plugin|scalascript-v2-native-yaml-plugin_*.jar'
  'feature-plugin|scalascript-v2-native-content-plugin_*.jar'
  'feature-plugin|scalascript-v2-native-dataset-plugin_*.jar'
  'feature-plugin|scalascript-v2-native-generator-plugin_*.jar'
  'feature-plugin|scalascript-v2-native-actors-plugin_*.jar'
  'feature-plugin|scalascript-v2-native-distributed-plugin_*.jar'
  'feature-plugin|scalascript-v2-native-graph-plugin_*.jar'
  'feature-plugin|scalascript-v2-native-optics-plugin_*.jar'
)

# Some plugin dependencies are selected by runtime configuration, JDBC URLs,
# or service loading and therefore do not appear in static jdeps output.  A
# closed distribution still needs an explicit owner for every one of them.
# Keep the list exact: a newly staged JAR remains a hard failure until reviewed.
declare -a reflective_specs=(
  'feature-plugin|sql-plugin|HikariCP-*.jar'
  'feature-plugin|sql-plugin|checker-qual-*.jar'
  'feature-plugin|sql-plugin|h2-*.jar'
  'feature-plugin|sql-plugin|postgresql-*.jar'
  'feature-plugin|sql-plugin|sqlite-jdbc-*.jar'
  'feature-plugin|sql-plugin|slf4j-api-*.jar'
  'feature-plugin|sql-plugin|slf4j-simple-*.jar'
  'feature-plugin|sql-plugin|scalascript-backend-config-runtime_*.jar'
  'feature-plugin|sql-plugin|scalascript-backend-typed-data-runtime_*.jar'
  'feature-plugin|sql-plugin|scalascript-markup-core_*.jar'
  'feature-plugin|sql-plugin|scalascript-yaml_*.jar'
)

mkdir -p "$(dirname -- "$report")"
tmp_report=$(mktemp "${TMPDIR:-/tmp}/ssc-v21-core-deps.XXXXXX")
classified=$(mktemp "${TMPDIR:-/tmp}/ssc-v21-core-classified.XXXXXX")
trap 'rm -f "$tmp_report" "$classified"' EXIT HUP INT TERM
printf 'layer\troot\tdependency\tparser_codec_edge\tpolicy\n' >"$tmp_report"

record_classified_jar() {
  local jar_name=$1
  local layer=$2
  [[ $jar_name == *.jar ]] || return 0
  if ! grep -F "${jar_name}"$'\t' "$classified" >/dev/null 2>&1; then
    printf '%s\t%s\n' "$jar_name" "$layer" >>"$classified"
  fi
}

dependency_layer() {
  local jar_name=$1
  local owner_layer=$2
  case "$jar_name" in
    scala-library-*.jar|scala3-library_*-*.jar|tasty-core_*-*.jar)
      printf 'seed-runtime' ;;
    scalascript-v2-core_*.jar)
      printf 'seed' ;;
    scalascript-v2-native-plugin-spi_*.jar)
      printf 'pure-core' ;;
    asm-*.jar|scalascript-v2-jvm-bytecode_*.jar)
      printf 'backend-plugin' ;;
    *)
      printf '%s' "$owner_layer" ;;
  esac
}

root_count=0
edge_count=0
plugin_parser_edges=0
violations=0
staged_jars=0
outside_closure=0
reflective_count=0

for spec in "${root_specs[@]}"; do
  layer=${spec%%|*}
  pattern=${spec#*|}
  shopt -s nullglob
  matches=("$jars_dir"/$pattern)
  shopt -u nullglob
  if [[ ${#matches[@]} -ne 1 ]]; then
    echo "v21-core-dependency-gate: expected one $pattern in $jars_dir, found ${#matches[@]}" >&2
    violations=$((violations + 1))
    continue
  fi
  root_jar=${matches[0]}
  root_name=${root_jar##*/}
  root_count=$((root_count + 1))
  record_classified_jar "$root_name" "$layer"

  verbose=$($jdeps_cmd --multi-release base --ignore-missing-deps -verbose:class \
    -cp "$jars_dir/*" "$root_jar")

  has_forbidden=0
  if printf '%s\n' "$verbose" | grep -E "$forbidden_re" >/dev/null || \
      archive_has_forbidden_reference "$root_jar"; then
    has_forbidden=1
  fi

  policy=allowed
  if [[ $has_forbidden -eq 1 ]]; then
    if [[ $layer == seed || $layer == pure-core || $strict_parsers -eq 1 ]]; then
      policy=forbidden
      violations=$((violations + 1))
      echo "v21-core-dependency-gate: forbidden parser/codec reference in $layer root $root_name" >&2
      printf '%s\n' "$verbose" | grep -E "$forbidden_re" >&2 || true
    else
      policy=migration-plugin
      plugin_parser_edges=$((plugin_parser_edges + 1))
    fi
  fi

  summary=$($jdeps_cmd --multi-release base --ignore-missing-deps -summary \
    -cp "$jars_dir/*" "$root_jar")
  dependency_count=0
  while IFS= read -r line; do
    [[ $line == *' -> '* ]] || continue
    dependency=${line##* -> }
    dependency=${dependency%% *}
    dependency=${dependency##*/}
    if [[ $dependency == *.jar ]]; then
      record_classified_jar "$dependency" "$(dependency_layer "$dependency" "$layer")"
    fi
    printf '%s\t%s\t%s\t%s\t%s\n' \
      "$layer" "$root_name" "$dependency" "$has_forbidden" "$policy" >>"$tmp_report"
    dependency_count=$((dependency_count + 1))
    edge_count=$((edge_count + 1))
  done <<<"$summary"
  if [[ $dependency_count -eq 0 ]]; then
    printf '%s\t%s\t%s\t%s\t%s\n' \
      "$layer" "$root_name" '(none)' "$has_forbidden" "$policy" >>"$tmp_report"
  fi
done

for spec in "${reflective_specs[@]}"; do
  layer=${spec%%|*}
  rest=${spec#*|}
  owner=${rest%%|*}
  pattern=${rest#*|}
  shopt -s nullglob
  matches=("$jars_dir"/$pattern)
  shopt -u nullglob
  if [[ ${#matches[@]} -ne 1 ]]; then
    echo "v21-core-dependency-gate: expected one reflective $pattern in $jars_dir, found ${#matches[@]}" >&2
    violations=$((violations + 1))
    continue
  fi
  owned_jar=${matches[0]}
  owned_name=${owned_jar##*/}
  reflective_count=$((reflective_count + 1))
  record_classified_jar "$owned_name" "$layer"

  has_forbidden=0
  if archive_has_forbidden_reference "$owned_jar"; then
    has_forbidden=1
  fi
  policy=reflective-plugin-dependency
  if [[ $has_forbidden -eq 1 ]]; then
    if [[ $strict_parsers -eq 1 ]]; then
      policy=forbidden
      violations=$((violations + 1))
      echo "v21-core-dependency-gate: forbidden parser/codec reference in $owner dependency $owned_name" >&2
    else
      policy=migration-plugin
      plugin_parser_edges=$((plugin_parser_edges + 1))
    fi
  fi
  printf '%s\t(layout:%s)\t%s\t%s\t%s\n' \
    "$layer" "$owner" "$owned_name" "$has_forbidden" "$policy" >>"$tmp_report"
done

# The migration layout still co-locates tools/compat JARs with the standard v2
# closure. Classify those explicitly in the report. Once TI-7 provides
# bin/lib/standard/jars, any such extra is an error instead.
shopt -s nullglob
all_staged=("$jars_dir"/*.jar)
shopt -u nullglob
for staged in "${all_staged[@]}"; do
  staged_jars=$((staged_jars + 1))
  staged_name=${staged##*/}
  if ! grep -F "${staged_name}"$'\t' "$classified" >/dev/null 2>&1; then
    outside_closure=$((outside_closure + 1))
    if [[ $require_closed_layout -eq 1 ]]; then
      violations=$((violations + 1))
      printf 'unclassified\t(staged-layout)\t%s\t-\tforbidden\n' "$staged_name" >>"$tmp_report"
      echo "v21-core-dependency-gate: unclassified JAR in closed standard layout: $staged_name" >&2
    else
      printf 'tools/compat\t(migration-full-layout)\t%s\t-\toutside-standard-closure\n' \
        "$staged_name" >>"$tmp_report"
    fi
  fi
done

mv "$tmp_report" "$report"
rm -f "$classified"
trap - EXIT HUP INT TERM

echo "=== roots: $root_count  dependency-edges: $edge_count  reflective-plugin-jars: $reflective_count"
echo "=== staged-jars: $staged_jars  outside-standard-closure: $outside_closure"
echo "=== migration-plugin-parser-roots: $plugin_parser_edges  violations: $violations"
echo "REPORT: $report"
if [[ $violations -ne 0 ]]; then
  exit 1
fi
echo 'PASS v21-core-dependency-gate'
