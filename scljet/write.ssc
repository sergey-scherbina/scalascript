# SclJet M3 write path

M3 builds the write path from the bottom up. The first slice serializes a
freshly-created empty database, byte-identical to reference SQLite's
`PRAGMA page_size=N; VACUUM` output: the 100-byte file header followed by a
single empty page-1 table-leaf B-tree header, zero-padded to the page size.
An empty database uses schema format 0 and text encoding 0 (the encoding is
fixed only when the first object is created), a change counter of 1, one page,
and the writer's SQLite version number (3.53.3 → 3053003), matching the
committed `empty-encoding-zero.db` fixture exactly.

[ByteSlice, ByteError, ByteRead, VarintRead, byteSliceToList, byteSliceZeroExtend, byteSliceGet, byteSliceSlice, encodeVarint, decodeVarint, readU16Be, readU32Be, writeU32Be](bytes.ssc)
[SqliteValue, SqlNull, SqlInteger, SqlReal, SqlText, SqlBlob](values.ssc)
[DecodedRecord, RecordField](record.ssc)
[MutablePager, mutableGet, mutablePut, mutablePageCount, mutableAllocate](journal.ssc)

```scalascript
// Big-endian fixed-width encoders. Division/modulo keeps them exact on every
// backend (no reliance on shift width).
def writeBe16(value: Int): List[Int] = List((value / 256) % 256, value % 256)

def writeBe32(value: Int): List[Int] =
  List((value / 16777216) % 256, (value / 65536) % 256, (value / 256) % 256, value % 256)

// Tail-recursive so the interpreter can TCO the large zero-fills (a leaf page's
// free space can be hundreds of bytes); order is irrelevant for zeros.
def writeZerosLoop(count: Int, acc: List[Int]): List[Int] =
  if count <= 0 then acc else writeZerosLoop(count - 1, 0 :: acc)

def writeZeros(count: Int): List[Int] = writeZerosLoop(count, Nil)

/** Bytes of a freshly-created empty SQLite database for `pageSize`.
 *
 *  Byte-identical to reference SQLite's `PRAGMA page_size=N; VACUUM` output:
 *  a page size of 65536 is stored as the special value 1, the cell content
 *  start is the page size (0 for 65536), schema format and text encoding are 0,
 *  and the single page-1 leaf-table B-tree header has zero cells. The result is
 *  the 108 header bytes zero-extended to a full page. */
def emptyDatabase(pageSize: Int): Either[ByteError, ByteSlice] =
  val pageSizeField = if pageSize == 65536 then 1 else pageSize
  val contentStart = if pageSize == 65536 then 0 else pageSize
  val header: List[Int] =
    List(83, 81, 76, 105, 116, 101, 32, 102, 111, 114, 109, 97, 116, 32, 51, 0) ++  // "SQLite format 3\0"
    writeBe16(pageSizeField) ++      // 16-17 page size
    List(1, 1, 0, 64, 32, 32) ++     // 18-23 write/read version, reserved, payload fractions 64/32/32
    writeBe32(1) ++                  // 24-27 file change counter
    writeBe32(1) ++                  // 28-31 database page count
    writeBe32(0) ++                  // 32-35 first freelist trunk page
    writeBe32(0) ++                  // 36-39 freelist page count
    writeBe32(1) ++                  // 40-43 schema cookie
    writeBe32(0) ++                  // 44-47 schema format number (0 = empty database)
    writeBe32(0) ++                  // 48-51 default page cache size
    writeBe32(0) ++                  // 52-55 largest root b-tree page (auto-vacuum)
    writeBe32(0) ++                  // 56-59 text encoding (0 = unset)
    writeBe32(0) ++                  // 60-63 user version
    writeBe32(0) ++                  // 64-67 incremental-vacuum mode
    writeBe32(0) ++                  // 68-71 application id
    writeZeros(20) ++                // 72-91 reserved for expansion
    writeBe32(1) ++                  // 92-95 version-valid-for number
    writeBe32(3053003) ++            // 96-99 SQLite version number (3.53.3)
    List(13, 0, 0, 0, 0) ++          // 100 leaf-table kind, 101-102 first freeblock, 103-104 cell count
    writeBe16(contentStart) ++       // 105-106 cell content area start
    List(0)                          // 107 fragmented free bytes
  ByteSlice.fromList(header) match
    case Left(error) => Left(error)
    case Right(prefix) => byteSliceZeroExtend(prefix, pageSize)

// ── Record encoder — the inverse of `record.ssc`'s decoder ──────────────────

case class EncodedValue(serialType: Long, body: List[Int])

/** One byte of `value`'s two's-complement big-endian representation. */
def recordIntByte(value: Long, index: Int): Int = ((value >> (index * 8)) & 255L).toInt

def recordIntBytes(value: Long, index: Int): List[Int] =
  if index < 0 then Nil else recordIntByte(value, index) :: recordIntBytes(value, index - 1)

/** SQLite integer serial type + big-endian body, matching the reader's
 *  `serialInfo`: 0 and 1 use the storage-class serials 8/9 (zero body bytes),
 *  every other value the narrowest of int8/16/24/32/48/64. */
def encodeInteger(value: Long): EncodedValue =
  if value == 0L then EncodedValue(8L, Nil)
  else if value == 1L then EncodedValue(9L, Nil)
  else if value >= -128L && value <= 127L then EncodedValue(1L, recordIntBytes(value, 0))
  else if value >= -32768L && value <= 32767L then EncodedValue(2L, recordIntBytes(value, 1))
  else if value >= -8388608L && value <= 8388607L then EncodedValue(3L, recordIntBytes(value, 2))
  else if value >= -2147483648L && value <= 2147483647L then EncodedValue(4L, recordIntBytes(value, 3))
  else if value >= -140737488355328L && value <= 140737488355327L then EncodedValue(5L, recordIntBytes(value, 5))
  else EncodedValue(6L, recordIntBytes(value, 7))

// ── IEEE-754 binary64 encoder (inverse of record.ssc's ieeeBinary64) ────────

case class RealNormal(exponent: Int, mantissa: Double)

/** Normalize a positive finite value to `mantissa in [1, 2)` and its base-2
 *  exponent (division/multiplication by 2 is exact, so no bits are lost). */
def normalizeReal(value: Double): RealNormal =
  var mantissa = value
  var exponent = 0
  while mantissa >= 2.0 do
    mantissa = mantissa / 2.0
    exponent = exponent + 1
  while mantissa < 1.0 do
    mantissa = mantissa * 2.0
    exponent = exponent - 1
  RealNormal(exponent, mantissa)

/** Big-endian 8-byte IEEE-754 binary64 of a real, matching what SQLite stores
 *  and the inverse of the reader's `ieeeBinary64`. Handles zero and normal
 *  numbers exactly; subnormals and non-finite values are out of scope (SQLite
 *  reals in stored records are finite). */
def encodeReal(value: Double): List[Int] =
  if value == 0.0 then List(0, 0, 0, 0, 0, 0, 0, 0)
  else
    val sign: Long = if value < 0.0 then 1L else 0L
    val magnitude: Double = if value < 0.0 then 0.0 - value else value
    val normal = normalizeReal(magnitude)
    val biased: Long = (normal.exponent + 1023).toLong
    val fraction: Long = ((normal.mantissa - 1.0) * 4503599627370496.0).toLong  // *2^52
    val bits: Long = (sign << 63) | (biased << 52) | fraction
    recordIntBytes(bits, 7)

/** UTF-8 bytes of one BMP code point (division/modulo → exact on every backend).
 *  Astral characters (surrogate pairs) are a follow-up. */
def utf8CodePoint(codePoint: Int): List[Int] =
  if codePoint < 128 then List(codePoint)
  else if codePoint < 2048 then List(192 + codePoint / 64, 128 + codePoint % 64)
  else List(224 + codePoint / 4096, 128 + (codePoint / 64) % 64, 128 + codePoint % 64)

// Uses `charAt` + `length` (portable to the native tier, unlike `.toList`).
// `charAt(i).toInt` is a UTF-16 code unit — correct for BMP text; astral
// (surrogate pairs) is a follow-up.
def utf8BytesLoop(text: String, index: Int, acc: List[Int]): List[Int] =
  if index >= text.length then acc
  else utf8BytesLoop(text, index + 1, acc ++ utf8CodePoint(text.charAt(index).toInt))

def utf8Bytes(text: String): List[Int] = utf8BytesLoop(text, 0, Nil)

def encodeValue(value: SqliteValue): Either[ByteError, EncodedValue] = value match
  case SqlNull => Right(EncodedValue(0L, Nil))
  case SqlInteger(v) => Right(encodeInteger(v))
  case SqlText(s) =>
    val bytes = utf8Bytes(s)
    Right(EncodedValue(13L + 2L * bytes.length.toLong, bytes))
  case SqlBlob(b) =>
    val bytes = byteSliceToList(b)
    Right(EncodedValue(12L + 2L * bytes.length.toLong, bytes))
  case SqlReal(d) => Right(EncodedValue(7L, encodeReal(d)))

case class EncodedFields(serialBytes: List[Int], body: List[Int])

def encodeFields(values: List[SqliteValue]): Either[ByteError, EncodedFields] = values match
  case Nil => Right(EncodedFields(Nil, Nil))
  case Cons(head, tail) =>
    encodeValue(head) match
      case Left(error) => Left(error)
      case Right(encoded) =>
        encodeFields(tail) match
          case Left(error) => Left(error)
          case Right(rest) =>
            val serial = byteSliceToList(encodeVarint(encoded.serialType))
            Right(EncodedFields(serial ++ rest.serialBytes, encoded.body ++ rest.body))

/** Total header length (its own varint + the serial-type varints), matching
 *  SQLite's self-describing record header. */
def recordHeaderLength(serialLength: Int): Int =
  if 1 + serialLength < 128 then 1 + serialLength
  else if 2 + serialLength < 16384 then 2 + serialLength
  else 3 + serialLength

/** Serialize a record: `varint(headerLen) ++ serial-type varints ++ body`,
 *  byte-identical to what SQLite writes and the inverse of `decodeRecord`. */
def encodeRecord(values: List[SqliteValue]): Either[ByteError, ByteSlice] =
  encodeFields(values) match
    case Left(error) => Left(error)
    case Right(fields) =>
      val headerLen = recordHeaderLength(fields.serialBytes.length)
      val record = byteSliceToList(encodeVarint(headerLen.toLong)) ++ fields.serialBytes ++ fields.body
      ByteSlice.fromList(record)

// ── Table-leaf page + single-table database assembly (m3c) ──────────────────

/** A table-leaf cell (no overflow): `varint(payloadLen) ++ varint(rowid) ++ record`. */
def encodeTableLeafCell(rowid: Long, record: ByteSlice): List[Int] =
  val recordBytes = byteSliceToList(record)
  byteSliceToList(encodeVarint(recordBytes.length.toLong)) ++
    byteSliceToList(encodeVarint(rowid)) ++ recordBytes

def cellsTotal(cells: List[List[Int]]): Int = cells match
  case Nil => 0
  case Cons(cell, tail) => cell.length + cellsTotal(tail)

// Iterative (not `cell ++ cellsFlatten(tail)`): the recursive form grows the
// stack with the number of pages, which overflows for tables with many leaves
// (e.g. large-value rows at ~1 row/leaf). Prepend every byte then reverse once —
// O(n), no recursion. Uniquely-named vars dodge the interpreter var-scope leak
// (BUGS.md interp-var-scope-leak-across-calls).
def cellsFlatten(cells: List[List[Int]]): List[Int] =
  var cfCells = cells
  var cfReversed: List[Int] = Nil
  while cfCells.nonEmpty do
    var cfCell = cfCells.head
    while cfCell.nonEmpty do
      cfReversed = cfCell.head :: cfReversed
      cfCell = cfCell.tail
    cfCells = cfCells.tail
  cfReversed.reverse

/** Big-endian u16 pointers to each cell, placed in order from `offset` upward. */
def cellPointers(cells: List[List[Int]], offset: Int): List[Int] = cells match
  case Nil => Nil
  case Cons(cell, tail) => writeBe16(offset) ++ cellPointers(tail, offset + cell.length)

/** Bytes of a table-leaf B-tree page after `headerOffset` (100 on page 1, else 0):
 *  8-byte leaf header, the cell pointer array in key order, free space, then the
 *  cell content area growing down from the page end. Cells must be in key order
 *  and fit on the page (no overflow / split — that is m3d). */
def buildTableLeafPage(pageSize: Int, headerOffset: Int, cells: List[List[Int]]): Either[ByteError, List[Int]] =
  val count = cells.length
  val total = cellsTotal(cells)
  val contentStart = pageSize - total
  val gap = contentStart - (headerOffset + 8 + 2 * count)
  if gap < 0 then Left(ByteError("overflow", "leaf page cells do not fit (needs a split — m3d)", 0))
  else
    val csField = if contentStart == 65536 then 0 else contentStart
    val header = List(13, 0, 0) ++ writeBe16(count) ++ writeBe16(csField) ++ List(0)
    Right(header ++ cellPointers(cells, contentStart) ++ writeZeros(gap) ++ cellsFlatten(cells))

/** The 100-byte file header for a rowid-table database: schema format 4, UTF-8
 *  encoding, trusted page count. `changeCounter`/`schemaCookie` are supplied by
 *  the caller (they depend on the write sequence, which the pager owns in m3e). */
def tableFileHeader(pageSize: Int, pageCount: Int, changeCounter: Int, schemaCookie: Int): List[Int] =
  val pageSizeField = if pageSize == 65536 then 1 else pageSize
  List(83, 81, 76, 105, 116, 101, 32, 102, 111, 114, 109, 97, 116, 32, 51, 0) ++
  writeBe16(pageSizeField) ++
  List(1, 1, 0, 64, 32, 32) ++
  writeBe32(changeCounter) ++       // 24-27 change counter
  writeBe32(pageCount) ++           // 28-31 page count
  writeBe32(0) ++ writeBe32(0) ++   // 32-39 freelist head + count
  writeBe32(schemaCookie) ++        // 40-43 schema cookie
  writeBe32(4) ++                   // 44-47 schema format 4
  writeBe32(0) ++ writeBe32(0) ++   // 48-55 default cache + largest root
  writeBe32(1) ++                   // 56-59 text encoding = UTF-8
  writeBe32(0) ++ writeBe32(0) ++ writeBe32(0) ++  // 60-71 user version, incr-vacuum, app id
  writeZeros(20) ++                 // 72-91 reserved
  writeBe32(changeCounter) ++       // 92-95 version-valid-for (= change counter → trusted page count)
  writeBe32(3053003)                // 96-99 SQLite version number

def encodeRowCells(rows: List[List[SqliteValue]], rowid: Long): Either[ByteError, List[List[Int]]] = rows match
  case Nil => Right(Nil)
  case Cons(row, tail) =>
    encodeRecord(row) match
      case Left(error) => Left(error)
      case Right(record) =>
        encodeRowCells(tail, rowid + 1L) match
          case Left(error) => Left(error)
          case Right(rest) => Right(encodeTableLeafCell(rowid, record) :: rest)

/** Assemble a two-page single rowid-table database: page 1 is `sqlite_schema`
 *  (one `CREATE TABLE` entry with root page 2), page 2 is the table root holding
 *  `rows` (auto rowids 1..n). Both must fit on one page. The result is a legal
 *  SQLite file that reference `integrity_check` accepts. */
def buildSingleTableDatabase(pageSize: Int, changeCounter: Int, schemaCookie: Int,
    tableName: String, createSql: String, rows: List[List[SqliteValue]]): Either[ByteError, ByteSlice] =
  val schemaValues = List(SqlText("table"), SqlText(tableName), SqlText(tableName),
    SqlInteger(2L), SqlText(createSql))
  encodeRecord(schemaValues) match
    case Left(error) => Left(error)
    case Right(schemaRecord) =>
      encodeRowCells(rows, 1L) match
        case Left(error) => Left(error)
        case Right(rowCells) =>
          buildTableLeafPage(pageSize, 100, List(encodeTableLeafCell(1L, schemaRecord))) match
            case Left(error) => Left(error)
            case Right(page1Body) =>
              buildTableLeafPage(pageSize, 0, rowCells) match
                case Left(error) => Left(error)
                case Right(page2Body) =>
                  val page1 = tableFileHeader(pageSize, 2, changeCounter, schemaCookie) ++ page1Body
                  ByteSlice.fromList(page1 ++ page2Body)

// ── Cell overflow (m3d follow-up: payloads larger than the leaf local threshold) ──
//
// A record whose serialized length P exceeds the table-leaf local threshold X is
// stored as `local bytes ++ u32(firstOverflowPage)` inside the cell, with the
// remainder spilled onto a chain of overflow pages `[u32 nextPage][content]`
// (content capacity `usableSize - 4`, last page `nextPage == 0`). `local` is the
// same SQLite formula the reader uses (page.ssc `localPayloadBytes`), so a written
// overflow cell round-trips through the read path and passes `integrity_check`.

case class OverflowCell(cell: List[Int], overflowPages: List[List[Int]])
case class OverflowRows(cells: List[List[Int]], overflowPages: List[List[Int]])

/** SQLite table-leaf local-payload size: how many bytes of a `payload`-byte
 *  record stay in the cell before spilling to overflow. Mirrors the reader. */
def tableLeafLocalBytes(usableSize: Int, payload: Int): Int =
  val m = (usableSize - 12) * 32 / 255 - 23
  val x = usableSize - 35
  if payload <= x then payload
  else
    val k = m + (payload - m) % (usableSize - 4)
    if k <= x then k else m

/** Chain `content` onto overflow pages numbered `page`, `page+1`, … Each full
 *  page is `[u32 nextPage][usableSize-4 content bytes]`; the final page carries
 *  `nextPage == 0` and is zero-padded to `pageSize`. */
def buildOverflowPages(content: List[Int], pageSize: Int, usableSize: Int, page: Int): List[List[Int]] =
  val capacity = usableSize - 4
  if content.length <= capacity then
    List(byteSliceToList(writeU32Be(0L)) ++ content ++ writeZeros(pageSize - 4 - content.length))
  else
    val chunk = content.take(capacity)
    (byteSliceToList(writeU32Be((page + 1).toLong)) ++ chunk) ::
      buildOverflowPages(content.drop(capacity), pageSize, usableSize, page + 1)

/** Encode one table-leaf cell, spilling to an overflow chain rooted at
 *  `firstOverflowPage` when the record exceeds the local threshold. */
def encodeOverflowCell(rowid: Long, record: List[Int], pageSize: Int, usableSize: Int, firstOverflowPage: Int): OverflowCell =
  val payload = record.length
  val local = tableLeafLocalBytes(usableSize, payload)
  if payload <= local then
    OverflowCell(byteSliceToList(encodeVarint(payload.toLong)) ++ byteSliceToList(encodeVarint(rowid)) ++ record, Nil)
  else
    val pages = buildOverflowPages(record.drop(local), pageSize, usableSize, firstOverflowPage)
    val cell = byteSliceToList(encodeVarint(payload.toLong)) ++ byteSliceToList(encodeVarint(rowid)) ++
      record.take(local) ++ byteSliceToList(writeU32Be(firstOverflowPage.toLong))
    OverflowCell(cell, pages)

// Prepend `pages` (in order) onto `acc`, leaving `acc` in reverse-of-input order;
// a later single `reverse` restores forward order across all rows.
def prependOverflowPages(pages: List[List[Int]], acc: List[List[Int]]): List[List[Int]] = pages match
  case Nil => acc
  case Cons(page, tail) => prependOverflowPages(tail, page :: acc)

/** Encode all rows into leaf cells + a flat, page-numbered overflow chain.
 *  Overflow pages are allocated consecutively from `startPage`. A `while`+`var`
 *  loop (not recursion) so a large row set cannot overflow the stack. */
def encodeOverflowRows(rows: List[List[SqliteValue]], pageSize: Int, usableSize: Int, startPage: Int): Either[ByteError, OverflowRows] =
  var remaining = rows
  var rowid = 1L
  var nextPage = startPage
  var cellsRev: List[List[Int]] = Nil
  var pagesRev: List[List[Int]] = Nil
  var failure: Option[ByteError] = None
  while remaining.nonEmpty && failure.isEmpty do
    encodeRecord(remaining.head) match
      case Left(error) => failure = Some(error)
      case Right(recordSlice) =>
        val cell = encodeOverflowCell(rowid, byteSliceToList(recordSlice), pageSize, usableSize, nextPage)
        cellsRev = cell.cell :: cellsRev
        pagesRev = prependOverflowPages(cell.overflowPages, pagesRev)
        nextPage = nextPage + cell.overflowPages.length
        rowid = rowid + 1L
        remaining = remaining.tail
  failure match
    case Some(error) => Left(error)
    case None => Right(OverflowRows(cellsRev.reverse, pagesRev.reverse))

/** Like `buildSingleTableDatabase`, but rows whose serialized record exceeds the
 *  leaf local threshold spill onto overflow pages (page 1 = schema, page 2 = table
 *  leaf, pages 3..N = the overflow chains). The result passes reference
 *  `integrity_check` and reads back byte-exact. Small-row inputs are byte-identical
 *  to `buildSingleTableDatabase`.
 *
 *  Single-leaf only: an overflow cell still keeps a local portion (up to the X
 *  threshold, ~477 bytes on a 512-byte page) on the table leaf, so the local
 *  portions of all rows must together fit one page. When they do not, the leaf
 *  builder returns "leaf page cells do not fit (needs a split — m3d)". Combining
 *  overflow with multi-leaf packing is a follow-up on `buildTableDatabase`. */
def buildOverflowTableDatabase(pageSize: Int, changeCounter: Int, schemaCookie: Int,
    tableName: String, createSql: String, rows: List[List[SqliteValue]]): Either[ByteError, ByteSlice] =
  val usableSize = pageSize
  val schemaValues = List(SqlText("table"), SqlText(tableName), SqlText(tableName),
    SqlInteger(2L), SqlText(createSql))
  encodeRecord(schemaValues) match
    case Left(error) => Left(error)
    case Right(schemaRecord) =>
      encodeOverflowRows(rows, pageSize, usableSize, 3) match
        case Left(error) => Left(error)
        case Right(overflow) =>
          buildTableLeafPage(pageSize, 100, List(encodeTableLeafCell(1L, schemaRecord))) match
            case Left(error) => Left(error)
            case Right(page1Body) =>
              buildTableLeafPage(pageSize, 0, overflow.cells) match
                case Left(error) => Left(error)
                case Right(page2Body) =>
                  val pageCount = 2 + overflow.overflowPages.length
                  val page1 = tableFileHeader(pageSize, pageCount, changeCounter, schemaCookie) ++ page1Body
                  ByteSlice.fromList(page1 ++ page2Body ++ cellsFlatten(overflow.overflowPages))

// ── Multi-page rowid-table B-tree (m3d: balancing via bottom-up bulk build) ──

case class RowCell(rowid: Long, bytes: List[Int])
case class LeafPlan(cells: List[List[Int]], maxRowid: Long)

// A `while` loop (not recursion) for uniformity with `packLeaves` below, whose
// natural formulation is not tail-recursive. (A tail-recursive accumulator would
// also work here — the interpreter does TCO tail self-calls, including inside a
// `match`.)
def encodeRowCellsWithRowid(rows: List[List[SqliteValue]], startRowid: Long): Either[ByteError, List[RowCell]] =
  var remaining = rows
  var rowid = startRowid
  var acc: List[RowCell] = Nil
  var failure: Option[ByteError] = None
  while remaining.nonEmpty && failure.isEmpty do
    encodeRecord(remaining.head) match
      case Left(error) => failure = Some(error)
      case Right(record) =>
        acc = RowCell(rowid, encodeTableLeafCell(rowid, record)) :: acc
        rowid = rowid + 1L
        remaining = remaining.tail
  failure match
    case Some(error) => Left(error)
    case None => Right(acc.reverse)

/** Greedily pack row cells (in rowid order) into leaf pages, each filled until
 *  the next cell would exceed the page. A `while` loop because the natural
 *  recursive form is not tail-recursive (it prepends a finalized leaf and then
 *  continues), so it would grow the stack with the number of rows.
 *  Assumes each cell fits on a page (no cell overflow — a separate follow-up). */
def packLeaves(cells: List[RowCell], pageSize: Int): List[LeafPlan] =
  var remaining = cells
  var curRev: List[List[Int]] = Nil
  var curBytes = 0
  var curCount = 0
  var curMax = 0L
  var leaves: List[LeafPlan] = Nil
  while remaining.nonEmpty do
    val rc = remaining.head
    val used = 8 + 2 * (curCount + 1) + curBytes + rc.bytes.length
    if used <= pageSize || curCount == 0 then
      curRev = rc.bytes :: curRev
      curBytes = curBytes + rc.bytes.length
      curCount = curCount + 1
      curMax = rc.rowid
      remaining = remaining.tail
    else
      leaves = LeafPlan(curRev.reverse, curMax) :: leaves
      curRev = Nil
      curBytes = 0
      curCount = 0
      curMax = 0L
  // NB: a bare post-`while` `if cond then stmt` (no else) is mis-evaluated by the
  // interpreter (see BUGS.md scljet-if-then-no-else-after-while) — use an
  // if/else expression to finalize the last partial leaf.
  val allLeaves = if curCount > 0 then LeafPlan(curRev.reverse, curMax) :: leaves else leaves
  allLeaves.reverse

// Iterative for the same reason as `cellsFlatten`: recursion depth = leaf count,
// which overflows for many-leaf tables. Uniquely-named vars dodge the interpreter
// var-scope leak (BUGS.md interp-var-scope-leak-across-calls).
def buildLeafPages(leaves: List[LeafPlan], pageSize: Int): Either[ByteError, List[List[Int]]] =
  var blRemaining = leaves
  var blAcc: List[List[Int]] = Nil
  var blFailure: Option[ByteError] = None
  while blRemaining.nonEmpty && blFailure.isEmpty do
    buildTableLeafPage(pageSize, 0, blRemaining.head.cells) match
      case Left(error) => blFailure = Some(error)
      case Right(body) => blAcc = body :: blAcc
    blRemaining = blRemaining.tail
  blFailure match
    case Some(error) => Left(error)
    case None => Right(blAcc.reverse)

/** A table interior cell: `u32(leftChildPage) ++ varint(rowidKey)`. */
def encodeInteriorCell(childPage: Int, rowid: Long): List[Int] =
  writeBe32(childPage) ++ byteSliceToList(encodeVarint(rowid))

/** Divider cells for every leaf except the last (which becomes the rightmost
 *  child); each key is that leaf's maximum rowid. */
def interiorDividers(leaves: List[LeafPlan], page: Int): List[List[Int]] = leaves match
  case Nil => Nil
  case Cons(leaf, Nil) => Nil
  case Cons(leaf, tail) => encodeInteriorCell(page, leaf.maxRowid) :: interiorDividers(tail, page + 1)

/** A table-interior B-tree page (12-byte header with the rightmost child). */
def buildTableInteriorPage(pageSize: Int, headerOffset: Int, cells: List[List[Int]], rightChild: Int): Either[ByteError, List[Int]] =
  val count = cells.length
  val total = cellsTotal(cells)
  val contentStart = pageSize - total
  val gap = contentStart - (headerOffset + 12 + 2 * count)
  if gap < 0 then Left(ByteError("overflow", "interior page cells do not fit (needs another level — m3d+)", 0))
  else
    val csField = if contentStart == 65536 then 0 else contentStart
    val header = List(5, 0, 0) ++ writeBe16(count) ++ writeBe16(csField) ++ List(0) ++ writeBe32(rightChild)
    Right(header ++ cellPointers(cells, contentStart) ++ writeZeros(gap) ++ cellsFlatten(cells))

/** Assemble a rowid-table database that may span many pages: page 1 is
 *  `sqlite_schema`, page 2 is the table root. Rows are bulk-loaded bottom-up —
 *  when they overflow one leaf, page 2 becomes a table-interior root over the
 *  leaves on pages 3..N. Generalizes `buildSingleTableDatabase`; produces a
 *  file reference `integrity_check` accepts. Deep (3+ level) trees and cell
 *  overflow are follow-ups. */
def buildTableDatabase(pageSize: Int, changeCounter: Int, schemaCookie: Int,
    tableName: String, createSql: String, rows: List[List[SqliteValue]]): Either[ByteError, ByteSlice] =
  val schemaValues = List(SqlText("table"), SqlText(tableName), SqlText(tableName),
    SqlInteger(2L), SqlText(createSql))
  encodeRecord(schemaValues) match
    case Left(error) => Left(error)
    case Right(schemaRecord) =>
      encodeRowCellsWithRowid(rows, 1L) match
        case Left(error) => Left(error)
        case Right(rowCells) =>
          val leaves = packLeaves(rowCells, pageSize)
          buildTableLeafPage(pageSize, 100, List(encodeTableLeafCell(1L, schemaRecord))) match
            case Left(error) => Left(error)
            case Right(page1Body) =>
              if leaves.length <= 1 then
                val leafCells = leaves match
                  case Nil => Nil
                  case Cons(leaf, _) => leaf.cells
                buildTableLeafPage(pageSize, 0, leafCells) match
                  case Left(error) => Left(error)
                  case Right(page2Body) =>
                    val page1 = tableFileHeader(pageSize, 2, changeCounter, schemaCookie) ++ page1Body
                    ByteSlice.fromList(page1 ++ page2Body)
              else
                buildLeafPages(leaves, pageSize) match
                  case Left(error) => Left(error)
                  case Right(leafPages) =>
                    val rightChild = 2 + leaves.length
                    buildTableInteriorPage(pageSize, 0, interiorDividers(leaves, 3), rightChild) match
                      case Left(error) => Left(error)
                      case Right(interiorBody) =>
                        val page1 = tableFileHeader(pageSize, 2 + leaves.length, changeCounter, schemaCookie) ++ page1Body
                        ByteSlice.fromList(page1 ++ interiorBody ++ cellsFlatten(leafPages))

// ── Multi-leaf B-tree WITH cell overflow (m3d follow-up (2)) ──
//
// Generalizes `buildOverflowTableDatabase` past a single leaf: rows are packed
// into leaves (and, on overflow, a table-interior root) exactly as
// `buildTableDatabase`, and any cell whose record exceeds the local threshold
// spills onto an overflow chain. An overflow cell's LEAF footprint is
// `local + 4-byte pointer`, which is independent of the pointer VALUE, so the
// leaf/interior layout can be fixed before the overflow pages are numbered.

case class OverflowBtreeRows(cells: List[RowCell], overflowPages: List[List[Int]])

/** Encode rows into leaf `RowCell`s (rowid-tagged for packing) plus a flat,
 *  page-numbered overflow chain rooted at `startPage`. `while`+`var` so a large
 *  row set never grows the stack. */
def encodeOverflowRowCells(rows: List[List[SqliteValue]], startRowid: Long, pageSize: Int, usableSize: Int, startPage: Int): Either[ByteError, OverflowBtreeRows] =
  var remaining = rows
  var rowid = startRowid
  var nextPage = startPage
  var cellsRev: List[RowCell] = Nil
  var pagesRev: List[List[Int]] = Nil
  var failure: Option[ByteError] = None
  while remaining.nonEmpty && failure.isEmpty do
    encodeRecord(remaining.head) match
      case Left(error) => failure = Some(error)
      case Right(recordSlice) =>
        val cell = encodeOverflowCell(rowid, byteSliceToList(recordSlice), pageSize, usableSize, nextPage)
        cellsRev = RowCell(rowid, cell.cell) :: cellsRev
        pagesRev = prependOverflowPages(cell.overflowPages, pagesRev)
        nextPage = nextPage + cell.overflowPages.length
        rowid = rowid + 1L
        remaining = remaining.tail
  failure match
    case Some(error) => Left(error)
    case None => Right(OverflowBtreeRows(cellsRev.reverse, pagesRev.reverse))

/** Like `buildTableDatabase`, but records larger than the leaf local threshold
 *  spill onto overflow-page chains. Page layout: page 1 = schema, page 2 = table
 *  root (leaf if it all fits one page, else a table-interior over leaves on
 *  pages 3..2+L), then the overflow chains on pages 3+L..N. Byte-verified against
 *  reference `integrity_check`; reads back exact. Non-overflowing inputs are
 *  byte-identical to `buildTableDatabase`. (Trees deeper than two levels are still
 *  a follow-up — a very large row set fails in `buildTableInteriorPage`.) */
def buildOverflowBtreeDatabase(pageSize: Int, changeCounter: Int, schemaCookie: Int,
    tableName: String, createSql: String, rows: List[List[SqliteValue]]): Either[ByteError, ByteSlice] =
  val usableSize = pageSize
  val schemaValues = List(SqlText("table"), SqlText(tableName), SqlText(tableName),
    SqlInteger(2L), SqlText(createSql))
  encodeRecord(schemaValues) match
    case Left(error) => Left(error)
    case Right(schemaRecord) =>
      // Pass 1: placeholder cells (pointer value irrelevant) fix the leaf count L.
      encodeOverflowRowCells(rows, 1L, pageSize, usableSize, 0) match
        case Left(error) => Left(error)
        case Right(probe) =>
          val leafCount = packLeaves(probe.cells, pageSize).length
          val overflowStart = if leafCount <= 1 then 3 else 3 + leafCount
          // Pass 2: real cells + overflow chains numbered from overflowStart.
          encodeOverflowRowCells(rows, 1L, pageSize, usableSize, overflowStart) match
            case Left(error) => Left(error)
            case Right(built) =>
              val leaves = packLeaves(built.cells, pageSize)
              buildTableLeafPage(pageSize, 100, List(encodeTableLeafCell(1L, schemaRecord))) match
                case Left(error) => Left(error)
                case Right(page1Body) =>
                  if leaves.length <= 1 then
                    val leafCells = leaves match
                      case Nil => Nil
                      case Cons(leaf, _) => leaf.cells
                    buildTableLeafPage(pageSize, 0, leafCells) match
                      case Left(error) => Left(error)
                      case Right(page2Body) =>
                        val pageCount = 2 + built.overflowPages.length
                        val page1 = tableFileHeader(pageSize, pageCount, changeCounter, schemaCookie) ++ page1Body
                        ByteSlice.fromList(page1 ++ page2Body ++ cellsFlatten(built.overflowPages))
                  else
                    buildLeafPages(leaves, pageSize) match
                      case Left(error) => Left(error)
                      case Right(leafPages) =>
                        val rightChild = 2 + leaves.length
                        buildTableInteriorPage(pageSize, 0, interiorDividers(leaves, 3), rightChild) match
                          case Left(error) => Left(error)
                          case Right(interiorBody) =>
                            val pageCount = 2 + leaves.length + built.overflowPages.length
                            val page1 = tableFileHeader(pageSize, pageCount, changeCounter, schemaCookie) ++ page1Body
                            ByteSlice.fromList(page1 ++ interiorBody ++ cellsFlatten(leafPages) ++ cellsFlatten(built.overflowPages))

// ── Arbitrary-depth rowid-table B-tree (m3d follow-up (3): 3+ levels) ──
//
// `buildTableDatabase` stops at two levels — one interior root over the leaves —
// and fails once the dividers no longer fit a single page. This builds the tree
// bottom-up to ANY depth: leaves, then interior levels over them, until one page
// (the root) remains. Pages are numbered top-down (root = 2, then each interior
// level, then the leaves last) so a node's children always sit in a contiguous,
// already-known page range.

case class InteriorPlan(firstChild: Int, childMaxRowids: List[Long], maxRowid: Long)

def varintLen(value: Long): Int = encodeVarint(value).length

/** Extract each leaf's / interior node's max rowid (iteratively — the node lists
 *  can be long). */
def leafMaxRowids(leaves: List[LeafPlan]): List[Long] =
  var remaining = leaves
  var acc: List[Long] = Nil
  while remaining.nonEmpty do
    acc = remaining.head.maxRowid :: acc
    remaining = remaining.tail
  acc.reverse

def interiorMaxRowids(nodes: List[InteriorPlan]): List[Long] =
  var remaining = nodes
  var acc: List[Long] = Nil
  while remaining.nonEmpty do
    acc = remaining.head.maxRowid :: acc
    remaining = remaining.tail
  acc.reverse

/** Greedily group a level's children (given each child's max rowid, in order)
 *  into interior pages. A group of `m` children holds `m-1` divider cells
 *  (`4-byte child ++ varint(rowid)`, `+2` pointer) plus the 12-byte header with
 *  the rightmost child — the exact fit test `buildTableInteriorPage` applies, so
 *  every produced page fits. A `while` loop (not recursion) over the children. */
def packInterior(childMaxRowids: List[Long], pageSize: Int): List[InteriorPlan] =
  var remaining = childMaxRowids
  var index = 0
  var groupStart = 0
  var groupRowidsRev: List[Long] = Nil
  var groupCount = 0
  var groupSize = 12
  var groupsRev: List[InteriorPlan] = Nil
  while remaining.nonEmpty do
    val rowid = remaining.head
    if groupCount == 0 then
      groupRowidsRev = rowid :: Nil
      groupCount = 1
      groupStart = index
      groupSize = 12
    else
      val prevLast = groupRowidsRev.head
      val newSize = groupSize + 6 + varintLen(prevLast)
      if newSize <= pageSize then
        groupRowidsRev = rowid :: groupRowidsRev
        groupCount = groupCount + 1
        groupSize = newSize
      else
        groupsRev = InteriorPlan(groupStart, groupRowidsRev.reverse, prevLast) :: groupsRev
        groupRowidsRev = rowid :: Nil
        groupCount = 1
        groupStart = index
        groupSize = 12
    index = index + 1
    remaining = remaining.tail
  // Close the final pending group with an if/else EXPRESSION (see BUGS.md
  // scljet-if-then-no-else-after-while).
  val groups = if groupCount > 0 then InteriorPlan(groupStart, groupRowidsRev.reverse, groupRowidsRev.head) :: groupsRev else groupsRev
  groups.reverse

/** Divider cells for one interior page: every child except the last (the
 *  rightmost, carried in the header). Child `k` sits on page
 *  `childStart + firstChild + k` and its divider key is that child's max rowid. */
def buildInteriorDividers(childStart: Int, firstChild: Int, childMaxRowids: List[Long]): List[List[Int]] =
  val bidLast = childMaxRowids.length - 1
  var bidRemaining = childMaxRowids
  var bidK = 0
  var bidAcc: List[List[Int]] = Nil
  while bidRemaining.nonEmpty do
    bidAcc = if bidK == bidLast then bidAcc else encodeInteriorCell(childStart + firstChild + bidK, bidRemaining.head) :: bidAcc
    bidK = bidK + 1
    bidRemaining = bidRemaining.tail
  bidAcc.reverse

/** Build the page bodies for one interior level; its children begin at page
 *  `childStart`. */
def buildInteriorLevelPages(level: List[InteriorPlan], childStart: Int, pageSize: Int): Either[ByteError, List[List[Int]]] =
  var ilRemaining = level
  var ilAcc: List[List[Int]] = Nil
  var ilFailure: Option[ByteError] = None
  while ilRemaining.nonEmpty && ilFailure.isEmpty do
    val ilNode = ilRemaining.head
    val ilDividers = buildInteriorDividers(childStart, ilNode.firstChild, ilNode.childMaxRowids)
    val ilRightmost = childStart + ilNode.firstChild + ilNode.childMaxRowids.length - 1
    buildTableInteriorPage(pageSize, 0, ilDividers, ilRightmost) match
      case Left(error) => ilFailure = Some(error)
      case Right(body) => ilAcc = body :: ilAcc
    ilRemaining = ilRemaining.tail
  ilFailure match
    case Some(error) => Left(error)
    case None => Right(ilAcc.reverse)

/** Build every interior level's pages in top-down order. `startPage` is where the
 *  head (top) level begins; its children start immediately after it, which is
 *  also the next level's start — so recursion threads the page numbers. */
def buildInteriorLevels(levels: List[List[InteriorPlan]], startPage: Int, pageSize: Int): Either[ByteError, List[List[Int]]] = levels match
  case Nil => Right(Nil)
  case Cons(level, tail) =>
    val childStart = startPage + level.length
    buildInteriorLevelPages(level, childStart, pageSize) match
      case Left(error) => Left(error)
      case Right(thisPages) =>
        buildInteriorLevels(tail, childStart, pageSize) match
          case Left(error) => Left(error)
          case Right(rest) => Right(thisPages ++ rest)

def totalInteriorPages(levels: List[List[InteriorPlan]]): Int =
  var remaining = levels
  var total = 0
  while remaining.nonEmpty do
    total = total + remaining.head.length
    remaining = remaining.tail
  total

/** Assemble a rowid-table database of ANY B-tree depth. Two levels reduce to the
 *  exact bytes `buildTableDatabase` produces; beyond that, interior levels stack
 *  until a single-page root. Byte-verified against reference `integrity_check`.
 *  (Cell overflow is orthogonal — combine via `buildOverflowBtreeDatabase` for a
 *  shallow tree; deep + overflow together is a further follow-up.) */
def buildDeepTableDatabase(pageSize: Int, changeCounter: Int, schemaCookie: Int,
    tableName: String, createSql: String, rows: List[List[SqliteValue]]): Either[ByteError, ByteSlice] =
  val schemaValues = List(SqlText("table"), SqlText(tableName), SqlText(tableName),
    SqlInteger(2L), SqlText(createSql))
  encodeRecord(schemaValues) match
    case Left(error) => Left(error)
    case Right(schemaRecord) =>
      encodeRowCellsWithRowid(rows, 1L) match
        case Left(error) => Left(error)
        case Right(rowCells) =>
          val leaves = packLeaves(rowCells, pageSize)
          buildTableLeafPage(pageSize, 100, List(encodeTableLeafCell(1L, schemaRecord))) match
            case Left(error) => Left(error)
            case Right(page1Body) =>
              if leaves.length <= 1 then
                val leafCells = leaves match
                  case Nil => Nil
                  case Cons(leaf, _) => leaf.cells
                buildTableLeafPage(pageSize, 0, leafCells) match
                  case Left(error) => Left(error)
                  case Right(page2Body) =>
                    val page1 = tableFileHeader(pageSize, 2, changeCounter, schemaCookie) ++ page1Body
                    ByteSlice.fromList(page1 ++ page2Body)
              else
                var levels: List[List[InteriorPlan]] = Nil
                var childRowids = leafMaxRowids(leaves)
                while childRowids.length > 1 do
                  val level = packInterior(childRowids, pageSize)
                  levels = level :: levels
                  childRowids = interiorMaxRowids(level)
                val interiorCount = totalInteriorPages(levels)
                buildInteriorLevels(levels, 2, pageSize) match
                  case Left(error) => Left(error)
                  case Right(interiorBodies) =>
                    buildLeafPages(leaves, pageSize) match
                      case Left(error) => Left(error)
                      case Right(leafBodies) =>
                        val pageCount = 1 + interiorCount + leaves.length
                        val page1 = tableFileHeader(pageSize, pageCount, changeCounter, schemaCookie) ++ page1Body
                        ByteSlice.fromList(page1 ++ cellsFlatten(interiorBodies) ++ cellsFlatten(leafBodies))

// ── Deep tree WITH cell overflow (full matrix: 3+ levels AND overflow chains) ──

case class TreeBodies(interiorBodies: List[List[Int]], leafBodies: List[List[Int]], treePages: Int)

/** How many B-tree pages (interior + leaves) a multi-leaf table occupies, without
 *  materializing them — used to place overflow pages after the whole tree. */
def treePageCount(leaves: List[LeafPlan], pageSize: Int): Int =
  if leaves.length <= 1 then 1
  else
    var tpcLevels: List[List[InteriorPlan]] = Nil
    var tpcRowids = leafMaxRowids(leaves)
    while tpcRowids.length > 1 do
      val tpcLevel = packInterior(tpcRowids, pageSize)
      tpcLevels = tpcLevel :: tpcLevels
      tpcRowids = interiorMaxRowids(tpcLevel)
    totalInteriorPages(tpcLevels) + leaves.length

/** Build the interior-level + leaf page bodies for a multi-leaf tree (root on
 *  page 2). Overflow-independent: a leaf cell's overflow pointer is part of its
 *  bytes, not of the tree shape, so the same tree serves overflow and non-overflow
 *  cells. */
def buildTreeBodies(leaves: List[LeafPlan], pageSize: Int): Either[ByteError, TreeBodies] =
  var tbLevels: List[List[InteriorPlan]] = Nil
  var tbRowids = leafMaxRowids(leaves)
  while tbRowids.length > 1 do
    val tbLevel = packInterior(tbRowids, pageSize)
    tbLevels = tbLevel :: tbLevels
    tbRowids = interiorMaxRowids(tbLevel)
  val tbInteriorCount = totalInteriorPages(tbLevels)
  buildInteriorLevels(tbLevels, 2, pageSize) match
    case Left(error) => Left(error)
    case Right(interiorBodies) =>
      buildLeafPages(leaves, pageSize) match
        case Left(error) => Left(error)
        case Right(leafBodies) => Right(TreeBodies(interiorBodies, leafBodies, tbInteriorCount + leaves.length))

/** The full matrix: a rowid-table B-tree of ANY depth whose oversized records
 *  ALSO spill onto overflow-page chains. Layout: page 1 = schema, pages 2..1+T =
 *  the tree (leaf if it all fits one page, else interior levels over leaves),
 *  then the overflow chains on pages 2+T..N. A two-pass build fixes the tree shape
 *  from placeholder cells, then numbers the overflow pages from 2+T. Byte-verified
 *  against reference `integrity_check`; reads back exact. */
def buildDeepOverflowTableDatabase(pageSize: Int, changeCounter: Int, schemaCookie: Int,
    tableName: String, createSql: String, rows: List[List[SqliteValue]]): Either[ByteError, ByteSlice] =
  val usableSize = pageSize
  val schemaValues = List(SqlText("table"), SqlText(tableName), SqlText(tableName),
    SqlInteger(2L), SqlText(createSql))
  encodeRecord(schemaValues) match
    case Left(error) => Left(error)
    case Right(schemaRecord) =>
      // Pass 1: placeholder overflow pointers fix leaf packing + tree shape.
      encodeOverflowRowCells(rows, 1L, pageSize, usableSize, 0) match
        case Left(error) => Left(error)
        case Right(probe) =>
          val probeLeaves = packLeaves(probe.cells, pageSize)
          val overflowStart = 2 + treePageCount(probeLeaves, pageSize)
          // Pass 2: real overflow pages numbered after the whole tree.
          encodeOverflowRowCells(rows, 1L, pageSize, usableSize, overflowStart) match
            case Left(error) => Left(error)
            case Right(built) =>
              val leaves = packLeaves(built.cells, pageSize)
              assembleOverflowTree(pageSize, changeCounter, schemaCookie, schemaRecord, leaves, built.overflowPages)

// ── Assemble a tree (leaf/interior) + trailing overflow chains from packed leaves. ──
//
// Shared by the deep-overflow and keyed writers: page 1 = schema, pages 2..1+T =
// the tree (a single leaf, or interior levels over leaves), then the overflow
// chains on 2+T..N.
def assembleOverflowTree(pageSize: Int, changeCounter: Int, schemaCookie: Int,
    schemaRecord: ByteSlice, leaves: List[LeafPlan], overflowPages: List[List[Int]]): Either[ByteError, ByteSlice] =
  buildTableLeafPage(pageSize, 100, List(encodeTableLeafCell(1L, schemaRecord))) match
    case Left(error) => Left(error)
    case Right(page1Body) =>
      if leaves.length <= 1 then
        val leafCells = leaves match
          case Nil => Nil
          case Cons(leaf, _) => leaf.cells
        buildTableLeafPage(pageSize, 0, leafCells) match
          case Left(error) => Left(error)
          case Right(page2Body) =>
            val pageCount = 2 + overflowPages.length
            val page1 = tableFileHeader(pageSize, pageCount, changeCounter, schemaCookie) ++ page1Body
            ByteSlice.fromList(page1 ++ page2Body ++ cellsFlatten(overflowPages))
      else
        buildTreeBodies(leaves, pageSize) match
          case Left(error) => Left(error)
          case Right(tree) =>
            val pageCount = 1 + tree.treePages + overflowPages.length
            val page1 = tableFileHeader(pageSize, pageCount, changeCounter, schemaCookie) ++ page1Body
            ByteSlice.fromList(page1 ++ cellsFlatten(tree.interiorBodies) ++ cellsFlatten(tree.leafBodies) ++ cellsFlatten(overflowPages))

// ── Explicit-rowid table writer (m3f foundation: preserve rowids across a rewrite) ──

case class KeyedRow(rowid: Long, values: List[SqliteValue])

/** Like `encodeOverflowRowCells`, but each row carries its OWN rowid (rather than
 *  an auto 1..n counter). Rowids must be strictly ascending — the B-tree/rowid
 *  order the reader and `integrity_check` require. */
def encodeKeyedOverflowRowCells(rows: List[KeyedRow], pageSize: Int, usableSize: Int, startPage: Int): Either[ByteError, OverflowBtreeRows] =
  var koRemaining = rows
  var koNextPage = startPage
  var koCellsRev: List[RowCell] = Nil
  var koPagesRev: List[List[Int]] = Nil
  var koFailure: Option[ByteError] = None
  while koRemaining.nonEmpty && koFailure.isEmpty do
    val koRow = koRemaining.head
    encodeRecord(koRow.values) match
      case Left(error) => koFailure = Some(error)
      case Right(recordSlice) =>
        val koCell = encodeOverflowCell(koRow.rowid, byteSliceToList(recordSlice), pageSize, usableSize, koNextPage)
        koCellsRev = RowCell(koRow.rowid, koCell.cell) :: koCellsRev
        koPagesRev = prependOverflowPages(koCell.overflowPages, koPagesRev)
        koNextPage = koNextPage + koCell.overflowPages.length
        koRemaining = koRemaining.tail
  koFailure match
    case Some(error) => Left(error)
    case None => Right(OverflowBtreeRows(koCellsRev.reverse, koPagesRev.reverse))

/** The most general bulk writer: rows with EXPLICIT (strictly ascending) rowids,
 *  any B-tree depth, and cell overflow. This is what a rowid-preserving rewrite
 *  (delete/update via read-modify-rewrite) builds on — the surviving rows keep
 *  their original rowids instead of being renumbered 1..n. Byte-verified against
 *  reference `integrity_check`; reads back exact including `rowid`. */
def buildKeyedDatabase(pageSize: Int, changeCounter: Int, schemaCookie: Int,
    tableName: String, createSql: String, rows: List[KeyedRow]): Either[ByteError, ByteSlice] =
  val usableSize = pageSize
  val schemaValues = List(SqlText("table"), SqlText(tableName), SqlText(tableName),
    SqlInteger(2L), SqlText(createSql))
  encodeRecord(schemaValues) match
    case Left(error) => Left(error)
    case Right(schemaRecord) =>
      // Pass 1: placeholder overflow pointers fix leaf packing + tree shape.
      encodeKeyedOverflowRowCells(rows, pageSize, usableSize, 0) match
        case Left(error) => Left(error)
        case Right(probe) =>
          val probeLeaves = packLeaves(probe.cells, pageSize)
          val overflowStart = 2 + treePageCount(probeLeaves, pageSize)
          // Pass 2: real overflow pages numbered after the whole tree.
          encodeKeyedOverflowRowCells(rows, pageSize, usableSize, overflowStart) match
            case Left(error) => Left(error)
            case Right(built) =>
              val leaves = packLeaves(built.cells, pageSize)
              assembleOverflowTree(pageSize, changeCounter, schemaCookie, schemaRecord, leaves, built.overflowPages)

// ── Raw-record keyed writer (rewrite an existing table from decoded records) ──
//
// Where `buildKeyedDatabase` re-encodes `List[SqliteValue]` per row,
// `buildKeyedRawDatabase` takes the ALREADY-ENCODED record payload bytes for each
// rowid. A read-modify-rewrite (delete/update) reconstructs those bytes from the
// reader's `DecodedRecord` and hands them straight back — no value round-trip, so
// text needs no code-point→String rebuild (see BUGS.md
// portable-codepoint-string-construction).

case class KeyedRawRow(rowid: Long, record: List[Int])

def encodeKeyedRawOverflowRowCells(rows: List[KeyedRawRow], pageSize: Int, usableSize: Int, startPage: Int): OverflowBtreeRows =
  var krRemaining = rows
  var krNextPage = startPage
  var krCellsRev: List[RowCell] = Nil
  var krPagesRev: List[List[Int]] = Nil
  while krRemaining.nonEmpty do
    val krRow = krRemaining.head
    val krCell = encodeOverflowCell(krRow.rowid, krRow.record, pageSize, usableSize, krNextPage)
    krCellsRev = RowCell(krRow.rowid, krCell.cell) :: krCellsRev
    krPagesRev = prependOverflowPages(krCell.overflowPages, krPagesRev)
    krNextPage = krNextPage + krCell.overflowPages.length
    krRemaining = krRemaining.tail
  OverflowBtreeRows(krCellsRev.reverse, krPagesRev.reverse)

/** Build a rowid table from rows given as `(rowid, raw-record-bytes)` — explicit
 *  ascending rowids, overflow, any depth. Reference `integrity_check` ok. */
def buildKeyedRawDatabase(pageSize: Int, changeCounter: Int, schemaCookie: Int,
    tableName: String, createSql: String, rows: List[KeyedRawRow]): Either[ByteError, ByteSlice] =
  val usableSize = pageSize
  val schemaValues = List(SqlText("table"), SqlText(tableName), SqlText(tableName),
    SqlInteger(2L), SqlText(createSql))
  encodeRecord(schemaValues) match
    case Left(error) => Left(error)
    case Right(schemaRecord) =>
      val probe = encodeKeyedRawOverflowRowCells(rows, pageSize, usableSize, 0)
      val probeLeaves = packLeaves(probe.cells, pageSize)
      val overflowStart = 2 + treePageCount(probeLeaves, pageSize)
      val built = encodeKeyedRawOverflowRowCells(rows, pageSize, usableSize, overflowStart)
      val leaves = packLeaves(built.cells, pageSize)
      assembleOverflowTree(pageSize, changeCounter, schemaCookie, schemaRecord, leaves, built.overflowPages)

/** Rebuild a single-table database from a RAW `sqlite_schema` record plus raw table
 *  rows — the form a rewrite (delete/update) produces. Preserving the schema record
 *  verbatim (rather than re-encoding it from a decoded name/SQL) avoids decoding
 *  text back to a String at all. The table root stays page 2. */
def buildFromRawSchema(pageSize: Int, changeCounter: Int, schemaCookie: Int,
    schemaRecord: List[Int], rows: List[KeyedRawRow]): Either[ByteError, ByteSlice] =
  val usableSize = pageSize
  ByteSlice.fromList(schemaRecord) match
    case Left(error) => Left(error)
    case Right(schemaSlice) =>
      val probe = encodeKeyedRawOverflowRowCells(rows, pageSize, usableSize, 0)
      val probeLeaves = packLeaves(probe.cells, pageSize)
      val overflowStart = 2 + treePageCount(probeLeaves, pageSize)
      val built = encodeKeyedRawOverflowRowCells(rows, pageSize, usableSize, overflowStart)
      val leaves = packLeaves(built.cells, pageSize)
      assembleOverflowTree(pageSize, changeCounter, schemaCookie, schemaSlice, leaves, built.overflowPages)

// ── Multi-table database (several rowid tables in one file) ──
//
// Page 1 is `sqlite_schema` with one `CREATE TABLE` entry per table (each with its
// own root page); each table's B-tree then occupies a contiguous page range, in
// declaration order, immediately after page 1. Root pages are assigned bottom-up
// from the tables' sizes, so an interior page can reference its children by
// absolute page number. Non-overflow, and the schema itself must fit page 1 (a
// handful of tables) — deeper generalizations are follow-ups.

case class TableSpec(name: String, createSql: String, rows: List[List[SqliteValue]])
case class TablePlan(rootPage: Int, treePages: Int, leaves: List[LeafPlan], schemaRecord: ByteSlice)

/** Plan each table: pack its rows into leaves, size its tree, assign its root page
 *  (cumulative from `firstRoot`), and build its `sqlite_schema` record. */
def planTables(tables: List[TableSpec], pageSize: Int, firstRoot: Int): Either[ByteError, List[TablePlan]] =
  var ptRemaining = tables
  var ptRoot = firstRoot
  var ptAcc: List[TablePlan] = Nil
  var ptFailure: Option[ByteError] = None
  while ptRemaining.nonEmpty && ptFailure.isEmpty do
    val ptTable = ptRemaining.head
    encodeRowCellsWithRowid(ptTable.rows, 1L) match
      case Left(error) => ptFailure = Some(error)
      case Right(rowCells) =>
        val ptLeaves = packLeaves(rowCells, pageSize)
        val ptPages = treePageCount(ptLeaves, pageSize)
        encodeRecord(List(SqlText("table"), SqlText(ptTable.name), SqlText(ptTable.name),
            SqlInteger(ptRoot.toLong), SqlText(ptTable.createSql))) match
          case Left(error) => ptFailure = Some(error)
          case Right(schemaRecord) =>
            ptAcc = TablePlan(ptRoot, ptPages, ptLeaves, schemaRecord) :: ptAcc
            ptRoot = ptRoot + ptPages
            ptRemaining = ptRemaining.tail
  ptFailure match
    case Some(error) => Left(error)
    case None => Right(ptAcc.reverse)

/** Build one table's B-tree pages rooted at `rootPage` (a single leaf, or interior
 *  levels over leaves). Non-overflow. */
def buildTableTreeAt(leaves: List[LeafPlan], pageSize: Int, rootPage: Int): Either[ByteError, List[Int]] =
  if leaves.length <= 1 then
    val leafCells = leaves match
      case Nil => Nil
      case Cons(leaf, _) => leaf.cells
    buildTableLeafPage(pageSize, 0, leafCells)
  else
    var bttLevels: List[List[InteriorPlan]] = Nil
    var bttRowids = leafMaxRowids(leaves)
    while bttRowids.length > 1 do
      val bttLevel = packInterior(bttRowids, pageSize)
      bttLevels = bttLevel :: bttLevels
      bttRowids = interiorMaxRowids(bttLevel)
    buildInteriorLevels(bttLevels, rootPage, pageSize) match
      case Left(error) => Left(error)
      case Right(interiorBodies) =>
        buildLeafPages(leaves, pageSize) match
          case Left(error) => Left(error)
          case Right(leafBodies) => Right(cellsFlatten(interiorBodies) ++ cellsFlatten(leafBodies))

def schemaCellsOf(plans: List[TablePlan], startRowid: Long): List[List[Int]] =
  var scRemaining = plans
  var scRowid = startRowid
  var scAcc: List[List[Int]] = Nil
  while scRemaining.nonEmpty do
    scAcc = encodeTableLeafCell(scRowid, scRemaining.head.schemaRecord) :: scAcc
    scRowid = scRowid + 1L
    scRemaining = scRemaining.tail
  scAcc.reverse

def buildAllTrees(plans: List[TablePlan], pageSize: Int): Either[ByteError, List[List[Int]]] =
  var atRemaining = plans
  var atAcc: List[List[Int]] = Nil
  var atFailure: Option[ByteError] = None
  while atRemaining.nonEmpty && atFailure.isEmpty do
    val atPlan = atRemaining.head
    buildTableTreeAt(atPlan.leaves, pageSize, atPlan.rootPage) match
      case Left(error) => atFailure = Some(error)
      case Right(bytes) =>
        atAcc = bytes :: atAcc
        atRemaining = atRemaining.tail
  atFailure match
    case Some(error) => Left(error)
    case None => Right(atAcc.reverse)

def sumTreePages(plans: List[TablePlan]): Int =
  var stRemaining = plans
  var stTotal = 0
  while stRemaining.nonEmpty do
    stTotal = stTotal + stRemaining.head.treePages
    stRemaining = stRemaining.tail
  stTotal

/** Assemble a database holding several rowid tables. Byte-verified against
 *  reference `integrity_check`; every table reads back exact. */
def buildMultiTableDatabase(pageSize: Int, changeCounter: Int, schemaCookie: Int,
    tables: List[TableSpec]): Either[ByteError, ByteSlice] =
  planTables(tables, pageSize, 2) match
    case Left(error) => Left(error)
    case Right(plans) =>
      buildTableLeafPage(pageSize, 100, schemaCellsOf(plans, 1L)) match
        case Left(error) => Left(error)
        case Right(page1Body) =>
          buildAllTrees(plans, pageSize) match
            case Left(error) => Left(error)
            case Right(treeBlocks) =>
              val pageCount = 1 + sumTreePages(plans)
              val page1 = tableFileHeader(pageSize, pageCount, changeCounter, schemaCookie) ++ page1Body
              ByteSlice.fromList(page1 ++ cellsFlatten(treeBlocks))

// ── Multi-table REWRITE from raw records (m3f: mutate one table of a multi-table DB) ──
//
// Rebuilds a whole multi-table database from each table's raw `sqlite_schema`
// record + raw rows, reassigning root pages by size. Because a rewrite shifts the
// page layout, every table's schema-record rootpage field (column index 3) is
// re-encoded with `encodeInteger`, keeping the other fields (type/name/tbl_name/
// sql) byte-for-byte — so no text is decoded to a String. Non-overflow.

case class RawTable(schemaRecord: DecodedRecord, rows: List[KeyedRawRow])
case class RawTablePlan(rootPage: Int, treePages: Int, leaves: List[LeafPlan], schemaBytes: List[Int])

/** Re-encode a `sqlite_schema` record with a new rootpage (field index 3),
 *  keeping every other field's raw serial type + body. */
def patchSchemaRootpage(record: DecodedRecord, newRoot: Long): List[Int] =
  var psFields = record.fields
  var psIndex = 0
  var psSerialRev: List[Int] = Nil
  var psBodyRev: List[Int] = Nil
  while psFields.nonEmpty do
    val psField = psFields.head
    val psEncoded = if psIndex == 3 then encodeInteger(newRoot) else EncodedValue(psField.serialType, byteSliceToList(psField.encoded))
    var psSerial = byteSliceToList(encodeVarint(psEncoded.serialType))
    while psSerial.nonEmpty do
      psSerialRev = psSerial.head :: psSerialRev
      psSerial = psSerial.tail
    var psBody = psEncoded.body
    while psBody.nonEmpty do
      psBodyRev = psBody.head :: psBodyRev
      psBody = psBody.tail
    psIndex = psIndex + 1
    psFields = psFields.tail
  val psSerialBytes = psSerialRev.reverse
  val psHeaderLen = recordHeaderLength(psSerialBytes.length)
  byteSliceToList(encodeVarint(psHeaderLen.toLong)) ++ psSerialBytes ++ psBodyRev.reverse

/** Table-leaf cells for raw rows (rowid + already-encoded record), no overflow. */
def rawRowCells(rows: List[KeyedRawRow]): List[RowCell] =
  var rcRemaining = rows
  var rcAcc: List[RowCell] = Nil
  while rcRemaining.nonEmpty do
    val rcRow = rcRemaining.head
    val rcCell = byteSliceToList(encodeVarint(rcRow.record.length.toLong)) ++
      byteSliceToList(encodeVarint(rcRow.rowid)) ++ rcRow.record
    rcAcc = RowCell(rcRow.rowid, rcCell) :: rcAcc
    rcRemaining = rcRemaining.tail
  rcAcc.reverse

def planRawTables(tables: List[RawTable], pageSize: Int, firstRoot: Int): List[RawTablePlan] =
  var prtRemaining = tables
  var prtRoot = firstRoot
  var prtAcc: List[RawTablePlan] = Nil
  while prtRemaining.nonEmpty do
    val prtTable = prtRemaining.head
    val prtLeaves = packLeaves(rawRowCells(prtTable.rows), pageSize)
    val prtPages = treePageCount(prtLeaves, pageSize)
    prtAcc = RawTablePlan(prtRoot, prtPages, prtLeaves, patchSchemaRootpage(prtTable.schemaRecord, prtRoot.toLong)) :: prtAcc
    prtRoot = prtRoot + prtPages
    prtRemaining = prtRemaining.tail
  prtAcc.reverse

def rawSchemaCells(plans: List[RawTablePlan], startRowid: Long): List[List[Int]] =
  var rscRemaining = plans
  var rscRowid = startRowid
  var rscAcc: List[List[Int]] = Nil
  while rscRemaining.nonEmpty do
    val rscBytes = rscRemaining.head.schemaBytes
    val rscCell = byteSliceToList(encodeVarint(rscBytes.length.toLong)) ++
      byteSliceToList(encodeVarint(rscRowid)) ++ rscBytes
    rscAcc = rscCell :: rscAcc
    rscRowid = rscRowid + 1L
    rscRemaining = rscRemaining.tail
  rscAcc.reverse

def buildAllRawTrees(plans: List[RawTablePlan], pageSize: Int): Either[ByteError, List[List[Int]]] =
  var artRemaining = plans
  var artAcc: List[List[Int]] = Nil
  var artFailure: Option[ByteError] = None
  while artRemaining.nonEmpty && artFailure.isEmpty do
    val artPlan = artRemaining.head
    buildTableTreeAt(artPlan.leaves, pageSize, artPlan.rootPage) match
      case Left(error) => artFailure = Some(error)
      case Right(bytes) =>
        artAcc = bytes :: artAcc
        artRemaining = artRemaining.tail
  artFailure match
    case Some(error) => Left(error)
    case None => Right(artAcc.reverse)

def sumRawTreePages(plans: List[RawTablePlan]): Int =
  var srtRemaining = plans
  var srtTotal = 0
  while srtRemaining.nonEmpty do
    srtTotal = srtTotal + srtRemaining.head.treePages
    srtRemaining = srtRemaining.tail
  srtTotal

/** Rebuild a multi-table database from raw schema records + raw rows, reassigning
 *  root pages. The rewrite behind multi-table delete/update. Byte-verified against
 *  reference `integrity_check`. */
def buildMultiTableRaw(pageSize: Int, changeCounter: Int, schemaCookie: Int, tables: List[RawTable]): Either[ByteError, ByteSlice] =
  val plans = planRawTables(tables, pageSize, 2)
  buildTableLeafPage(pageSize, 100, rawSchemaCells(plans, 1L)) match
    case Left(error) => Left(error)
    case Right(page1Body) =>
      buildAllRawTrees(plans, pageSize) match
        case Left(error) => Left(error)
        case Right(treeBlocks) =>
          val pageCount = 1 + sumRawTreePages(plans)
          val page1 = tableFileHeader(pageSize, pageCount, changeCounter, schemaCookie) ++ page1Body
          ByteSlice.fromList(page1 ++ cellsFlatten(treeBlocks))

// ── Single-leaf index B-tree (CREATE INDEX on one integer column) ──
//
// An index is a separate B-tree (page kind 10 = index leaf) whose records are the
// indexed column value followed by the row's rowid, sorted by (value, rowid). The
// cell is `varint(payloadLen) ++ record` — no separate rowid varint (the rowid is
// the record's last field). Reference `integrity_check` cross-checks the index
// against its table, so a passing file proves the index is correct.

case class IndexEntry(key: List[SqliteValue], rowid: Long, record: List[Int])

/** Lexicographic comparison of composite index keys (single-level ops only, to
 *  dodge the JIT nested-match bug). */
def compareKeyList(a: List[SqliteValue], b: List[SqliteValue]): Int =
  if a.isEmpty || b.isEmpty then 0
  else
    val c = compareKeys(a.head, b.head)
    if c != 0 then c else compareKeyList(a.tail, b.tail)

/** SQLite's cross-type sort order: NULL < numeric < TEXT < BLOB. */
def valueClass(value: SqliteValue): Int = value match
  case SqlNull => 0
  case SqlInteger(_) => 1
  case SqlReal(_) => 1
  case SqlText(_) => 2
  case SqlBlob(_) => 3

def integerOf(value: SqliteValue): Long = value match
  case SqlInteger(x) => x
  case _ => 0L

def textOf(value: SqliteValue): String = value match
  case SqlText(x) => x
  case _ => ""

/** Compare two index-key values: by storage class first, then numeric value /
 *  BINARY text order (codepoint = byte order for ASCII/BMP). Single-level matches
 *  only (via `integerOf`/`textOf`) — a nested `match` here miscompiles on the
 *  interpreter's JIT (BUGS.md interp-jit-nested-match-duplicate-var). */
def compareKeys(a: SqliteValue, b: SqliteValue): Int =
  val ca = valueClass(a)
  val cb = valueClass(b)
  if ca != cb then (if ca < cb then -1 else 1)
  else if ca == 1 then
    val x = integerOf(a)
    val y = integerOf(b)
    if x < y then -1 else if x > y then 1 else 0
  else if ca == 2 then
    val x = textOf(a)
    val y = textOf(b)
    if x < y then -1 else if x > y then 1 else 0
  else 0

/** A leaf B-tree page with an explicit page kind (13 = table leaf, 10 = index
 *  leaf). Same body layout as `buildTableLeafPage`. */
def buildLeafPageKind(pageSize: Int, headerOffset: Int, cells: List[List[Int]], kind: Int): Either[ByteError, List[Int]] =
  val count = cells.length
  val total = cellsTotal(cells)
  val contentStart = pageSize - total
  val gap = contentStart - (headerOffset + 8 + 2 * count)
  if gap < 0 then Left(ByteError("overflow", "index leaf cells do not fit (multi-leaf index is a follow-up)", 0))
  else
    val csField = if contentStart == 65536 then 0 else contentStart
    val header = List(kind, 0, 0) ++ writeBe16(count) ++ writeBe16(csField) ++ List(0)
    Right(header ++ cellPointers(cells, contentStart) ++ writeZeros(gap) ++ cellsFlatten(cells))

def nthValue(values: List[SqliteValue], index: Int): SqliteValue =
  if index <= 0 then values match
    case Cons(head, _) => head
    case Nil => SqlNull
  else values match
    case Cons(_, tail) => nthValue(tail, index - 1)
    case Nil => SqlNull

/** The key-column values of a row, in `keyColumns` order. */
def keyValues(row: List[SqliteValue], keyColumns: List[Int]): List[SqliteValue] =
  var kvRemaining = keyColumns
  var kvAcc: List[SqliteValue] = Nil
  while kvRemaining.nonEmpty do
    kvAcc = nthValue(row, kvRemaining.head) :: kvAcc
    kvRemaining = kvRemaining.tail
  kvAcc.reverse

/** Build one index entry per row: record = `[key columns…, rowid]`. */
def buildIndexEntries(rows: List[List[SqliteValue]], keyColumns: List[Int], startRowid: Long): Either[ByteError, List[IndexEntry]] =
  var bieRemaining = rows
  var bieRowid = startRowid
  var bieAcc: List[IndexEntry] = Nil
  var bieFailure: Option[ByteError] = None
  while bieRemaining.nonEmpty && bieFailure.isEmpty do
    val bieKey = keyValues(bieRemaining.head, keyColumns)
    encodeRecord(bieKey ++ List(SqlInteger(bieRowid))) match
      case Left(error) => bieFailure = Some(error)
      case Right(record) =>
        bieAcc = IndexEntry(bieKey, bieRowid, byteSliceToList(record)) :: bieAcc
        bieRowid = bieRowid + 1L
        bieRemaining = bieRemaining.tail
  bieFailure match
    case Some(error) => Left(error)
    case None => Right(bieAcc.reverse)

def insertIndexEntry(sorted: List[IndexEntry], entry: IndexEntry): List[IndexEntry] = sorted match
  case Nil => entry :: Nil
  case Cons(head, tail) =>
    val cmp = compareKeyList(entry.key, head.key)
    if cmp < 0 || (cmp == 0 && entry.rowid < head.rowid) then entry :: sorted
    else head :: insertIndexEntry(tail, entry)

def sortIndexEntries(entries: List[IndexEntry]): List[IndexEntry] =
  var sieRemaining = entries
  var sieSorted: List[IndexEntry] = Nil
  while sieRemaining.nonEmpty do
    sieSorted = insertIndexEntry(sieSorted, sieRemaining.head)
    sieRemaining = sieRemaining.tail
  sieSorted

/** Index leaf cells: `varint(payloadLen) ++ record`, in sorted order. */
def indexLeafCells(entries: List[IndexEntry]): List[List[Int]] =
  var ilcRemaining = entries
  var ilcAcc: List[List[Int]] = Nil
  while ilcRemaining.nonEmpty do
    val ilcRecord = ilcRemaining.head.record
    ilcAcc = (byteSliceToList(encodeVarint(ilcRecord.length.toLong)) ++ ilcRecord) :: ilcAcc
    ilcRemaining = ilcRemaining.tail
  ilcAcc.reverse

// ── Multi-leaf index B-tree (interior index cells carry a full key record) ──
//
// When the entries do not fit one leaf they are packed into several leaves with a
// SEPARATOR entry PROMOTED between each adjacent pair — the separator lives in the
// interior (not a leaf), unlike a table interior which only copies a rowid. Index
// interior cell = `u32(leftChild) ++ varint(payloadLen) ++ record`; page kind 2.

case class IndexTreePlan(leafGroups: List[List[IndexEntry]], separators: List[IndexEntry])
case class IndexTreeBytes(bytes: List[Int], pageCount: Int)

/** An interior B-tree page with an explicit kind (5 = table interior, 2 = index
 *  interior). Same layout as `buildTableInteriorPage`. */
def buildInteriorPageKind(pageSize: Int, headerOffset: Int, cells: List[List[Int]], rightChild: Int, kind: Int): Either[ByteError, List[Int]] =
  val count = cells.length
  val total = cellsTotal(cells)
  val contentStart = pageSize - total
  val gap = contentStart - (headerOffset + 12 + 2 * count)
  if gap < 0 then Left(ByteError("overflow", "interior index cells do not fit one page", 0))
  else
    val csField = if contentStart == 65536 then 0 else contentStart
    val header = List(kind, 0, 0) ++ writeBe16(count) ++ writeBe16(csField) ++ List(0) ++ writeBe32(rightChild)
    Right(header ++ cellPointers(cells, contentStart) ++ writeZeros(gap) ++ cellsFlatten(cells))

def indexInteriorCell(childPage: Int, record: List[Int]): List[Int] =
  writeBe32(childPage) ++ byteSliceToList(encodeVarint(record.length.toLong)) ++ record

/** Greedily pack sorted index entries into leaves, promoting one entry as a
 *  separator between each adjacent pair. `while`+`var` (not recursion). */
def packIndexTree(entries: List[IndexEntry], pageSize: Int): IndexTreePlan =
  var pitRemaining = entries
  var pitCurRev: List[IndexEntry] = Nil
  var pitBytes = 8
  var pitCount = 0
  var pitLeaves: List[List[IndexEntry]] = Nil
  var pitSeparators: List[IndexEntry] = Nil
  while pitRemaining.nonEmpty do
    val pitEntry = pitRemaining.head
    val pitCellSize = 2 + varintLen(pitEntry.record.length.toLong) + pitEntry.record.length
    if pitCount == 0 then
      pitCurRev = pitEntry :: Nil
      pitBytes = 8 + pitCellSize
      pitCount = 1
      pitRemaining = pitRemaining.tail
    else if pitBytes + pitCellSize <= pageSize then
      pitCurRev = pitEntry :: pitCurRev
      pitBytes = pitBytes + pitCellSize
      pitCount = pitCount + 1
      pitRemaining = pitRemaining.tail
    else if pitRemaining.tail.nonEmpty then
      // leaf full, entries remain after this one → promote this entry as separator
      pitLeaves = pitCurRev.reverse :: pitLeaves
      pitSeparators = pitEntry :: pitSeparators
      pitCurRev = Nil
      pitBytes = 8
      pitCount = 0
      pitRemaining = pitRemaining.tail
    else
      // leaf full and this is the LAST entry → give it its own leaf (no separator)
      pitLeaves = pitCurRev.reverse :: pitLeaves
      pitCurRev = pitEntry :: Nil
      pitBytes = 8 + pitCellSize
      pitCount = 1
      pitRemaining = pitRemaining.tail
  val pitAll = if pitCount > 0 then pitCurRev.reverse :: pitLeaves else pitLeaves
  IndexTreePlan(pitAll.reverse, pitSeparators.reverse)

def buildIndexLeaves(groups: List[List[IndexEntry]], pageSize: Int): Either[ByteError, List[List[Int]]] =
  var bilRemaining = groups
  var bilAcc: List[List[Int]] = Nil
  var bilFailure: Option[ByteError] = None
  while bilRemaining.nonEmpty && bilFailure.isEmpty do
    buildLeafPageKind(pageSize, 0, indexLeafCells(bilRemaining.head), 10) match
      case Left(error) => bilFailure = Some(error)
      case Right(leaf) =>
        bilAcc = leaf :: bilAcc
        bilRemaining = bilRemaining.tail
  bilFailure match
    case Some(error) => Left(error)
    case None => Right(bilAcc.reverse)

/** Interior cells: separator `i` has left child = leaf `firstChild + i`. */
def indexInteriorCells(separators: List[IndexEntry], firstChild: Int): List[List[Int]] =
  var iicRemaining = separators
  var iicIndex = 0
  var iicAcc: List[List[Int]] = Nil
  while iicRemaining.nonEmpty do
    iicAcc = indexInteriorCell(firstChild + iicIndex, iicRemaining.head.record) :: iicAcc
    iicIndex = iicIndex + 1
    iicRemaining = iicRemaining.tail
  iicAcc.reverse

// ── Arbitrary-depth index B-tree (stacked interior levels, promoted separators) ──
//
// When even the interior separators overflow one page, interior levels stack like
// a table's deep tree (buildDeepTableDatabase) — but an index interior carries
// PROMOTED SEPARATOR RECORDS (a real entry between two children), so splitting a
// level promotes the between-page separator up to the parent.

case class IdxNode(childCount: Int, separators: List[IndexEntry])
case class IdxLevelPlan(nodes: List[IdxNode], promoted: List[IndexEntry])

/** Interior index cell footprint incl. its 2-byte pointer:
 *  `2 (pointer) + 4 (leftChild) + varint(payloadLen) + record`. */
def idxCellCost(record: List[Int]): Int = 6 + varintLen(record.length.toLong) + record.length

/** Pack one interior level: `childCount` children (in order) with the
 *  `childCount-1` separators between adjacent children. Group children into
 *  interior pages — each holds a run of children with their in-between separators
 *  as divider cells; the separator between two pages is PROMOTED to the parent.
 *  `12 + Σ idxCellCost` is exactly what `buildInteriorPageKind` checks, so every
 *  produced node fits one page. `while`+`var` (not recursion). */
def packIdxLevel(childCount: Int, separators: List[IndexEntry], pageSize: Int): IdxLevelPlan =
  var pilSeps = separators
  var pilChild = 0
  var pilNodeCount = 0
  var pilNodeSepsRev: List[IndexEntry] = Nil
  var pilNodeSize = 12
  var pilNodesRev: List[IdxNode] = Nil
  var pilPromotedRev: List[IndexEntry] = Nil
  while pilChild < childCount do
    if pilNodeCount == 0 then
      pilNodeCount = 1
      pilNodeSepsRev = Nil
      pilNodeSize = 12
      pilChild = pilChild + 1
    else
      val pilSep = pilSeps.head
      val pilCost = idxCellCost(pilSep.record)
      if pilNodeSize + pilCost <= pageSize then
        pilNodeSepsRev = pilSep :: pilNodeSepsRev
        pilNodeSize = pilNodeSize + pilCost
        pilNodeCount = pilNodeCount + 1
        pilSeps = pilSeps.tail
        pilChild = pilChild + 1
      else
        pilNodesRev = IdxNode(pilNodeCount, pilNodeSepsRev.reverse) :: pilNodesRev
        pilPromotedRev = pilSep :: pilPromotedRev
        pilSeps = pilSeps.tail
        pilNodeCount = 1
        pilNodeSepsRev = Nil
        pilNodeSize = 12
        pilChild = pilChild + 1
  val pilNodes = if pilNodeCount > 0 then IdxNode(pilNodeCount, pilNodeSepsRev.reverse) :: pilNodesRev else pilNodesRev
  IdxLevelPlan(pilNodes.reverse, pilPromotedRev.reverse)

/** Divider cells of one interior node: separator `i` sits between the node's child
 *  `i` (at `childStart + firstChild + i`) and child `i+1`. */
def buildIdxDividers(childStart: Int, firstChild: Int, separators: List[IndexEntry]): List[List[Int]] =
  var bidRemaining = separators
  var bidI = 0
  var bidAcc: List[List[Int]] = Nil
  while bidRemaining.nonEmpty do
    bidAcc = indexInteriorCell(childStart + firstChild + bidI, bidRemaining.head.record) :: bidAcc
    bidI = bidI + 1
    bidRemaining = bidRemaining.tail
  bidAcc.reverse

/** Build one interior level's page bodies; its children begin at `childStart`. */
def buildIdxLevelPages(level: List[IdxNode], childStart: Int, pageSize: Int): Either[ByteError, List[List[Int]]] =
  var bilpRemaining = level
  var bilpFirstChild = 0
  var bilpAcc: List[List[Int]] = Nil
  var bilpFailure: Option[ByteError] = None
  while bilpRemaining.nonEmpty && bilpFailure.isEmpty do
    val bilpNode = bilpRemaining.head
    val bilpDividers = buildIdxDividers(childStart, bilpFirstChild, bilpNode.separators)
    val bilpRightmost = childStart + bilpFirstChild + bilpNode.childCount - 1
    buildInteriorPageKind(pageSize, 0, bilpDividers, bilpRightmost, 2) match
      case Left(error) => bilpFailure = Some(error)
      case Right(body) => bilpAcc = body :: bilpAcc
    bilpFirstChild = bilpFirstChild + bilpNode.childCount
    bilpRemaining = bilpRemaining.tail
  bilpFailure match
    case Some(error) => Left(error)
    case None => Right(bilpAcc.reverse)

/** Build every index interior level top-down, threading page numbers like
 *  `buildInteriorLevels`: the head level begins at `startPage`, its children (the
 *  next level, or the leaves) begin right after it. */
def buildIdxLevels(levels: List[List[IdxNode]], startPage: Int, pageSize: Int): Either[ByteError, List[List[Int]]] = levels match
  case Nil => Right(Nil)
  case Cons(level, tail) =>
    val bilChildStart = startPage + level.length
    buildIdxLevelPages(level, bilChildStart, pageSize) match
      case Left(error) => Left(error)
      case Right(bilThis) =>
        buildIdxLevels(tail, bilChildStart, pageSize) match
          case Left(error) => Left(error)
          case Right(bilRest) => Right(bilThis ++ bilRest)

def totalIdxPages(levels: List[List[IdxNode]]): Int =
  var tipRemaining = levels
  var tipTotal = 0
  while tipRemaining.nonEmpty do
    tipTotal = tipTotal + tipRemaining.head.length
    tipRemaining = tipRemaining.tail
  tipTotal

/** Build the whole index tree rooted at `indexRoot`, to ANY depth. One kind-10 leaf
 *  if it all fits; else interior levels (kind 2, promoted separators) stacked
 *  bottom-up until a single-page root, numbered top-down (root, interior levels,
 *  then the leaves). Two-level output is byte-identical to the earlier single
 *  interior over the leaves. */
def buildIndexTree(entries: List[IndexEntry], pageSize: Int, indexRoot: Int): Either[ByteError, IndexTreeBytes] =
  val plan = packIndexTree(entries, pageSize)
  val leafCount = plan.leafGroups.length
  if leafCount <= 1 then
    buildLeafPageKind(pageSize, 0, indexLeafCells(entries), 10) match
      case Left(error) => Left(error)
      case Right(leaf) => Right(IndexTreeBytes(leaf, 1))
  else
    var bitLevels: List[List[IdxNode]] = Nil
    var bitCount = leafCount
    var bitSeps = plan.separators
    var bitDone = false
    while !bitDone do
      val bitPlan = packIdxLevel(bitCount, bitSeps, pageSize)
      bitLevels = bitPlan.nodes :: bitLevels
      // Stop at a single-page root; the `>= bitCount` guard avoids a non-reducing
      // loop for pathological oversized keys.
      if bitPlan.nodes.length <= 1 || bitPlan.nodes.length >= bitCount then bitDone = true
      else
        bitCount = bitPlan.nodes.length
        bitSeps = bitPlan.promoted
    val bitInteriorPages = totalIdxPages(bitLevels)
    buildIdxLevels(bitLevels, indexRoot, pageSize) match
      case Left(error) => Left(error)
      case Right(bitInterior) =>
        buildIndexLeaves(plan.leafGroups, pageSize) match
          case Left(error) => Left(error)
          case Right(bitLeaves) =>
            Right(IndexTreeBytes(cellsFlatten(bitInterior) ++ cellsFlatten(bitLeaves), bitInteriorPages + leafCount))

/** Assemble a database with one rowid table and one single-leaf index on a single
 *  integer column of it. Page 1 = schema (table entry root 2, index entry root
 *  N), page 2..1+T = the table's B-tree, page 2+T = the index leaf. Reference
 *  `integrity_check` validates the index against the table. Non-overflow; the index
 *  must fit one leaf. */
def buildTableWithIndexDatabase(pageSize: Int, changeCounter: Int, schemaCookie: Int,
    tableName: String, tableSql: String, indexName: String, indexSql: String,
    keyColumns: List[Int], rows: List[List[SqliteValue]]): Either[ByteError, ByteSlice] =
  encodeRowCellsWithRowid(rows, 1L) match
    case Left(error) => Left(error)
    case Right(rowCells) =>
      val tableLeaves = packLeaves(rowCells, pageSize)
      val tablePages = treePageCount(tableLeaves, pageSize)
      val indexRoot = 2 + tablePages
      buildIndexEntries(rows, keyColumns, 1L) match
        case Left(error) => Left(error)
        case Right(entries) =>
          val sortedEntries = sortIndexEntries(entries)
          encodeRecord(List(SqlText("table"), SqlText(tableName), SqlText(tableName), SqlInteger(2L), SqlText(tableSql))) match
            case Left(error) => Left(error)
            case Right(tableSchema) =>
              encodeRecord(List(SqlText("index"), SqlText(indexName), SqlText(tableName), SqlInteger(indexRoot.toLong), SqlText(indexSql))) match
                case Left(error) => Left(error)
                case Right(indexSchema) =>
                  buildTableLeafPage(pageSize, 100, List(encodeTableLeafCell(1L, tableSchema), encodeTableLeafCell(2L, indexSchema))) match
                    case Left(error) => Left(error)
                    case Right(page1Body) =>
                      buildTableTreeAt(tableLeaves, pageSize, 2) match
                        case Left(error) => Left(error)
                        case Right(tableTree) =>
                          buildIndexTree(sortedEntries, pageSize, indexRoot) match
                            case Left(error) => Left(error)
                            case Right(indexTree) =>
                              val pageCount = 1 + tablePages + indexTree.pageCount
                              val page1 = tableFileHeader(pageSize, pageCount, changeCounter, schemaCookie) ++ page1Body
                              ByteSlice.fromList(page1 ++ tableTree ++ indexTree.bytes)

/** Rebuild a table + index database from raw table rows and freshly-built index
 *  entries, preserving the two raw `sqlite_schema` records (table + index) and
 *  reassigning their root pages. This is what index-maintaining delete/update
 *  produces — the index is regenerated from the surviving rows so it never goes
 *  stale. Byte-verified against reference `integrity_check`. */
def buildTableWithIndexRaw(pageSize: Int, changeCounter: Int, schemaCookie: Int,
    tableSchema: DecodedRecord, indexSchema: DecodedRecord,
    tableRows: List[KeyedRawRow], indexEntries: List[IndexEntry]): Either[ByteError, ByteSlice] =
  val tableLeaves = packLeaves(rawRowCells(tableRows), pageSize)
  val tablePages = treePageCount(tableLeaves, pageSize)
  val indexRoot = 2 + tablePages
  val tableSchemaBytes = patchSchemaRootpage(tableSchema, 2L)
  val indexSchemaBytes = patchSchemaRootpage(indexSchema, indexRoot.toLong)
  val schemaCell1 = byteSliceToList(encodeVarint(tableSchemaBytes.length.toLong)) ++ byteSliceToList(encodeVarint(1L)) ++ tableSchemaBytes
  val schemaCell2 = byteSliceToList(encodeVarint(indexSchemaBytes.length.toLong)) ++ byteSliceToList(encodeVarint(2L)) ++ indexSchemaBytes
  buildTableLeafPage(pageSize, 100, List(schemaCell1, schemaCell2)) match
    case Left(error) => Left(error)
    case Right(page1Body) =>
      buildTableTreeAt(tableLeaves, pageSize, 2) match
        case Left(error) => Left(error)
        case Right(tableTree) =>
          buildIndexTree(sortIndexEntries(indexEntries), pageSize, indexRoot) match
            case Left(error) => Left(error)
            case Right(indexTree) =>
              val pageCount = 1 + tablePages + indexTree.pageCount
              val page1 = tableFileHeader(pageSize, pageCount, changeCounter, schemaCookie) ++ page1Body
              ByteSlice.fromList(page1 ++ tableTree ++ indexTree.bytes)

// ── Cell-level in-place edits on a single table-leaf page ──
//
// Decode a leaf page's cells, insert/delete/replace one by rowid, and re-serialize
// the page compactly (a defragmented page SQLite accepts). Combined with the mutable
// pager this mutates a table one PAGE at a time — only the touched leaf changes —
// rather than rewriting the whole file. No overflow (payload must be fully local) and
// no split/merge: a page that would overflow returns an error (that is `balance()`,
// the remaining follow-up); the read-modify-rewrite path in `mutate.ssc` handles the
// general case today.

case class LeafCell(rowid: Long, bytes: List[Int])

/** Read one non-overflow table-leaf cell (`varint(payloadLen) varint(rowid) payload`). */
def readLeafCellAt(page: ByteSlice, offset: Int): Either[ByteError, LeafCell] =
  decodeVarint(page, offset) match
    case Left(error) => Left(error)
    case Right(VarintRead(payloadLen, plLen, afterPl)) =>
      decodeVarint(page, afterPl) match
        case Left(error) => Left(error)
        case Right(VarintRead(rowid, ridLen, _)) =>
          val cellTotal = plLen + ridLen + payloadLen.toInt
          byteSliceSlice(page, offset, cellTotal) match
            case Left(error) => Left(error)
            case Right(cellSlice) => Right(LeafCell(rowid, byteSliceToList(cellSlice)))

/** Decode every cell of a table-leaf page, in stored (key) order. `headerOffset` is
 *  100 on page 1, else 0. */
def readLeafCells(page: ByteSlice, headerOffset: Int): Either[ByteError, List[LeafCell]] =
  readU16Be(page, headerOffset + 3) match
    case Left(error) => Left(error)
    case Right(ByteRead(count, _)) =>
      var rlcI = 0
      var rlcAcc: List[LeafCell] = Nil
      var rlcFailure: Option[ByteError] = None
      while rlcI < count.toInt && rlcFailure.isEmpty do
        readU16Be(page, headerOffset + 8 + 2 * rlcI) match
          case Left(error) => rlcFailure = Some(error)
          case Right(ByteRead(cellOffset, _)) =>
            readLeafCellAt(page, cellOffset.toInt) match
              case Left(error) => rlcFailure = Some(error)
              case Right(cell) => rlcAcc = cell :: rlcAcc
        rlcI = rlcI + 1
      rlcFailure match
        case Some(error) => Left(error)
        case None => Right(rlcAcc.reverse)

def leafCellBytesList(cells: List[LeafCell]): List[List[Int]] =
  var lcbRemaining = cells
  var lcbAcc: List[List[Int]] = Nil
  while lcbRemaining.nonEmpty do
    lcbAcc = lcbRemaining.head.bytes :: lcbAcc
    lcbRemaining = lcbRemaining.tail
  lcbAcc.reverse

/** Insert a cell in ascending rowid order; error on a duplicate rowid. */
def leafInsertCell(cells: List[LeafCell], rowid: Long, record: ByteSlice): Either[String, List[LeafCell]] =
  val newCell = LeafCell(rowid, encodeTableLeafCell(rowid, record))
  var licRemaining = cells
  var licBeforeRev: List[LeafCell] = Nil
  var licDup = false
  var licPlaced = false
  var licTailAfter: List[LeafCell] = Nil
  while licRemaining.nonEmpty && !licPlaced && !licDup do
    val licHead = licRemaining.head
    if licHead.rowid == rowid then licDup = true
    else if licHead.rowid > rowid then
      licPlaced = true
      licTailAfter = licRemaining
    else
      licBeforeRev = licHead :: licBeforeRev
      licRemaining = licRemaining.tail
  if licDup then Left("duplicate rowid " + rowid.toString)
  else
    val licBefore = leafReverseCells(licBeforeRev, Nil)
    val licTail = if licPlaced then licTailAfter else Nil
    Right(leafAppendCells(licBefore, newCell :: licTail))

def leafReverseCells(items: List[LeafCell], acc: List[LeafCell]): List[LeafCell] = items match
  case Nil => acc
  case Cons(head, tail) => leafReverseCells(tail, head :: acc)

def leafAppendCells(front: List[LeafCell], back: List[LeafCell]): List[LeafCell] = front match
  case Nil => back
  case Cons(head, tail) => head :: leafAppendCells(tail, back)

/** Remove the cell with `rowid` (no-op if absent). */
def leafDeleteCell(cells: List[LeafCell], rowid: Long): List[LeafCell] =
  var ldcRemaining = cells
  var ldcAcc: List[LeafCell] = Nil
  while ldcRemaining.nonEmpty do
    if ldcRemaining.head.rowid != rowid then ldcAcc = ldcRemaining.head :: ldcAcc
    ldcRemaining = ldcRemaining.tail
  leafReverseCells(ldcAcc, Nil)

/** Replace the payload of the cell with `rowid`, keeping its position. */
def leafUpdateCell(cells: List[LeafCell], rowid: Long, record: ByteSlice): List[LeafCell] =
  var lucRemaining = cells
  var lucAcc: List[LeafCell] = Nil
  while lucRemaining.nonEmpty do
    val lucHead = lucRemaining.head
    val lucNew = if lucHead.rowid == rowid then LeafCell(rowid, encodeTableLeafCell(rowid, record)) else lucHead
    lucAcc = lucNew :: lucAcc
    lucRemaining = lucRemaining.tail
  leafReverseCells(lucAcc, Nil)

/** Re-serialize a leaf page from its cells (compact — no freeblocks). Errors if the
 *  cells no longer fit one page (a split is needed). */
def rebuildLeafPage(cells: List[LeafCell], pageSize: Int, headerOffset: Int): Either[ByteError, List[Int]] =
  buildTableLeafPage(pageSize, headerOffset, leafCellBytesList(cells))

// ── Incremental B-tree balance() on in-place insert/delete ──
//
// A real balance: descend to the target leaf, edit it, and on the way back up split
// any node that overflows into sibling pages — the first chunk keeps the node's page,
// the rest are allocated at EOF, and the parent's single child slot is replaced by
// the pieces with new dividers (an interior split PROMOTES a divider). When the root
// overflows the tree grows a level (`balance_deeper`) with the root page number kept.
// Divider keys never change on insert (a routed rowid is <= its subtree's divider, or
// lands in the rightmost child). Delete just rewrites the leaf: an underfull (even
// empty) leaf and a slightly-stale divider key are still a valid B-tree. Assumes rows
// with no per-cell overflow and tables rooted at page >= 2 (`headerOffset` 0).

case class InteriorNode(children: List[Int], keys: List[Long])
case class SplitPiece(page: Int, maxRowid: Long)
case class NodeSplit(pieces: List[SplitPiece])
case class BalanceState(pager: MutablePager, nextPage: Int)
case class LeafChunk(cells: List[LeafCell], maxRowid: Long)
case class InteriorChunk(children: List[Int], keys: List[Long], promoted: Long)

def hoff(page: Int): Int = if page == 1 then 100 else 0
def pageKindAt(page: ByteSlice, headerOffset: Int): Int = byteSliceGet(page, headerOffset) match
  case Right(value) => value
  case Left(_) => -1

def intReverse(items: List[Int], acc: List[Int]): List[Int] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

def longReverse(items: List[Long], acc: List[Long]): List[Long] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

def intListGet(items: List[Int], index: Int): Int =
  var r = items
  var i = 0
  var out = -1
  while r.nonEmpty do
    if i == index then out = r.head
    i = i + 1
    r = r.tail
  out

def intLast(items: List[Int]): Int =
  var r = items
  var out = -1
  while r.nonEmpty do
    out = r.head
    r = r.tail
  out

def intTake(items: List[Int], n: Int): List[Int] =
  var r = items
  var i = 0
  var accRev: List[Int] = Nil
  while i < n && r.nonEmpty do
    accRev = r.head :: accRev
    r = r.tail
    i = i + 1
  intReverse(accRev, Nil)

def intDrop(items: List[Int], n: Int): List[Int] =
  var r = items
  var i = 0
  while i < n && r.nonEmpty do
    r = r.tail
    i = i + 1
  r

def longTake(items: List[Long], n: Int): List[Long] =
  var r = items
  var i = 0
  var accRev: List[Long] = Nil
  while i < n && r.nonEmpty do
    accRev = r.head :: accRev
    r = r.tail
    i = i + 1
  longReverse(accRev, Nil)

def longDrop(items: List[Long], n: Int): List[Long] =
  var r = items
  var i = 0
  while i < n && r.nonEmpty do
    r = r.tail
    i = i + 1
  r

def reverseCellList(items: List[List[Int]], acc: List[List[Int]]): List[List[Int]] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

def reverseLeafChunks(items: List[LeafChunk], acc: List[LeafChunk]): List[LeafChunk] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

def reverseInteriorChunks(items: List[InteriorChunk], acc: List[InteriorChunk]): List[InteriorChunk] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

def reversePieces(items: List[SplitPiece], acc: List[SplitPiece]): List[SplitPiece] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

/** Decode a table-interior page into children (m+1, rightmost last) + dividers (m). */
def readInteriorNode(page: ByteSlice, headerOffset: Int): Either[ByteError, InteriorNode] =
  readU16Be(page, headerOffset + 3) match
    case Left(error) => Left(error)
    case Right(ByteRead(count, _)) => readU32Be(page, headerOffset + 8) match
      case Left(error) => Left(error)
      case Right(ByteRead(rightChild, _)) =>
        var rinI = 0
        var rinChildrenRev: List[Int] = Nil
        var rinKeysRev: List[Long] = Nil
        var rinFailure: Option[ByteError] = None
        while rinI < count.toInt && rinFailure.isEmpty do
          readU16Be(page, headerOffset + 12 + 2 * rinI) match
            case Left(error) => rinFailure = Some(error)
            case Right(ByteRead(cellPtr, _)) => readU32Be(page, cellPtr.toInt) match
              case Left(error) => rinFailure = Some(error)
              case Right(ByteRead(leftChild, _)) => decodeVarint(page, cellPtr.toInt + 4) match
                case Left(error) => rinFailure = Some(error)
                case Right(VarintRead(key, _, _)) =>
                  rinChildrenRev = leftChild.toInt :: rinChildrenRev
                  rinKeysRev = key :: rinKeysRev
          rinI = rinI + 1
        rinFailure match
          case Some(error) => Left(error)
          case None => Right(InteriorNode(intReverse(rinChildrenRev, List(rightChild.toInt)), longReverse(rinKeysRev, Nil)))

/** The child slot to follow for `rowid`: the first divider whose key >= rowid, else
 *  the rightmost child. */
def chooseChild(node: InteriorNode, rowid: Long): Int =
  var ccKeys = node.keys
  var ccI = 0
  var ccFound = -1
  while ccKeys.nonEmpty && ccFound < 0 do
    if rowid <= ccKeys.head then ccFound = ccI
    else
      ccI = ccI + 1
      ccKeys = ccKeys.tail
  if ccFound >= 0 then ccFound else node.children.length - 1

/** Greedily pack leaf cells into page-fitting chunks (each cell costs 2 + its bytes). */
def packLeafChunks(cells: List[LeafCell], pageSize: Int): List[LeafChunk] =
  val budget = pageSize - 8
  var plcRemaining = cells
  var plcCurRev: List[LeafCell] = Nil
  var plcSize = 0
  var plcChunksRev: List[LeafChunk] = Nil
  while plcRemaining.nonEmpty do
    val plcCell = plcRemaining.head
    val plcCost = 2 + plcCell.bytes.length
    if plcCurRev.isEmpty then
      plcCurRev = plcCell :: Nil
      plcSize = plcCost
      plcRemaining = plcRemaining.tail
    else if plcSize + plcCost <= budget then
      plcCurRev = plcCell :: plcCurRev
      plcSize = plcSize + plcCost
      plcRemaining = plcRemaining.tail
    else
      plcChunksRev = LeafChunk(leafReverseCells(plcCurRev, Nil), plcCurRev.head.rowid) :: plcChunksRev
      plcCurRev = plcCell :: Nil
      plcSize = plcCost
      plcRemaining = plcRemaining.tail
  val plcChunks = if plcCurRev.nonEmpty then LeafChunk(leafReverseCells(plcCurRev, Nil), plcCurRev.head.rowid) :: plcChunksRev else plcChunksRev
  reverseLeafChunks(plcChunks, Nil)

/** Greedily pack an interior node's children into page-fitting chunks; the divider at
 *  each chunk boundary is promoted (its key becomes a piece's `promoted` maxRowid). */
def packInteriorChunks(children: List[Int], keys: List[Long], pageSize: Int): List[InteriorChunk] =
  val budget = pageSize - 12
  var picChildren = children.tail
  var picKeys = keys
  var picCurChildrenRev: List[Int] = children.head :: Nil
  var picCurKeysRev: List[Long] = Nil
  var picSize = 0
  var picChunksRev: List[InteriorChunk] = Nil
  while picChildren.nonEmpty do
    val picNext = picChildren.head
    val picKey = picKeys.head
    val picCost = 6 + varintLen(picKey)
    if picSize + picCost <= budget then
      picCurKeysRev = picKey :: picCurKeysRev
      picCurChildrenRev = picNext :: picCurChildrenRev
      picSize = picSize + picCost
      picChildren = picChildren.tail
      picKeys = picKeys.tail
    else
      picChunksRev = InteriorChunk(intReverse(picCurChildrenRev, Nil), longReverse(picCurKeysRev, Nil), picKey) :: picChunksRev
      picCurChildrenRev = picNext :: Nil
      picCurKeysRev = Nil
      picSize = 0
      picChildren = picChildren.tail
      picKeys = picKeys.tail
  val picChunks = InteriorChunk(intReverse(picCurChildrenRev, Nil), longReverse(picCurKeysRev, Nil), 0L) :: picChunksRev
  reverseInteriorChunks(picChunks, Nil)

def buildInteriorCells(children: List[Int], keys: List[Long]): List[List[Int]] =
  var bicKeys = keys
  var bicI = 0
  var bicAccRev: List[List[Int]] = Nil
  while bicKeys.nonEmpty do
    bicAccRev = encodeInteriorCell(intListGet(children, bicI), bicKeys.head) :: bicAccRev
    bicI = bicI + 1
    bicKeys = bicKeys.tail
  reverseCellList(bicAccRev, Nil)

def buildInteriorFrom(children: List[Int], keys: List[Long], pageSize: Int, headerOffset: Int): Either[ByteError, List[Int]] =
  buildTableInteriorPage(pageSize, headerOffset, buildInteriorCells(children, keys), intLast(children))

/** Serialize a split's leaf chunks: chunk 0 keeps `firstPage`, the rest are allocated. */
def buildLeafChunks(state: BalanceState, firstPage: Int, chunks: List[LeafChunk], pageSize: Int): Either[ByteError, (BalanceState, NodeSplit)] =
  var blcPager = state.pager
  var blcNext = state.nextPage
  var blcRemaining = chunks
  var blcIndex = 0
  var blcPiecesRev: List[SplitPiece] = Nil
  var blcFailure: Option[ByteError] = None
  while blcRemaining.nonEmpty && blcFailure.isEmpty do
    val blcChunk = blcRemaining.head
    val blcPage = if blcIndex == 0 then firstPage else blcNext
    if blcIndex > 0 then blcNext = blcNext + 1
    buildTableLeafPage(pageSize, hoff(blcPage), leafCellBytesList(blcChunk.cells)) match
      case Left(error) => blcFailure = Some(error)
      case Right(body) => ByteSlice.fromList(body) match
        case Left(error) => blcFailure = Some(error)
        case Right(slice) =>
          blcPager = mutablePut(blcPager, blcPage, slice)
          blcPiecesRev = SplitPiece(blcPage, blcChunk.maxRowid) :: blcPiecesRev
    blcIndex = blcIndex + 1
    blcRemaining = blcRemaining.tail
  blcFailure match
    case Some(error) => Left(error)
    case None => Right((BalanceState(blcPager, blcNext), NodeSplit(reversePieces(blcPiecesRev, Nil))))

def buildInteriorChunks(state: BalanceState, firstPage: Int, chunks: List[InteriorChunk], pageSize: Int): Either[ByteError, (BalanceState, NodeSplit)] =
  var bicPager = state.pager
  var bicNext = state.nextPage
  var bicRemaining = chunks
  var bicIndex = 0
  var bicPiecesRev: List[SplitPiece] = Nil
  var bicFailure: Option[ByteError] = None
  while bicRemaining.nonEmpty && bicFailure.isEmpty do
    val bicChunk = bicRemaining.head
    val bicPage = if bicIndex == 0 then firstPage else bicNext
    if bicIndex > 0 then bicNext = bicNext + 1
    buildInteriorFrom(bicChunk.children, bicChunk.keys, pageSize, hoff(bicPage)) match
      case Left(error) => bicFailure = Some(error)
      case Right(body) => ByteSlice.fromList(body) match
        case Left(error) => bicFailure = Some(error)
        case Right(slice) =>
          bicPager = mutablePut(bicPager, bicPage, slice)
          bicPiecesRev = SplitPiece(bicPage, bicChunk.promoted) :: bicPiecesRev
    bicIndex = bicIndex + 1
    bicRemaining = bicRemaining.tail
  bicFailure match
    case Some(error) => Left(error)
    case None => Right((BalanceState(bicPager, bicNext), NodeSplit(reversePieces(bicPiecesRev, Nil))))

def splitPiecePages(pieces: List[SplitPiece]): List[Int] =
  var r = pieces
  var accRev: List[Int] = Nil
  while r.nonEmpty do
    accRev = r.head.page :: accRev
    r = r.tail
  intReverse(accRev, Nil)

def splitPieceKeysExceptLast(pieces: List[SplitPiece]): List[Long] =
  var r = pieces
  var accRev: List[Long] = Nil
  while r.nonEmpty do
    if r.tail.nonEmpty then accRev = r.head.maxRowid :: accRev
    r = r.tail
  longReverse(accRev, Nil)

/** Replace `node`'s child at `slot` with the split's pieces, inserting the first
 *  (pieces-1) piece maxRowids as new dividers at `slot`. */
def replaceChild(node: InteriorNode, slot: Int, split: NodeSplit): InteriorNode =
  val newChildren = intTake(node.children, slot) ++ splitPiecePages(split.pieces) ++ intDrop(node.children, slot + 1)
  val newKeys = longTake(node.keys, slot) ++ splitPieceKeysExceptLast(split.pieces) ++ longDrop(node.keys, slot)
  InteriorNode(newChildren, newKeys)

/** Rewrite a leaf's page (single chunk) or split it into sibling pages. */
def finishLeaf(state: BalanceState, pageNumber: Int, cells: List[LeafCell], pageSize: Int): Either[ByteError, (BalanceState, NodeSplit)] =
  buildLeafChunks(state, pageNumber, packLeafChunks(cells, pageSize), pageSize)

/** Rewrite an interior page or split it into sibling interior pages. */
def finishInterior(state: BalanceState, pageNumber: Int, node: InteriorNode, pageSize: Int): Either[ByteError, (BalanceState, NodeSplit)] =
  buildInteriorChunks(state, pageNumber, packInteriorChunks(node.children, node.keys, pageSize), pageSize)

/** Insert `rowid`/`record` into the subtree at `pageNumber`, balancing on the way up.
 *  Returns the updated state and this node's split result (1 piece = it did not split). */
def balanceInsertNode(state: BalanceState, pageNumber: Int, rowid: Long, record: ByteSlice, pageSize: Int, depth: Int): Either[ByteError, (BalanceState, NodeSplit)] =
  val bho = hoff(pageNumber)
  if depth > 64 then Left(ByteError("cycle", "balance descent exceeded 64 levels at page " + pageNumber.toString, pageNumber))
  else mutableGet(state.pager, pageNumber) match
    case Left(error) => Left(error)
    case Right(page) =>
      val kind = pageKindAt(page, bho)
      if kind == 13 then
        readLeafCells(page, bho) match
          case Left(error) => Left(error)
          case Right(cells) => leafInsertCell(cells, rowid, record) match
            case Left(msg) => Left(ByteError("duplicate", msg, 0))
            case Right(newCells) => finishLeaf(state, pageNumber, newCells, pageSize)
      else if kind == 5 then
        readInteriorNode(page, bho) match
          case Left(error) => Left(error)
          case Right(node) =>
            val slot = chooseChild(node, rowid)
            balanceInsertNode(state, intListGet(node.children, slot), rowid, record, pageSize, depth + 1) match
              case Left(error) => Left(error)
              case Right(childResult) =>
                val childState = childResult._1
                val childSplit = childResult._2
                if childSplit.pieces.length == 1 then Right((childState, NodeSplit(List(SplitPiece(pageNumber, 0L)))))
                else finishInterior(childState, pageNumber, replaceChild(node, slot, childSplit), pageSize)
      else Left(ByteError("kind", "unexpected page kind " + kind.toString + " at page " + pageNumber.toString, pageNumber))

/** Grow the tree a level: the overflowing root's content moves to a fresh page and
 *  the root page becomes an interior over the split pieces (root page number kept). */
def balanceDeeper(state: BalanceState, rootPage: Int, split: NodeSplit, pageSize: Int): Either[ByteError, MutablePager] =
  val newPage = state.nextPage
  mutableGet(state.pager, rootPage) match
    case Left(error) => Left(error)
    case Right(rootContent) =>
      val pager2 = mutablePut(state.pager, newPage, rootContent)
      val childPages = newPage :: intDrop(splitPiecePages(split.pieces), 1)
      buildInteriorFrom(childPages, splitPieceKeysExceptLast(split.pieces), pageSize, hoff(rootPage)) match
        case Left(error) => Left(error)
        case Right(body) => ByteSlice.fromList(body) match
          case Left(error) => Left(error)
          case Right(slice) => Right(mutablePut(pager2, rootPage, slice))

/** Set the file header's database size in pages (bytes 28..31 of page 1) to
 *  `totalPages`, so a grown tree's new child pages are in range for the reader and
 *  reference `integrity_check`. */
def patchHeaderPageCount(pager: MutablePager, totalPages: Int): Either[ByteError, MutablePager] =
  mutableGet(pager, 1) match
    case Left(error) => Left(error)
    case Right(page1) => byteSliceSlice(page1, 0, 28) match
      case Left(error) => Left(error)
      case Right(prefix) => byteSliceSlice(page1, 32, page1.length - 32) match
        case Left(error) => Left(error)
        case Right(suffix) =>
          ByteSlice.fromList(byteSliceToList(prefix) ++ byteSliceToList(writeU32Be(totalPages.toLong)) ++ byteSliceToList(suffix)) match
            case Left(error) => Left(error)
            case Right(newPage1) => Right(mutablePut(pager, 1, newPage1))

/** Insert one row in place with full B-tree balancing, staged on the mutable pager
 *  (commit it with `mutableCommit`). `rootPage` is the table's root page. */
def pagerInsertBalanced(pager: MutablePager, rootPage: Int, rowid: Long, record: ByteSlice, pageSize: Int): Either[ByteError, MutablePager] =
  balanceInsertNode(BalanceState(pager, mutableAllocate(pager)), rootPage, rowid, record, pageSize, 0) match
    case Left(error) => Left(error)
    case Right(result) =>
      val finalState = result._1
      val split = result._2
      val balanced = if split.pieces.length == 1 then Right(finalState.pager)
        else balanceDeeper(finalState, rootPage, split, pageSize)
      balanced match
        case Left(error) => Left(error)
        case Right(pagerAfter) => patchHeaderPageCount(pagerAfter, mutableAllocate(pagerAfter) - 1)

def descendToLeaf(pager: MutablePager, pageNumber: Int, rowid: Long): Either[ByteError, Int] =
  mutableGet(pager, pageNumber) match
    case Left(error) => Left(error)
    case Right(page) =>
      if pageKindAt(page, hoff(pageNumber)) == 13 then Right(pageNumber)
      else readInteriorNode(page, hoff(pageNumber)) match
        case Left(error) => Left(error)
        case Right(node) => descendToLeaf(pager, intListGet(node.children, chooseChild(node, rowid)), rowid)

/** Delete a row in place: rewrite the leaf holding `rowid` with the cell removed.
 *  No rebalance is needed for validity. Staged on the pager. */
def pagerDeleteBalanced(pager: MutablePager, rootPage: Int, rowid: Long, pageSize: Int): Either[ByteError, MutablePager] =
  descendToLeaf(pager, rootPage, rowid) match
    case Left(error) => Left(error)
    case Right(leafPage) => mutableGet(pager, leafPage) match
      case Left(error) => Left(error)
      case Right(page) => readLeafCells(page, hoff(leafPage)) match
        case Left(error) => Left(error)
        case Right(cells) => rebuildLeafPage(leafDeleteCell(cells, rowid), pageSize, hoff(leafPage)) match
          case Left(error) => Left(error)
          case Right(body) => ByteSlice.fromList(body) match
            case Left(error) => Left(error)
            case Right(slice) => Right(mutablePut(pager, leafPage, slice))

```
