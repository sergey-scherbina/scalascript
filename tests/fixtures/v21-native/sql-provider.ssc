#!/usr/bin/env ssc
---
databases:
  default:
    url: "jdbc:h2:mem:v21-native-sql;DB_CLOSE_DELAY=-1"
---

# Native SQL provider

```scalascript
Db.execute("default", "CREATE TABLE people (id BIGINT PRIMARY KEY, name VARCHAR(80), active BOOLEAN)", List())
println(Db.execute("default", "INSERT INTO people VALUES (?, ?, ?)", List(7, "Ada", true)))
println(Db.query("default", "SELECT id FROM people WHERE id = ?", List(7))(0)("ID"))
println(Db.query("default", "SELECT name FROM people WHERE id = ?", List(7))(0)("NAME"))
println(Db.query("default", "SELECT active FROM people WHERE id = ?", List(7))(0)("ACTIVE"))
```
