// `;`; a `with` inside the TYPE (`A with B`) is stepped over (not followed by `{`) until the real body/end.
def skipGivenDecl(ts) = skipGDscan(tl(ts))
def skipGDscan(ts) = if isEmpty(ts) then ts else (if isWord(hd(ts), "with") then skipGDwith(tl(ts)) else (if isTok(hd(ts), 2, 20) then skipStmt(ts) else (if isTok(hd(ts), 2, 52) then tl(ts) else skipGDscan(tl(ts)))))
