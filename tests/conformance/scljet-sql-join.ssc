---

# SclJet SQL inner join

`SELECT … FROM a JOIN b ON a.x = b.y [WHERE …]` is a nested-loop inner join: for each row of the
outer table and each row of the inner table where the ON condition holds (and the WHERE), one row
is emitted. Columns may be qualified (`a.col`) or bare. Verified out-of-band against reference
sqlite3 running the same SQL on the same file (join order matches the nested loop); locked here
across backends.

[ByteSlice, SqliteValue, SqlInteger, SqlText, buildTableDatabase](std/scljet/index.ssc)
[queryImage, renderRows, executeMutation](std/scljet/sql.ssc)

```scalascript
def apply(db: ByteSlice, sql: String): ByteSlice =
  executeMutation(db, sql) match
    case Left(m) =>
      println(sql + " => ERR:" + m)
      db
    case Right(next) => next

def show(db: ByteSlice, sql: String): Unit =
  queryImage(db, sql) match
    case Left(m) => println(sql + " => ERR:" + m)
    case Right(rows) => println(sql + " => " + renderRows(rows).toString)

buildTableDatabase(512, 1, 1, "emp", "CREATE TABLE emp(id INTEGER, name TEXT, dept INTEGER)",
  List(List(SqlInteger(1L), SqlText("ann"), SqlInteger(10L)),
       List(SqlInteger(2L), SqlText("bob"), SqlInteger(20L)),
       List(SqlInteger(3L), SqlText("cat"), SqlInteger(10L)),
       List(SqlInteger(4L), SqlText("dan"), SqlInteger(30L)))) match
  case Left(error) => println("build-error:" + error.message)
  case Right(db0) =>
    val db1 = apply(db0, "CREATE TABLE dept(did INTEGER, dname TEXT)")
    val db2 = apply(db1, "INSERT INTO dept VALUES (10, 'eng')")
    val db3 = apply(db2, "INSERT INTO dept VALUES (20, 'sales')")
    val db4 = apply(db3, "INSERT INTO dept VALUES (40, 'ops')")
    show(db4, "SELECT emp.name, dept.dname FROM emp JOIN dept ON emp.dept = dept.did")
    show(db4, "SELECT name, dname FROM emp JOIN dept ON emp.dept = dept.did WHERE dname = 'eng'")
    show(db4, "SELECT emp.id, emp.name FROM emp JOIN dept ON emp.dept = dept.did WHERE emp.id >= 2")
    show(db4, "SELECT * FROM emp JOIN dept ON emp.dept = dept.did")
    show(db4, "SELECT emp.name FROM emp JOIN dept ON emp.dept = dept.did WHERE emp.dept < 20")
    show(db4, "SELECT emp.name, dept.dname FROM emp LEFT JOIN dept ON emp.dept = dept.did")
    show(db4, "SELECT name, did FROM emp LEFT OUTER JOIN dept ON emp.dept = dept.did")
    show(db4, "SELECT emp.name FROM emp LEFT JOIN dept ON emp.dept = dept.did WHERE dept.did = 10")
```
