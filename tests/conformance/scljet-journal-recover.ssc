// A complete (hot) journal restores page 2's pre-image and reports 1 record.
applyRollbackJournal(dirty, hotJournal) match
  case Right(rec) => println("hot:" + rec.records.toString + ":" + rec.pages.toString + ":" + byteSliceToList(rec.database).toString)
  case Left(e) => println("hot:ERR:" + e.message)

// A journal without the complete-header magic is not hot; the database is unchanged.
applyRollbackJournal(dirty, coldJournal) match
  case Right(rec) => println("cold:" + rec.records.toString)
  case Left(e) => println("cold:ERR:" + e.message)
```
