      |fn _tui_table_height(attrs: &[(String, String)]) -> u16 {
      |    let sig = _tui_attr(attrs, "data-ssc-rows-sig").unwrap_or("");
      |    let path = _tui_attr(attrs, "data-ssc-rows-path").unwrap_or("");
      |    let json = crate::value::ssc_signals().lock().unwrap().get(sig).cloned().unwrap_or_default();
      |    let n = serde_json::from_str::<serde_json::Value>(&json).ok()
      |        .and_then(|v| _tui_drill(&v, path).and_then(|x| x.as_array()).map(|a| a.len()))
      |        .unwrap_or(0);
      |    (n as u16) + 1
      |}
