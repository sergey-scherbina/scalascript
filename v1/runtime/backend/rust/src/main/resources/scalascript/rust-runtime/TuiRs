      |/// Stack children — vertically (measured row heights) or, when the container
      |/// is CSS `flex-direction:row`, horizontally (equal columns).
      |fn _tui_stack(frame: &mut Frame, area: Rect, children: &[View], ctx: &mut _TuiCtx, horizontal: bool) {
      |    if children.is_empty() { return; }
      |    if children.len() == 1 { _tui_render(frame, area, &children[0], ctx); return; }
      |    let n = children.len() as u32;
      |    let chunks = if horizontal {
      |        let cons: Vec<Constraint> = (0..n).map(|_| Constraint::Ratio(1, n)).collect();
      |        Layout::horizontal(cons).split(area)
      |    } else {
      |        let cons: Vec<Constraint> = children.iter().map(|c| Constraint::Length(_tui_height(c))).collect();
      |        Layout::vertical(cons).split(area)
      |    };
      |    for (i, c) in children.iter().enumerate() { _tui_render(frame, chunks[i], c, ctx); }
      |}
