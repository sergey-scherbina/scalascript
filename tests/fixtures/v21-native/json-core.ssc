# Self-hosted JSON core

[JsonCoreErr, jsonCoreParseStrict, jsonCoreParseTolerant, jsonCoreValueOrNull, jsonCoreGet, jsonCoreAt, jsonCoreIsNull, jsonCoreAsDecimalText, jsonCoreAsBool, jsonCoreArraySize, jsonCoreRender, jsonCoreRenderResult, jsonCoreKind](std/json-core.ssc)

```scalascript
val valid = List(
  "null",
  "true",
  "-12.3400e+2",
  "\"line\\nquote: \\\" slash: \\\\\u0041\"",
  "\"\\u0041\"",
  "[1, 2, {\"ok\":true}]",
  "{\"name\":\"Ada\",\"emoji\":\"\\uD83D\\uDE00\"}",
  " \n{\"x\":0} \t"
)

for source <- valid do
  println(jsonCoreRenderResult(jsonCoreParseStrict(source)))

val invalid = List(
  "01",
  "1.",
  "1e+",
  "\"\\u12G4\"",
  "\"\\uD800\"",
  "\"\\uDE00\"",
  "\"abc",
  "[1,]",
  "{\"a\":1,}",
  "{\"a\" 1}",
  "true false"
)

for source <- invalid do
  println(jsonCoreRenderResult(jsonCoreParseStrict(source)))

val navigable = jsonCoreValueOrNull(
  jsonCoreParseStrict("{\"amount\":1234567890.0012300,\"ok\":true,\"steps\":[1,2]}")
)
println(jsonCoreAsDecimalText(jsonCoreGet(navigable, "amount")))
println(jsonCoreAsBool(jsonCoreGet(navigable, "ok")))
println(jsonCoreAsDecimalText(jsonCoreAt(jsonCoreGet(navigable, "steps"), 1)))
println(jsonCoreArraySize(jsonCoreGet(navigable, "steps")))
println(jsonCoreIsNull(jsonCoreGet(navigable, "missing")))
println(jsonCoreIsNull(jsonCoreAt(jsonCoreGet(navigable, "steps"), 9)))
println(jsonCoreIsNull(jsonCoreGet(jsonCoreAt(navigable, 0), "wrong-shape")))

println(jsonCoreRender(jsonCoreParseTolerant("not-json")))
println(jsonCoreKind(jsonCoreParseTolerant("[]")))
```
