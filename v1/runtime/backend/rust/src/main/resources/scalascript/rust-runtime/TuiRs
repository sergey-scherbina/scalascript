      |// ── fetch + DataTable (tui target, intrinsic-overlaid) ───────────────────────
      |// fetchUrlSignal: a blocking GET at construction seeds the signal store with the
      |// response body, and the returned signal carries it. (refreshTick is ignored on
      |// tui — the fetch happens once at startup; tick-driven re-fetch is a follow-up.)
      |pub fn _tui_fetch_url_signal(name: String, url: String, _tick: crate::value::Value) -> crate::value::Value {
      |    let body = _tui_http_get(&url);
      |    crate::value::ssc_signals().lock().unwrap().insert(name.clone(), body.clone());
      |    crate::value::Value::Signal(name, Box::new(crate::value::Value::Str(body)))
      |}
      |
      |fn _tui_http_get(url: &str) -> String {
      |    match ureq::get(url).call() {
      |        Ok(resp) => resp.into_string().unwrap_or_default(),
      |        Err(_) => String::new(),
      |    }
      |}
