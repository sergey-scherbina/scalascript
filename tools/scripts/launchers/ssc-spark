#!/usr/bin/env bash
# ssc-spark — ScalaScript Apache Spark runner.
#
# Generates Scala 3 + Spark source from a .ssc module via the Spark
# backend (SparkGen) and runs it through `scala-cli`, which pulls
# spark-core + spark-sql at the requested version from Maven Central
# (cached by Coursier on first use).
#
# Usage:
#   ssc-spark file.ssc                                       # defaults: 4.0.0, local[*]
#   ssc-spark --spark-version 3.5.1 file.ssc                 # override version
#   ssc-spark --spark-master local[4] file.ssc               # override master URL
#   ssc-spark --spark-master spark://host:7077 file.ssc      # run against a cluster
#
# Spark version + master URL resolution (each independently), highest first:
#   1. --spark-version <v> / --spark-master <url> on the command line
#   2. spark-version: / spark-master: in the .ssc front-matter
#   3. SparkGen.DefaultVersion ("4.0.0") / SparkGen.DefaultMaster ("local[*]")
#
# Requires `scala-cli` on PATH and (first run only) network access to
# fetch the Spark JARs.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SSC="$SCRIPT_DIR/ssc"

if ! command -v scala-cli >/dev/null 2>&1; then
  cat >&2 <<EOF
ssc-spark: scala-cli not found on PATH.

The Spark backend works by generating a Scala 3 source file and handing
it to scala-cli with the right --dep flags.  Install scala-cli first:

  curl -sSLf https://scala-cli.virtuslab.org/get | sh

Then re-run: ssc-spark "\$@"
EOF
  exit 2
fi

if [ "$#" -eq 0 ]; then
  cat >&2 <<EOF
Usage: ssc-spark [--spark-version <v>] [--spark-master <url>] <file.ssc> [<file.ssc>...]

  --spark-version <v>   Override the Spark version (front-matter
                        spark-version: wins otherwise; default
                        SparkGen.DefaultVersion = 4.0.0).
  --spark-master <url>  Override the Spark master URL (front-matter
                        spark-master: wins otherwise; default
                        SparkGen.DefaultMaster = local[*]).
                        Accepted: local[*] / local[N] / spark://...
                        / yarn / k8s://...

Examples:
  ssc-spark examples/word-count.ssc
  ssc-spark --spark-version 3.5.1 examples/word-count.ssc
  ssc-spark --spark-master local[4] examples/word-count.ssc
  ssc-spark --spark-master spark://prod.example.com:7077 examples/word-count.ssc
EOF
  exit 1
fi

exec "$SSC" run --backend spark "$@"
