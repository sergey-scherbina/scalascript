# Hidden files and directories — catch-all; only the whitelisted ones below are tracked
.*
.*/
!.github/
!.gitignore
!.gitattributes
!.work/
!.agents/
!.githooks/
!.githooks/**

.ssc-artifacts/
# Allow .ssc-artifacts/ inside scripted test fixtures (they are checked-in test data)
!tools/sbt-plugin/src/sbt-test/**/.ssc-artifacts/
!tools/sbt-plugin/src/sbt-test/**/.ssc-artifacts/**

# Build outputs
target/
out/
dist/
build/

# Repo-local bin/ is generated by `install.sh` / `sbt cli/stage`.
# bin/lib/ holds staged JARs; bin/lib/compiler/plugins/ holds .sscpkg files.
# Sources for bin/ wrappers live in scripts/launchers/.
/bin/
/lib/
# Compiled JVM artifacts produced by compile-jvm / package
*.scjvm

# Scala CLI
.scala-build/

# IDE
.idea/
.vscode/
*.iml
.project
.classpath
.settings/

# Scala
*.class
*.log
.bloop/
.metals/
.bsp/
project/target/
project/project/

# JMH profiler / per-benchmark output directories
runtime/backend/interpreter-bench/scalascript.bench.*/
lang/core-bench/scalascript.bench.*/
bench/BASELINE_RUNTIME.md
bench/jmh-results*.json
bench/jmh-smoke*.json
bench/*.jfr

# Node (for JS backend tooling)
node_modules/
npm-debug.log
yarn-error.log

# OS
.DS_Store
Thumbs.db

# Temporary files
*.swp
*.swo
*~
.cache/

# ScalaScript compiled artifacts
*.ssc.js
*.ssc.class
.scalascript/

# SQLite databases generated by ssc scripts at runtime
todos.db
*.db

# Conformance test artifacts (generated at runtime, not source)
conf-results*.txt
*.scjs
*.scjs-runtime

# Generated docs site (produced by v1/tools/docs-site/generate.ssc in the Pages workflow)
site/docs/
