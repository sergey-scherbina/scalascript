# `std.http` — HTTP server primitives

Platform-neutral HTTP server primitives.  Implementations live in each
backend's intrinsic table (Stage 5+/B); the per-backend runtime helpers
are shipped via `Backend.runtimePreamble` (Stage 5+/A.6).

```scalascript
// TLS configuration — pass to serve() to enable HTTPS.
extern def tls(certPath: String, keyPath: String): TlsContext

// Lifecycle
extern def serve(port: Int): Unit
extern def serve(port: Int, tlsCtx: TlsContext): Unit
extern def stop(): Unit

// Route registration — curried: route(method, path) { handler }
extern def route(method: String, path: String, handler: Request => Response): Unit

// Middleware — wraps every route handler.  First registered = outermost.
// Call next() to pass control to the next middleware / route handler.
extern def use(fn: (Request, () => Response) => Response): Unit

// Outbound HTTP client
extern def httpGet(url: String): Response
extern def httpGet(url: String, headers: Map[String, String]): Response
extern def httpPost(url: String, body: String): Response
extern def httpPost(url: String, body: String, headers: Map[String, String]): Response
extern def httpPut(url: String, body: String): Response
extern def httpPut(url: String, body: String, headers: Map[String, String]): Response
extern def httpPatch(url: String, body: String): Response
extern def httpPatch(url: String, body: String, headers: Map[String, String]): Response
extern def httpDelete(url: String): Response
extern def httpDelete(url: String, headers: Map[String, String]): Response
extern def httpClient(baseUrl: String)(block: => Unit): Unit
// Set outbound HTTP timeout (ms) for all requests in the current httpClient{} block.
// Default: 30 000 ms.  Scoped — restored to the previous value when the block exits.
extern def httpTimeout(ms: Int): Unit
// Retry on network errors and 5xx responses.  maxAttempts = total tries (not extra).
// delayMs between attempts, default 1 000 ms.  Scoped like httpTimeout.
extern def httpRetry(maxAttempts: Int): Unit
extern def httpRetry(maxAttempts: Int, delayMs: Int): Unit

// Streaming outbound HTTP — calls handler for each line as it arrives.
// Useful for SSE consumers, LLM streaming APIs (OpenAI, Anthropic), and chunked
// downloads.  Returns a Response with status + headers; body is empty (consumed
// line-by-line by the handler).
extern def httpGetStream(url: String)(handler: String => Unit): Response
extern def httpGetStream(url: String, headers: Map[String, String])(handler: String => Unit): Response
extern def httpPostStream(url: String, body: String)(handler: String => Unit): Response
extern def httpPostStream(url: String, body: String, headers: Map[String, String])(handler: String => Unit): Response

// Outbound WebSocket client — blocks until the server closes the connection.
// handler receives a WebSocket object with send / recv / onMessage / close / ping / etc.
extern def wsConnect(url: String)(handler: WebSocket => Unit): Unit
extern def wsConnect(url: String, headers: Map[String, String])(handler: WebSocket => Unit): Unit
extern def wsConnect(url: String, headers: Map[String, String], protocols: List[String])(handler: WebSocket => Unit): Unit

// CORS — register a global policy applied to every response (including OPTIONS preflight).
// origins: List("*") for open or List("https://app.com") for specific.
extern def cors(origins: List[String]): Unit
extern def cors(origins: List[String], methods: List[String]): Unit
extern def cors(origins: List[String], methods: List[String], headers: List[String]): Unit

// gzip — enable automatic compression for text/* / JSON responses when client accepts it.
extern def useGzip(): Unit

// Cache helpers — add Cache-Control / ETag to an existing Response.
// 304 short-circuit fires automatically in the server when ETag matches If-None-Match.
extern def cacheable(response: Response, maxAge: Int): Response
extern def cacheable(response: Response, maxAge: Int, etag: String): Response
extern def noCache(response: Response): Response

// Streaming responses — chunked transfer; the block receives a write(chunk) callback.
extern def streamResponse(block: (String => Unit) => Unit): Response
extern def streamResponse(status: Int)(block: (String => Unit) => Unit): Response
extern def streamResponse(status: Int, headers: Map[String, String])(block: (String => Unit) => Unit): Response

// Body size limit — reject requests whose body exceeds n bytes with 413.
extern def maxBodySize(bytes: Int): Unit

// Spool-to-disk — file parts larger than the threshold are written to a
// temp file under uploadDir instead of held in memory.
// Default threshold: 1 MiB.  Default dir: OS temp directory.
// The temp file is deleted automatically after the route handler returns.
extern def uploadSpoolThreshold(bytes: Int): Unit
extern def uploadDir(path: String): Unit

// Server-Sent Events — sets Content-Type: text/event-stream and keeps the
// connection open while the block runs.  stream.send(data) writes
// "data: <data>\n\n"; stream.send(event, data) also sets the event field.
extern def sse(req: Request)(block: SseStream => Unit): Response
```

# SseStream

```scalascript
// Yielded to the sse() block; not constructable by user code.
extern class SseStream:
  def send(data: String): Unit
  def send(event: String, data: String): Unit
  def close(): Unit
```

# UploadedFile

```scalascript
// Multipart file upload.  For parts ≤ uploadSpoolThreshold the raw bytes
// are available in `bytes` (Latin-1 encoded, 1 char = 1 byte); use
// `Buffer.from(bytes, 'latin1')` (JS) or `bytes.getBytes("ISO-8859-1")`
// (JVM) to recover the original bytes.  For parts that were spooled to
// disk `bytes` is empty and `path` holds the temp-file path; read with
// java.nio.file.Files.readAllBytes / fs.readFileSync as appropriate.
extern class UploadedFile:
  val name:        String  // form field name
  val filename:    String  // original filename from the browser
  val contentType: String  // MIME type, e.g. "image/jpeg"
  val size:        Int     // part body length in bytes
  val bytes:       String  // raw bytes as Latin-1 String; empty when spooled
  val path:        String  // temp-file path when spooled; "" otherwise
```

# Request / Response

```scalascript
// Incoming HTTP request.  All fields are populated by the backend before
// the route handler is called; absent values are empty/None.
case class Request(
  method:  String,                    // "GET", "POST", …
  path:    String,                    // decoded URL path, e.g. "/users/42"
  headers: Map[String, String],       // header name → value (lower-cased)
  body:    String,                    // raw request body (UTF-8)
  form:    Map[String, String],       // application/x-www-form-urlencoded fields
  files:   Map[String, Any],          // multipart file uploads → UploadedFile
  cookies: Map[String, String],       // Cookie header, parsed
  session: Map[String, String],       // signed session payload
  json:    Option[Any]                // parsed JSON body, or None
)

// Outgoing HTTP response.  Build with Response.json / Response.text / etc.
// or construct directly.
case class Response(
  status:  Int,                       // HTTP status code, e.g. 200
  headers: Map[String, String],       // response headers
  body:    String                     // response body (UTF-8)
)
```
