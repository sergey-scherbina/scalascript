#!/usr/bin/env bash
# ssc1 — end-to-end v1.0 .ssc Markdown runner (KC13)
# Usage: ./ssc1 <file.ssc>
# Pipeline: extract scalascript blocks → compile → run on v2 VM
set -euo pipefail
DIR="$(cd "$(dirname "$0")" && pwd)"
# --java-opt=-Xss512m: large .ssc programs recurse deeply in the VM's compile stage.
IR=$(command scala-cli run "$DIR/src" --server=false --quiet --java-opt=-Xss512m -- run "$DIR/bin/ssc1-run.ssc0" "$@")
printf '%s\n' "$IR" | command scala-cli run "$DIR/src" --server=false --quiet --java-opt=-Xss512m -- run-ir /dev/stdin
