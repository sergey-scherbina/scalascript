// The original page 2 is the pre-image; write it into a rollback journal.
byteSliceSlice(original, 512, 512) match
  case Left(e) => println("slice-err:" + e.message)
  case Right(page2) =>
    writeRollbackJournal(512, 512, 2, 12345, List(JournalPage(2, page2))) match
      case Left(e) => println("write-err:" + e.message)
      case Right(journal) =>
        // Recovering the dirtied database with that hot journal restores page 2.
        applyRollbackJournal(dirty, journal) match
          case Left(e) => println("recover-err:" + e.message)
          case Right(rec) => println("hot:" + rec.records.toString + ":" + rec.pages.toString + ":" + byteSliceToList(rec.database).toString)
