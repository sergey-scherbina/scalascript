      |/// dataTableView(source, columns, actions, row_key_path) → a `<table>` View whose data attrs
      |/// encode the source signal id, the rows path, and the columns; the tui renderer
      |/// reads the LIVE signal JSON and renders a ratatui Table.
      |pub fn _tui_data_table_view(
      |    source: crate::value::Value,
      |    columns: Vec<crate::value::Value>,
      |    _actions: Vec<crate::value::Value>,
      |    row_key_path: String,
      |) -> View {
      |    use crate::value::Value;
      |    let (sig_name, rows_path) = match source {
      |        Value::Tuple(parts) if parts.len() == 2 => {
      |            let name = match &parts[0] { Value::Signal(n, _) => n.clone(), other => other.show() };
      |            let path = match &parts[1] { Value::Str(p) => p.clone(), other => other.show() };
      |            (name, path)
      |        }
      |        Value::Signal(n, _) => (n, String::new()),
      |        other => (other.show(), String::new()),
      |    };
      |    let cols_enc = columns.iter().map(|c| match c {
      |        Value::Tuple(p) if p.len() >= 2 => format!("{}\u{1}{}", p[0].show(), p[1].show()),
      |        other => other.show(),
      |    }).collect::<Vec<_>>().join("\u{2}");
      |    View::Element {
      |        tag: "table".to_string(),
      |        attrs: vec![
      |            ("data-ssc-rows-sig".to_string(), sig_name),
      |            ("data-ssc-rows-path".to_string(), rows_path),
      |            ("data-ssc-cols".to_string(), cols_enc),
      |            ("data-ssc-row-key".to_string(), row_key_path),
      |        ],
      |        children: vec![],
      |    }
      |}
      |
      |fn _tui_decode_cols(enc: &str) -> Vec<(String, String)> {
      |    if enc.is_empty() { return vec![]; }
      |    enc.split('\u{2}').filter_map(|c| {
      |        let mut it = c.splitn(2, '\u{1}');
      |        let title = it.next()?.to_string();
      |        let field = it.next().unwrap_or("").to_string();
      |        Some((title, field))
      |    }).collect()
      |}
