      |fn _tui_drill<'a>(v: &'a serde_json::Value, path: &str) -> Option<&'a serde_json::Value> {
      |    if path.is_empty() {
      |        return ["data", "rows", "items", "results"].iter().find_map(|k| v.get(k)).or(Some(v));
      |    }
      |    let mut cur = v;
      |    for part in path.split('.') { cur = cur.get(part)?; }
      |    Some(cur)
      |}
      |
      |fn _tui_json_field(row: &serde_json::Value, path: &str) -> String {
      |    let mut cur = row;
      |    for part in path.split('.') {
      |        match cur.get(part) { Some(x) => cur = x, None => return String::new() }
      |    }
      |    match cur {
      |        serde_json::Value::String(s) => s.clone(),
      |        serde_json::Value::Null => String::new(),
      |        other => other.to_string(),
      |    }
      |}
