```scalascript
val condition = if (true || false) && true then "condition-ok" else "condition-bad"
println(condition)

val stages = List(("stage", 7))
val emptyTail = stages match {
  case (name, pass) :: rest =>
    println(name)
    println(pass)
    rest == Nil
  case _ => false
}
println(emptyTail)
```
