      |fn _tui_snapshot(view: &View, focus: usize) -> String {
      |    let mut terminal = Terminal::new(TestBackend::new(100, 40)).expect("tui init");
      |    terminal.draw(|f| {
      |        let a = f.area();
      |        let mut ctx = _TuiCtx { focus, counter: 0 };
      |        _tui_render(f, a, view, &mut ctx);
