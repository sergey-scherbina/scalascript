#!/usr/bin/env bash
# ssctc — the ssct COMPILER: .ssct -> Core IR bytecode (stdout). An ssc0 program
# (bin/ssctc.ssc0) run on the ssc VM. Pipe to `ssc run-ir` to execute:
#   ./ssctc examples/id.ssct > id.coreir && ./ssc run-ir id.coreir
set -euo pipefail
DIR="$(cd "$(dirname "$0")" && pwd)"
exec command scala-cli run "$DIR/src" --server=false --quiet -- run "$DIR/bin/ssctc.ssc0" "$@"
