#!/usr/bin/env bash
# Read-only coordination status for parallel agents.

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
REMOTE_REF="${SSC_COORD_REF:-origin/main}"
DO_FETCH=true

usage() {
  cat <<'EOF'
Usage: scripts/coord-status [--no-fetch]

Shows the authoritative remote queue/claims plus local worktree state:
  - current origin/main commit
  - exact-commit GitHub CI state (green/red/pending/unknown)
  - active .work/active/*.claim files from origin/main
  - live and prunable git worktrees
  - clean linked worktrees whose HEAD has already landed on origin/main
  - first pending configured sprint item that looks free to pick

This script is read-only except for `git fetch origin`.

Environment:
  SSC_COORD_REF=origin/main   remote ref to inspect
  SSC_COORD_NOW_EPOCH=<secs>  fixed current time for deterministic tests
EOF
}

significant_tokens() {
  printf '%s\n' "$1" |
    LC_ALL=C tr '[:upper:]' '[:lower:]' |
    sed -E 's/[^a-z0-9]+/ /g' |
    tr ' ' '\n' |
    grep -E '^[a-z0-9]{3,}$' |
    grep -Ev '^(feature|feat|fix|perf|tooling|cleanup|claim|phase|open|chore|docs|doc|test|tests|bench|jmh|wip|main|green|red)$' |
    grep -Ev '^[0-9]+$' || true
}

token_count() {
  local tokens="$1"
  local count=0
  while IFS= read -r token; do
    [[ -n "$token" ]] || continue
    count=$((count + 1))
  done <<<"$tokens"
  printf '%s\n' "$count"
}

slug_matches_record() {
  local slug="$1"
  local record_tokens="$2"
  local slug_tokens
  slug_tokens="$(significant_tokens "$slug")"

  local needed
  needed="$(token_count "$slug_tokens")"
  if [[ "$needed" -gt 2 ]]; then
    needed=2
  fi

  local matched=0
  local token
  while IFS= read -r token; do
    [[ -n "$token" ]] || continue
    if printf '%s\n' "$record_tokens" | tr ' ' '\n' | grep -Fxq "$token"; then
      matched=$((matched + 1))
      if [[ "$matched" -ge "$needed" ]]; then
        return 0
      fi
    fi
  done <<<"$slug_tokens"
  return 1
}

find_live_match() {
  local slug="$1"

  if printf '%s\n' "$live_keys" | grep -Fxq "$slug"; then
    printf 'exact live key match: %s\n' "$slug"
    return 0
  fi

  local record
  while IFS= read -r record; do
    [[ -n "$record" ]] || continue
    local record_tokens="${record%%|*}"
    local rest="${record#*|}"
    local branch="${rest%%|*}"
    local wt_dir="${rest#*|}"
    if slug_matches_record "$slug" "$record_tokens"; then
      printf '%s (%s)\n' "$branch" "$wt_dir"
      return 0
    fi
  done <<<"$live_records"

  return 1
}

claim_declared_branch() {
  local claim_text="$1"
  printf '%s\n' "$claim_text" |
    sed -n 's/^branch:[[:space:]]*//p' |
    head -1
}

parse_utc_epoch() {
  local value="$1"
  [[ "$value" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$ ]] || return 1

  local parsed
  if parsed="$(date -u -d "$value" +%s 2>/dev/null)"; then
    printf '%s\n' "$parsed"
    return 0
  fi
  if parsed="$(date -j -u -f '%Y-%m-%dT%H:%M:%SZ' "$value" +%s 2>/dev/null)"; then
    printf '%s\n' "$parsed"
    return 0
  fi
  return 1
}

claim_heartbeat() {
  local claim_text="$1"
  printf '%s\n' "$claim_text" |
    sed -n 's/^heartbeat:[[:space:]]*//p' |
    head -1
}

claim_declared_branch_is_live() {
  local claim_text="$1"
  local claim_branch
  claim_branch="$(claim_declared_branch "$claim_text")"
  [[ -n "$claim_branch" ]] || return 1
  printf '%s\n' "$live_keys" | grep -Fxq "$claim_branch"
}

claim_branch_diagnostic() {
  local claim_text="$1"
  local live_match="$2"
  local claim_branch
  claim_branch="$(claim_declared_branch "$claim_text")"
  if [[ -n "$live_match" ]]; then
    printf 'live:%s\n' "$live_match"
  elif [[ -n "$claim_branch" ]]; then
    printf 'missing:%s\n' "$claim_branch"
  else
    printf 'missing:unknown\n'
  fi
}

NOW_EPOCH="${SSC_COORD_NOW_EPOCH:-}"
if [[ -z "$NOW_EPOCH" ]]; then
  NOW_EPOCH="$(date -u +%s)"
elif [[ ! "$NOW_EPOCH" =~ ^[0-9]+$ ]]; then
  printf 'coord-status: SSC_COORD_NOW_EPOCH must be integer seconds, got %q\n' "$NOW_EPOCH" >&2
  exit 2
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    --no-fetch) DO_FETCH=false; shift ;;
    --help|-h) usage; exit 0 ;;
    *) echo "coord-status: unknown argument: $1" >&2; usage >&2; exit 2 ;;
  esac
done

if $DO_FETCH; then
  git -C "$ROOT" fetch origin --quiet
fi

agents_text="$(git -C "$ROOT" show "$REMOTE_REF:AGENTS.md" 2>/dev/null || true)"
queue_file="$(printf '%s\n' "$agents_text" | grep -m1 '^SPRINT:' | awk '{print $2}' || true)"
if [[ -z "$queue_file" ]]; then
  queue_file="$(
    printf '%s\n' "$agents_text" |
      sed -n 's/^\*\*Queue file for this project:\*\* `\([^`]*\)`.*/\1/p' |
      head -1
  )"
fi
queue_file="${queue_file:-SPRINT.md}"

echo "== $REMOTE_REF =="
git -C "$ROOT" log --oneline -1 "$REMOTE_REF"
echo

echo "== GitHub CI for $REMOTE_REF =="
remote_sha="$(git -C "$ROOT" rev-parse "$REMOTE_REF^{commit}")"
ci_code=0
"$ROOT/scripts/ci-status" --sha "$remote_sha" || ci_code=$?
if [[ "$ci_code" -ne 0 ]]; then
  printf '  exact-SHA CI is not green (exit %s); coordination status continues\n' "$ci_code"
fi
echo

active_files="$(git -C "$ROOT" ls-tree -r --name-only "$REMOTE_REF" .work/active 2>/dev/null || true)"
claim_files="$(printf '%s\n' "$active_files" | grep '\.claim$' || true)"
invalid_active_files="$(
  printf '%s\n' "$active_files" |
    grep -Ev '(^$|^\.work/active/_placeholder$|\.claim$)' || true
)"

claimed_slugs=""
invalid_slugs=""
echo "== active claims =="
if [[ -z "$claim_files" ]]; then
  if [[ -n "$invalid_active_files" ]]; then
    echo "none (invalid active markers found below)"
  else
    echo "none"
  fi
else
  while IFS= read -r claim_file; do
    [[ -n "$claim_file" ]] || continue
    slug="${claim_file##*/}"
    slug="${slug%.claim}"
    owner="$(git -C "$ROOT" show "$REMOTE_REF:$claim_file" 2>/dev/null || true)"
    owner="${owner//$'\n'/ }"
    printf '%-42s %s\n' "$slug" "$owner"
    claimed_slugs="${claimed_slugs}"$'\n'"${slug}"
  done <<<"$claim_files"
fi
echo

echo "== invalid active markers =="
if [[ -z "$invalid_active_files" ]]; then
  echo "none"
else
  while IFS= read -r marker_file; do
    [[ -n "$marker_file" ]] || continue
    marker="${marker_file##*/}"
    owner="$(git -C "$ROOT" show "$REMOTE_REF:$marker_file" 2>/dev/null || true)"
    owner="${owner//$'\n'/ }"
    printf '%-42s %s\n' "$marker" "$owner"
    printf '  repair: git mv %s %s.claim\n' "$marker_file" "$marker_file"
    invalid_slugs="${invalid_slugs}"$'\n'"${marker}"
  done <<<"$invalid_active_files"
fi
echo

live_keys=""
live_records=""
clean_landed_worktrees=""
print_worktree() {
  local wt_dir="$1"
  local branch="$2"
  local prunable="$3"
  local locked="$4"
  local branch_name="$branch"
  local base_name
  base_name="${wt_dir##*/}"

  [[ -n "$branch_name" ]] || branch_name="(detached)"
  printf '%s\n' "$wt_dir"
  printf '  branch: %s\n' "$branch_name"
  if [[ -n "$locked" ]]; then
    printf '  locked: %s\n' "$locked"
  fi

  if [[ -n "$prunable" ]]; then
    printf '  prunable: %s\n' "$prunable"
    return
  fi

  live_keys="${live_keys}"$'\n'"${base_name}"
  if [[ "$branch_name" != "(detached)" ]]; then
    live_keys="${live_keys}"$'\n'"${branch_name}"$'\n'"${branch_name//\//+}"
  fi

  local record_tokens
  record_tokens="$(printf '%s\n%s\n' "$(significant_tokens "$base_name")" "$(significant_tokens "$branch_name")" | sort -u | tr '\n' ' ' | sed -E 's/[[:space:]]+$//')"
  if [[ -n "$record_tokens" ]]; then
    live_records="${live_records}"$'\n'"${record_tokens}|${branch_name}|${wt_dir}"
  fi

  local status
  status="$(git -C "$wt_dir" status -s 2>/dev/null | head -5 || true)"
  if [[ -n "$status" ]]; then
    printf '  status:\n%s\n' "$(printf '%s\n' "$status" | sed 's/^/    /')"
  else
    printf '  status: clean\n'
  fi

  local ahead
  ahead="$(git -C "$wt_dir" log --oneline "$REMOTE_REF"..HEAD 2>/dev/null | head -5 || true)"
  if [[ -n "$ahead" ]]; then
    printf '  ahead of %s:\n%s\n' "$REMOTE_REF" "$(printf '%s\n' "$ahead" | sed 's/^/    /')"
  fi

  if [[ -z "$status" && -z "$ahead" && -z "$locked" && ! -d "$wt_dir/.git" ]]; then
    if git -C "$wt_dir" merge-base --is-ancestor HEAD "$REMOTE_REF" 2>/dev/null; then
      local head
      head="$(git -C "$wt_dir" rev-parse --short HEAD 2>/dev/null || true)"
      clean_landed_worktrees="${clean_landed_worktrees}"$'\n'"${wt_dir}|${branch_name}|${head}"
    fi
  fi
}

echo "== worktrees =="
wt_dir=""
wt_branch=""
wt_prunable=""
wt_locked=""
while IFS= read -r line; do
  case "$line" in
    worktree\ *)
      if [[ -n "$wt_dir" ]]; then
        print_worktree "$wt_dir" "$wt_branch" "$wt_prunable" "$wt_locked"
      fi
      wt_dir="${line#worktree }"
      wt_branch=""
      wt_prunable=""
      wt_locked=""
      ;;
    branch\ refs/heads/*)
      wt_branch="${line#branch refs/heads/}"
      ;;
    prunable\ *)
      wt_prunable="${line#prunable }"
      ;;
    locked*)
      wt_locked="${line#locked }"
      if [[ "$wt_locked" = "$line" ]]; then
        wt_locked="locked"
      fi
      ;;
  esac
done < <(git -C "$ROOT" worktree list --porcelain)
if [[ -n "$wt_dir" ]]; then
  print_worktree "$wt_dir" "$wt_branch" "$wt_prunable" "$wt_locked"
fi
echo

echo "== clean landed worktrees =="
if [[ -z "$clean_landed_worktrees" ]]; then
  echo "none"
else
  while IFS='|' read -r wt_dir branch_name head; do
    [[ -n "$wt_dir" ]] || continue
    printf '%s\n' "$wt_dir"
    printf '  branch: %s\n' "$branch_name"
    printf '  head: %s is already in %s\n' "${head:-unknown}" "$REMOTE_REF"
    printf '  cleanup: git worktree remove --force %q' "$wt_dir"
    if [[ "$branch_name" != "(detached)" ]]; then
      printf ' && git branch -D %q' "$branch_name"
    fi
    printf '\n'
  done <<<"$clean_landed_worktrees"
fi
echo

echo "== stale-claim check =="
if [[ -z "$claim_files" ]]; then
  echo "no claims"
else
  found_stale=false
  while IFS= read -r claim_file; do
    [[ -n "$claim_file" ]] || continue
    slug="${claim_file##*/}"
    slug="${slug%.claim}"
    claim_text="$(git -C "$ROOT" show "$REMOTE_REF:$claim_file" 2>/dev/null || true)"
    live_match=""
    if claim_declared_branch_is_live "$claim_text"; then
      live_match="$(claim_declared_branch "$claim_text")"
    fi
    if printf '%s\n' "$live_keys" | grep -Fxq "$slug"; then
      live_match="${live_match:-$slug}"
    fi
    if [[ -z "$live_match" ]]; then
      live_match="$(find_live_match "$slug" || true)"
    fi

    heartbeat="$(claim_heartbeat "$claim_text")"
    heartbeat_epoch=""
    heartbeat_reason=""
    heartbeat_age_seconds=""
    if [[ -z "$heartbeat" ]]; then
      heartbeat_reason="missing"
    else
      heartbeat_epoch="$(parse_utc_epoch "$heartbeat" || true)"
      if [[ -z "$heartbeat_epoch" ]]; then
        heartbeat_reason="invalid"
      else
        heartbeat_age_seconds=$((NOW_EPOCH - heartbeat_epoch))
        if [[ "$heartbeat_age_seconds" -lt 0 ]]; then
          heartbeat_age_seconds=0
        elif [[ "$heartbeat_age_seconds" -gt 1200 ]]; then
          heartbeat_reason="older-than-20m"
        fi
      fi
    fi

    if [[ -n "$heartbeat_reason" ]]; then
      branch_diagnostic="$(claim_branch_diagnostic "$claim_text" "$live_match")"
      if [[ -n "$heartbeat_age_seconds" ]]; then
        age_diagnostic="${heartbeat_age_seconds}s/$((heartbeat_age_seconds / 60))m"
      else
        age_diagnostic="unknown"
      fi
      printf 'potentially stale heartbeat: %s (heartbeat=%s age=%s reason=%s branch=%s)\n' \
        "$slug" "${heartbeat:-missing}" "$age_diagnostic" "$heartbeat_reason" "$branch_diagnostic"
      found_stale=true
      continue
    fi

    if [[ -n "$live_match" ]]; then
      continue
    fi
    claim_summary="$(printf '%s\n' "$claim_text" | tr '\n' ' ' | sed 's/[[:space:]][[:space:]]*/ /g' || true)"
    printf 'maybe stale: %s (%s)\n' "$slug" "${claim_summary:-unknown claim}"
    found_stale=true
  done <<<"$claim_files"
  if ! $found_stale; then
    echo "no stale-looking claims"
  fi
fi
echo

echo "== pending $queue_file item status =="
queue="$(git -C "$ROOT" show "$REMOTE_REF:$queue_file" 2>/dev/null || true)"
if [[ -z "$queue" ]]; then
  echo "$queue_file not found on $REMOTE_REF"
else
  section=""
  occupied_item=""
  occupied_reason=""
  next_item=""
  while IFS= read -r line; do
    case "$line" in
      "## "*)
        section="${line#\#\# }"
        ;;
      "- [ ] **"*)
        slug="$(printf '%s\n' "$line" | sed -n 's/^- \[ \] \*\*\([^*][^*]*\)\*\*.*/\1/p')"
        [[ -n "$slug" ]] || continue
        desc="$(printf '%s\n' "$line" | sed -n 's/^- \[ \] \*\*[^*][^*]*\*\*[[:space:]]*//p')"
        if printf '%s\n' "$claimed_slugs" | grep -Fxq "$slug"; then
          continue
        fi
        if printf '%s\n' "$invalid_slugs" | grep -Fxq "$slug"; then
          if [[ -z "$occupied_item" ]]; then
            occupied_item="${section}: ${slug} ${desc}"
            occupied_reason="invalid active marker: .work/active/${slug} (rename to .work/active/${slug}.claim or release it)"
          fi
          continue
        fi
        live_match="$(find_live_match "$slug" || true)"
        if [[ -n "$live_match" ]]; then
          if [[ -z "$occupied_item" ]]; then
            occupied_item="${section}: ${slug} ${desc}"
            occupied_reason="$live_match"
          fi
          continue
        fi
        next_item="${section}: ${slug} ${desc}"
        break
        ;;
    esac
  done <<<"$queue"
  if [[ -n "$occupied_item" ]]; then
    echo "occupied-looking: $occupied_item"
    echo "  live worktree/branch match: $occupied_reason"
  fi
  if [[ -n "$next_item" ]]; then
    echo "next safe-looking: $next_item"
  else
    if [[ -n "$occupied_item" ]]; then
      echo "no safe-looking unclaimed pending items found"
    else
      echo "no unclaimed pending items found"
    fi
  fi
fi
