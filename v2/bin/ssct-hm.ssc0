-- ssct-hm driver: read a source file, lex+parse (ssc0), INFER its principal type (ssc0), print.
import "../lib/ssct-hm-front.ssc0"
import "../lib/ssct-hm.ssc0"

def main = () =>
  match #io.args() {
    case Cons(path, rest) => hm(parse(#utf8->str(#io.readFile(path))))
    case Nil              => "usage: ssct-hm <file>"
  }
