#!/usr/bin/env bash
# v2-output-parity — TRUE v1-vs-v2 output-equality for examples/, the real "does v2 replace v1?" metric.
#
# For each .ssc it runs the program BOTH ways and diffs stdout:
#   v1 (rollback runner): ssc run --v1 <file>
#   v2 (ssc 2.0 VM):      ssc run --v2 <file>   (the FrontendBridge path; also the plain default)
# and reports MATCH / MISMATCH / V2-ERROR per example plus the overall parity %.
#
# This is the output-equality gate the exit-0 coverage number (`scripts/v2-compat-coverage`) can't give:
# a program can exit 0 on v2 while printing DIFFERENT output than v1 (e.g. examples/algebraic-effects.ssc).
#
# Usage:
#   scripts/v2-output-parity                       # a curated pure-language sample
#   scripts/v2-output-parity examples/foo.ssc ...  # explicit files
#   SSC="path/to/assembled/ssc" scripts/v2-output-parity examples/*.ssc   # fast full-corpus run
#
# Speed: without $SSC it shells out to sbt per example (slow — fine for a sample). For the full 193-example
# corpus, point $SSC at an assembled/native `ssc` (one `sbt cli/assembly`) so each run is a cheap JVM start.
set -u
cd "$(dirname "$0")/.."

die() {
  printf 'v2-output-parity: %s\n' "$*" >&2
  exit 2
}

export TMPDIR="${SSC_PARITY_TMPDIR:-$PWD/target/v2-output-parity-tmp}"
mkdir -p "$TMPDIR" || die "cannot create temp dir: $TMPDIR"

# Curated pure-language sample (no network/threads/frontend) if no files are given.
DEFAULT=(examples/bitwise-operators.ssc examples/custom-derives-mirror.ssc examples/hello.ssc
         examples/graph-codecs.ssc examples/content-linked-namespaces.ssc examples/algebraic-effects.ssc)
# `--all`: the WHOLE examples/ corpus (server/actor/dataset ones are auto-skipped, they never terminate).
if [ "${1:-}" = "--all" ]; then FILES=(examples/*.ssc)
else FILES=("$@"); [ ${#FILES[@]} -eq 0 ] && FILES=("${DEFAULT[@]}"); fi

# Programs that spin a server / spawn actors / stream infinite datasets don't terminate — skip (don't stall).
# TRUE servers (bind a port / event loop) never terminate — skip without running.
# Everything else (actors, async, datasets, spawn) is MEASURED with a bounded run:
# most of those terminate; a v1 timeout reclassifies to long-running.
SKIP_RE='serve\(|listen|WebServer|websocket|\btui\b'

# Run one program on one backend, returning only its stdout (strip sbt/JVM noise).
# Each run is bounded by $PARITY_TIMEOUT seconds so a server/actor example can't stall the sweep.
# Exit code travels via a file: $(run_one …) runs in a subshell, and piping
# through grep would clobber $? anyway. 124 = timeout (long-running program).
RC_FILE="$(mktemp "$TMPDIR/v2-output-parity.rc.XXXXXX")" || die "cannot create rc file in $TMPDIR"
trap 'rm -f "$RC_FILE"' EXIT
write_rc() {
  printf '%s\n' "$1" > "$RC_FILE" || die "cannot write parity rc file: $RC_FILE"
}
run_one() { # $1=file  $2=extra-flag(--v1 or --v2)
  local out rc
  if [ -n "${SSC:-}" ]; then
    # $SSC is a command (unquoted so "java -jar ssc.jar" word-splits).
    out=$(timeout "${PARITY_TIMEOUT:-45}" $SSC run $2 "$1" 2>/dev/null); rc=$?
    write_rc "$rc"
    # normalize random server ports so real-server banners can byte-match
    printf '%s' "$out" | grep -vE '^NOTE: Picked up' | sed -E 's#localhost:[0-9]+#localhost:PORT#g'
  else
    out=$(timeout "${PARITY_TIMEOUT:-180}" sbt -Dsbt.color=false -batch "cli/runMain scalascript.cli.ssc run $2 $1" 2>/dev/null); rc=$?
    write_rc "$rc"
    printf '%s' "$out" | grep -vE '^\[(info|success|warn|error)\]|^NOTE: Picked up|running scalascript\.cli'
  fi
}

match=0; mismatch=0; err=0; bothfail=0; v1only=0; skip=0
printf '%-38s %s\n' "EXAMPLE" "PARITY"
printf '%-38s %s\n' "-------" "------"
# jvm-lane examples (front-matter `backend: jvm`, scala fences, typeddata imports) are
# AUTHOR-declared JVM-codegen programs — same lane rule as BatchCli's SKIP(lane); after the
# v2 switch they keep running via `--backend jvm`, so they are not part of the v2 gate.
# Nondeterministic-output examples can never byte-match across two runs by DESIGN:
#   sql-sqlite-file — persistent /tmp db, the count grows every run
#   uuid-v7         — random UUIDs
#   os-env          — host/worktree-specific platform, cwd, env values
#   mcp/oauth demos — generated OAuth client ids/secrets + server banners
# V1-side/better-output examples are known rows where v2 matches the documented
# behavior and the rollback v1 runner truncates or aborts its own output.
NONDET_RE='^(sql-sqlite-file|uuid-v7|os-env|mcp-server-protected|oauth-mcp-full-stack)\.ssc$'
V1_SIDE_RE='^(effects|dsl-calc-parser|distributed-streams|streams)\.ssc$'
lane_skip=0; nondet_skip=0; v1side_skip=0; longrun_skip=0
for f in "${FILES[@]}"; do
  [ -f "$f" ] || { printf '%-38s %s\n' "$(basename "$f")" "MISSING"; continue; }
  if [ "${1:-}" = "--all" ] && grep -qiE "$SKIP_RE" "$f" 2>/dev/null; then
    skip=$((skip+1)); continue   # server/actor/dataset — never terminates, excluded from the ratio
  fi
  if head -15 "$f" | grep -qE '^backend:[[:space:]]*(jvm|spark|js|rust|wasm)'; then
    printf '%-38s %s\n' "$(basename "$f")" "· skip (jvm lane)"; lane_skip=$((lane_skip+1)); continue
  fi
  if basename "$f" | grep -qE "$NONDET_RE"; then
    printf '%-38s %s\n' "$(basename "$f")" "· skip (nondeterministic output by design)"; nondet_skip=$((nondet_skip+1)); continue
  fi
  if basename "$f" | grep -qE "$V1_SIDE_RE"; then
    printf '%-38s %s\n' "$(basename "$f")" "· skip (v1-side: v2 output is documented behavior)"; v1side_skip=$((v1side_skip+1)); continue
  fi
  v1=$(run_one "$f" "--v1"); run_status=$?
  [ "$run_status" -eq 0 ] || exit "$run_status"
  v1_rc=$(cat "$RC_FILE") || die "cannot read parity rc file: $RC_FILE"
  name=$(basename "$f")
  if [ "$v1_rc" = "124" ]; then
    # v1 didn't terminate within PARITY_TIMEOUT — long-running (actor loop /
    # stream); no output-equality signal without a driver. Not a v2 gap.
    printf '%-38s %s\n' "$name" "· skip (long-running: v1 timeout)"; longrun_skip=$((longrun_skip+1)); continue
  fi
  # Fixed-port server examples: the v1 process/socket may still be draining
  # when the v2 lane starts — run --v2 against a temp copy with port+1
  # (the localhost:PORT normalization keeps outputs comparable).
  v2f="$f"
  if grep -qE '^val port = [0-9]+' "$f"; then
    v2f=$(mktemp "$TMPDIR/sscparity.XXXXXX.ssc") || die "cannot create temp source in $TMPDIR"
    sed -E 's/^val port = ([0-9]+)/val port = \1 + 1/' "$f" > "$v2f" || die "cannot write temp source: $v2f"
  fi
  v2=$(run_one "$v2f" "--v2"); run_status=$?
  [ "$run_status" -eq 0 ] || exit "$run_status"
  [ "$v2f" != "$f" ] && rm -f "$v2f"
  # NB: "both empty" means the program fails/prints nothing on BOTH runners (e.g. needs a --plugin the
  # default `ssc run` doesn't load) — that is NOT a v2 gap, so it must not count as an identical match.
  if [ -z "$v1" ] && [ -z "$v2" ]; then
    printf '%-38s %s\n' "$name" "· both-fail (not a v2 gap)"; bothfail=$((bothfail+1))
  elif [ -z "$v2" ]; then
    printf '%-38s %s\n' "$name" "V2-ERROR (v1 works, v2 empty)"; err=$((err+1))
  elif [ -z "$v1" ]; then
    printf '%-38s %s\n' "$name" "v1-only (v2 works, v1 empty)"; v1only=$((v1only+1))
  elif [ "$v1" = "$v2" ]; then
    printf '%-38s %s\n' "$name" "✅ MATCH"; match=$((match+1))
  else
    printf '%-38s %s\n' "$name" "❌ MISMATCH"; mismatch=$((mismatch+1))
    diff <(printf '%s' "$v1") <(printf '%s' "$v2") | sed 's/^/      /' | head -8
  fi
done

total=${#FILES[@]}
real=$((match + mismatch + err + v1only))   # examples where at least one runner produced real output
echo
echo "parity: $match/$real identical · $mismatch mismatch · $err v2-error · $v1only v1-only"
echo "        ($bothfail both-fail not-a-gap · $skip true-server · $longrun_skip long-running · $lane_skip backend-lane · $nondet_skip nondet · $v1side_skip v1-side · $total total)"
[ $((mismatch + err)) -eq 0 ]
