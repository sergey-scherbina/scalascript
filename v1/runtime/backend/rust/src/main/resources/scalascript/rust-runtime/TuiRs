      |/// Value of a CSS declaration in a `"k:v;k:v"` `style` string.
      |fn _tui_css(attrs: &[(String, String)], prop: &str) -> Option<String> {
      |    let style = _tui_attr(attrs, "style")?;
      |    let needle = format!("{}:", prop);
      |    for decl in style.split(';') {
      |        let d = decl.trim();
      |        if let Some(v) = d.strip_prefix(&needle) { return Some(v.trim().to_string()); }
      |    }
      |    None
      |}
      |
      |/// Map a CSS color (`#rrggbb` or a basic name) to a ratatui `Color`.
      |fn _tui_color(s: &str) -> Option<ratatui::style::Color> {
      |    use ratatui::style::Color;
      |    let s = s.trim();
      |    if let Some(hex) = s.strip_prefix('#') {
      |        if hex.len() == 6 {
      |            let r = u8::from_str_radix(&hex[0..2], 16).ok()?;
      |            let g = u8::from_str_radix(&hex[2..4], 16).ok()?;
      |            let b = u8::from_str_radix(&hex[4..6], 16).ok()?;
      |            return Some(Color::Rgb(r, g, b));
      |        }
      |    }
      |    match s {
      |        "red" => Some(Color::Red), "green" => Some(Color::Green), "blue" => Some(Color::Blue),
      |        "yellow" => Some(Color::Yellow), "cyan" => Some(Color::Cyan),
      |        "magenta" | "purple" => Some(Color::Magenta), "white" => Some(Color::White),
      |        "black" => Some(Color::Black), "gray" | "grey" => Some(Color::Gray),
      |        _ => None,
      |    }
      |}
      |
      |/// Merge CSS `color` / `background` / `font-weight` from `style` onto `base`.
      |fn _tui_text_style(attrs: &[(String, String)], base: Style) -> Style {
      |    let mut st = base;
      |    if let Some(c) = _tui_css(attrs, "color").as_deref().and_then(_tui_color) { st = st.fg(c); }
      |    let bg = _tui_css(attrs, "background").or_else(|| _tui_css(attrs, "background-color"));
      |    if let Some(c) = bg.as_deref().and_then(_tui_color) { st = st.bg(c); }
      |    if _tui_css(attrs, "font-weight").map(|v| v == "bold" || v == "600" || v == "700").unwrap_or(false) {
      |        st = st.add_modifier(Modifier::BOLD);
      |    }
      |    st
      |}
      |
      |/// A container that lays its children out horizontally (CSS `flex-direction:row`)?
      |fn _tui_is_row(attrs: &[(String, String)]) -> bool {
      |    _tui_css(attrs, "flex-direction").map(|d| d == "row").unwrap_or(false)
      |}
