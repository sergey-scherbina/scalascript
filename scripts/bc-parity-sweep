#!/usr/bin/env bash
# Corpus output parity: v2 VM (`ssc run`) versus direct v2 JVM bytecode
# (`ssc run --bytecode`). Runs from any checkout/worktree and always writes a
# machine-readable TSV report.
set -u
set -o pipefail
export LC_ALL=C

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
ROOT=$(git -C "$SCRIPT_DIR" rev-parse --show-toplevel 2>/dev/null) || {
  echo "bc-parity-sweep: cannot locate repository root" >&2
  exit 2
}

ssc=${SSC:-"$ROOT/bin/ssc"}
seconds=${BC_PARITY_TIMEOUT:-45}
only='*.ssc'
strict=0
report=${BC_PARITY_REPORT:-"${TMPDIR:-/tmp}/scalascript-bc-parity-$$.tsv"}

usage() {
  cat <<'EOF'
usage: scripts/bc-parity-sweep [options]
  --ssc PATH       staged ssc launcher (default: <repo>/bin/ssc)
  --timeout SEC    per-backend timeout (default: 45)
  --only GLOB      basename glob, e.g. 'hello*.ssc'
  --report PATH    TSV output path (default: temporary file)
  --strict         fail on both-fail, mismatch, or one-sided backend error
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --ssc)     ssc=$2; shift 2 ;;
    --timeout) seconds=$2; shift 2 ;;
    --only)    only=$2; shift 2 ;;
    --report)  report=$2; shift 2 ;;
    --strict)  strict=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) echo "bc-parity-sweep: unknown option: $1" >&2; usage >&2; exit 2 ;;
  esac
done

if [[ ! -x "$ssc" ]]; then
  echo "bc-parity-sweep: staged launcher not found: $ssc (run scripts/sbtc \"installBin\")" >&2
  exit 2
fi

mkdir -p "$(dirname -- "$report")"
tmp=$(mktemp -d "${TMPDIR:-/tmp}/ssc-bc-parity.XXXXXX") || exit 2
trap 'rm -rf "$tmp"' EXIT HUP INT TERM

printf 'file\tcategory\tvm_rc\tbytecode_rc\tdetail\n' > "$report"

explicit_manifest="$ROOT/tests/fixtures/v21-explicit-lanes/manifest.tsv"
[[ -f $explicit_manifest ]] || {
  echo "bc-parity-sweep: missing explicit-lane manifest: $explicit_manifest" >&2
  exit 2
}
awk -F '\t' '
  NR == 1 {
    if ($0 != "file\tfamily\tlane\tregression\tdependency_tier") bad=1
    next
  }
  NF != 5 || $1 == "" || ($3 != "provider-lane" && $3 != "target-lane") { bad=1 }
  seen[$1]++ > 0 { bad=1 }
  { total++ }
  END { if (total != 15 || bad) exit 1 }
' "$explicit_manifest" || {
  echo 'bc-parity-sweep: invalid explicit-lane manifest' >&2
  exit 2
}

skip_re='(^|[^[:alnum:]_])serve([[:space:]]*\(|[[:space:]]*\{|[A-Z][[:alnum:]_]*[[:space:]]*\()|listen|WebServer|websocket|(^|[^[:alnum:]_])tui([^[:alnum:]_]|$)'
nondet_re='^(sql-sqlite-file|uuid-v7|os-env|mcp-server-protected|oauth-mcp-full-stack|async-parallel-demo|distributed-word-count|graphql-client|v2-http-sql-demo)\.ssc$'
# The v2 JVM bytecode backend emits one monolithic `ssc/gen/Entry` class. A program
# that inlines the whole scljet pure-.ssc SQLite engine PLUS the JDBC facade overflows
# the JVM per-class size limit and aborts with "Class too large: ssc/gen/Entry" — the
# VM lane runs these correctly, so there is simply no bytecode output to compare, not a
# parity mismatch. This is an explicit, named allow-list (never a heuristic): any OTHER
# program that grows too large still surfaces as a real bytecode-error and fails the
# strict sweep. See BUGS.md `scljet-jdbc-facade-bytecode-class-too-large`.
oversize_re='^(scljet-hello|scljet-jdbc)\.ssc$'
ident=0; mismatch=0; bcerr=0; bothfail=0; skipped=0; vmerr=0; total=0
delegated=0; provider_lane=0; target_lane=0
mlist=''; elist=''; vlist=''

record() {
  local file=$1 category=$2 vm_rc=$3 bc_rc=$4 detail=$5
  detail=$(printf '%s' "$detail" | tr '\t\r\n' '   ')
  printf '%s\t%s\t%s\t%s\t%s\n' "$file" "$category" "$vm_rc" "$bc_rc" "$detail" >> "$report"
}

for f in "$ROOT"/examples/*.ssc; do
  b=$(basename -- "$f")
  case "$b" in $only) ;; *) continue ;; esac
  total=$((total + 1))

  lane_row=$(awk -F '\t' -v file="$b" 'NR > 1 && $1 == file { print $3 "\t" $2 "\t" $4; exit }' "$explicit_manifest")
  if [[ -n $lane_row ]]; then
    lane=$(printf '%s\n' "$lane_row" | cut -f1)
    family=$(printf '%s\n' "$lane_row" | cut -f2)
    regression=$(printf '%s\n' "$lane_row" | cut -f3)
    delegated=$((delegated + 1))
    if [[ $lane == provider-lane ]]; then provider_lane=$((provider_lane + 1))
    else target_lane=$((target_lane + 1))
    fi
    record "$b" "$lane" - - "$family via $regression"
    continue
  fi

  if grep -qiE "$skip_re" "$f" 2>/dev/null; then
    skipped=$((skipped + 1)); record "$b" skipped-server - - 'server/tui source'; continue
  fi
  if head -25 "$f" | grep -qE '^(backend|target):[[:space:]]*(jvm|spark|js|node|rust|wasm)|^frontend:[[:space:]]*(react|solid|vue|electron|swing|javafx|swiftui)'; then
    skipped=$((skipped + 1)); record "$b" skipped-backend - - 'target/backend/frontend-specific front matter'; continue
  fi
  if head -25 "$f" | grep -qE '^backends:[[:space:]]*\[[[:space:]]*(js|node|wasm)([[:space:]]*,[[:space:]]*(js|node|wasm))*[[:space:]]*\][[:space:]]*$'; then
    skipped=$((skipped + 1)); record "$b" skipped-backend - - 'JS-family backends-only front matter'; continue
  fi
  if printf '%s\n' "$b" | grep -qE "$nondet_re"; then
    skipped=$((skipped + 1)); record "$b" skipped-nondeterministic - - 'declared nondeterministic output'; continue
  fi
  if printf '%s\n' "$b" | grep -qE "$oversize_re"; then
    skipped=$((skipped + 1)); record "$b" skipped-oversized-bytecode - - 'exceeds JVM class-size limit (Class too large: ssc/gen/Entry)'; continue
  fi
  if head -25 "$f" | grep -qE '^runScalaFences:[[:space:]]*true([[:space:]]|$)'; then
    skipped=$((skipped + 1)); record "$b" skipped-backend - - 'explicit mixed Scala-fence compiler surface'; continue
  fi
  if grep -qE '^```(scala|java|javascript|rust)([[:space:]]|$)' "$f" 2>/dev/null &&
     ! grep -qE '^```scalascript([[:space:]]|$)' "$f" 2>/dev/null; then
    skipped=$((skipped + 1)); record "$b" skipped-backend - - 'backend-specific fenced document with no standard scalascript block'; continue
  fi

  program_args=()
  case "$b" in
    distributed-join.ssc)
      program_args=(-- "$ROOT/tests/fixtures/v21-native/distributed-orders.csv"
        "$ROOT/tests/fixtures/v21-native/distributed-customers.csv")
      ;;
    distributed-log-aggregation.ssc)
      program_args=(-- "$ROOT/tests/fixtures/v21-native/distributed-app.log")
      ;;
  esac

  "$SCRIPT_DIR/run-with-timeout" "$seconds" "$ssc" run "$f" "${program_args[@]}" >"$tmp/vm.out" 2>"$tmp/vm.err"
  vm_rc=$?
  "$SCRIPT_DIR/run-with-timeout" "$seconds" "$ssc" run --bytecode "$f" "${program_args[@]}" >"$tmp/bc.out" 2>"$tmp/bc.err"
  bc_rc=$?

  if [[ $vm_rc -ne 0 && $bc_rc -ne 0 ]]; then
    bothfail=$((bothfail + 1))
    detail=$(head -1 "$tmp/bc.err")
    record "$b" both-fail "$vm_rc" "$bc_rc" "$detail"
  elif [[ $bc_rc -ne 0 ]]; then
    bcerr=$((bcerr + 1)); elist="$elist $b"
    detail=$(head -1 "$tmp/bc.err")
    record "$b" bytecode-error "$vm_rc" "$bc_rc" "$detail"
  elif [[ $vm_rc -ne 0 ]]; then
    vmerr=$((vmerr + 1)); vlist="$vlist $b"
    detail=$(head -1 "$tmp/vm.err")
    record "$b" vm-error "$vm_rc" "$bc_rc" "$detail"
  elif cmp -s "$tmp/vm.out" "$tmp/bc.out"; then
    ident=$((ident + 1)); record "$b" identical "$vm_rc" "$bc_rc" ''
  else
    mismatch=$((mismatch + 1)); mlist="$mlist $b"
    record "$b" mismatch "$vm_rc" "$bc_rc" 'stdout differs'
  fi
done

echo "=== total: $total  identical: $ident  mismatch: $mismatch  bytecode-error: $bcerr  vm-error: $vmerr  both-fail: $bothfail  skipped: $skipped  delegated: $delegated (provider: $provider_lane target: $target_lane)"
echo "MISMATCH:$mlist"
echo "BYTECODE-ERROR:$elist"
echo "VM-ERROR:$vlist"
echo "REPORT: $report"

if [[ $strict -eq 1 && $((bothfail + mismatch + bcerr + vmerr)) -ne 0 ]]; then
  exit 1
fi
