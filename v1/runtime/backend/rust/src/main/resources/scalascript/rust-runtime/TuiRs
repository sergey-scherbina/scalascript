      |/// `serve(view, port)` on the tui target. `SSC_TUI_SNAPSHOT` = headless:
      |/// render the initial frame, then apply the first action + recompute and
      |/// render again, printing both (so a test sees a LIVE computedSignal update
      |/// without a TTY). Otherwise run the interactive crossterm loop.
      |pub fn _tui_run(view: View) {
