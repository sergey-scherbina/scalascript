#!/usr/bin/env bash
# Mock ssc for scripted testing — implements only `generate-facade`.
# Reads .scim files from <artifactDir> and writes hard-coded facade sources
# to <outputDir> for the test fixtures provided alongside this script.
set -euo pipefail

if [ "$1" != "generate-facade" ]; then
  echo "[mock-ssc] unknown command: $1" >&2
  exit 1
fi

# Parse: generate-facade <artifactDir> -o <outputDir>
ARTIFACT_DIR="$2"
OUTPUT_DIR="$4"   # after -o flag

mkdir -p "${OUTPUT_DIR}/demo/math"

cat > "${OUTPUT_DIR}/demo/math.scala" << 'FACADE'
// AUTO-GENERATED by scalascript-interop FacadeGenerator.
// Do not edit by hand — regenerate via your build tool or
// `ssc link --emit-scala-facade`.
// Source modules: math
//
// Each `export` aliases a legacy Tier-1 mangled JVM symbol
// (`_ssc_runtime.X`) back to its natural ScalaScript FQN.
// Zero runtime overhead — pure compile-time alias.
// See specs/scala-interop.md.

import _ssc_runtime as Ssc

package demo.math:

  export Ssc.demo_math_add as add
  export Ssc.demo_math_double as double
FACADE

echo "[mock-ssc] wrote ${OUTPUT_DIR}/demo/math.scala" >&2
