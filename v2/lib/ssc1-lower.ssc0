  Cons(listFlatMapDef,
  Nil))))))))))))))))))))))))))))))))))))))

-- Build a complete IrProg from parsed statements
-- Enum pre-scan: [Pair(enumName, cases)] so a `EnumName.Case` / `EnumName.values`
-- companion access can resolve regardless of decl-vs-use order.
def collectEnums = (stmts) =>
  match stmts {
    case Nil => Nil
    case Cons(s, rest) =>
      match s {
        case Pair(tag, data) =>
          if #seq(tag, "enum") then
            match data { case Pair(ename, cases) => Cons(Pair(ename, cases), collectEnums(rest)) }
          else if #seq(tag, "object") then
            -- Nested enums (`object O: enum E: …`) must register too, so `E.Case`
            -- resolves to the case ctor rather than an unbound `E` global.
            match data { case Pair(oname, obody) => append(collectEnums(obody), collectEnums(rest)) }
          else collectEnums(rest)
      }
  }

-- K62.7b: pre-scan user `object` names so isKnownObject is reliable during lowering
-- (a `Foo.method` on a KNOWN object → static Foo_method; on an UNKNOWN uppercase
-- name like Dataset/Graph → __method__, resolved by the plugin runtime's
-- __fallback__.Foo.method).
def collectObjects = (stmts) =>
  match stmts {
    case Nil => Nil
    case Cons(s, rest) =>
      match s {
        case Pair(tag, data) =>
          if #seq(tag, "object") then
            match data { case Pair(name, ss) => Cons(name, collectObjects(rest)) }
          else if #seq(tag, "effect_decl") then
            match data { case Pair(name, ss) => Cons(name, collectObjects(rest)) }
          else collectObjects(rest)
      }
  }

-- K62.6e: gather every case-class field name (across all case classes) so
-- resolveField can tell a generated-accessor field from a plugin/record field.
-- K62.13: enum cases contribute the same field metadata as case classes.
def enumCaseFields = (cases) =>
  match cases {
    case Nil => Nil
    case Cons(c, rest) =>
      match c { case Pair(cname, params) => append(params, enumCaseFields(rest)) }
  }
def enumCaseOrder = (cases) =>
  match cases {
    case Nil => Nil
    case Cons(c, rest) =>
      match c { case Pair(cname, params) => Cons(Pair(cname, params), enumCaseOrder(rest)) }
  }

def collectCaseFields = (stmts) =>
  match stmts {
    case Nil => Nil
    case Cons(s, rest) =>
      match s {
        case Pair(tag, data) =>
          if #seq(tag, "casecls") then
            match data { case Pair(name, caseMeta) =>
              match caseMeta { case Pair(params, typeAndDerives) =>
                append(append(params, bodyFieldNames(classBodyFields(name))), collectCaseFields(rest)) } }
          else if #seq(tag, "enum") then
            match data { case Pair(ename, cases) => append(enumCaseFields(cases), collectCaseFields(rest)) }
          else collectCaseFields(rest)
      }
  }

-- named-args: per-class ordered field lists [Pair(name, params)] for constructor reorder.
def collectCaseClassOrder = (stmts) =>
  match stmts {
    case Nil => Nil
    case Cons(s, rest) =>
      match s {
        case Pair(tag, data) =>
          if #seq(tag, "casecls") then
            match data { case Pair(name, caseMeta) =>
              match caseMeta { case Pair(params, typeAndDerives) =>
                Cons(Pair(name, append(params, bodyFieldNames(classBodyFields(name)))),
                     collectCaseClassOrder(rest)) } }
          else if #seq(tag, "enum") then
            match data { case Pair(ename, cases) => append(enumCaseOrder(cases), collectCaseClassOrder(rest)) }
          else if #seq(tag, "object") then
            -- Descend into the object body so TYPE decls nested in it (case class /
            -- enum) get field/case order registered → accessors are generated
            -- (prefixDefs lowers their ctors globally; without this the fields Stub).
            match data { case Pair(oname, obody) =>
              append(collectCaseClassOrder(obody), collectCaseClassOrder(rest)) }
          else collectCaseClassOrder(rest)
      }
  }

-- K62.6b: names of top-level `var` declarations (become global cells).
def collectTopVars = (stmts) =>
  match stmts {
    case Nil => Nil
    case Cons(s, rest) =>
      match s {
        case Pair(tag, data) =>
          if #seq(tag, "var") then
            match data { case Pair(name, init) => Cons(name, collectTopVars(rest)) }
          else collectTopVars(rest)
      }
  }

-- Names bound by top-level immutable vals, including tuple patterns.
def collectTopVals = (stmts) =>
  match stmts {
    case Nil => Nil
    case Cons(s, rest) =>
      match s {
        case Pair(tag, data) =>
          if #seq(tag, "val") then
            match data { case Pair(name, init) => Cons(name, collectTopVals(rest)) }
          else if #seq(tag, "tuppat") then
            match data { case Pair(names, init) => appendL(names, collectTopVals(rest)) }
          else if #seq(tag, "casecls") then
            match data { case Pair(typeName, caseMeta) =>
              match caseMeta { case Pair(params, typeAndDerives) =>
                match typeAndDerives { case Pair(types, derives) =>
                  appendL(derivedValueNames(typeName, derives), collectTopVals(rest)) } } }
          else collectTopVals(rest)
      }
  }

-- K62.6b: an empty global cell def per top-level var; the init runs in document
-- order in the entry (as cell.set), so ordering matches source.
def topVarCellDefs = (stmts) =>
  match stmts {
    case Nil => Nil
    case Cons(s, rest) =>
      match s {
        case Pair(tag, data) =>
          if #seq(tag, "var") then
            match data { case Pair(name, init) =>
              Cons(IrDef(#sconcat(name, "__cell"), IrPrim("cell.new", Cons(IrLit(IrUnit), Nil))),
                   topVarCellDefs(rest)) }
          else topVarCellDefs(rest)
      }
  }

def topValCellDefs = (names) =>
  match names {
    case Nil => Nil
    case Cons(name, rest) =>
      Cons(IrDef(#sconcat(name, "__cell"), IrPrim("cell.new", Cons(IrLit(IrUnit), Nil))),
           topValCellDefs(rest))
  }

-- K62.15: build ONE `_sel_<field>` accessor per unique field name, with a match arm for
-- EVERY case class / enum case that declares that field (each arm returns the field at its
-- OWN index). Fixes shared field names (Person.name + Student.name) that previously
-- overwrote each other. Source = caseFieldOrderCell ([Pair(ctorName, [field…])]).
def acc_isMember = (x, xs) =>
  match xs {
    case Nil => false
    case Cons(h, t) => if #seq(h, x) then true else acc_isMember(x, t)
  }
def acc_triples = (caseOrder) =>
  match caseOrder {
    case Nil => Nil
    case Cons(cc, rest) =>
      match cc { case Pair(ctorName, params) =>
        let ar = lenL(params) in
        let rec go = (ps, idx) =>
          match ps {
            case Nil => Nil
            case Cons(f, more) =>
              Cons(Pair(f, Pair(ctorName, Pair(ar, idx))), go(more, #i.add(idx, 1)))
          } in
        append(go(params, 0), acc_triples(rest)) }
  }
def acc_uniqFields = (triples, seen) =>
  match triples {
    case Nil => Nil
    case Cons(t, rest) =>
      match t { case Pair(f, r) =>
        if acc_isMember(f, seen) then acc_uniqFields(rest, seen)
        else Cons(f, acc_uniqFields(rest, Cons(f, seen))) }
  }
def acc_armsFor = (field, triples) =>
  match triples {
    case Nil => Nil
    case Cons(t, rest) =>
      match t { case Pair(f, r) =>
        if #seq(f, field) then
          match r { case Pair(ctorName, r2) =>
            match r2 { case Pair(ar, idx) =>
              Cons(IrArm(ctorName, ar, IrLocal(#i.sub(#i.sub(ar, 1), idx))),
                   acc_armsFor(field, rest)) } }
        else acc_armsFor(field, rest) }
  }
def buildMergedAccessors = (caseOrder) =>
  let triples = acc_triples(caseOrder) in
  let rec go = (fs) =>
    match fs {
      case Nil => Nil
      case Cons(f, rest) =>
        -- Default arm → runtime field-by-name lookup: a `.f` access whose receiver
        -- is NOT one of the user case classes carrying `f` (e.g. a PLUGIN record like
        -- exec's ProcessResult, whose fields aren't in the compile-time registry) hit
        -- the None default → hard "no arm for <Tag>/<n>". __method__ resolves it via
        -- V2PluginRegistry.lookupFieldNames(tag, arity) at runtime (mirrors the bridge).
        Cons(IrDef(#sconcat("_sel_", f),
               IrLam(1, IrMatch(IrLocal(0), acc_armsFor(f, triples),
                 Some(IrPrim("__method__", Cons(IrLit(IrStr(f)), Cons(IrLocal(0), Nil))))))),
             go(rest))
    } in
  go(acc_uniqFields(triples, Nil))

-- K62.28: register native case-class field NAMES with the runtime so a field access that
-- can't be a static _sel_ accessor — e.g. `.head` (ambiguous with List.head, so routed to the
-- polymorphic runtime __method__) — resolves by name. Emits __regfields__(tag, [names…]) per
-- case class at program start (prepended to the entry, before any field access). Mirrors what
-- the scalameta bridge does with V2PluginRegistry.registerFieldNames at convert time.
def strListIr = (names) =>
  match names {
    case Nil => IrCtor("Nil", Nil)
    case Cons(n, rest) =>
      IrCtor("Cons", Cons(IrLit(IrStr(n)), Cons(strListIr(rest), Nil)))
  }

def caseFieldRegs = (order) =>
  match order {
    case Nil => Nil
    case Cons(cc, rest) =>
      match cc { case Pair(ctorName, params) =>
        Cons(IrPrim("__regfields__",
              Cons(IrLit(IrStr(ctorName)), Cons(strListIr(params), Nil))),
             caseFieldRegs(rest)) }
  }

-- Case-class BODY methods (caseMethodsCell = [Pair(tag, Pair(fields, defs))]).
-- Each captured `def` becomes a `Tag_method(self, params…)` global whose body has
-- the case-class fields bound from self (so bare field refs resolve as locals), and
-- a `__regmethod__(tag, method, IrGlobal(Tag_method))` entry so __method__ dispatches.
def lowerCaseMethodBody = (fields, scope, body) =>
  match fields {
    case Nil => lowerE(scope, body)
    case Cons(f, rest) =>
      -- A mutable `var` field is NOT bound as a local: it is stored as a cell in
      -- the DataV, so a read routes to `cell.get(_sel_f(__self))` and a write to
      -- `cell.set(...)` (handled in lowerE's var branch / assign lowering). Binding
      -- it as a local would snapshot the cell and lose mutation across reads.
      if isCurrentVarField(f) then
        lowerCaseMethodBody(rest, scope, body)
      else if isCurrentLazyField(f) then
        -- lazy field: not bound as a local; a bare read forces via __lazyForce__.
        lowerCaseMethodBody(rest, scope, body)
      else
        IrLet(Cons(IrApp(IrGlobal(#sconcat("_sel_", f)),
                     Cons(lookupVar(scope, "__self"), Nil)), Nil),
              lowerCaseMethodBody(rest, Cons(f, scope), body))
  }
def caseMethodDefsFor = (tag, fields, defs) =>
  match defs {
    case Nil => Nil
    case Cons(d, rest) =>
      match d { case Pair(dtag, ddata) =>
        match ddata { case Pair(mname, mrest) =>
          match mrest { case Pair(mparams, mbody) =>
            let selfAndParams = Cons("__self", mparams) in
            -- Wrap a (case-)class method in `__with_return__` iff it uses a non-local
            -- `return` (MarkdownBlocks is a plain class → its methods reach here, not the
            -- object-method path).
            let prevHR = #cell.get(defHasReturnCell) in
            let _rstHR = #cell.set(defHasReturnCell, false) in
            let mbodyIr = lowerCaseMethodBody(fields, revL(selfAndParams), mbody) in
            let hadRet = #cell.get(defHasReturnCell) in
            let _rst2HR = #cell.set(defHasReturnCell, prevHR) in
            let mbodyFinal = if hadRet then wrapReturn(mbodyIr) else mbodyIr in
            let mdef = IrDef(#sconcat(tag, #sconcat("_", mname)),
                         IrLam(lenL(selfAndParams), mbodyFinal)) in
            Cons(mdef, caseMethodDefsFor(tag, fields, rest)) } } }
  }
def methodNamesOf = (defs) =>
  match defs {
    case Nil => Nil
    case Cons(d, rest) =>
      match d { case Pair(dtag, ddata) =>
        match ddata { case Pair(mname, mrest) => Cons(mname, methodNamesOf(rest)) } }
  }
def caseMethodDefs = (regs) =>
  match regs {
    case Nil => Nil
    case Cons(r, rest) =>
      match r { case Pair(tag, fd) =>
        match fd { case Pair(fields, defs) =>
          -- Activate the sibling-call context for THIS tag's method bodies, lower
          -- them (eager — `let` is strict), then clear before the next tag.
          let _set = #cell.set(caseSelfCtxCell, Pair(tag, methodNamesOf(defs))) in
          let ds = caseMethodDefsFor(tag, fields, defs) in
          let _clr = #cell.set(caseSelfCtxCell, Nil) in
          appendL(ds, caseMethodDefs(rest)) } }
  }
def caseMethodRegsFor = (tag, defs) =>
  match defs {
    case Nil => Nil
    case Cons(d, rest) =>
      match d { case Pair(dtag, ddata) =>
        match ddata { case Pair(mname, mrest) =>
          Cons(IrPrim("__regmethod__",
                 Cons(IrLit(IrStr(tag)), Cons(IrLit(IrStr(mname)),
                   Cons(IrGlobal(#sconcat(tag, #sconcat("_", mname))), Nil)))),
               caseMethodRegsFor(tag, rest)) } }
  }
def caseMethodRegs = (regs) =>
  match regs {
    case Nil => Nil
    case Cons(r, rest) =>
      match r { case Pair(tag, fd) =>
        match fd { case Pair(fields, defs) =>
          appendL(caseMethodRegsFor(tag, defs), caseMethodRegs(rest)) } }
  }

-- Object methods are emitted under mangled `O_method` names; register their
-- arities under that same mangled key so call-site arity queries (vararg packing,
-- curried-call matching) resolve `O.method(...)` → `O_method`.
def collectObjMethodArities = (oname, stmts) =>
  match stmts {
    case Nil => Nil
    case Cons(stmt, rest) =>
      match stmt {
        case Pair(tag, data) =>
          if #seq(tag, "def") then
            match data {
              case Pair(name, defRest) =>
                match defRest {
                  case Pair(params, body) =>
                    Cons(Pair(#sconcat(oname, #sconcat("_", name)), lenL(params)),
                      collectObjMethodArities(oname, rest))
                }
            }
          else collectObjMethodArities(oname, rest)
      }
  }

def collectDefArities = (stmts) =>
  match stmts {
    case Nil => Nil
    case Cons(stmt, rest) =>
      match stmt {
        case Pair(tag, data) =>
          if #seq(tag, "def") then
            match data {
              case Pair(name, defRest) =>
                match defRest {
                  case Pair(params, body) =>
                    Cons(Pair(name, lenL(params)), collectDefArities(rest))
                }
            }
          else if #seq(tag, "object") then
            match data {
              case Pair(oname, ostmts) =>
                appendL(collectObjMethodArities(oname, ostmts), collectDefArities(rest))
            }
          else collectDefArities(rest)
      }
  }

def collectParameterlessDefs = (stmts) =>
  match stmts {
    case Nil => Nil
    case Cons(stmt, rest) =>
      match stmt {
        case Pair(tag, data) =>
          if #seq(tag, "def") then
            match data {
              case Pair(name, defRest) =>
                match defRest {
                  case Pair(params, body) =>
                    if isParameterlessBody(body) then
                      Cons(name, collectParameterlessDefs(rest))
                    else collectParameterlessDefs(rest)
                }
            }
          else collectParameterlessDefs(rest)
      }
  }

-- ── KC5-mono: emit specialised defs collected during lowering ──────────────────────────────────
-- Find a def stmt's (params, body) by name.
def findDefStmt = (stmts, name) =>
  match stmts {
    case Nil => None
    case Cons(s, rest) =>
      match s {
        case Pair(tag, data) =>
          if #seq(tag, "def") then
            match data { case Pair(dname, drest) => if #seq(dname, name) then Some(drest) else findDefStmt(rest, name) }
          else findDefStmt(rest, name)
      }
  }

-- Emit one specialised IrDef: `fnName`'s body lowered with active ctx = the CONCRETE instance, so
-- `combine`/`empty` resolve to `<instance>_<method>` globals. Same arity (the ctx param stays but is
-- unused). Nil if the def is missing.
def emitOneMonoDef = (stmts, fnName, instance, tc) =>
  match findDefStmt(stmts, fnName) {
    case None => Nil
    case Some(drest) =>
      match drest {
        case Pair(params, body) =>
          let scope = revL(params) in
          let prevCtx = #cell.get(kc5ActiveCtxCell) in
          let _set = #cell.set(kc5ActiveCtxCell, Cons(Pair(instance, tc), Nil)) in
          let _resetAlias = #cell.set(summonAliasCell, Nil) in
          let resolvedBody = resolveE(body) in
          let ir = match resolvedBody {
            case Pair(btag, bdata) =>
              if #seq(btag, "block") then IrDef(monoName(fnName, instance), IrLam(lenL(params), lowerBlock(scope, bdata)))
              else IrDef(monoName(fnName, instance), IrLam(lenL(params), lowerE(scope, resolvedBody)))
          } in
          let _rest = #cell.set(kc5ActiveCtxCell, prevCtx) in
          Cons(ir, Nil)
      }
  }

-- Emit all specialisations in kc5MonoCell, deduped by specialised name.
def emitMonoDefs = (stmts) =>
  let rec go = (work, seen) =>
    match work {
      case Nil => Nil
      case Cons(entry, rest) =>
        match entry {
          case Pair(fnName, instTc) =>
            match instTc {
              case Pair(instance, tc) =>
                let key = monoName(fnName, instance) in
                let seenIt =
                  let rec mem = (xs) => match xs { case Nil => false case Cons(h, t) => if #seq(h, key) then true else mem(t) } in
                  mem(seen) in
                if seenIt then go(rest, seen)
                else appendL(emitOneMonoDef(stmts, fnName, instance, tc), go(rest, Cons(key, seen)))
            }
        }
    } in
  go(#cell.get(kc5MonoCell), Nil)

-- ── Extension-method instance dispatch ────────────────────────────────────────
-- An `extension … def m` declared INSIDE `given g: TC[T] with …` is emitted prefixed as `g_m`
-- (given_obj lowering). But a call `recv.m(args)` references the BARE name `m` (via __methodOrExt__).
-- With 2+ instances (`Functor[List]`, `Functor[Option]`) there is no single `m` to bind. We synthesise
-- a bare `m` DISPATCHER that type-tests the receiver's runtime tag and forwards to the matching `g_m`.

-- Runtime constructor tags for a nominal type head (built-ins + user ADTs via subtypeChildren).
def extTypeTags = (typeHead) =>
  if #seq(typeHead, "List") then Cons("Cons", Cons("Nil", Nil))
  else if #seq(typeHead, "Option") then Cons("Some", Cons("None", Nil))
  else if #seq(typeHead, "Either") then Cons("Left", Cons("Right", Nil))
  -- A tuple literal lowers to IrCtor("Pair", …); runtime ops (zip/map/groupBy) produce DataV("Tuple2", …).
  else if #seq(typeHead, "Tuple2") then Cons("Pair", Cons("Tuple2", Nil))
  else
    let subs = subtypeChildren(typeHead) in
    match subs { case Nil => Cons(typeHead, Nil) case Cons(h, t) => subs }

def extMemberStr = (x, xs) =>
  match xs { case Nil => false case Cons(h, t) => if #seq(h, x) then true else extMemberStr(x, t) }

-- First top-level (depth-0) comma-separated component of a type-arg string: the CONTAINER type of a
-- multi-param TC. "Option, Unit" → "Option" (MonadError[F, E]); "Map[K, V], E" → "Map[K, V]"; "List" → "List".
def firstTypeArg = (t) =>
  let len = #slen(t) in
  let rec scan = (i, depth) =>
    if #i.lt(i, len) then
      let c = #sslice(t, i, #i.add(i, 1)) in
      if #seq(c, "[") then scan(#i.add(i, 1), #i.add(depth, 1))
      else if #seq(c, "]") then scan(#i.add(i, 1), #i.sub(depth, 1))
      else if #seq(c, ",") then (if #i.eq(depth, 0) then i else scan(#i.add(i, 1), depth))
      else scan(#i.add(i, 1), depth)
    else i in
  #sslice(t, 0, scan(0, 0))

-- Extension methods declared at TOP LEVEL (not inside a given body). A method with BOTH a top-level
-- extension AND given-body instances gets its top-level impl emitted under `m__ext_default`, and the
-- bare `m` dispatcher falls back to it (instead of clobbering it / returning the receiver).
def collectTopLevelExtMethods = (stmts) =>
  let rec go = (ss, active) =>
    match ss {
      case Nil => Nil
      case Cons(s, rest) =>
        match s {
          case Pair(tag, data) =>
            if #seq(tag, "extension_start") then go(rest, true)
            else if #seq(tag, "extension_end") then go(rest, false)
            else if active then
              (if #seq(tag, "def") then match data { case Pair(name, dr) => Cons(name, go(rest, active)) }
               else go(rest, active))
            else go(rest, active)
        }
    } in
  go(stmts, false)

def topLevelExtMethodsCell = #cell.new(Nil)
def extDispatchMethodsCell = #cell.new(Nil)
def hasTopLevelExt = (name) => extMemberStr(name, #cell.get(topLevelExtMethodsCell))
-- `m` should have its top-level ext mangled iff it ALSO has given-body dispatch instances.
def extNeedsMangle = (name) =>
  if extMemberStr(name, #cell.get(topLevelExtMethodsCell)) then
    extMemberStr(name, #cell.get(extDispatchMethodsCell))
  else false

-- Arg locals for an arity-N lambda, in source-param order [IrLocal(N-1) … IrLocal(0)] (param at
-- source position k binds to IrLocal(N-1-k), so the first param/receiver is IrLocal(N-1)).
def descLocals = (n) =>
  let rec go = (k) => if #i.lt(k, 0) then Nil else Cons(IrLocal(k), go(#i.sub(k, 1))) in
  go(#i.sub(n, 1))

-- Collect [Pair(method, Pair(typeHead, Pair(implName, arity)))] for every extension def in a given body.
def collectExtDispatch = (stmts) =>
  match stmts {
    case Nil => Nil
    case Cons(s, rest) =>
      let more = collectExtDispatch(rest) in
      match s {
        case Pair(tag, data) =>
          if #seq(tag, "given_obj") then
            match data {
              case Pair(gname, rest2) =>
                match rest2 {
                  case Pair(typeStr, gstmts) =>
                    let typeHead = firstTypeArg(match parseGivenType(typeStr) { case Pair(tc, t) => t }) in
                    -- Track the extension group within the given body (extension_start/_end); a def
                    -- while active is an extension method implemented for `typeHead`.
                    let rec scan = (ss, active) =>
                      match ss {
                        case Nil => more
                        case Cons(s2, r2) =>
                          match s2 {
                            case Pair(stag, sdata) =>
                              if #seq(stag, "extension_start") then scan(r2, true)
                              else if #seq(stag, "extension_end") then scan(r2, false)
                              else if #seq(stag, "def") then
                                (if active then
                                  match sdata {
                                    case Pair(dname, drest) =>
                                      match drest {
                                        case Pair(dparams, dbody) =>
                                          Cons(Pair(dname, Pair(typeHead,
                                                 Pair(#sconcat(gname, #sconcat("_", dname)), lenL(dparams)))),
                                               scan(r2, active))
                                      }
                                  }
                                 else scan(r2, active))
                              else scan(r2, active)
                          }
                      } in
                    scan(gstmts, false)
                }
            }
          else more
      }
  }

def extInstancesFor = (m, entries) =>
  match entries {
    case Nil => Nil
    case Cons(e, r) =>
      match e { case Pair(em, rst) => if #seq(em, m) then Cons(rst, extInstancesFor(m, r)) else extInstancesFor(m, r) }
  }

-- Distinct extension-method names defined across given bodies.
def extDispatchMethodNames = (stmts) =>
  let rec uniq = (es, seen) =>
    match es {
      case Nil => Nil
      case Cons(e, r) =>
        match e { case Pair(mm, mrest) => if extMemberStr(mm, seen) then uniq(r, seen) else Cons(mm, uniq(r, Cons(mm, seen))) }
    } in
  uniq(collectExtDispatch(stmts), Nil)

-- One bare dispatcher IrDef for extension method `m`: if <recv is T1> then g1_m(args…) else … else
-- <fallback>, where fallback delegates to a top-level `m__ext_default` impl if one exists, else recv.
def emitOneExtDispatcher = (m, insts) =>
  match insts {
    case Nil => Nil
    case Cons(first, instsTail) =>
      let arity = match first { case Pair(th, rr) => match rr { case Pair(impl, ar) => ar } } in
      let args = descLocals(arity) in
      let recvLocal = IrLocal(#i.sub(arity, 1)) in
      let fallback = if hasTopLevelExt(m) then IrApp(IrGlobal(#sconcat(m, "__ext_default")), args) else recvLocal in
      let rec build = (is) =>
        match is {
          case Nil => fallback
          case Cons(i, r) =>
            match i { case Pair(th, rr) => match rr { case Pair(impl, ar) =>
              IrIf(orTagTests(recvLocal, extTypeTags(th)), IrApp(IrGlobal(impl), args), build(r)) } }
        } in
      Cons(IrDef(m, IrLam(arity, build(insts))), Nil)
  }

-- Emit one dispatcher per distinct extension-method name defined across given bodies.
def emitExtDispatchers = (stmts) =>
  let entries = collectExtDispatch(stmts) in
  let rec emitAll = (ms) =>
    match ms {
      case Nil => Nil
      case Cons(mm, r) => appendL(emitOneExtDispatcher(mm, extInstancesFor(mm, entries)), emitAll(r))
    } in
  emitAll(extDispatchMethodNames(stmts))

-- AST-carried case-class body methods: a front that does not populate caseMethodsCell as a parse side
-- effect (e.g. the new self-hosting spike) instead emits `("casemethods", (name, (fields, defs)))` nodes.
-- Collect them here and UNION with the cell — additive, so ssc1-front's own parse (which never emits these
-- nodes) is unaffected and production output stays byte-identical.
-- REVERSE-accumulate (like collectSubtypeNodesAcc below): ssc1-front populates caseMethodsCell as a parse
-- side effect by PREPENDING each class as it is parsed, so the cell ends up in REVERSE source order, and
-- that order is observable in the emitted `<Class>_<method>` defs. Collecting AST-carried nodes in source
-- order put the FIRST class's methods first and permuted the whole output (same bytes, wrong order).
def collectCaseMethodsNodesAcc = (stmts, acc) =>
  match stmts {
    case Nil => acc
    case Cons(s, rest) =>
      match s {
        case Pair(tag, data) =>
          if #seq(tag, "casemethods") then collectCaseMethodsNodesAcc(rest, Cons(data, acc))
          else collectCaseMethodsNodesAcc(rest, acc)
      }
  }
def collectCaseMethodsNodes = (stmts) => collectCaseMethodsNodesAcc(stmts, Nil)

-- AST-carried `using` signatures — same additive, production-safe pattern as collectCaseMethodsNodes:
-- a front that does not populate usingSigCell as a parse side effect emits `("usingsig", (name,
-- (usingTypes, fullCount)))` nodes; union them into usingSigCell for call-site given injection.
def collectUsingSigNodes = (stmts) =>
  match stmts {
    case Nil => Nil
    case Cons(s, rest) =>
      match s {
        case Pair(tag, data) =>
          if #seq(tag, "usingsig") then Cons(data, collectUsingSigNodes(rest))
          else collectUsingSigNodes(rest)
      }
  }

-- AST-carried default-parameter registry — same additive, production-safe pattern: a front that does not
-- populate funcDefaultsCell as a parse side effect emits `("funcdefaults", (name, (params, positionalDflts)))`.
def collectFuncDefaultsNodes = (stmts) =>
  match stmts {
    case Nil => Nil
    case Cons(s, rest) =>
      match s {
        case Pair(tag, data) =>
          if #seq(tag, "funcdefaults") then Cons(data, collectFuncDefaultsNodes(rest))
          else collectFuncDefaultsNodes(rest)
      }
  }

-- AST-carried subtype hierarchy — same additive, production-safe pattern: a front that does not populate
-- subtypeRegCell as a parse side effect emits `("subtype", (parent, childName))` per `case class C extends P`.
-- ssc1-front PREPENDS each entry (reverse source order), and subtypeChildren preserves cell order, so
-- accumulate in reverse (last-seen at the front) to reproduce the child-tag test order byte-for-byte.
def collectSubtypeNodesAcc = (stmts, acc) =>
  match stmts {
    case Nil => acc
    case Cons(s, rest) =>
      match s {
        case Pair(tag, data) =>
          if #seq(tag, "subtype") then collectSubtypeNodesAcc(rest, Cons(data, acc))
          else collectSubtypeNodesAcc(rest, acc)
      }
  }
def collectSubtypeNodes = (stmts) => collectSubtypeNodesAcc(stmts, Nil)

def lowerProg = (stmts) =>
  -- K62.18: imported extension identity is AST-owned, never transient parser
  -- state. This must run before resolveE classifies selected method calls.
  let _cmn = #cell.set(caseMethodsCell, appendL(collectCaseMethodsNodes(stmts), #cell.get(caseMethodsCell))) in
  let _usn = #cell.set(usingSigCell, appendL(collectUsingSigNodes(stmts), #cell.get(usingSigCell))) in
  let _fdn = #cell.set(funcDefaultsCell, appendL(collectFuncDefaultsNodes(stmts), #cell.get(funcDefaultsCell))) in
  let _stn = #cell.set(subtypeRegCell, appendL(collectSubtypeNodes(stmts), #cell.get(subtypeRegCell))) in
  let _em = #cell.set(extensionMethodsCell, collectExtensionMethods(stmts)) in
  -- Extension-dispatch registries: top-level extension methods + given-body dispatch names, so a
  -- method with both gets its top-level impl mangled to `m__ext_default` (dispatcher fallback).
  let _tle = #cell.set(topLevelExtMethodsCell, collectTopLevelExtMethods(stmts)) in
  let _ede = #cell.set(extDispatchMethodsCell, extDispatchMethodNames(stmts)) in
  -- KC5: initialize given table and sig table from parsed stmts
  let _gt = #cell.set(kc5GivenCell, buildGivenTable(stmts)) in
  let _st = #cell.set(kc5SigCell, buildSigTable(stmts)) in
  -- KC7b: reset known-objects registry (lower-case given instances)
  let _ko = #cell.set(kc7bObjectsCell, collectObjects(stmts)) in
  let _kov = #cell.set(objectVarsCell, collectObjectVars(stmts)) in
  -- Nested-type registry: `O.Inner(…)`/`O.Singleton` → unqualified hoisted global.
  let _kont = #cell.set(objectNestedTypesCell, collectObjectNestedTypes(stmts)) in
  let _ke = #cell.set(enumCasesCell, collectEnums(stmts)) in
  let _kop = #cell.set(kc7bOwnerPrefixCell, "") in
  let _kom = #cell.set(kc7bOwnerMembersCell, Nil) in
  -- K62.6e: reset case-class field registry (generated _sel_ accessors)
  let _cf = #cell.set(caseFieldsCell, collectCaseFields(stmts)) in
  -- named-args: per-class ordered field lists (constructor reorder)
  let _cfo = #cell.set(caseFieldOrderCell, collectCaseClassOrder(stmts)) in
  -- KC5b: reset active ctx (summon dispatch)
  let _ac = #cell.set(kc5ActiveCtxCell, Nil) in
  -- KC5-mono: reset the typeclass-monomorphisation worklist (populated while lowering)
  let _mono = #cell.set(kc5MonoCell, Nil) in
  -- Reset array/map/list variable registries
  let _av = #cell.set(arrVarsCell, Nil) in
  let _mv = #cell.set(mapVarsCell, Nil) in
  let _lv = #cell.set(listVarsCell, Nil) in
  let _da = #cell.set(defAritiesCell, collectDefArities(stmts)) in
  let _pd = #cell.set(parameterlessDefsCell, collectParameterlessDefs(stmts)) in
  let _ct = #cell.set(copyTempCounterCell, 0) in
  -- K62.6b: register top-level var names BEFORE lowering so references resolve to cells
  let _tv = #cell.set(topVarsCell, collectTopVars(stmts)) in
  let topValNames = collectTopVals(stmts) in
  let _tvl = #cell.set(topValsCell, topValNames) in
  let defs =
    Cons(printlnDef,
    Cons(printDef,
    Cons(mathDef,
    appendL(exceptionDefs, kc6Defs)))) in
  let userDefs = lowerStmts(stmts) in
  -- K62.15: merged field accessors (one _sel_<field> per name, all ctors) from the order registry
  let accDefs = buildMergedAccessors(#cell.get(caseFieldOrderCell)) in
  let allDefs = appendL(defs,
    appendL(topVarCellDefs(stmts),
    appendL(topValCellDefs(topValNames),
    appendL(caseMethodDefs(#cell.get(caseMethodsCell)), appendL(accDefs, userDefs))))) in
  -- T5.7: top-level expression statements ("expr") used to be silently dropped
  -- (~190/194 real .ssc files became no-ops). Collect them in document order into
  -- the entry: Seq(exprs..., main() if present). Defs are all registered before the
  -- entry runs, so document-order execution is safe.
  let rec topExprs = (ss) =>
    match ss {
      case Nil => Nil
      case Cons(s1, rest1) =>
        match s1 {
          case Pair(stag, sdata) =>
            if #seq(stag, "expr") then
              Cons(lowerE(Nil, resolveE(sdata)), topExprs(rest1))
            else if #seq(stag, "assign") then
              -- K62.6b: top-level assignment → cell.set (lowerE's assign case handles isTopVar)
              Cons(lowerE(Nil, s1), topExprs(rest1))
            else if #seq(stag, "while") then
              -- K62.19: reuse the block path so top-level cell mutation and
              -- IrWhile emission stay identical to a loop inside a function.
              Cons(lowerBlock(Nil, Cons(s1, Nil)), topExprs(rest1))
            else if #seq(stag, "var") then
              -- K62.6b: run the var's initializer in document order as cell.set(name__cell, init)
              match sdata {
                case Pair(vname, vinit) =>
                  Cons(IrPrim("cell.set",
                        Cons(IrGlobal(#sconcat(vname, "__cell")),
                        Cons(lowerE(Nil, resolveE(vinit)), Nil))),
                       topExprs(rest1))
              }
            else if #seq(stag, "val") then
              match sdata {
                case Pair(vname, vinit) =>
                  Cons(IrPrim("cell.set",
                        Cons(IrGlobal(#sconcat(vname, "__cell")),
                        Cons(lowerE(Nil, resolveE(vinit)), Nil))),
                       topExprs(rest1))
              }
            else if #seq(stag, "tuppat") then
              match sdata {
                case Pair(names, init) =>
                  let rec tupleSets = (ns, k) =>
                    match ns {
                      case Nil => Nil
                      case Cons(nm, more) =>
                        Cons(IrPrim("cell.set",
                               Cons(IrGlobal(#sconcat(nm, "__cell")),
                               Cons(IrApp(IrGlobal(#sconcat("_sel__", #i->str(k))),
                                     Cons(IrLocal(0), Nil)), Nil))),
                             tupleSets(more, #i.add(k, 1)))
                    } in
                  let sets = tupleSets(names, 1) in
                  let setBody = match sets {
                    case Nil => IrLit(IrUnit)
                    case Cons(one, more) => match more {
                      case Nil => one
                      case _ => IrSeq(sets)
                    }
                  } in
                  Cons(IrLet(Cons(lowerE(Nil, resolveE(init)), Nil), setBody),
                       topExprs(rest1))
              }
            else if #seq(stag, "casecls") then
              match sdata {
                case Pair(typeName, caseMeta) =>
                  match caseMeta {
                    case Pair(params, typeAndDerives) =>
                      match typeAndDerives {
                        case Pair(types, derives) =>
                          appendL(derivedInitIrs(typeName, derives), topExprs(rest1))
                      }
                  }
              }
            else topExprs(rest1)
        }
    } in
  let entryExprs = appendL(caseFieldRegs(#cell.get(caseFieldOrderCell)),
    appendL(caseMethodRegs(#cell.get(caseMethodsCell)), topExprs(stmts))) in
  let mainCall =
    if hasZeroArgMain(stmts) then Cons(IrApp(IrGlobal("main"), Nil), Nil)
    else Nil in
  let seqItems = appendL(entryExprs, mainCall) in
  let entry =
    match seqItems {
      case Nil => IrLit(IrUnit)
      case Cons(e1, r1) =>
        match r1 {
          case Nil => e1
          case _ => IrSeq(seqItems)
        }
    } in
  -- KC5-mono: append the specialised typeclass copies collected while lowering (defs + top exprs).
  -- Then bare extension-method dispatchers (given-body `extension def m` → type-dispatched `m`).
  IrProg(appendL(appendL(allDefs, emitMonoDefs(stmts)), emitExtDispatchers(stmts)), entry)
