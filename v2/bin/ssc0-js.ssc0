-- ssc0 -> JavaScript backend driver (multi-file: resolves `import`s via lib/loader).
--   ssc run bin/ssc0-js.ssc0 examples/fact.ssc0 | node   =>  120
import "../lib/backend-js.ssc0"
import "../lib/loader.ssc0"

def main = () =>
  match #io.args() {
    case Cons(path, rest) =>
      match loadDefs(path, Nil) { case Pair(defs, seen) => #io.print(genProg(compileModule(defs))) }
    case Nil => #io.eprint("usage: ssc0-js <file.ssc0>")
  }
