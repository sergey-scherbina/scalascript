      |/// The action marker of an element, if it has one (a `data-ssc-set`/
      |/// `data-ssc-toggle` = a focusable widget).
      |fn _tui_action_of(attrs: &[(String, String)]) -> Option<String> {
      |    if let Some(s) = _tui_attr(attrs, "data-ssc-set") { Some(format!("set:{}", s)) }
      |    else if let Some(s) = _tui_attr(attrs, "data-ssc-toggle") { Some(format!("toggle:{}", s)) }
      |    else { None }
      |}
      |
      |/// Collect the action markers (focusables) in document order.
      |fn _tui_collect_actions(v: &View, out: &mut Vec<String>) {
      |    match v {
      |        View::Element { attrs, children, .. } => {
      |            if let Some(a) = _tui_action_of(attrs) { out.push(a); }
      |            for c in children { _tui_collect_actions(c, out); }
      |        }
      |        View::Fragment(cs) => { for c in cs { _tui_collect_actions(c, out); } }
      |        _ => {}
      |    }
      |}
      |
      |/// Apply a focused action to the signal store, then recompute every
      |/// `computedSignal` so derived values reflect the change.
      |fn _tui_apply_action(marker: &str) {
      |    {
      |        let mut store = crate::value::ssc_signals().lock().unwrap();
      |        if let Some(rest) = marker.strip_prefix("set:") {
      |            if let Some(i) = rest.find(':') {
      |                store.insert(rest[..i].to_string(), rest[i + 1..].to_string());
      |            }
      |        } else if let Some(name) = marker.strip_prefix("toggle:") {
      |            let cur = store.get(name).map(|s| s == "true").unwrap_or(false);
      |            store.insert(name.to_string(), (!cur).to_string());
      |        }
      |    }
      |    crate::value::ssc_recompute_all();
      |}
      |
      |/// Plain text of a subtree. A `data-ssc-text` element reads the LIVE signal
      |/// value from the store, so computed/signal values are current.
      |fn _tui_text(v: &View) -> String {
      |    match v {
      |        View::Text(s) => s.clone(),
      |        View::Fragment(cs) => cs.iter().map(_tui_text).collect::<Vec<_>>().join(""),
      |        View::Element { attrs, children, .. } => {
      |            if let Some(name) = _tui_attr(attrs, "data-ssc-text") {
      |                crate::value::ssc_signals().lock().unwrap().get(name).cloned().unwrap_or_default()
      |            } else {
      |                children.iter().map(_tui_text).collect::<Vec<_>>().join("")
      |            }
      |        }
      |    }
      |}
      |
      |/// Rows a node occupies (drives vertical `Constraint::Length`).
      |fn _tui_height(v: &View) -> u16 {
      |    match v {
      |        View::Text(_) => 1,
      |        View::Fragment(cs) => cs_sum(cs),
      |        View::Element { tag, attrs, children } => {
      |            if _tui_attr(attrs, "data-ssc-text").is_some() { return 1; }
      |            match tag.as_str() {
      |                "h1" | "h2" | "h3" | "h4" | "h5" | "h6"
      |                | "p" | "span" | "button" | "input" | "a" | "label" | "hr" => 1,
      |                "table" => _tui_table_height(attrs),
      |                _ => if _tui_is_row(attrs) { cs_max(children) } else { cs_sum(children) },
      |            }
      |        }
      |    }
      |}
      |
      |fn cs_sum(children: &[View]) -> u16 {
      |    let s: u16 = children.iter().map(_tui_height).sum();
      |    s.max(1)
      |}
      |
      |fn cs_max(children: &[View]) -> u16 {
      |    children.iter().map(_tui_height).max().unwrap_or(1).max(1)
      |}
