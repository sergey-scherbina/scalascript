#!/usr/bin/env bash
# ssc — the ssc 2.0 runtime compiler (ssc0 -> ir -> ssc -> cpu).
# Thin launcher over scala-cli + v2/src. `command` bypasses any shell wrapper;
# --server=false keeps it daemonless.
set -euo pipefail
DIR="$(cd "$(dirname "$0")" && pwd)"
# --java-opt=-Xss512m: the VM's Compiler.compile / FastCode recurse deeply when lowering
# large programs (control-center-live, auth-full, …); the default stack overflows.
exec command scala-cli run "$DIR/src" --server=false --quiet --java-opt=-Xss512m -- "$@"
