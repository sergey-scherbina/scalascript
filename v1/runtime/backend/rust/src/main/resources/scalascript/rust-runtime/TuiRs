      |            if focused { style = style.add_modifier(Modifier::REVERSED); }
      |            if _tui_attr(attrs, "data-ssc-text").is_some() {
      |                frame.render_widget(Paragraph::new(_tui_text(v)).style(_tui_text_style(attrs, style)), area);
      |                return;
      |            }
      |            match tag.as_str() {
      |                "h1" | "h2" | "h3" | "h4" | "h5" | "h6" => {
      |                    frame.render_widget(
      |                        Paragraph::new(_tui_text(v)).style(_tui_text_style(attrs, style).add_modifier(Modifier::BOLD)), area);
      |                }
      |                "p" | "span" | "button" | "a" | "label" | "input" => {
      |                    frame.render_widget(Paragraph::new(_tui_text(v)).style(_tui_text_style(attrs, style)), area);
      |                }
      |                "hr" => { frame.render_widget(Block::default().borders(Borders::TOP), area); }
      |                "table" => _tui_table(frame, area, attrs),
      |                _ => _tui_stack(frame, area, children, ctx, _tui_is_row(attrs)),
      |            }
      |        }
      |    }
      |}
