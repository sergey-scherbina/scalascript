{
  "name": "@scalascript/control",
  "version": "0.1.0-snapshot.0",
  "description": "Compiler-independent ScalaScript effects and delimited control for JavaScript and TypeScript",
  "type": "module",
  "sideEffects": false,
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./index.d.ts",
  "files": [
    "LICENSE",
    "index.js",
    "index.d.ts",
    "README.md"
  ],
  "scripts": {
    "test": "node --test --test-concurrency=1 test/*.test.js",
    "typecheck": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  }
}
