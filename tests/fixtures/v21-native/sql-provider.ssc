#!/usr/bin/env ssc
---
databases:
  default:
    url: "jdbc:h2:mem:v21-native-sql;DB_CLOSE_DELAY=-1"
---

# Native SQL provider

```scalascript
Db.execute("default", "CREATE TABLE people (id BIGINT PRIMARY KEY, name VARCHAR(80), active BOOLEAN)", List())
println(Db.execute("default", "INSERT INTO people VALUES (?, ?, ?)", List(7, "Ada", true)))
val rows = Db.query("default", "SELECT id, name, active FROM people WHERE id = ?", List(7))
println(rows(0)("ID"))
println(rows(0)("NAME"))
println(rows(0)("ACTIVE"))
```
