       |// ── std.process — synchronous process spawning (java.lang.ProcessBuilder) ──
       |// Like the http Request/Response model, std/process's case classes are NOT
       |// inlined from the import on JVM codegen — the runtime supplies both the
       |// types AND `exec`. Appended unconditionally (self-contained, no user-type
       |// refs) to BOTH the inline preamble and the shared `_ssc_runtime` object
       |// (split --bytecode/run-jvm path), so `exec` resolves cross-module the same
       |// way `readFile` does. ssc Int is 64-bit → Long. `exec` honours
       |// opts.cwd / opts.env (the interpreter ignores them).
       |case class ProcessOptions(cwd: Option[String] = None, env: Map[String, String] = Map(), timeout: Option[Long] = None, inheritEnv: Boolean = true)
       |case class ProcessResult(stdout: String, stderr: String, exitCode: Long)
       |def exec(cmd: String, args: List[String], opts: ProcessOptions): ProcessResult =
       |  val _sscPb = new java.lang.ProcessBuilder((cmd :: args)*)
       |  _sscPb.redirectErrorStream(false)
       |  opts.cwd.foreach(_d => _sscPb.directory(new java.io.File(_d)))
       |  if !opts.inheritEnv then _sscPb.environment().clear()  // L3: scrub parent secrets
       |  if opts.env.nonEmpty then
       |    val _sscEnv = _sscPb.environment()
       |    opts.env.foreach { case (_k, _v) => _sscEnv.put(_k, _v) }
       |  val _sscProc = _sscPb.start()
       |  // Drain BOTH stdout and stderr on separate threads: reading a stream to EOF blocks
       |  // until the child exits, which would defeat opts.timeout AND (stderr >~64 KB) deadlock.
       |  val _sscOutBuf = new java.util.concurrent.atomic.AtomicReference[String]("")
       |  val _sscErrBuf = new java.util.concurrent.atomic.AtomicReference[String]("")
       |  val _sscOutThread = new Thread(() =>
       |    _sscOutBuf.set(scala.io.Source.fromInputStream(_sscProc.getInputStream).mkString))
       |  val _sscErrThread = new Thread(() =>
       |    _sscErrBuf.set(scala.io.Source.fromInputStream(_sscProc.getErrorStream).mkString))
       |  _sscOutThread.setDaemon(true)
       |  _sscErrThread.setDaemon(true)
       |  _sscOutThread.start()
       |  _sscErrThread.start()
       |  // Honour opts.timeout (ms): kill the child and report exit -1 on expiry.
       |  val _sscCode = opts.timeout match
       |    case Some(_ms) =>
       |      if _sscProc.waitFor(_ms, java.util.concurrent.TimeUnit.MILLISECONDS) then _sscProc.exitValue()
       |      else { _sscProc.destroyForcibly(); _sscProc.waitFor(); -1 }
       |    case None => _sscProc.waitFor()
       |  _sscOutThread.join(1000)
       |  _sscErrThread.join(1000)
       |  ProcessResult(_sscOutBuf.get(), _sscErrBuf.get(), _sscCode.toLong)
       |
