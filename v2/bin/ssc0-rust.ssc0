-- ssc0 -> Rust backend driver (multi-file: resolves `import`s via lib/loader).
--   ssc run bin/ssc0-rust.ssc0 examples/fact.ssc0 > f.rs ; rustc f.rs -o f ; ./f   =>  120
import "../lib/backend-rust.ssc0"
import "../lib/loader.ssc0"

def main = () =>
  match #io.args() {
    case Cons(path, rest) =>
      match loadDefs(path, Nil) { case Pair(defs, seen) => #io.print(genRProg(compileModule(defs))) }
    case Nil => #io.eprint("usage: ssc0-rust <file.ssc0>")
  }
