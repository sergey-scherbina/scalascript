#!/usr/bin/env bash
set -euo pipefail

# Robust release freeze for the standard-only negative-toolchain gate.
#
# The negative gate runs over the whole examples corpus, which GROWS and whose
# per-program classification SHIFTS as the compiler/breadth lanes advance (a program
# that used to fail the standard front now reaches the VM/bytecode/run lanes, etc.).
# Freezing every count to an exact value made the gate a moving target: every corpus
# addition or breadth advance turned it red on a baseline mismatch, not on a real
# regression. This freeze instead separates the RELEASE INVARIANTS (which must hold
# exactly, forever) from the DERIVED COUNTS (which may drift as the corpus grows):
#
#   HARD (exact)      — toolchain is physically absent; parity is clean; smokes pass.
#                       These are the actual guarantees the gate exists to prove.
#   FLOOR (>=)        — anti-fail-open: the corpus and parity coverage cannot silently
#                       collapse (a broken skip regex or a shrunken corpus is caught).
#   CAP (<=)          — sanity bounds.
#   CONSISTENCY (==)  — every example is classified exactly once (accounting closes),
#                       and the delegated split adds up.
#
# The one invariant that must NEVER be softened is parity.mismatch=0 (the VM/oracle
# disagreeing with direct bytecode is a real bug and stays loud). Timeouts and
# capacity gaps (Class too large) are environmental/backend and are classified as
# non-fatal skips upstream in bc-parity-sweep; they never reach these counters.

report=${1:-}
[[ -f $report ]] || {
  echo 'usage: scripts/v21-negative-toolchain-freeze REPORT.tsv' >&2
  exit 2
}

awk -F '\t' '
function req(key) {
  if (!(key in value)) { print P "missing metric: " key > "/dev/stderr"; bad=1; return 0 }
  return 1
}
function exact(key, want) {
  if (req(key) && value[key] != want)
    { print P key " expected " want ", got " value[key] > "/dev/stderr"; bad=1 }
}
function floorge(key, min) {
  if (req(key) && (value[key] + 0) < min)
    { print P key "=" value[key] " below floor " min > "/dev/stderr"; bad=1 }
}
function caple(key, max) {
  if (req(key) && (value[key] + 0) > max)
    { print P key "=" value[key] " above cap " max > "/dev/stderr"; bad=1 }
}
BEGIN { P = "v21-negative-toolchain-freeze: " }
NR == 1 {
  if ($1 != "metric" || $2 != "value") { print P "invalid header" > "/dev/stderr"; bad=1 }
  next
}
{
  if ($1 == "" || seen[$1]++) { print P "empty or duplicate metric: " $1 > "/dev/stderr"; bad=1 }
  value[$1]=$2
}
END {
  # --- HARD release invariants (the actual guarantees; exact) ---
  exact("default.launcher", "standard")
  exact("tools.present", "false")
  exact("compiler.jars", "0")
  exact("scalameta.jars", "0")
  exact("scala-cli.available", "false")
  exact("scalac.available", "false")
  exact("javac.available", "false")
  exact("java.compiler.available", "false")
  exact("jdk.compiler.available", "false")
  exact("forbidden.references", "0")
  exact("parity.both-fail", "0")   # a real deterministic both-lane gap must be classified away
  exact("parity.mismatch", "0")    # NEVER soften: VM/oracle vs bytecode disagreement = real bug
  exact("parity.one-sided", "0")   # a real single-lane error (non-capacity, non-timeout)
  exact("runtime.blockers", "0")
  exact("provider.smoke", "pass")
  exact("server.smoke", "pass")
  exact("release.ready", "true")

  # --- anti-fail-open floors (coverage cannot silently collapse) ---
  floorge("frontend.total", 210)   # corpus must not shrink below the known baseline
  floorge("frontend.ok", 200)      # the standard front must keep working for ~all examples
  floorge("checker.ok", 200)       # the standard checker must keep working for ~all examples
  floorge("parity.identical", 50)  # real VM==bytecode parity coverage must not collapse
  floorge("parity.delegated", 15)  # the explicit provider/target lanes must all be present

  # --- sanity caps ---
  caple("frontend.non-code", 5)

  # --- consistency (relationships that always hold) ---
  if (req("parity.provider-lane") && req("parity.target-lane") && req("parity.delegated") &&
      (value["parity.provider-lane"] + 0) + (value["parity.target-lane"] + 0) != (value["parity.delegated"] + 0))
    { print P "delegated != provider-lane + target-lane" > "/dev/stderr"; bad=1 }

  if (req("frontend.ok") && req("frontend.total") && (value["frontend.ok"] + 0) > (value["frontend.total"] + 0))
    { print P "frontend.ok > frontend.total" > "/dev/stderr"; bad=1 }

  # Accounting closure: bc-parity classifies every example into exactly one bucket,
  # so the buckets must sum back to the whole corpus. Catches any miscount/loss.
  if (req("frontend.total") && req("parity.identical") && req("parity.skipped") &&
      req("parity.delegated") && req("parity.both-fail") && req("parity.mismatch") &&
      req("parity.one-sided")) {
    sum = (value["parity.identical"] + 0) + (value["parity.skipped"] + 0) + \
          (value["parity.delegated"] + 0) + (value["parity.both-fail"] + 0) + \
          (value["parity.mismatch"] + 0) + (value["parity.one-sided"] + 0)
    if (sum != (value["frontend.total"] + 0))
      { print P "parity accounting " sum " != frontend.total " value["frontend.total"] > "/dev/stderr"; bad=1 }
  }

  # --- runtime module set must be present and free of the compiler modules ---
  modules=value["runtime.modules"]
  if (modules == "" || modules ~ /(^|,)(java[.]compiler|jdk[.]compiler)(,|$)/)
    { print P "invalid runtime.modules: " modules > "/dev/stderr"; bad=1 }

  exit bad
}
' "$report"

echo 'PASS v21-negative-toolchain-freeze'
