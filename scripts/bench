#!/usr/bin/env bash
# Single-entry benchmark runner. See docs/benchmarks.md for what each
# command measures and when to use it.
#
# Usage:
#   scripts/bench <command> [name-pattern]
#
# Run `scripts/bench help` for the full command list.

set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

# JMH defaults (override via env): 3 warmup x 5 measure x 1 fork ~= 25 s/bench.
WI="${BENCH_WI:-3}"
MI="${BENCH_MI:-5}"
F="${BENCH_F:-1}"

COMPILER_BENCH_CLASSES='(ParserBench|TyperBench|UnifyBench|SsccFormatCompilerBench)'

usage() {
  cat <<'EOF'
Usage: scripts/bench <command> [name-pattern]

Commands:
  interp [pat]    Interpreter microbenchmarks (InterpreterBench).
                  Use this for everyday interpreter perf A/B.
  cross [pat]     Cross-backend execution speed
                  (RuntimeBench: interp_X vs js_X vs jvm_X).
                  Use this to see how far interp is from JVM/JS backends.
  gen [pat]       Codegen-time benchmarks (CrossBackendBench: jvmGen_X / jsGen_X).
                  Use this to track how long backends take to PRODUCE code.
  compile [pat]   Compiler perf (parser / typer / unifier / .sscc format).
  compile-profile <pat>
                  `compile <pat>` + JFR alloc samples + JMH gc profiler.

  asm [pat]       Same as `interp [pat]` but with SSC_JIT_BACKEND=asm.
                  Use this to verify AsmJitBackend is at parity with Javac.
  off <pat>       Same as `interp <pat>` but with SSC_JIT_BYTECODE=off
                  and SSC_FASTTIER=off — proves the fall-back paths still
                  run correctly.
  profile <pat>   `interp <pat>` + JFR alloc samples + JMH gc profiler.
                  Use this when you need to know WHY a bench is slow.

  smoke           One-iteration smoke (proves the bench infra is wired up).
                  Same command as the perf-manifest smoke target.
  wall            Wall-clock cross-language run (tests/bench/run.sc):
                  ssc-interp / ssc-jvm / ssc-js / scala-direct / node-direct.
                  Use this for cold-JVM, fresh-process numbers.
  v2-backends [pat]
                  Corpus wall-clock through v2 VM, v2 JVM source backend,
                  and v2 Rust source backend (bench/run.sc --v2-backends).
  v2-bytecode [pat]
                  Corpus wall-clock through v2 VM and the v2 JVM bytecode lane
                  (bench/run.sc --v2-bytecode).

  list            List all available @Benchmark methods.
  help            This message.

Examples:
  scripts/bench interp                  # all interp benches (Javac JIT)
  scripts/bench interp recursionFib     # filter to one bench
  scripts/bench asm                     # all interp benches with AsmJitBackend
  scripts/bench asm recursionFib        # one bench, ASM backend
  scripts/bench off recursionFib        # same bench with optimizations off
  scripts/bench profile instanceFieldAccess
  scripts/bench compile-profile parseActors
  scripts/bench cross arithLoop         # interp vs JS vs JVM, one workload
  scripts/bench v2-bytecode arith-loop  # v2 VM vs v2 bytecode, one workload

Env overrides:
  BENCH_WI=N   warmup iterations (default 3)
  BENCH_MI=N   measure iterations (default 5)
  BENCH_F=N    forks (default 1; use 2 for higher-confidence A/B)
EOF
}

cmd="${1:-help}"
case "$cmd" in
  help|-h|--help) usage; exit 0 ;;
esac
shift
pat="${1:-.*}"

# Sprint notes use CLI-friendly kebab names. JMH method names stay JVM-safe.
case "$cmd" in
  interp|cross|gen|compile|compile-profile|asm|off|profile)
    case "$pat" in
      option-chain) pat="optionChain" ;;
      either-chain) pat="eitherChain" ;;
      hof-pipeline) pat="hofPipeline" ;;
      range-sum)    pat="rangeSum" ;;
      typeclass-fold) pat="typeclassFold" ;;
    esac
    ;;
esac

# Class-scoped JMH pattern. `.*Class.*pat.*` is permissive on both ends so
# `interp_X` / `jvmGen_X` prefixes inside the class match a bare workload
# name like `arithLoop`.
jmh_run() {
  local project="$1"; shift
  local cls="$1"; shift
  local extra=("$@")
  local regex=".*${cls}.*${pat}.*"
  local options="-wi ${WI} -i ${MI} -f ${F}"
  if ((${#extra[@]})); then
    options+=" ${extra[*]}"
  fi
  sbt "${project}/Jmh/run ${options} ${regex}"
}

require_pat() {
  if [[ "$pat" == ".*" ]]; then
    echo "scripts/bench $cmd: requires a name pattern" >&2
    exit 2
  fi
}

jmh_profile() {
  require_pat
  jmh_run "$1" "$2" '-prof' 'gc' '-prof' '"jfr:configName=profile"'
}

case "$cmd" in
  interp)   jmh_run interpreterBench InterpreterBench ;;
  cross)    jmh_run interpreterBench RuntimeBench ;;
  gen)      jmh_run interpreterBench CrossBackendBench ;;
  compile)  jmh_run compilerBench "$COMPILER_BENCH_CLASSES" ;;
  compile-profile) jmh_profile compilerBench "$COMPILER_BENCH_CLASSES" ;;

  asm)
    # SSC_JIT_BACKEND is read from sys.env only; env var propagates to the
    # JMH-forked JVM automatically via ProcessBuilder's inherited environment.
    SSC_JIT_BACKEND=asm jmh_run interpreterBench InterpreterBench
    ;;

  off)
    require_pat
    # Set BOTH env and system properties so the off-mode reaches the JMH-forked
    # JVM regardless of which one BytecodeJit/FastTier sees first.
    SSC_JIT_BYTECODE=off SSC_FASTTIER=off \
      jmh_run interpreterBench InterpreterBench \
        '-jvmArgsPrepend' '"-Dssc.jit.bytecode=off -Dssc.fasttier=off"'
    ;;

  profile)
    jmh_profile interpreterBench InterpreterBench
    ;;

  smoke)
    # Absolute path: JMH forks run in the subproject baseDirectory, so a
    # relative `bench/...` would resolve under runtime/backend/interpreter-bench.
    sbt "interpreterBench/Jmh/run -wi 1 -i 1 -f 1 -rff ${ROOT}/bench/jmh-smoke.json -rf json .*InterpreterBench.arithLoop.*"
    ;;

  wall)
    if ! command -v scala-cli >/dev/null 2>&1; then
      echo "scripts/bench wall: scala-cli not found; install it or skip" >&2
      exit 1
    fi
    scala-cli --server=false tests/bench/run.sc   # serverless: no lingering bloop daemon
    ;;

  v2-backends)
    if ! command -v scala-cli >/dev/null 2>&1; then
      echo "scripts/bench v2-backends: scala-cli not found; install it or skip" >&2
      exit 1
    fi
    if [[ "$pat" == ".*" ]]; then
      ./bench.sh --v2-backends
    else
      ./bench.sh --v2-backends "$pat"
    fi
    ;;

  v2-bytecode)
    if ! command -v scala-cli >/dev/null 2>&1; then
      echo "scripts/bench v2-bytecode: scala-cli not found; install it or skip" >&2
      exit 1
    fi
    if [[ "$pat" == ".*" ]]; then
      ./bench.sh --v2-bytecode
    else
      ./bench.sh --v2-bytecode "$pat"
    fi
    ;;

  list)
    sbt 'interpreterBench/Jmh/run -lp .*' 'compilerBench/Jmh/run -lp .*' 2>/dev/null | \
      grep -E 'scalascript\.bench\.' | sort -u
    ;;

  *)
    echo "scripts/bench: unknown command '$cmd'" >&2
    usage >&2
    exit 2
    ;;
esac
