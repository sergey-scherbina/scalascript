description: SclJet M3 deep B-tree AND cell overflow together — a 3-level tree whose oversized rows spill onto overflow chains, cross-backend
backends: [int, js]
---

# SclJet deep tree + cell overflow (full bulk-build matrix)

[ByteSlice, byteSliceGet, SqliteValue, SqlInteger, SqlText, buildDeepOverflowTableDatabase](std/scljet/index.ssc)

```scalascript
def text(n: Int): String =
  if n <= 0 then ""
  else if n == 1 then "a"
  else
    val half = text(n / 2)
    if n % 2 == 0 then half + half else half + half + "a"

// 80 rows: ~250-byte values pack ~1 per leaf → ~76 leaves → a three-level tree
// (root → interior → leaves). Every 20th row is a 1016-char value that also
// spills onto a two-page overflow chain — so a single file exercises BOTH deep
// packing and overflow. Verified out-of-band against reference SQLite (88 pages,
// integrity_check ok, depth 3, every row exact). Fingerprinted (iterative
// Adler-32) so int and JS must agree byte-for-byte.
def rows(n: Int): List[List[SqliteValue]] =
  var i = n
  var acc: List[List[SqliteValue]] = Nil
  while i >= 1 do
    val v = if i % 20 == 0 then text(1016) else "row-" + i.toString + "-" + text(240)
    acc = List(SqlInteger(i.toLong), SqlText(v)) :: acc
    i = i - 1
  acc

def adler32(bytes: ByteSlice): Long =
  var adI = 0
  var adA = 1L
  var adB = 0L
  while adI < bytes.length do
    byteSliceGet(bytes, adI) match
      case Right(b) =>
        adA = (adA + b.toLong) % 65521L
        adB = (adB + adA) % 65521L
      case Left(e) => adA = adA
    adI = adI + 1
  adB * 65536L + adA

buildDeepOverflowTableDatabase(512, 7, 3, "big", "CREATE TABLE big(n INTEGER, v TEXT)", rows(80)) match
  case Right(bytes) => println((bytes.length / 512).toString + ":" + bytes.length.toString + ":" + adler32(bytes).toString)
  case Left(error) => println("ERROR:" + error.message)
```
