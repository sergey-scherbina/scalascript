      |/// fieldColumn(title, fieldPath) → a (title, fieldPath) pair carried as a Tuple.
      |pub fn _tui_field_column(title: String, field: String) -> crate::value::Value {
      |    crate::value::Value::Tuple(vec![crate::value::Value::Str(title), crate::value::Value::Str(field)])
      |}
