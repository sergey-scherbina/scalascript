-- KC4+KC6: lower v1.0 ScalaScript AST (from ssc1-front.ssc0) to Core IR Data.
-- KC4 = de Bruijn lowering; KC6 = pre-lowering resolve pass (intrinsics, ctors).
-- Written in ssc0 to avoid Mira HM stack overflow on large inputs.
-- Import this, then call:  #coreir.encode(lowerProg(parse(src)))
import "../lib/ssc1-front.ssc0"

-- ── Utilities ──────────────────────────────────────────────────────────────

-- Unwrap Option[Int] from #str->i (parser only emits valid int strings)
def parseI = (s) => match #str->i(s) { case Some(n) => n case None => 0 }

-- Reverse a list (used to build de Bruijn scope from params)
def revL = (xs) =>
  let rec go = (xs2, acc) =>
    match xs2 { case Nil => acc case Cons(h, t) => go(t, Cons(h, acc)) } in
  go(xs, Nil)

-- Length of a list
def lenL = (xs) =>
  let rec go = (xs2, n) =>
    match xs2 { case Nil => n case Cons(u, t) => go(t, #i.add(n, 1)) } in
  go(xs, 0)

-- Append two lists
def appendL = (xs, ys) =>
  match xs { case Nil => ys case Cons(h, t) => Cons(h, appendL(t, ys)) }

-- De Bruijn lookup: returns IrLocal(i) if found, else IrGlobal(name)
def lookupVar = (scope, name) =>
  let rec go = (sc, d) =>
    match sc {
      case Nil => IrGlobal(name)
      case Cons(h, t) =>
        if #seq(h, name) then IrLocal(d)
        else go(t, #i.add(d, 1))
    } in
  go(scope, 0)

-- Optional De Bruijn lookup: returns Some(IrLocal(i)) if found, None if not
def lookupVarOpt = (scope, name) =>
  let rec go = (sc, d) =>
    match sc {
      case Nil => None
      case Cons(h, t) =>
        if #seq(h, name) then Some(IrLocal(d))
        else go(t, #i.add(d, 1))
    } in
  go(scope, 0)

-- Is this expression an integer literal? (for lcell optimization)
def isIntLitExpr = (expr) =>
  match expr {
    case Pair(etag, edata) => #seq(etag, "int")
  }

-- Check if a name is a registered array/vector variable
def isArrVar = (name) =>
  let rec go = (xs) =>
    match xs { case Nil => false case Cons(n, rest) => if #seq(n, name) then true else go(rest) } in
  go(#cell.get(arrVarsCell))

-- Check if a name is a registered map variable
def isMapVar = (name) =>
  let rec go = (xs) =>
    match xs { case Nil => false case Cons(n, rest) => if #seq(n, name) then true else go(rest) } in
  go(#cell.get(mapVarsCell))

-- K62.6b: top-level mutable `var`s become global cells (visible to global defs,
-- unlike block vars which live in the de Bruijn scope). A reference to such a name
-- lowers to `cell.get(global name__cell)`; an assignment to `cell.set`.
def isTopVar = (name) =>
  let rec go = (xs) =>
    match xs { case Nil => false case Cons(n, rest) => if #seq(n, name) then true else go(rest) } in
  go(#cell.get(topVarsCell))

-- Top-level immutable values are also initialized through global cells.  Their
-- initializers execute from the entry in document order instead of being
-- evaluated eagerly with IrDef before earlier expression statements.
def isTopVal = (name) =>
  let rec go = (xs) =>
    match xs { case Nil => false case Cons(n, rest) => if #seq(n, name) then true else go(rest) } in
  go(#cell.get(topValsCell))

-- Check if a resolved expression is Array/Vector construction
def isArrayConstruction = (rb) =>
  match rb {
    case Pair(rtag, rdata) =>
      if #seq(rtag, "app") then
        match rdata {
          case Pair(fn, args) =>
            match fn {
              case Pair(ftag, fname) =>
                if #seq(ftag, "var") then #seq(fname, "_arr_fill")
                else false
            }
        }
      else false
  }

-- Check if a resolved expression is Map construction
def isMapConstruction = (rb) =>
  match rb {
    case Pair(rtag, rdata) =>
      if #seq(rtag, "prim") then
        match rdata {
          case Pair(op, args) => #seq(op, "map.new")
        }
      else false
  }

-- ── KC5: given auto-injection ────────────────────────────────────────────────
-- Given table: List[Pair(Pair(TC_name, T_name), given_var_name)]
-- Sig table:   List[Pair(fn_name, List[TC_name])] — fns with ctx dict params
-- Uses mutable cells (same pattern as mira.ssc0 rowFreshCell).

def kc5GivenCell = #cell.new(Nil)
def kc5SigCell   = #cell.new(Nil)
-- Active TC context: List[Pair(given_name, tc_name)] for current def body
def kc5ActiveCtxCell = #cell.new(Nil)
-- Set of object names (lowercase given instances) for static dispatch
def kc7bObjectsCell = #cell.new(Nil)
-- Enum registry: [Pair(enumName, cases)] where cases = [Pair(caseName, params)].
-- Lets a `EnumName.Case` companion access lower to a bare `(ctor Case)` and
-- `EnumName.values` to the list of nullary case ctors (mirrors the scalameta
-- bridge, which drops the enum qualifier — shared case names across enums are
-- the same ctor tag, which is correct for `==`/pattern semantics).
def enumCasesCell = #cell.new(Nil)
-- While lowering one static object/given body, bare references to sibling
-- members resolve to the same deterministic owner prefix. Parameters and
-- locals still win because lowerE consults its lexical scope first.
def kc7bOwnerPrefixCell  = #cell.new("")
def kc7bOwnerMembersCell = #cell.new(Nil)
-- Set true while lowering a def body whenever a `return` is lowered to a non-local
-- throw. Read after the body to decide whether to wrap it in `__with_return__`
-- (only defs that CONTAIN a return are wrapped, so return-free/TCO defs are untouched).
def defHasReturnCell = #cell.new(false)
def wrapReturn = (body) => IrPrim("__with_return__", Cons(IrLam(0, body), Nil))
-- Active case-class body-method context: `Pair(tag, siblingMethodNames)` while a
-- case class's method body is being lowered, else `Nil`. Lets a bare sibling call
-- inside a method (`def run() = helper(5)`) resolve to the mangled `Tag_helper`
-- global WITH `__self` prepended (case-class methods are `Tag_m(self, params…)`).
def caseSelfCtxCell = #cell.new(Nil)
def memberOfL = (x, xs) =>
  match xs {
    case Nil => false
    case Cons(h, t) => if #seq(h, x) then true else memberOfL(x, t)
  }

-- Mutable class `var` fields (--mutable flag; mutableFieldsCell = [Pair(tag, [names])]).
-- A var field is stored as a CELL in the object's DataV, so reads/writes inside a
-- method route through cell.get / cell.set on `_sel_<field>(__self)`.
def classVarFields = (tag) =>
  let rec go = (rs) =>
    match rs {
      case Nil => Nil
      case Cons(r, rest) =>
        match r { case Pair(t, vs) => if #seq(t, tag) then vs else go(rest) }
    } in
  go(#cell.get(mutableFieldsCell))
-- Is `name` a var field of the CURRENT method's class (caseSelfCtxCell tag)?
def isCurrentVarField = (name) =>
  match #cell.get(caseSelfCtxCell) {
    case Nil => false
    case Pair(tag, sibs) => memberOfL(name, classVarFields(tag))
  }
-- Is `name` a `var` field of ANY class? Used to unwrap an external `obj.field`
-- read (the receiver's class is not known statically); the unwrap is SAFE
-- (cell.getOr) so a same-named non-var field elsewhere is unaffected.
def isAnyVarField = (name) =>
  let rec go = (rs) =>
    match rs {
      case Nil => false
      case Cons(r, rest) =>
        match r { case Pair(t, vs) => if memberOfL(name, vs) then true else go(rest) }
    } in
  go(#cell.get(mutableFieldsCell))
-- Already a `cell.new(...)` wrap? resolveE can revisit the ctor args, so the wrap
-- must be idempotent (else `cell.new(cell.new(5))`).
def isCellNewWrap = (e) =>
  match e {
    case Pair(t, d) =>
      if #seq(t, "prim") then (match d { case Pair(op, xs) => #seq(op, "cell.new") })
      else false
  }
def classFieldOrder = (tag) =>
  let rec go = (rs) =>
    match rs {
      case Nil => Nil
      case Cons(r, rest) =>
        match r { case Pair(t, fs) => if #seq(t, tag) then fs else go(rest) }
    } in
  go(#cell.get(caseFieldOrderCell))
-- Wrap the (positional) ctor args of a mutable class at var-field positions in a
-- `cell.new` so the DataV stores a cell for each `var` field.
def cellWrapCtorArgs = (cname, args) =>
  let vars = classVarFields(cname) in
  match vars {
    case Nil => args
    case Cons(vh, vt) =>
      let rec go = (fields, as) =>
        match as {
          case Nil => Nil
          case Cons(a, arest) =>
            match fields {
              case Cons(f, frest) =>
                let a2 = if memberOfL(f, vars) then
                           (if isCellNewWrap(a) then a else Pair("prim", Pair("cell.new", Cons(a, Nil))))
                         else a in
                Cons(a2, go(frest, arest))
              case Nil => Cons(a, go(Nil, arest))
            }
        } in
      go(classFieldOrder(cname), args)
  }
-- Names of MUTABLE `var` members of the object being lowered. A read/write of such
-- a name inside the object's methods routes to the owner-prefixed global cell
-- (`Owner_name__cell`), like a top-level var — objects with mutable state
-- (e.g. std/mapreduce HandlerRegistry's `var entries`) were otherwise unbound.
def kc7bOwnerVarsCell = #cell.new(Nil)
-- K62.6e: field names of all case classes — a field access whose name is here
-- has a generated _sel_<field> accessor (index extractor); anything else routes
-- to __method__ (plugin/record field resolution in the VM).
def caseFieldsCell = #cell.new(Nil)
-- named-args: per-class ordered field list [Pair(name, params)] so a construction
-- `Foo(b = y, a = x)` can be reordered to declared field order. Separate from the
-- flat caseFieldsCell above so it does not disturb the field-access routing.
def caseFieldOrderCell = #cell.new(Nil)
-- Array and Map variable name registries (for indexed read/write lowering)
def arrVarsCell = #cell.new(Nil)
def topVarsCell = #cell.new(Nil)
def topValsCell = #cell.new(Nil)
def mapVarsCell = #cell.new(Nil)
-- List variable name registry (for .length dispatch to _sel_length vs slen)
def listVarsCell = #cell.new(Nil)
-- Summon-value alias registry: [Pair(localName, tc)] for `val m = summon[TC[A]]` where the given is
-- abstract (poly body). m has no value representation; m.method/m.field dispatch to the active-ctx
-- instance for tc. Reset per def body (block-local aliases are consumed during resolveBlock).
def summonAliasCell = #cell.new(Nil)
def registerSummonAlias = (name, tc) =>
  #cell.set(summonAliasCell, Cons(Pair(name, tc), #cell.get(summonAliasCell)))
def summonAliasTC = (name) =>
  let rec go = (xs) =>
    match xs {
      case Nil => None
      case Cons(p, rest) => match p { case Pair(n, tc) => if #seq(n, name) then Some(tc) else go(rest) }
    } in
  go(#cell.get(summonAliasCell))
-- Total arity of assembled top-level definitions. Source parameter clauses are
-- flattened in def nodes but calls retain nested App clauses; this table lets
-- resolveE reconcile only a known full curried call without relaxing CoreIR.
def defAritiesCell = #cell.new(Nil)
-- Source declarations that omitted a parameter clause. Their CoreIR body is a
-- nullary factory, but a bare source reference denotes the produced value.
-- Explicit `def f()` declarations are intentionally absent from this set.
def parameterlessDefsCell = #cell.new(Nil)
-- Synthetic lexical names for named-copy single-evaluation lowering.
def copyTempCounterCell = #cell.new(0)

def freshCopyTemp = (kind) =>
  let n = #cell.get(copyTempCounterCell) in
  let _next = #cell.set(copyTempCounterCell, #i.add(n, 1)) in
  #sconcat("__ssc_copy_", #sconcat(kind, #sconcat("_", #i->str(n))))

def defArity = (name) =>
  let rec go = (entries) =>
    match entries {
      case Nil => Pair(false, 0)
      case Cons(entry, rest) =>
        match entry {
          case Pair(defName, arity) =>
            if #seq(defName, name) then Pair(true, arity) else go(rest)
        }
    } in
  go(#cell.get(defAritiesCell))

def isParameterlessDef = (name) =>
  let rec go = (names) =>
    match names {
      case Nil => false
      case Cons(h, rest) => if #seq(h, name) then true else go(rest)
    } in
  go(#cell.get(parameterlessDefsCell))

def isParameterlessBody = (body) =>
  match body {
    case Pair(tag, data) => #seq(tag, "parameterless")
  }

-- A callee position already supplies an explicit argument clause. Do not
-- auto-apply it while resolving the surrounding App or `f()` would become
-- `f()()`.
def resolveCallee = (fn) =>
  match fn {
    case Pair(tag, data) =>
      if #seq(tag, "var") then
        if isParameterlessDef(data) then fn else resolveE(fn)
      else resolveE(fn)
  }

-- Check if a name is a registered list variable
def isListVar = (name) =>
  let rec go = (xs) =>
    match xs { case Nil => false case Cons(n, rest) => if #seq(n, name) then true else go(rest) } in
  go(#cell.get(listVarsCell))

-- Check if a resolved expression returns a list (call to a list-returning selector)
def isListConstruction = (rb) =>
  match rb {
    case Pair(rtag, rdata) =>
      if #seq(rtag, "app") then
        match rdata {
          case Pair(fn, args) =>
            match fn {
              case Pair(ftag, fname) =>
                if #seq(ftag, "var") then
                  if #seq(fname, "_sel_runToList") then true
                  else if #seq(fname, "_sel_filter") then true
                  else if #seq(fname, "_sel_map") then true
                  else if #seq(fname, "_sel_flatMap") then true
                  else if #seq(fname, "_sel_take") then true
                  else false
                else false
            }
        }
      else false
  }

def isKnownObject = (name) =>
  let rec go = (xs) =>
    match xs {
      case Nil => false
      case Cons(h, t) => if #seq(h, name) then true else go(t)
    } in
  go(#cell.get(kc7bObjectsCell))

-- Enum companion queries over enumCasesCell ([Pair(enumName, cases)]).
def enumCasesOf = (ename) =>
  let rec go = (xs) =>
    match xs {
      case Nil => Nil
      case Cons(e, t) =>
        match e { case Pair(en, cases) => if #seq(en, ename) then cases else go(t) }
    } in
  go(#cell.get(enumCasesCell))
def isEnumUid = (ename) =>
  let rec go = (xs) =>
    match xs {
      case Nil => false
      case Cons(e, t) =>
        match e { case Pair(en, cs) => if #seq(en, ename) then true else go(t) }
    } in
  go(#cell.get(enumCasesCell))
-- A case is nullary iff it declares no params. Only nullary cases lower a BARE
-- `EnumName.Case` to `(ctor Case)`; parametrized cases (e.g. `Custom(hex)`) reach
-- here only via application `EnumName.Case(args)`, which the applied path handles.
def enumNullaryCase = (cases, cname) =>
  match cases {
    case Nil => false
    case Cons(c, t) =>
      match c { case Pair(cn, params) =>
        if #seq(cn, cname) then (match params { case Nil => true case Cons(h, m) => false })
        else enumNullaryCase(t, cname) }
  }
-- EnumName.values → the Cons-list of the enum's NULLARY case ctors (Scala `.values`
-- yields the singleton cases). Built as `ctorap` sexprs so lowerArgs turns them into
-- nested IrCtor Cons cells.
def enumValuesList = (cases) =>
  match cases {
    case Nil => Pair("ctorap", Pair("Nil", Nil))
    case Cons(c, t) =>
      match c { case Pair(cn, params) =>
        match params {
          case Nil => Pair("ctorap", Pair("Cons",
                        Cons(Pair("ctorap", Pair(cn, Nil)), Cons(enumValuesList(t), Nil))))
          case Cons(h, m) => enumValuesList(t)
        } }
  }

def isActiveOwnerMember = (name) =>
  let rec go = (xs) =>
    match xs {
      case Nil => false
      case Cons(h, t) => if #seq(h, name) then true else go(t)
    } in
  go(#cell.get(kc7bOwnerMembersCell))

def isActiveOwnerVar = (name) =>
  let rec go = (xs) =>
    match xs {
      case Nil => false
      case Cons(h, t) => if #seq(h, name) then true else go(t)
    } in
  go(#cell.get(kc7bOwnerVarsCell))

def ownerVarNames = (stmts) =>
  match stmts {
    case Nil => Nil
    case Cons(s, rest) =>
      match s {
        case Pair(tag, data) =>
          if #seq(tag, "var") then
            match data { case Pair(name, init) => Cons(name, ownerVarNames(rest)) }
          else ownerVarNames(rest)
      }
  }

-- Registry of each object's `var` fields (`[Pair(objName, [varNames])]`), so an
-- EXTERNAL read `O.f` of an object's mutable field resolves to `cell.get(O_f__cell)`
-- (internal reads already route via isActiveOwnerVar). Objects are module-level
-- singletons — their `var` fields are like top-level vars and are NOT --mutable-gated.
def objectVarsCell = #cell.new(Nil)
def collectObjectVars = (stmts) =>
  match stmts {
    case Nil => Nil
    case Cons(s, rest) =>
      match s {
        case Pair(tag, data) =>
          if #seq(tag, "object") then
            match data { case Pair(oname, ostmts) =>
              Cons(Pair(oname, ownerVarNames(ostmts)), collectObjectVars(rest)) }
          else collectObjectVars(rest)
      }
  }
def objectVarFields = (oname) =>
  let rec go = (rs) =>
    match rs {
      case Nil => Nil
      case Cons(r, rest) =>
        match r { case Pair(o, vs) => if #seq(o, oname) then vs else go(rest) }
    } in
  go(#cell.get(objectVarsCell))
-- Registry of each object's NESTED TYPE names — case class / case object / enum.
-- prefixDefs hoists these to TOP-LEVEL UNqualified globals (v2 types are global and
-- tag-based), so a qualified reference `O.Inner(…)`/`O.Singleton` must resolve to the
-- unqualified `Inner`/`Singleton`, NOT `O_Inner` (which was never bound → `unbound
-- global`). `[Pair(objName, [typeNames])]`.
def objectNestedTypesCell = #cell.new(Nil)
def nestedTypeNames = (stmts) =>
  match stmts {
    case Nil => Nil
    case Cons(s, rest) =>
      match s {
        case Pair(tag, data) =>
          if #seq(tag, "casecls") then
            match data { case Pair(n, drest) => Cons(n, nestedTypeNames(rest)) }
          else if #seq(tag, "caseobj") then
            Cons(data, nestedTypeNames(rest))
          else if #seq(tag, "enum") then
            match data { case Pair(n, cs) => Cons(n, nestedTypeNames(rest)) }
          else nestedTypeNames(rest)
      }
  }
def collectObjectNestedTypes = (stmts) =>
  match stmts {
    case Nil => Nil
    case Cons(s, rest) =>
      match s {
        case Pair(tag, data) =>
          if #seq(tag, "object") then
            match data { case Pair(oname, ostmts) =>
              Cons(Pair(oname, nestedTypeNames(ostmts)), collectObjectNestedTypes(rest)) }
          else collectObjectNestedTypes(rest)
      }
  }
def objectNestedTypes = (oname) =>
  let rec go = (rs) =>
    match rs {
      case Nil => Nil
      case Cons(r, rest) =>
        match r { case Pair(o, ts) => if #seq(o, oname) then ts else go(rest) }
    } in
  go(#cell.get(objectNestedTypesCell))
-- Resolve `O.member(rargs)` on a known object: a no-arg read of a mutable `var`
-- field is `cell.get(O_member__cell)`; everything else is the static `O_member`.
def resolveObjMember = (rname, method, rargs) =>
  if memberOfL(method, objectNestedTypes(rname)) then
    -- `O.Inner(args)` where Inner is a nested type hoisted to top-level unqualified:
    -- construct the bare ctor (reorder named args + fill defaults, exactly like a
    -- direct `Inner(args)` call), NOT the unbound `O_Inner`.
    Pair("ctorap", Pair(method, ctorApplyDefaults(method, resolveCtorArgs(method, rargs))))
  else if memberOfL(method, objectVarFields(rname)) then
    match rargs {
      case Nil =>
        Pair("prim", Pair("cell.get",
          Cons(Pair("var", #sconcat(rname, #sconcat("_", #sconcat(method, "__cell")))), Nil)))
      case _ =>
        let mangled = #sconcat(rname, #sconcat("_", method)) in
        Pair("app", Pair(Pair("var", mangled), packObjVarargs(method, mangled, rargs)))
    }
  else
    let mangled = #sconcat(rname, #sconcat("_", method)) in
    Pair("app", Pair(Pair("var", mangled), packObjVarargs(method, mangled, rargs)))
-- Property read `O.field` (no call): a mutable `var` field is `cell.get(O_field__cell)`,
-- otherwise the static `O_field` global.
def resolveObjProp = (rname, field) =>
  if memberOfL(field, objectNestedTypes(rname)) then
    -- A nested type hoisted to top-level unqualified. `O.Enum` only ever appears as
    -- `O.Enum.Case` (an enum type isn't a value) → pass the bare enum name through as
    -- a `uid` so the outer `.Case` select hits the normal enum-case machinery
    -- (`Dir.North` → `North`). A `case object` reference is a real value → bare global.
    if isEnumUid(field) then Pair("uid", field)
    else Pair("var", field)
  else if memberOfL(field, objectVarFields(rname)) then
    Pair("prim", Pair("cell.get",
      Cons(Pair("var", #sconcat(rname, #sconcat("_", #sconcat(field, "__cell")))), Nil)))
  else Pair("var", #sconcat(rname, #sconcat("_", field)))

def staticMemberNames = (stmts) =>
  match stmts {
    case Nil => Nil
    case Cons(s, rest) =>
      match s {
        case Pair(tag, data) =>
          if #seq(tag, "def") then
            match data { case Pair(name, body) => Cons(name, staticMemberNames(rest)) }
          else if #seq(tag, "val") then
            match data { case Pair(name, body) => Cons(name, staticMemberNames(rest)) }
          else staticMemberNames(rest)
      }
  }

-- Build the alternating name/value payload expected by the existing portable
-- __mk_method_obj__ primitive. Static member globals are still emitted for
-- direct owner/summon dispatch; the method object makes the same members
-- survive when the given flows through an ordinary value.
def staticMemberObjectArgs = (prefix, stmts) =>
  match stmts {
    case Nil => Nil
    case Cons(s, rest) =>
      match s {
        case Pair(tag, data) =>
          if #seq(tag, "def") then
            match data {
              case Pair(name, body) =>
                Cons(IrLit(IrStr(name)),
                  Cons(IrGlobal(#sconcat(prefix, name)),
                    staticMemberObjectArgs(prefix, rest)))
            }
          else if #seq(tag, "val") then
            match data {
              case Pair(name, body) =>
                Cons(IrLit(IrStr(name)),
                  Cons(IrGlobal(#sconcat(prefix, name)),
                    staticMemberObjectArgs(prefix, rest)))
            }
          else staticMemberObjectArgs(prefix, rest)
      }
  }

def isExtensionMethod = (name) =>
  let rec go = (xs) =>
    match xs {
      case Nil => false
      case Cons(h, t) => if #seq(h, name) then true else go(t)
    } in
  go(#cell.get(extensionMethodsCell))

-- Extension parser state is per source module, while lowering runs once over
-- the assembled import closure. Explicit start/end markers in the parsed stmt
-- stream preserve ownership across that boundary; rebuild the method registry
-- here instead of trusting whichever module happened to parse last.
def collectExtensionMethods = (stmts) =>
  let rec go = (ss, active) =>
    match ss {
      case Nil => Nil
      case Cons(s, rest) =>
        match s {
          case Pair(tag, data) =>
            if #seq(tag, "extension_start") then go(rest, true)
            else if #seq(tag, "extension_end") then go(rest, false)
            else if #seq(tag, "given_obj") then
              -- An `extension` group can live INSIDE a `given … with` body; descend so its
              -- methods register too (else `recv.m` misroutes to __method__ and stubs).
              match data { case Pair(gname, rest2) =>
                match rest2 { case Pair(typeStr, gstmts) =>
                  appendL(go(gstmts, false), go(rest, active)) } }
            else if active then
              if #seq(tag, "def") then
                match data {
                  case Pair(name, defRest) => Cons(name, go(rest, active))
                }
              else go(rest, active)
            else go(rest, active)
        }
    } in
  go(stmts, false)

def isCaseField = (name) =>
  let rec go = (xs) =>
    match xs {
      case Nil => false
      case Cons(h, t) => if #seq(h, name) then true else go(t)
    } in
  go(#cell.get(caseFieldsCell))

-- K62.19: the positional tuple accessors _1.._4 have built-in `_sel__N` defs in the prelude
-- (match Pair/Tuple4). Route them to `_sel_<field>` too — the __method__ path only resolves
-- them via a Long fast-path (Runtime.scala:1256) that fires in numeric contexts, so
-- `println(x._2)` / `best._2` in a non-Long context returned a Stub. `_sel__N` is correct in
-- ALL contexts (fixed the `recursion.ssc via ssc1` Collatz regression: (1,0) → (871,178)).
def isTupleField = (name) =>
  if #seq(name, "_1") then true
  else if #seq(name, "_2") then true
  else if #seq(name, "_3") then true
  else if #seq(name, "_4") then true
  else false

-- K62.6e: a known case field keeps its generated _sel_<field> accessor; every
-- other field access routes to __method__ (VM resolves record field-index or
-- plugin field — _sel_<field> was an unbound global otherwise).
def selOrMethod = (field, robj) =>
  if isCaseField(field) then
    let base = Pair("app", Pair(Pair("var", #sconcat("_sel_", field)), Cons(robj, Nil))) in
    -- A mutable `var` field is stored as a cell (unwrap via cell.getOr, a no-op on
    -- non-cells); a `lazy val` field is a cell holding a thunk (force via __lazyForce__).
    if isAnyVarField(field) then Pair("prim", Pair("cell.getOr", Cons(base, Nil)))
    else if isAnyLazyField(field) then Pair("prim", Pair("__lazyForce__", Cons(base, Nil)))
    else base
  else if isTupleField(field) then
    Pair("app", Pair(Pair("var", #sconcat("_sel_", field)), Cons(robj, Nil)))
  else if (match robj {
             case Pair(rt, rn) =>
               if #seq(rt, "uid") then (if #seq(rn, "Set") then #seq(field, "empty") else false)
               else false }) then
    -- `Set.empty` = `Set()` = `[].toSet` (empty DISTINCT list). Set is NOT a registered
    -- ctor, so the generic companion path `ctorap(Set)` stays the Set closure and `.empty`
    -- on it → `Op("Set.empty")`. Emit the empty-set construction directly.
    Pair("prim", Pair("__method__", Cons(Pair("str", "toSet"), Cons(buildListExpr(Nil), Nil))))
  else
    -- K62.25: a bare companion static like `Array.empty` reaches here with robj = uid(Array),
    -- which lowers to an UNBOUND `global Array`. The applied path (Array.tabulate(…)) already
    -- wraps the receiver as ctorap(Array) → DataV("Array") so the runtime __method__ dispatch
    -- fires; do the same for the 0-arg case. Gated on collection companions so enum-case value
    -- access (Color.Red) and user objects are untouched.
    let recv = match robj {
      case Pair(rt, rn) =>
        if #seq(rt, "uid") then
          (if isCollectionCompanion(rn) then Pair("ctorap", Pair(rn, Nil)) else robj)
        else robj
    } in
    Pair("prim", Pair("__method__", Cons(Pair("str", field), Cons(recv, Nil))))

-- Parse "Show[Int]" → Pair("Show","Int"); "String" → Pair("String","*")
-- ASCII 91='[', 93=']'
def parseGivenType = (typeStr) =>
  let len = #slen(typeStr) in
  let rec findBr = (i) =>
    if #i.ge(i, len) then #i.neg(1)
    else if #i.eq(#scodeAt(typeStr, i), 91) then i
    else findBr(#i.add(i, 1)) in
  let bi = findBr(0) in
  if #i.lt(bi, 0) then Pair(typeStr, "*")
  else
    let tc = #sslice(typeStr, 0, bi) in
    let inner = #sslice(typeStr, #i.add(bi, 1), #i.sub(len, 1)) in
    Pair(tc, inner)

def mirrorDefName = (typeName) => #sconcat("__mirror_", typeName)
def derivedDefName = (tc, typeName) =>
  #sconcat("__derived_", #sconcat(tc, #sconcat("_", typeName)))

def derivedGivenEntries = (typeName, derives) =>
  match derives {
    case Nil => Nil
    case Cons(tc, rest) =>
      Cons(Pair(Pair(tc, typeName), derivedDefName(tc, typeName)),
        derivedGivenEntries(typeName, rest))
  }

def caseGeneratedGivenEntries = (typeName, derives) =>
  let mirrorName = mirrorDefName(typeName) in
  Cons(Pair(Pair("Mirror.Of", typeName), mirrorName),
  Cons(Pair(Pair("Mirror.ProductOf", typeName), mirrorName),
  Cons(Pair(Pair("deriving.Mirror.Of", typeName), mirrorName),
  Cons(Pair(Pair("deriving.Mirror.ProductOf", typeName), mirrorName),
    derivedGivenEntries(typeName, derives)))))

-- Ancestor TCs of `tc` via the shared trait hierarchy (tcExtendsCell), fuel-bounded against cycles.
def tcAncestors = (tc) =>
  let rec lookupParent = (pairs, t) =>
    match pairs {
      case Nil => None
      case Cons(p, rest) =>
        match p { case Pair(child, parent) => if #seq(child, t) then Some(parent) else lookupParent(rest, t) }
    } in
  let rec go = (t, acc, fuel) =>
    if #i.lt(fuel, 1) then acc
    else match lookupParent(#cell.get(tcExtendsCell), t) {
      case None => acc
      case Some(parent) => go(parent, Cons(parent, acc), #i.sub(fuel, 1))
    } in
  go(tc, Nil, 16)

-- Given-table entries for one given: (TC, T)->name PLUS (ancestorTC, T)->name for each ancestor TC,
-- so a `given X: Monoid[Int]` also resolves a `Semigroup[Int]` context bound.
def givenEntriesFor = (tcType, gname) =>
  match tcType {
    case Pair(tc, t) =>
      let rec ancEntries = (ancs) =>
        match ancs {
          case Nil => Nil
          case Cons(a, rest) => Cons(Pair(Pair(a, t), gname), ancEntries(rest))
        } in
      Cons(Pair(tcType, gname), ancEntries(tcAncestors(tc)))
  }

-- Build given table from parsed stmts — "given" and "given_obj" tags
def buildGivenTable = (stmts) =>
  match stmts {
    case Nil => Nil
    case Cons(s, rest) =>
      let more = buildGivenTable(rest) in
      match s {
        case Pair(tag, data) =>
          if #seq(tag, "given") then
            match data {
              case Pair(gname, rest2) =>
                match rest2 {
                  case Pair(typeStr, body) =>
                    appendL(givenEntriesFor(parseGivenType(typeStr), gname), more)
                }
            }
          else if #seq(tag, "given_obj") then
            match data {
              case Pair(gname, rest2) =>
                match rest2 {
                  case Pair(typeStr, stmts2) =>
                    appendL(givenEntriesFor(parseGivenType(typeStr), gname), more)
                }
            }
          else if #seq(tag, "casecls") then
            match data {
              case Pair(typeName, caseMeta) =>
                match caseMeta {
                  case Pair(params, typeAndDerives) =>
                    match typeAndDerives {
                      case Pair(types, derives) =>
                        appendL(caseGeneratedGivenEntries(typeName, derives), more)
                    }
                }
            }
          else more
      }
  }

-- True if param name starts with "__tc_" (context dict param marker)
def isCtxParam = (p) =>
  if #i.lt(#slen(p), 5) then false
  else #seq(#sslice(p, 0, 5), "__tc_")

-- Extract TC name: "__tc_Show" → "Show"
def ctxParamTC = (p) => #sslice(p, 5, #slen(p))

-- Get list of TC names from param list (ctx params only)
def ctxTCsOf = (params) =>
  match params {
    case Nil => Nil
    case Cons(p, rest) =>
      if isCtxParam(p) then Cons(ctxParamTC(p), ctxTCsOf(rest))
      else ctxTCsOf(rest)
  }

-- Build sig table: fns that have context dict params
def buildSigTable = (stmts) =>
  match stmts {
    case Nil => Nil
    case Cons(s, rest) =>
      let more = buildSigTable(rest) in
      match s {
        case Pair(tag, data) =>
          if #seq(tag, "def") then
            match data {
              case Pair(name, rest2) =>
                match rest2 {
                  case Pair(params, body) =>
                    let tcs = ctxTCsOf(params) in
                    match tcs {
                      case Nil => more
                      case _   => Cons(Pair(name, tcs), more)
                    }
                }
            }
          else more
      }
  }

-- Look up TC list for a function name
def lookupSig = (sigTab, name) =>
  match sigTab {
    case Nil => None
    case Cons(entry, rest) =>
      match entry {
        case Pair(n, tcs) =>
          if #seq(n, name) then Some(tcs)
          else lookupSig(rest, name)
      }
  }

-- Find given name for (TC, typeName); "*" is a wildcard T_name
def findGiven = (givenTab, tc, typeName) =>
  match givenTab {
    case Nil => None
    case Cons(entry, rest) =>
      match entry {
        case Pair(gtype, gname) =>
          match gtype {
            case Pair(gtc, gt) =>
              if #seq(gtc, tc) then
                if #seq(gt, typeName) then Some(gname)
                else if #seq(gt, "*") then Some(gname)
                else findGiven(rest, tc, typeName)
              else findGiven(rest, tc, typeName)
          }
      }
  }

-- Find any given for a TC (ignores type arg)
def findAnyGiven = (givenTab, tc) =>
  match givenTab {
    case Nil => None
    case Cons(entry, rest) =>
      match entry {
        case Pair(gtype, gname) =>
          match gtype {
            case Pair(gtc, gt) =>
              if #seq(gtc, tc) then Some(gname) else findAnyGiven(rest, tc)
          }
      }
  }

-- Compute active ctx list from params: List[Pair(given_name, tc_name)]
def computeActiveCtx = (params) =>
  match params {
    case Nil => Nil
    case Cons(p, rest) =>
      if isCtxParam(p) then
        let tc = ctxParamTC(p) in
        let given = match findGiven(#cell.get(kc5GivenCell), tc, "*") {
          case Some(g) => g
          case None => match findAnyGiven(#cell.get(kc5GivenCell), tc) {
            case Some(g) => g
            case None => #sconcat("__missing_", tc)
          }
        } in
        Cons(Pair(given, tc), computeActiveCtx(rest))
      else computeActiveCtx(rest)
  }

-- Lookup given name for TC from active ctx (for summon dispatch)
def lookupActiveCtx = (tc) =>
  let rec go = (xs) =>
    match xs {
      case Nil => None
      case Cons(pair, rest) =>
        match pair {
          case Pair(gname, gtc) =>
            if #seq(gtc, tc) then Some(gname) else go(rest)
        }
    } in
  go(#cell.get(kc5ActiveCtxCell))

-- Get first given name from active ctx (for summon[] without explicit TC arg)
def firstActiveGiven = (dummy) =>
  match #cell.get(kc5ActiveCtxCell) {
    case Nil => None
    case Cons(pair, rest) =>
      match pair { case Pair(gname, tc) => Some(gname) }
  }

-- Best-effort type of a RESOLVED expression (no full HM). `List(..)` is resolved to
-- `ctorap(Cons, [head, tail])` / `ctorap(Nil, [])` by the time we see it (resolveE runs first).
def typeOfExpr = (e) =>
  match e {
    case Pair(tag, data) =>
      if #seq(tag, "int") then "Int"
      else if #seq(tag, "str") then "String"
      else if #seq(tag, "bool") then "Bool"
      else if #seq(tag, "ctorap") then
        match data {
          case Pair(cname, cargs) =>
            -- List[elem]: recurse into the head so the key matches a `TC[List[Int]]` given.
            if #seq(cname, "Cons") then
              match cargs { case Nil => "List" case Cons(h, t) => #sconcat("List[", #sconcat(typeOfExpr(h), "]")) }
            else if #seq(cname, "Nil") then "List"
            else "?"
        }
      else "?"
  }

-- Is `e` a resolved cons-list `ctorap(Cons, ..)`?
def isListApp = (e) =>
  match e {
    case Pair(tag, data) =>
      if #seq(tag, "ctorap") then
        match data { case Pair(cname, cargs) => #seq(cname, "Cons") }
      else false
  }

-- Head element of a resolved cons-list `ctorap(Cons, [head, tail])`, or None.
def listFirstElem = (e) =>
  match e {
    case Pair(tag, data) =>
      match data {
        case Pair(cname, cargs) =>
          match cargs { case Nil => None case Cons(h, t) => Some(h) }
      }
  }

-- ── KC5-mono: typeclass monomorphisation (specs/v2-typeclass-monomorphization.md) ──────────────
-- Worklist of specialisations to emit: List[Pair(fnName, Pair(instance, tc))].
def kc5MonoCell = #cell.new(Nil)
-- Specialised def name for (fnName, instance): `fnName__mono__instance`.
def monoName = (fnName, instance) => #sconcat(fnName, #sconcat("__mono__", instance))
-- Select the instance for a single-ctx-TC call by the arg type (List[A] → element type A).
def monoArgType = (args) =>
  match args {
    case Nil => "?"
    case Cons(fa, ra) =>
      if isListApp(fa) then
        match listFirstElem(fa) { case None => "?" case Some(el) => typeOfExpr(el) }
      else typeOfExpr(fa)
  }
-- If `fn` is a polymorphic typeclass fn with exactly ONE ctx TC and the instance resolves from the
-- arg type, record the specialisation and return Some(specialisedName); else None (call unchanged).
def monoInstanceFor = (fn, args) =>
  match fn {
    case Pair(ftag, fname) =>
      if #seq(ftag, "var") then
        match lookupSig(#cell.get(kc5SigCell), fname) {
          case None => None
          case Some(tcs) =>
            match tcs {
              case Cons(tc, tcRest) =>
                match tcRest {
                  case Nil =>
                    match findGiven(#cell.get(kc5GivenCell), tc, monoArgType(args)) {
                      case None => None
                      case Some(instance) =>
                        let _rec = #cell.set(kc5MonoCell,
                          Cons(Pair(fname, Pair(instance, tc)), #cell.get(kc5MonoCell))) in
                        Some(monoName(fname, instance))
                    }
                  case _ => None
                }
              case Nil => None
            }
        }
      else None
  }

-- Build given-injected arg list: prepend one given per TC name, before actual args
def buildGivenArgs = (givenTab, tcNames, actualArgs) =>
  match tcNames {
    case Nil => actualArgs
    case Cons(tc, restTCs) =>
      let argType = match actualArgs {
        case Nil => "?"
        case Cons(firstArg, restA) => typeOfExpr(firstArg)
      } in
      let injArg = match findGiven(givenTab, tc, argType) {
        case None    => match findAnyGiven(givenTab, tc) {
          case None => Pair("var", #sconcat("__missing_tc_", tc))
          case Some(g) => Pair("var", g)
        }
        case Some(g) => Pair("var", g)
      } in
      Cons(injArg, buildGivenArgs(givenTab, restTCs, actualArgs))
  }

-- Named `using` param registry (populated by the front's parseDef): defName → ([usingTypeStr], full).
def lookupUsingSig = (name) =>
  let rec go = (xs) =>
    match xs {
      case Nil => None
      case Cons(e, r) => match e { case Pair(n, info) => if #seq(n, name) then Some(info) else go(r) }
    } in
  go(#cell.get(usingSigCell))

-- Build the END-injected given args for named `using` params (one per using TC head, in source order).
def buildUsingGivenArgs = (givenTab, tcNames, args) =>
  match tcNames {
    case Nil => Nil
    case Cons(tc, rest) =>
      let argType = match args { case Nil => "?" case Cons(fa, ra) => typeOfExpr(fa) } in
      let injArg = match findGiven(givenTab, tc, argType) {
        case None => match findAnyGiven(givenTab, tc) {
          case None => Pair("var", #sconcat("__missing_using_", tc))
          case Some(g) => Pair("var", g) }
        case Some(g) => Pair("var", g) } in
      Cons(injArg, buildUsingGivenArgs(givenTab, rest, args))
  }

-- At call site f(args): inject context-bound givens at the FRONT (prepend) and named `using` givens at
-- the END (append), matching the param layout [ctxParams, regular, usingParams]. `using` givens are
-- appended only when the call has fewer args than the full (regular+using) count — so an explicit
-- `f(a)(using x)` (KC8-merged to f(a, x)) is not double-injected.
def injectGivens = (fn, args) =>
  match fn {
    case Pair(ftag, fdata) =>
      if #seq(ftag, "var") then
        let ctxTCs = match lookupSig(#cell.get(kc5SigCell), fdata) { case None => Nil case Some(t) => t } in
        let withCtx = buildGivenArgs(#cell.get(kc5GivenCell), ctxTCs, args) in
        match lookupUsingSig(fdata) {
          case None => withCtx
          case Some(info) =>
            match info {
              case Pair(usingTypeStrs, fullCount) =>
                if #i.lt(lenL(args), fullCount) then
                  appendL(withCtx, buildUsingGivenArgs(#cell.get(kc5GivenCell), usingTypeStrs, args))
                else withCtx
            }
        }
      else args
  }

-- ── KC6: pre-lowering resolve pass ─────────────────────────────────────────
-- Transforms known v1.0 patterns into canonical IR tags before lowering.
-- New tags produced:
--   ("ctorap", Pair(name, args_list)) → IrCtor(name, lowered args)
--   ("prim",   Pair(op,   args_list)) → IrPrim(op,   lowered args)
--                                        or IrApp(IrGlobal helper, ...) for pseudo-ops

-- Resolve a list of args
def resolveArgs = (args) =>
  match args { case Nil => Nil case Cons(e, rest) => Cons(resolveE(e), resolveArgs(rest)) }

-- Block-form `handle { ... }` is parsed as a zero-argument lambda. Force only
-- that source sugar; `handle(expr)` passes its already-evaluated computation.
def forceHandleCompute = (resolved) =>
  match resolved {
    case Pair(tag, data) =>
      if #seq(tag, "lam") then
        match data {
          case Pair(params, body) =>
            match params {
              case Nil => Pair("app", Pair(resolved, Nil))
              case _ => resolved
            }
        }
      else resolved
  }

-- ── named-argument support ───────────────────────────────────────────────────
-- An `narg` node is Pair("narg", Pair(label, valueExpr)); it appears only inside a
-- call's argument list. nargVal drops the label (best-effort positional lowering for
-- calls we cannot reorder, e.g. plugin functions); reorderByFields maps named args to
-- the declared field order of a known case class (the correct path).
def nargVal = (a) =>
  match a { case Pair(tag, d) => if #seq(tag, "narg") then (match d { case Pair(l, v) => v }) else a }
def nargLabel = (a) =>
  match a { case Pair(tag, d) => match d { case Pair(l, v) => l } }
def hasNarg = (args) =>
  match args { case Nil => false
    case Cons(h, t) => match h { case Pair(tag, d) => if #seq(tag, "narg") then true else hasNarg(t) } }
def allNargs = (args) =>
  match args { case Nil => true
    case Cons(h, t) => match h { case Pair(tag, d) => if #seq(tag, "narg") then allNargs(t) else false } }
def stripNargs = (args) =>
  match args { case Nil => Nil case Cons(h, t) => Cons(nargVal(h), stripNargs(t)) }
-- Named copy is sequenced through lexical bindings because general multi-arg
-- primitive evaluation is not the source-language ordering contract. Bind the
-- receiver first, then each override in written order, then call the existing
-- alternating field-name/value portable runtime ABI using only pure locals.
def namedCopyBindingStmts = (args, recvName, encoded) =>
  match args {
    case Nil =>
      Cons(Pair("expr", Pair("prim", Pair("__method__",
        Cons(Pair("str", "copy"), Cons(Pair("var", recvName), encoded))))), Nil)
    case Cons(h, t) =>
      match h {
        case Pair(tag, data) =>
          match data {
            case Pair(label, value) =>
              let argName = freshCopyTemp("arg") in
              Cons(Pair("val", Pair(argName, value)),
                namedCopyBindingStmts(t, recvName,
                  appendL(encoded, Cons(Pair("str", label), Cons(Pair("var", argName), Nil)))))
          }
      }
  }
def desugarNamedCopy = (recv, args) =>
  let recvName = freshCopyTemp("recv") in
  Pair("block", Cons(Pair("val", Pair(recvName, recv)),
    namedCopyBindingStmts(args, recvName, Nil)))

-- Copy with MIXED positional + named args: positional at position i → label `#i`, named → its label.
-- The runtime copy maps `#i`/name overrides onto the case-class fields (unspecified kept from recv).
def copyBindingStmts = (args, recvName, idx, encoded) =>
  match args {
    case Nil =>
      Cons(Pair("expr", Pair("prim", Pair("__method__",
        Cons(Pair("str", "copy"), Cons(Pair("var", recvName), encoded))))), Nil)
    case Cons(h, t) =>
      match h {
        case Pair(tag, data) =>
          if #seq(tag, "narg") then
            match data {
              case Pair(label, value) =>
                let argName = freshCopyTemp("arg") in
                Cons(Pair("val", Pair(argName, value)),
                  copyBindingStmts(t, recvName, #i.add(idx, 1),
                    appendL(encoded, Cons(Pair("str", label), Cons(Pair("var", argName), Nil)))))
            }
          else
            let argName = freshCopyTemp("arg") in
            Cons(Pair("val", Pair(argName, h)),
              copyBindingStmts(t, recvName, #i.add(idx, 1),
                appendL(encoded, Cons(Pair("str", #sconcat("#", #i->str(idx))), Cons(Pair("var", argName), Nil)))))
      }
  }
def desugarCopy = (recv, args) =>
  let recvName = freshCopyTemp("recv") in
  Pair("block", Cons(Pair("val", Pair(recvName, recv)),
    copyBindingStmts(args, recvName, 0, Nil)))

-- ── bounded structural Focus/Prism lowering ─────────────────────────────────
-- Extract selector chains before ordinary field/method resolution erases the
-- source path. The only native steps are registered product fields, Option.some,
-- and List.each; arbitrary getter bodies fail explicitly without executing.
def focusStep = (field) =>
  if #seq(field, "some") then Pair("ctorap", Pair("OSome", Nil))
  else if #seq(field, "each") then Pair("ctorap", Pair("OEach", Nil))
  else Pair("ctorap", Pair("OField", Cons(Pair("str", field), Nil)))

-- `.index(i)` / `.at(k)` pointwise steps (List index, Map key). The plugin's
-- optics.focus already interprets OIndex/OAt; the front just has to emit them.
-- The index/key argument is resolved so a non-literal (a captured var) lowers.
def focusMethodStep = (mname, args) =>
  match args {
    case Cons(arg, rest) =>
      match rest {
        case Nil =>
          if #seq(mname, "index") then Pair("__ok__", Pair("ctorap", Pair("OIndex", Cons(resolveE(arg), Nil))))
          else if #seq(mname, "at") then Pair("__ok__", Pair("ctorap", Pair("OAt", Cons(resolveE(arg), Nil))))
          else Pair("__bad__", Nil)
        case _ => Pair("__bad__", Nil)
      }
    case Nil => Pair("__bad__", Nil)
  }

def isFocusMarker = (expr) =>
  match expr { case Pair(tag, data) => #seq(tag, "focus_marker") }

def focusPathSteps = (expr, param) =>
  match expr {
    case Pair(tag, data) =>
      if #seq(tag, "var") then
        if #seq(data, param) then Pair("__ok__", Nil) else Pair("__bad__", Nil)
      else if #seq(tag, "sel") then
        match data {
          case Pair(base, field) =>
            match focusPathSteps(base, param) {
              case Pair(status, steps) =>
                if #seq(status, "__ok__") then
                  Pair("__ok__", appendL(steps, Cons(focusStep(field), Nil)))
                else Pair("__bad__", Nil)
            }
        }
      else if #seq(tag, "app") then
        -- method-call steps: app(sel(base, method), [arg]) for .index(i) / .at(k)
        match data {
          case Pair(callee, args) =>
            match callee {
              case Pair(ctag, cdata) =>
                if #seq(ctag, "sel") then
                  match cdata {
                    case Pair(base, mname) =>
                      match focusMethodStep(mname, args) {
                        case Pair(sok, step) =>
                          if #seq(sok, "__ok__") then
                            match focusPathSteps(base, param) {
                              case Pair(status, steps) =>
                                if #seq(status, "__ok__") then
                                  Pair("__ok__", appendL(steps, Cons(step, Nil)))
                                else Pair("__bad__", Nil)
                            }
                          else Pair("__bad__", Nil)
                      }
                  }
                else Pair("__bad__", Nil)
            }
        }
      else Pair("__bad__", Nil)
  }

def resolveFocusArgs = (args) =>
  match args {
    case Cons(arg, rest) =>
      match rest {
        case Nil =>
          match arg {
            case Pair(tag, data) =>
              if #seq(tag, "lam") then
                match data {
                  case Pair(params, body) =>
                    match params {
                      case Cons(param, more) =>
                        match more {
                          case Nil =>
                            match focusPathSteps(body, param) {
                              case Pair(status, steps) =>
                                if #seq(status, "__ok__") then
                                  Pair("prim", Pair("optics.focus", Cons(buildListExpr(steps), Nil)))
                                else Pair("var", "__unsupported_focus_path")
                            }
                          case _ => Pair("var", "__unsupported_focus_path")
                        }
                      case Nil => Pair("var", "__unsupported_focus_path")
                    }
                }
              else Pair("var", "__unsupported_focus_path")
          }
        case _ => Pair("var", "__unsupported_focus_path")
      }
    case Nil => Pair("var", "__unsupported_focus_path")
  }

def prismVariant = (typeArgs) =>
  let n = #slen(typeArgs) in
  let rec lastComma = (i, found) =>
    if #i.ge(i, n) then found
    else if #i.eq(#scodeAt(typeArgs, i), 44) then lastComma(#i.add(i, 1), i)
    else lastComma(#i.add(i, 1), found) in
  let comma = lastComma(0, #i.neg(1)) in
  if #i.lt(comma, 0) then ""
  else #sslice(typeArgs, #i.add(comma, 1), n)
def findNarg = (label, args) =>
  match args {
    case Nil => Pair("var", #sconcat("__missing_named_arg_", label))
    case Cons(h, t) => if #seq(nargLabel(h), label) then nargVal(h) else findNarg(label, t)
  }
def reorderByFields = (fields, args) =>
  match fields {
    case Nil => Nil
    case Cons(f, rest) => Cons(findNarg(f, args), reorderByFields(rest, args))
  }
-- Like findNarg, but when a field's named arg is omitted, fall back to its REGISTERED
-- default expr (resolved) instead of a __missing_named_arg sentinel. A `__nodflt__`
-- default means the field is genuinely required, so the sentinel still fires.
def findNargD = (label, args, dflt) =>
  match args {
    case Nil =>
      if dfltIsNone(dflt) then Pair("var", #sconcat("__missing_named_arg_", label))
      else resolveE(dflt)
    case Cons(h, t) => if #seq(nargLabel(h), label) then nargVal(h) else findNargD(label, t, dflt)
  }
-- reorderByFields with per-field defaults (aligned with `fields`). Used for all-named
-- case-class construction so omitted default-valued fields (e.g. Diagnostic's
-- `dialect = None`, `details = Vector.empty`) are filled from the registry.
def reorderByFieldsD = (fields, dflts, args) =>
  match fields {
    case Nil => Nil
    case Cons(f, frest) =>
      match dflts {
        case Nil => Cons(findNarg(f, args), reorderByFieldsD(frest, Nil, args))
        case Cons(d, drest) => Cons(findNargD(f, args, d), reorderByFieldsD(frest, drest, args))
      }
  }
def lookupFields = (name) =>
  let rec go = (xs) =>
    match xs {
      case Nil => Nil
      case Cons(h, t) => match h { case Pair(n, ps) => if #seq(n, name) then ps else go(t) }
    } in
  go(#cell.get(caseFieldOrderCell))
-- Resolve a case-class construction's arg list: all-named → reorder to field order;
-- otherwise (mixed, or unknown/plugin callee) strip labels keeping written order.
def resolveCtorArgs = (name, rargs) =>
  if hasNarg(rargs) then
    if allNargs(rargs) then
      let fs = lookupFields(name) in
      match fs {
        case Nil => stripNargs(rargs)
        case Cons(h, t) =>
          -- Fill omitted default-valued fields from the registry; without it a defaulted
          -- field not passed by name becomes a __missing_named_arg sentinel (unbound at
          -- runtime). `dparams` is aligned with `dflts`, both from the case-class decl.
          match dfltRegLookup(name, #cell.get(funcDefaultsCell)) {
            case Pair(found, entry) =>
              if #seq(found, "__some__") then
                match entry { case Pair(dparams, dflts) => reorderByFieldsD(dparams, dflts, rargs) }
              else reorderByFields(fs, rargs)
          }
      }
    else stripNargs(rargs)
  else rargs

-- Build a List literal as nested ctorap nodes
def buildListExpr = (args) =>
  match args {
    case Nil => Pair("ctorap", Pair("Nil", Nil))
    case Cons(h, rest) =>
      Pair("ctorap", Pair("Cons", Cons(h, Cons(buildListExpr(rest), Nil))))
  }

-- Trailing-vararg call packing. A def whose last parameter is `T*` (registered in
-- varargDefsCell by the front) binds that param as ONE list value — the body does
-- `xs.toList`. But the parser flattens a call's argument clauses into individual
-- args, so `card(a, b)` (arity 1) and `vstack(g)(a, b)` (arity 2) arrive with too
-- many args and fail the CoreIR arity check. Pack everything past the leading
-- (arity-1) non-vararg params into a Cons-list so the flattened call matches arity.
def isVarargDef = (name) =>
  let rec go = (xs) =>
    match xs { case Nil => false case Cons(n, rest) => if #seq(n, name) then true else go(rest) } in
  go(#cell.get(varargDefsCell))

def takeL = (n, xs) =>
  if #i.lt(n, 1) then Nil
  else match xs { case Nil => Nil case Cons(h, t) => Cons(h, takeL(#i.sub(n, 1), t)) }

def dropL = (n, xs) =>
  if #i.lt(n, 1) then xs
  else match xs { case Nil => Nil case Cons(h, t) => dropL(#i.sub(n, 1), t) }

-- Pack a call's (already-resolved) args for a trailing-vararg def; a no-op for
-- non-vararg defs or when the def arity is unknown.
def packVarargsArgs = (name, args) =>
  if isVarargDef(name) then
    match defArity(name) {
      case Pair(found, arity) =>
        if found then
          let lead = #i.sub(arity, 1) in
          if #i.ge(lenL(args), lead) then
            append(takeL(lead, args), Cons(buildListExpr(dropL(lead, args)), Nil))
          else args
        else args
    }
  else args

-- Object-method trailing-vararg pack. `O.f(a, b, c)` with `def f(xs: T*)`:
-- `isVarargDef` is keyed by the BARE method name (front's parse registry) while
-- the emitted arity lives under the MANGLED `O_f` (defArity, via
-- collectObjMethodArities). Pack the trailing args into one list.
def packObjVarargs = (bareMethod, mangled, args) =>
  if isVarargDef(bareMethod) then
    match defArity(mangled) {
      case Pair(found, arity) =>
        if found then
          let lead = #i.sub(arity, 1) in
          if #i.ge(lenL(args), lead) then
            append(takeL(lead, args), Cons(buildListExpr(dropL(lead, args)), Nil))
          else args
        else args
    }
  else args

-- K62.6c: build a Map from (resolved) `k -> v` / (k, v) entries. `map.put` MUTATES
-- and returns Unit, so use an IIFE: (fn __m => { map.put(__m,k,v); …; __m })(map.new).
def buildMapExpr = (args) =>
  let rec puts = (as) =>
    match as {
      case Nil => Cons(Pair("expr", Pair("var", "__m")), Nil)
      case Cons(a, rest) =>
        match a {
          case Pair(atag, adata) =>
            let kv = if #seq(atag, "inf") then
                       match adata { case Pair(op, pair) => pair }
                     else if #seq(atag, "tup") then
                       match adata { case Cons(k0, r0) =>
                         match r0 { case Cons(v0, r1) => Pair(k0, v0) } }
                     else Pair(a, a) in
            match kv {
              case Pair(k, v) =>
                Cons(Pair("expr", Pair("prim", Pair("map.put",
                       Cons(Pair("var", "__m"), Cons(k, Cons(v, Nil)))))),
                     puts(rest))
            }
        }
    } in
  Pair("app", Pair(
    Pair("lam", Pair(Cons("__m", Nil), Pair("block", puts(args)))),
    Cons(Pair("prim", Pair("map.new", Nil)), Nil)))

-- Whether `cname` is ANY case (nullary or parametrized) of the given enum cases.
def enumHasCase = (cases, cname) =>
  match cases {
    case Nil => false
    case Cons(c, t) =>
      match c { case Pair(cn, params) => if #seq(cn, cname) then true else enumHasCase(t, cname) }
  }

-- Resolve a method call obj.method(rargs) — obj and rargs already resolved
-- The runtime method-dispatch prim for a CALL `recv.method(args)`.
--
-- A bare selection `recv.m` and an applied zero-arg call `recv.m()` lower to
-- byte-identical CoreIR (`__method__(m, recv)`), so the VM's __method__ fallthrough
-- cannot tell a genuine method REF (`list.exists(lc.contains)` — must eta-expand to
-- `x => recv.m(x)`) from a TYPO (`42.bogusMethod()` — must fail). It chose to
-- eta-expand, so every typo'd zero-arg method silently produced `<closure>` and
-- exited 0 (BUGS.md v2-zero-arg-unknown-method-fails-open).
--
-- The front DOES know: `sel` vs `app(sel, [])`. Preserve that here — an applied
-- zero-arg call emits `__method0__` (dispatch or ERROR, never eta-expand). Bare
-- selections keep `__method__` (via selOrMethod), so method refs still work. Only the
-- call path uses this: resolveMethodCall/selMethodOr are reached solely from
-- `app(sel(...), rargs)`.
def methodPrim = (rargs) =>
  match rargs { case Nil => "__method0__" case _ => "__method__" }

def resolveMethodCall = (robj, method, rargs) =>
  if isExtensionMethod(method) then
    -- Extension names are collected over the whole imported module closure,
    -- but Scala member selection is receiver-owned: a real List.map (or any
    -- other runtime method) wins over an unrelated imported extension with the
    -- same name. Keep the extension closure as the final fallback argument so
    -- the shared runtime can make that type-erased choice generically.
    Pair("prim", Pair("__methodOrExt__",
      Cons(Pair("str", method),
        Cons(robj, appendL(rargs, Cons(Pair("var", method), Nil))))))
  else if #seq(method, "charAt") then
    match rargs {
      case Cons(idx, idxRest) =>
        Pair("prim", Pair("scodeAt", Cons(robj, Cons(idx, Nil))))
    }
  else if #seq(method, "substring") then
    match rargs {
      case Cons(frm, r0) =>
        match r0 {
          case Cons(too, r1) =>
            Pair("prim", Pair("sslice", Cons(robj, Cons(frm, Cons(too, Nil)))))
          case Nil =>
            -- single-arg substring(from) == substring(from, length) (Scala String)
            let lenE = Pair("prim", Pair("slen", Cons(robj, Nil))) in
            Pair("prim", Pair("sslice", Cons(robj, Cons(frm, Cons(lenE, Nil)))))
        }
    }
  else
    -- KC7b: if receiver is a plain uid or known given-object var, static dispatch O_method(args)
    match robj {
      case Pair(rtag, rname) =>
        if #seq(rtag, "uid") then
          -- A parametrized enum case constructor `Color.Custom("#fff")` → `Custom("#fff")`
          -- (bare ctor application), mirroring the scalameta bridge. Without this it fell
          -- through to `__method__("Custom", (ctor Color), …)`, which the VM read as an
          -- unhandled effect Op `Op("Color.Custom", …)`. Nullary `Color.Red` is handled by
          -- the bare-selector enum intercept; this covers the applied parametrized form.
          (if isEnumUid(rname) then
             (if enumHasCase(enumCasesOf(rname), method) then
                -- resolveCtorArgs reorders an all-named construction to field order and
                -- fills omitted defaults (incl. a NON-trailing/leading one like
                -- `Reframe(open=…, closeAfter=…)` omitting `closeBefore`); ctorApplyDefaults
                -- then fills any trailing positional defaults for the non-named case.
                Pair("ctorap", Pair(method, ctorApplyDefaults(method, resolveCtorArgs(method, rargs))))
              else
                Pair("prim", Pair(methodPrim(rargs),
                  Cons(Pair("str", method), Cons(Pair("ctorap", Pair(rname, Nil)), rargs)))))
           -- K62.7b: a user object (Math.square) → static Math_square; an unknown
           -- uppercase object (Dataset.of, Graph.vertices) → __method__ dispatch,
           -- resolved by the plugin runtime's __fallback__.<Name>.<method>.
           else if isKnownObject(rname) then
             resolveObjMember(rname, method, rargs)
           else
             Pair("prim", Pair("__method__",
               Cons(Pair("str", method), Cons(Pair("ctorap", Pair(rname, Nil)), rargs)))))
        else if #seq(rtag, "summon_tc") then
          -- summon[TC].method → the active-ctx instance for THIS tc (rname), fallback first given
          let gopt = match lookupActiveCtx(rname) { case Some(g) => Some(g) case None => firstActiveGiven(0) } in
          match gopt {
            case None => selMethodOr(method, robj, rargs)
            case Some(gname) =>
              Pair("app", Pair(Pair("var", #sconcat(gname, #sconcat("_", method))), rargs))
          }
        else if #seq(rtag, "var") then
          match summonAliasTC(rname) {
            case Some(aliasTC) =>
              -- m from `val m = summon[aliasTC[A]]`: dispatch m.method via the active-ctx instance
              let gopt = match lookupActiveCtx(aliasTC) { case Some(g) => Some(g) case None => firstActiveGiven(0) } in
              match gopt {
                case None => selMethodOr(method, robj, rargs)
                case Some(gname) => Pair("app", Pair(Pair("var", #sconcat(gname, #sconcat("_", method))), rargs))
              }
            case None =>
          if #seq(rname, "summon") then
            -- summon[TC].method → static dispatch via active ctx cell (untyped fallback)
            match firstActiveGiven(0) {
              case None => selMethodOr(method, robj, rargs)
              case Some(gname) =>
                Pair("app", Pair(Pair("var", #sconcat(gname, #sconcat("_", method))), rargs))
            }
          else if isKnownObject(rname) then
            resolveObjMember(rname, method, rargs)
          else if isMapVar(rname) then
            if #seq(method, "updated") then
              Pair("app", Pair(Pair("var", "_sel_mapUpdated"), Cons(robj, rargs)))
            else if #seq(method, "getOrElse") then
              Pair("app", Pair(Pair("var", "_sel_mapGetOrElse"), Cons(robj, rargs)))
            else
              Pair("prim", Pair(methodPrim(rargs), Cons(Pair("str", method), Cons(robj, rargs))))
          else
            Pair("prim", Pair(methodPrim(rargs), Cons(Pair("str", method), Cons(robj, rargs))))
          }
        else
          selMethodOr(method, robj, rargs)
    }

def isKnownSelMethod = (m) =>
  -- K62.6c-rest: takeWhile/dropWhile REMOVED — their prelude _sel_ helpers are STRING-only
  -- (scodeAt char-code predicate) and silently returned empty on a List. Routing to __method__
  -- lets the runtime dispatch: (StrV, takeWhile) with a char-code arg, (isList, takeWhile) with
  -- the element. See Runtime.scala str handler fix (char-code, not 1-char string).
  let ks = Cons("map", Cons("filter", Cons("flatMap", Cons("fold", Cons("foldLeft",
           Cons("foreach", Cons("getOrElse", Cons("length", Cons("mkString", Cons("split",
           Cons("trim", Cons("sum", Cons("take", Cons("to", Cons("until",
           Cons("toList", Cons("runToList", Cons("mapUpdated", Cons("mapGetOrElse",
           Cons("_1", Cons("_2", Cons("_3", Cons("_4", Nil))))))))))))))))))))))) in
  let rec go = (xs) =>
    match xs { case Nil => false
      case Cons(h, t) => if #seq(h, m) then true else go(t) } in
  go(ks)

-- A parenthesized multi-parameter mapper is parsed as an ordinary selected
-- method call, so the generic `_sel_map` helper would receive a Tuple2 head
-- but call the mapper with that tuple as one argument. The VM's polymorphic
-- __method__ map path owns tuple spreading; use it only for this shape and
-- retain `_sel_map` for the one-parameter LazyCons/Option/Either cases.
def isSingleMultiParamLambda = (args) =>
  match args {
    case Cons(arg, rest) =>
      match rest {
        case Nil =>
          match arg {
            case Pair(tag, data) =>
              if #seq(tag, "lam") then
                match data { case Pair(params, body) => #i.gt(lenL(params), 1) }
              else false
          }
        case _ => false
      }
    case Nil => false
  }

def selMethodOr = (method, robj, rargs) =>
  -- K62.32: the _sel_mkString prelude helper is arity-2 (receiver, sep), so the 0-arg
  -- (mkString) and 3-arg (mkString(pre, sep, post)) forms crashed "arity: 2 expected, N given".
  -- Route those to the polymorphic runtime __method__ (handles all three arities on List AND
  -- ArrayBuffer); keep the 1-arg (sep) form on the fast _sel_mkString path.
  if #seq(method, "map") then
    (if isSingleMultiParamLambda(rargs) then
       Pair("prim", Pair("__method__", Cons(Pair("str", "map"), Cons(robj, rargs))))
     else
       Pair("app", Pair(Pair("var", "_sel_map"), Cons(robj, rargs))))
  else if #seq(method, "mkString") then
    (if #i.eq(lenL(rargs), 1) then
       Pair("app", Pair(Pair("var", "_sel_mkString"), Cons(robj, rargs)))
     else
       Pair("prim", Pair(methodPrim(rargs), Cons(Pair("str", "mkString"), Cons(robj, rargs)))))
  else if #seq(method, "take") then
    Pair("prim", Pair(methodPrim(rargs), Cons(Pair("str", "take"), Cons(robj, rargs))))
  else if #seq(method, "sum") then
    Pair("prim", Pair(methodPrim(rargs), Cons(Pair("str", "sum"), Cons(robj, rargs))))
  -- foldLeft via the runtime __method__ (not the self-hosted _sel_foldLeft): its methodOp threads an
  -- Op receiver (`perform().foldLeft(z)(f)`), which the curried _sel_foldLeft's inner Local-match does
  -- NOT (the bytecode backend only A-normalizes mayOp Match/Let/Seq scrutinees, and a Local isn't one).
  -- __method__ also handles a superset of receiver types (List/ArrayBuffer/Map). Same for foldRight.
  else if #seq(method, "foldLeft") then
    Pair("prim", Pair(methodPrim(rargs), Cons(Pair("str", "foldLeft"), Cons(robj, rargs))))
  else if #seq(method, "foldRight") then
    Pair("prim", Pair(methodPrim(rargs), Cons(Pair("str", "foldRight"), Cons(robj, rargs))))
  else if isKnownSelMethod(method) then
    Pair("app", Pair(Pair("var", #sconcat("_sel_", method)), Cons(robj, rargs)))
  else
    Pair("prim", Pair(methodPrim(rargs), Cons(Pair("str", method), Cons(robj, rargs))))

-- Resolve a pure field access obj.field (no args)
def resolveField = (robj, field) =>
  let roundingOwner = match robj {
    case Pair(rt, rd) =>
      if #seq(rt, "uid") then #seq(rd, "RoundingMode")
      else if #seq(rt, "var") then #seq(rd, "RoundingMode")
      else false
  } in
  let yamlSection = match robj {
    case Pair(rt, rn) =>
      if #seq(field, "yaml") then
        if #seq(rt, "var") then
          let hidden = #sconcat("__yaml_", rn) in
          if isTopVal(hidden) then hidden else ""
        else if #seq(rt, "uid") then
          let hidden2 = #sconcat("__yaml_", rn) in
          if isTopVal(hidden2) then hidden2 else ""
        else ""
      else ""
  } in
  if #i.gt(#slen(yamlSection), 0) then Pair("var", yamlSection)
  else if isExtensionMethod(field) then
    Pair("app", Pair(Pair("var", field), Cons(robj, Nil)))
  else if roundingOwner then Pair("str", field)
  else if #seq(field, "length") then
    let rname = match robj { case Pair(rt, rd) => if #seq(rt, "var") then rd else "" } in
    if isListVar(rname) then
      Pair("app", Pair(Pair("var", "_sel_length"), Cons(robj, Nil)))
    else if isListConstruction(robj) then
      Pair("app", Pair(Pair("var", "_sel_length"), Cons(robj, Nil)))
    else if isConcatInf(robj) then
      Pair("prim", Pair("__method__", Cons(Pair("str", "length"), Cons(robj, Nil))))
    else if isStrExpr(robj) then
      Pair("prim", Pair("slen", Cons(robj, Nil)))
    else
      Pair("prim", Pair("__method__", Cons(Pair("str", "length"), Cons(robj, Nil))))
  else if #seq(field, "size") then
    let rname2 = match robj { case Pair(rt, rd) => if #seq(rt, "var") then rd else "" } in
    if isListVar(rname2) then
      Pair("app", Pair(Pair("var", "_sel_length"), Cons(robj, Nil)))
    else if isListConstruction(robj) then
      Pair("app", Pair(Pair("var", "_sel_length"), Cons(robj, Nil)))
    else if isConcatInf(robj) then
      Pair("prim", Pair("__method__", Cons(Pair("str", "size"), Cons(robj, Nil))))
    else if isStrExpr(robj) then
      Pair("prim", Pair("slen", Cons(robj, Nil)))
    else
      Pair("prim", Pair("__method__", Cons(Pair("str", "size"), Cons(robj, Nil))))
  else if #seq(field, "toString") then
    -- A selected conversion may receive BigInt/Float/String/record values from
    -- an imported call or another dynamic expression. Keep the direct integer
    -- primitive only when the receiver itself proves that shape; otherwise the
    -- shared runtime method table owns the conversion.
    (if isIntLitExpr(robj) then Pair("prim", Pair("i->str", Cons(robj, Nil)))
     else Pair("prim", Pair("__method__", Cons(Pair("str", "toString"), Cons(robj, Nil)))))
  else if #seq(field, "toInt") then
    -- The receiver may be a dynamically-produced String (for example
    -- Option[String].getOrElse) or a numeric value. Runtime method dispatch
    -- preserves both cases; erasing unknown receivers loses String conversion.
    Pair("prim", Pair("__method__", Cons(Pair("str", "toInt"), Cons(robj, Nil))))
  -- `toLong` was a no-op on the reasoning "Long IS Int here". True for an INT receiver
  -- (ssc Int is 64-bit, so Int.toLong is identity) and FALSE for a Double one, which must
  -- actually truncate: erasing it left a Float in a Long slot, and the first bit/Long op
  -- died with "expected Int, got <the double>". The value even printed as an integer, so
  -- nothing looked wrong until arithmetic. Route it like toInt/toDouble below and let the
  -- receiver decide. (v2-native-double-toLong-noop; it broke every REAL write in scljet.)
  else if #seq(field, "toLong") then
    Pair("prim", Pair("__method__", Cons(Pair("str", "toLong"), Cons(robj, Nil))))
  -- toDouble/toFloat must actually convert Int->Float; lowering to `robj` (a no-op)
  -- left the value an Int, so a following `/` did integer division (7.toDouble/2 -> 3,
  -- not 3.5). Route to the shared runtime method table (IntV.toDouble -> FloatV) like
  -- toInt above; String receivers convert too.
  else if #seq(field, "toDouble") then
    Pair("prim", Pair("__method__", Cons(Pair("str", "toDouble"), Cons(robj, Nil))))
  else if #seq(field, "toFloat") then
    Pair("prim", Pair("__method__", Cons(Pair("str", "toFloat"), Cons(robj, Nil))))
  else if #seq(field, "toShort") then robj
  else if #seq(field, "head") then
    Pair("prim", Pair("_list_head", Cons(robj, Nil)))
  else if #seq(field, "tail") then
    Pair("prim", Pair("_list_tail", Cons(robj, Nil)))
  else if #seq(field, "isEmpty") then
    Pair("prim", Pair("_list_isEmpty", Cons(robj, Nil)))
  else if #seq(field, "nonEmpty") then
    Pair("prim", Pair("_list_nonEmpty", Cons(robj, Nil)))
  else
    -- KC7b: static dispatch for known given-object vars
    match robj {
      case Pair(rtag, rname) =>
        if #seq(rtag, "summon_tc") then
          -- summon[TC].field → the active-ctx instance for THIS tc (rname), fallback first given
          let gopt = match lookupActiveCtx(rname) { case Some(g) => Some(g) case None => firstActiveGiven(0) } in
          match gopt {
            case None => selOrMethod(field, robj)
            case Some(gname) => Pair("var", #sconcat(gname, #sconcat("_", field)))
          }
        else if #seq(rtag, "var") then
          match summonAliasTC(rname) {
            case Some(aliasTC) =>
              -- m from `val m = summon[aliasTC[A]]`: dispatch m.field via the active-ctx instance
              let gopt = match lookupActiveCtx(aliasTC) { case Some(g) => Some(g) case None => firstActiveGiven(0) } in
              match gopt {
                case None => selOrMethod(field, robj)
                case Some(gname) => Pair("var", #sconcat(gname, #sconcat("_", field)))
              }
            case None =>
          if #seq(rname, "summon") then
            -- summon[TC].field → static dispatch via active ctx cell (untyped fallback)
            match firstActiveGiven(0) {
              case None => selOrMethod(field, robj)
              case Some(gname) =>
                Pair("var", #sconcat(gname, #sconcat("_", field)))
            }
          else if isKnownObject(rname) then
            -- 0-param method / property accessed as a value (var field → cell.get)
            resolveObjProp(rname, field)
          else
            selOrMethod(field, robj)
          }
        else if #seq(rtag, "uid") then
          if isEnumUid(rname) then
            -- Enum companion: `EnumName.Case` → `(ctor Case)` (nullary), `EnumName.values`
            -- → the list of nullary case ctors. Mirrors the scalameta bridge (drops the
            -- enum qualifier). A parametrized case reaches here only via application
            -- `EnumName.Case(args)`, so falls through to the applied-ctor path.
            if #seq(field, "values") then enumValuesList(enumCasesOf(rname))
            else if enumNullaryCase(enumCasesOf(rname), field) then Pair("ctorap", Pair(field, Nil))
            else selOrMethod(field, robj)
          else if isKnownObject(rname) then
            -- User objects parse as uid receivers; properties use the same
            -- deterministic owner prefix (var field → cell.get).
            resolveObjProp(rname, field)
          else
            selOrMethod(field, robj)
        else
          selOrMethod(field, robj)
    }

-- KC5-micro: detect string-producing expressions after resolve (for + upgrade)
-- K62.30: `a ++ b` is AMBIGUOUS — string concat OR list concat. isStrExpr treats it as a
-- string, so `(xs ++ ys).length` mis-routed to slen and crashed ("slen: not Str: List(…)").
-- A ++ receiver for .length/.size goes to the polymorphic runtime __method__ instead (String
-- and List both answer length there), keeping the slen fast path for UNAMBIGUOUS strings.
def isConcatInf = (e) =>
  match e {
    case Pair(tag, data) =>
      if #seq(tag, "inf") then match data { case Pair(op, lr) => #seq(op, "++") } else false
  }

def isStrExpr = (e) =>
  match e {
    case Pair(tag, data) =>
      if #seq(tag, "str") then true
      else if #seq(tag, "prim") then
        match data {
          case Pair(op, args) =>
            if #seq(op, "i->str") then true
            else if #seq(op, "sslice") then true
            else false
        }
      else if #seq(tag, "inf") then
        match data { case Pair(op2, lr2) => #seq(op2, "++") }
      else if #seq(tag, "app") then
        -- detect _sel_trim(s) and _sel_split(s, delim) results (string-producing)
        match data {
          case Pair(fn, args) =>
            match fn {
              case Pair(fntag, fndata) =>
                if #seq(fntag, "var") then
                  if #seq(fndata, "_sel_trim") then true
                  else false
                else false
            }
        }
      else false
  }

-- K62.17: call-site default-parameter synthesis. funcDefaultsCell (populated by the
-- front, shared process) maps funcName → Pair(paramNames, positional defaults).
-- An under-applied positional call is expanded into nested one-argument lambdas so
-- arguments/defaults evaluate once, left-to-right, and later defaults see earlier params.
def dfltRegLookup = (nm, reg) =>
  match reg {
    case Nil => Pair("__none__", Nil)
    case Cons(h, t) =>
      match h { case Pair(fnm, entry) =>
        if #seq(fnm, nm) then Pair("__some__", entry) else dfltRegLookup(nm, t) }
  }

-- An `object O { def f(x, y = d) }` method is registered (by the front's parseDef)
-- under the BARE name `f`, but the call `O.f(a)` lowers to `app(var O_f, …)` so the
-- call-site default synthesis looks up the MANGLED `O_f` and misses. When an object
-- is lowered, mirror each bare-name default entry under its `O_`-prefixed name.
-- `funcDefaultsCell` is keyed by BARE name, so two objects' same-named methods
-- (e.g. Tool.text/1 vs Resource.text/2) share one entry — only mirror it when its
-- arity matches THIS method's own param count, else Tool_text would inherit
-- Resource.text's 2-param default and over-apply.
def aliasFuncDefault = (bareName, mangledName, arity) =>
  match dfltRegLookup(bareName, #cell.get(funcDefaultsCell)) {
    case Pair(found, entry) =>
      if #seq(found, "__some__") then
        match entry { case Pair(params, dflts) =>
          if #i.eq(lenL(params), arity) then
            #cell.set(funcDefaultsCell,
              Cons(Pair(mangledName, entry), #cell.get(funcDefaultsCell)))
          else 0 }
      else 0
  }
def hasNamedDfltArg = (args) =>
  match args {
    case Nil => false
    case Cons(h, t) =>
      match h { case Pair(tag, data) =>
        if #seq(tag, "narg") then true else hasNamedDfltArg(t) }
  }
-- Enum-case constructor with a trailing default param, e.g. `Transport.Http(8080)`
-- where `case Http(port: Int, path: String = "/mcp")`. Case-class ctors pick up
-- defaults via the app path (expandDefaultCall); enum cases lower straight to
-- `ctorap`, so synthesize the missing trailing defaults here. `rargs` are already
-- resolved, so the appended default exprs (raw AST from funcDefaultsCell) are too.
def resolveDfltTail = (ds) =>
  match ds {
    case Nil => Nil
    case Cons(d, rest) => Cons(resolveE(d), resolveDfltTail(rest))
  }
def allDfltReal = (ds) =>
  match ds {
    case Nil => true
    case Cons(d, rest) => if dfltIsNone(d) then false else allDfltReal(rest)
  }
-- Curry-collapse helper: when a curried def's FIRST clause is under-applied
-- (`hstack()(kids)`), fill that clause's defaults so a later clause's args don't
-- shift into it. Only fills when every missing first-clause param has a real
-- default (else it's a genuine required-arg error, left as-is).
def firstListDfltsLookup = (nm) =>
  let rec go = (reg) =>
    match reg {
      case Nil => Pair("__none__", Nil)
      case Cons(h, t) =>
        match h { case Pair(fnm, ds) =>
          if #seq(fnm, nm) then Pair("__some__", ds) else go(t) }
    } in
  go(#cell.get(firstListDfltsCell))
def padFirstClauseDflts = (name, innerArgs) =>
  match firstListDfltsLookup(name) {
    case Pair(found, firstDflts) =>
      if #seq(found, "__some__") then
        let missing = dropL(lenL(innerArgs), firstDflts) in
        if allDfltReal(missing) then append(innerArgs, resolveDfltTail(missing))
        else innerArgs
      else innerArgs
  }
def ctorApplyDefaults = (name, args) =>
  match dfltRegLookup(name, #cell.get(funcDefaultsCell)) {
    case Pair(found, entry) =>
      if #seq(found, "__some__") then
        match entry {
          case Pair(params, dflts) =>
            let provided = lenL(args) in
            if #i.lt(provided, lenL(params)) then
              let tail = dropL(provided, dflts) in
              if allDfltReal(tail) then append(args, resolveDfltTail(tail))
              else args
            else args
        }
      else args
  }

def buildDfltBindings = (params, dflts, args) =>
  match params {
    case Nil =>
      match args { case Nil => Pair("__ok__", Nil) case Cons(h, t) => Pair("__bad__", Nil) }
    case Cons(p, prest) =>
      match dflts {
        case Nil => Pair("__bad__", Nil)
        case Cons(d, drest) =>
          match args {
            case Cons(a, arest) =>
              match buildDfltBindings(prest, drest, arest) {
                case Pair(status, bindings) =>
                  if #seq(status, "__ok__") then Pair("__ok__", Cons(Pair(p, a), bindings))
                  else Pair("__bad__", Nil)
              }
            case Nil =>
              if dfltIsNone(d) then Pair("__bad__", Nil)
              else match buildDfltBindings(prest, drest, Nil) {
                case Pair(status, bindings) =>
                  if #seq(status, "__ok__") then Pair("__ok__", Cons(Pair(p, d), bindings))
                  else Pair("__bad__", Nil)
              }
          }
      }
  }
def dfltBindingVars = (bindings) =>
  match bindings {
    case Nil => Nil
    case Cons(h, t) => match h { case Pair(name, value) =>
      Cons(Pair("var", name), dfltBindingVars(t)) }
  }
def wrapDfltBindings = (bindings, body) =>
  match bindings {
    case Nil => body
    case Cons(h, t) => match h { case Pair(name, value) =>
      Pair("app", Pair(Pair("lam", Pair(Cons(name, Nil), wrapDfltBindings(t, body))),
        Cons(value, Nil))) }
  }
def expandDefaultCall = (fn, args) =>
  let nm = match fn { case Pair(ftag, fdata) =>
    if #seq(ftag, "var") then fdata else if #seq(ftag, "uid") then fdata else "" } in
  if #seq(nm, "") then Pair("__none__", Nil)
  else if hasNamedDfltArg(args) then Pair("__none__", Nil)
  else match dfltRegLookup(nm, #cell.get(funcDefaultsCell)) {
    case Pair(found, entry) =>
      if #seq(found, "__none__") then Pair("__none__", Nil)
      else match entry { case Pair(params, dflts) =>
        if #i.lt(lenL(args), lenL(params)) then
          match buildDfltBindings(params, dflts, args) {
            case Pair(status, bindings) =>
              if #seq(status, "__ok__") then
                let fullCall = Pair("app", Pair(fn, dfltBindingVars(bindings))) in
                Pair("__some__", wrapDfltBindings(bindings, fullCall))
              else Pair("__none__", Nil)
          }
        else Pair("__none__", Nil) }
  }
def isCollectionCompanion = (name) =>
  if #seq(name, "List") then true
  else if #seq(name, "Seq") then true
  else if #seq(name, "Vector") then true
  else if #seq(name, "Array") then true
  -- K62.27: Map too, so `Map.empty` (bare companion) lowers its receiver to ctorap(Map) →
  -- DataV("Map") for the runtime __method__ Map.empty handler, instead of the unbound global
  -- Map (a constructor closure) → "no dispatch for .empty on <closure>". Map construction
  -- (Map(a -> b)) uses the separate direct-application path, and the curried-factory sugar is
  -- gated to tabulate/fill (which Map lacks), so both are unaffected.
  else #seq(name, "Map")
def isCurriedCollectionFactory = (method) =>
  if #seq(method, "tabulate") then true else #seq(method, "fill")
def expandCollectionCurry = (fn, args) =>
  match fn {
    case Pair(fnTag, fnData) =>
      if #seq(fnTag, "app") then
        match fnData { case Pair(innerFn, innerArgs) =>
          match innerFn { case Pair(innerTag, innerData) =>
            if #seq(innerTag, "sel") then
              match innerData { case Pair(owner, method) =>
                match owner { case Pair(ownerTag, ownerName) =>
                  if #seq(ownerTag, "uid") then
                    if isCollectionCompanion(ownerName) then
                      if isCurriedCollectionFactory(method) then
                        if #i.eq(lenL(innerArgs), 1) then
                          if #i.eq(lenL(args), 1) then
                            Pair("__some__", Pair("app", Pair(innerFn, append(innerArgs, args))))
                          else Pair("__none__", Nil)
                        else Pair("__none__", Nil)
                      else Pair("__none__", Nil)
                    else Pair("__none__", Nil)
                  else Pair("__none__", Nil)
                }
              }
            else Pair("__none__", Nil)
          }
        }
      else Pair("__none__", Nil)
  }
def expandCallSugar = (fn, args) =>
  match expandCollectionCurry(fn, args) {
    case Pair(tag, expanded) =>
      if #seq(tag, "__some__") then Pair(tag, expanded)
      else expandDefaultCall(fn, args)
  }

-- K62.26b: is this call the front's f-interpolation marker app(var("__fInterpolate__"), …)?
def fInterpCall = (fn) =>
  match fn { case Pair(ftag, fdata) =>
    if #seq(ftag, "var") then #seq(fdata, "__fInterpolate__") else false }

def isTypedDbQueryMarker = (fn) =>
  match fn { case Pair(ftag, fdata) => #seq(ftag, "typed_db_query") }

def resolveTypedDbQuery = (fn, args) =>
  match fn { case Pair(ftag, typeName) =>
    Pair("app", Pair(Pair("var", "Db.queryTyped"),
      Cons(Pair("str", typeName), resolveArgs(args)))) }

def directNameIn = (name, names) =>
  match names {
    case Nil => false
    case Cons(h, rest) => if #seq(name, h) then true else directNameIn(name, rest)
  }

def directSupportedMonad = (monad) =>
  if #seq(monad, "Option") then true else #seq(monad, "List")

def directThen = (stmt, restExpr) =>
  Pair("block", Cons(stmt, Cons(Pair("expr", restExpr), Nil)))

def directBind = (name, rhs, restExpr) =>
  Pair("app", Pair(
    Pair("sel", Pair(rhs, "flatMap")),
    Cons(Pair("lam", Pair(Cons(name, Nil), restExpr)), Nil)))

def directStmts = (monad, stmts, mutableNames) =>
  match stmts {
    case Nil => Pair("tup", Nil)
    case Cons(stmt, rest) =>
      match stmt {
        case Pair(stag, sdata) =>
          if #seq(stag, "assign") then
            match sdata {
              case Pair(name, rhs) =>
                if directNameIn(name, mutableNames) then
                  directThen(stmt, directStmts(monad, rest, mutableNames))
                else
                  directBind(name, rhs, directStmts(monad, rest, mutableNames))
            }
          else if #seq(stag, "var") then
            match sdata {
              case Pair(name, init) =>
                directThen(stmt, directStmts(monad, rest, Cons(name, mutableNames)))
            }
          else if #seq(stag, "val") then
            directThen(stmt, directStmts(monad, rest, mutableNames))
          else if #seq(stag, "expr") then
            match rest {
              case Nil => sdata
              case Cons(next, more) =>
                directThen(stmt, directStmts(monad, rest, mutableNames))
            }
          else
            directThen(stmt, directStmts(monad, rest, mutableNames))
      }
  }

def desugarDirect = (monad, body) =>
  if directSupportedMonad(monad) then
    match body {
      case Pair(tag, stmts) =>
        if #seq(tag, "block") then directStmts(monad, stmts, Nil)
        else Pair("var", "__malformed_direct_block")
    }
  else Pair("var", #sconcat("__unsupported_direct_", monad))

-- Main resolve function — transforms one AST node
def resolveE = (expr) =>
  match expr {
    case Pair(tag, data) =>
      if #seq(tag, "int") then expr
      else if #seq(tag, "str") then expr
      else if #seq(tag, "bool") then expr
      else if #seq(tag, "var") then
        if isParameterlessDef(data) then Pair("parameterless_app", data) else expr
      else if #seq(tag, "parameterless_app") then expr
      else if #seq(tag, "parameterless") then resolveE(data)
      else if #seq(tag, "direct") then
        match data { case Pair(monad, body) => resolveE(desugarDirect(monad, body)) }
      else if #seq(tag, "focus_marker") then Pair("var", "__unsupported_focus_path")
      else if #seq(tag, "prism") then
        let variant = prismVariant(data) in
        if #seq(variant, "") then Pair("var", "__unsupported_prism_type")
        else Pair("prim", Pair("optics.prism", Cons(Pair("str", variant), Nil)))
      else if #seq(tag, "summon") then
        match parseGivenType(data) {
          case Pair(tc, typeName) =>
            match findGiven(#cell.get(kc5GivenCell), tc, typeName) {
              case Some(gname) => Pair("var", gname)
              -- Abstract type param (e.g. summon[Pretty[A]] in a poly body): defer to the active
              -- ctx, carrying the TC so `.method`/`.field` dispatch resolves THIS tc's instance
              -- (not just the first active given — wrong when a body has 2+ context bounds).
              case None => Pair("summon_tc", tc)
            }
        }
      else if #seq(tag, "uid") then
        if isTopVal(data) then Pair("var", data)
        else if isTopVar(data) then Pair("var", data)
        else if #seq(data, "None") then Pair("ctorap", Pair("None", Nil))
        else if #seq(data, "Nil") then Pair("ctorap", Pair("Nil", Nil))
        else expr
      else if #seq(tag, "narg") then
        match data { case Pair(label, v) => Pair("narg", Pair(label, resolveE(v))) }
      else if #seq(tag, "app") then
        match data {
          case Pair(fn, args) =>
            -- K62.26b: f"" interpolation is emitted by the front as
            -- app(var("__fInterpolate__"), [head, spec,arg,rest, …]); route it to a prim
            -- node so lowerE emits IrPrim("__fInterpolate__", …) (the runtime String.format
            -- op), not an unbound-global call.
            if isTypedDbQueryMarker(fn) then resolveTypedDbQuery(fn, args)
            else if isFocusMarker(fn) then
              resolveFocusArgs(args)
            else if fInterpCall(fn) then Pair("prim", Pair("__fInterpolate__", resolveArgs(args)))
            else
            -- K62.17: expand omitted positional defaults into a scoped,
            -- single-evaluation lambda chain before ordinary call resolution.
            match expandCallSugar(fn, args) {
                  case Pair(expandedTag, expanded) =>
                    if #seq(expandedTag, "__some__") then resolveE(expanded)
                    else
                      let rargs = resolveArgs(args) in
                      match fn {
              case Pair(ftag, fdata) =>
                if #seq(ftag, "uid") then
                  if #seq(fdata, "Some") then Pair("ctorap", Pair("Some", rargs))
                  else if #seq(fdata, "Cons") then Pair("ctorap", Pair("Cons", rargs))
                  else if #seq(fdata, "Left") then Pair("ctorap", Pair("Left", rargs))
                  else if #seq(fdata, "Right") then Pair("ctorap", Pair("Right", rargs))
                  -- K62.33: Signal(x) / ComputedSignal(x) are COMPILER-special ctors (Runtime
                  -- Ctor("Signal") → a mutable ForeignV cell so .get/.set work). The scalameta
                  -- bridge lowers them as ctors; the native front used to fall to the unknown-
                  -- uid `app(global Signal)` path → "unbound global: Signal". Lower to ctorap so
                  -- the compiler special-case fires (no reactive plugin global needed).
                  else if #seq(fdata, "Signal") then Pair("ctorap", Pair("Signal", rargs))
                  else if #seq(fdata, "ComputedSignal") then Pair("ctorap", Pair("ComputedSignal", rargs))
                  else if #seq(fdata, "List") then buildListExpr(rargs)
                  else if #seq(fdata, "Set") then
                    -- v2 sets are DISTINCT lists (`.toSet`); `Set(a, b, …)` / `Set()` →
                    -- `[a, b, …].toSet`. Was an unbound global (Set not a collection
                    -- companion); blocked the std/mapreduce distributed modules (`retried
                    -- = Set()`, `pending: Set[Int]`).
                    Pair("prim", Pair("__method__",
                      Cons(Pair("str", "toSet"), Cons(buildListExpr(rargs), Nil))))
                  else if #seq(fdata, "Array") then
                    Pair("app", Pair(Pair("var", "_arr_fill"), Cons(buildListExpr(rargs), Nil)))
                  else if #seq(fdata, "Vector") then
                    -- `Vector(a, b, …)` is IMMUTABLE → a Cons-list (like `List(…)`), NOT
                    -- the mutable `_arr_fill` ArrayBuffer. The ArrayBuffer form has no
                    -- `.head`/`.tail` dispatch and `.map` on it returns another
                    -- ArrayBuffer, so `Vector(…).map(f).head` failed with
                    -- ".head on <foreign>". Cons-lists support indexed access `v(i)`
                    -- and all list ops, so this is strictly more capable.
                    buildListExpr(rargs)
                  else if #seq(fdata, "Seq") then
                    buildListExpr(rargs)
                  else if #seq(fdata, "Map") then
                    buildMapExpr(rargs)
                  else if #seq(fdata, "BigInt") then
                    match rargs {
                      case Cons(value, rest) =>
                        match rest {
                          case Nil => Pair("prim", Pair("i->big", Cons(value, Nil)))
                          case _ => Pair("app", Pair(fn, rargs))
                        }
                    }
                  else if #seq(fdata, "Decimal") then
                    match rargs {
                      case Cons(value, rest) =>
                        match rest {
                          case Nil =>
                            Pair("prim", Pair("dec.parse", Cons(value, Nil)))
                          case Cons(scale, tail) =>
                            match tail {
                              case Nil => Pair("prim", Pair("dec.from-unscaled",
                                Cons(value, Cons(scale, Nil))))
                              case _ => Pair("app", Pair(fn, rargs))
                            }
                        }
                    }
                  else Pair("app", Pair(fn, cellWrapCtorArgs(fdata, resolveCtorArgs(fdata, rargs))))
                else if #seq(ftag, "sel") then
                  match fdata {
                    case Pair(obj, method) =>
                      if #seq(method, "copy") then
                        -- Any named arg (mixed positional+named too): encode positionals as `#i` and
                        -- named as their label so the runtime copy maps each to the right field. Stripping
                        -- the labels (old mixed path) applied a named value positionally (z=99 → field y).
                        if hasNarg(rargs) then desugarCopy(resolveE(obj), rargs)
                        else resolveMethodCall(resolveE(obj), method, rargs)
                      else
                        -- KEEP the named-arg labels for an ENUM-CASE construction
                        -- (`E.Case(field = …)`) so resolveMethodCall's enum branch can
                        -- REORDER them to field order + fill omitted defaults. Every other
                        -- method uses its args positionally, so strip the labels there.
                        let rObjE = resolveE(obj) in
                        match rObjE {
                          case Pair(rtag, rname) =>
                            if #seq(rtag, "uid") then
                              (if isEnumUid(rname) then
                                 (if enumHasCase(enumCasesOf(rname), method) then
                                    resolveMethodCall(rObjE, method, rargs)
                                  else resolveMethodCall(rObjE, method, stripNargs(rargs)))
                               else resolveMethodCall(rObjE, method, stripNargs(rargs)))
                            else resolveMethodCall(rObjE, method, stripNargs(rargs))
                        }
                  }
                else if #seq(ftag, "app") then
                  -- Explicit portable handler: retain both the computation and
                  -- parsed partial-function closure. Block-form `handle { ... }`
                  -- supplies a zero-argument thunk, which is forced inside the
                  -- handler boundary; parenthesized computations are already
                  -- values.
                  -- ssc0 does not support nested ctor patterns; use nested match
                  let isHandleCall = match fdata {
                    case Pair(innerFn, innerArgs) =>
                      match innerFn {
                        case Pair(iftag, ifdata) =>
                          if #seq(iftag, "var") then #seq(ifdata, "handle") else false
                      }
                  } in
                  if isHandleCall then
                    match fdata {
                      case Pair(innerFn, innerArgs) =>
                        match innerArgs {
                          case Cons(computExpr, innerArgRest) =>
                            match innerArgRest {
                              case Nil =>
                                let resolvedCompute0 = resolveE(computExpr) in
                                let resolvedCompute = forceHandleCompute(resolvedCompute0) in
                                match stripNargs(rargs) {
                                  case Cons(handlerExpr, handlerRest) =>
                                    match handlerRest {
                                      case Nil => Pair("prim", Pair("effect.handle",
                                        Cons(resolvedCompute, Cons(resolveE(handlerExpr), Nil))))
                                      case _ => Pair("app", Pair(resolveCallee(fn), stripNargs(rargs)))
                                    }
                                  case Nil => Pair("app", Pair(resolveCallee(fn), Nil))
                                }
                              case _ => Pair("app", Pair(resolveCallee(fn), stripNargs(rargs)))
                            }
                          case _ => Pair("app", Pair(resolveCallee(fn), stripNargs(rargs)))
                        }
                    }
                  else
                    match fdata {
                      case Pair(innerFn, innerArgs) =>
                        let innerName = match innerFn {
                          case Pair(innerTag, innerData) =>
                            if #seq(innerTag, "var") then innerData
                            else if #seq(innerTag, "uid") then innerData
                            else ""
                        } in
                        let combinedArgs = append(padFirstClauseDflts(innerName, innerArgs), args) in
                        match defArity(innerName) {
                          case Pair(found, arity) =>
                            if found then
                              if #i.eq(lenL(combinedArgs), arity) then
                                resolveE(Pair("app", Pair(innerFn, combinedArgs)))
                              -- Trailing-vararg curried def (e.g. `vstack(g)(a, b)`): the last
                              -- clause holds unpacked varargs so combinedArgs OVERFLOWS arity.
                              -- Flatten and re-resolve as a direct call; the var-callee path
                              -- below packs the trailing args into one list to match arity.
                              else if isVarargDef(innerName) then
                                if #i.ge(lenL(combinedArgs), #i.sub(arity, 1)) then
                                  resolveE(Pair("app", Pair(innerFn, combinedArgs)))
                                else Pair("app", Pair(resolveCallee(fn), stripNargs(rargs)))
                              else Pair("app", Pair(resolveCallee(fn), stripNargs(rargs)))
                            else Pair("app", Pair(resolveCallee(fn), stripNargs(rargs)))
                        }
                    }
                else Pair("app", Pair(resolveCallee(fn), stripNargs(rargs)))
                  }
            }
        }
      else if #seq(tag, "sel") then
        match data {
          case Pair(obj, field) =>
            resolveField(resolveE(obj), field)
        }
      else if #seq(tag, "if") then
        match data {
          case Pair(c, rest) =>
            match rest {
              case Pair(t, e) =>
                Pair("if", Pair(resolveE(c), Pair(resolveE(t), resolveE(e))))
            }
        }
      else if #seq(tag, "inf") then
        match data {
          case Pair(op, lr) =>
            match lr {
              case Pair(l, r) =>
                let rl = resolveE(l) in
                let rr = resolveE(r) in
                -- KC5-micro: upgrade int + to string ++ when a literal/prim string side detected
                let op2 = if #seq(op, "+") then
                  if isStrExpr(rl) then "++"
                  else if isStrExpr(rr) then "++"
                  else op
                else op in
                Pair("inf", Pair(op2, Pair(rl, rr)))
            }
        }
      else if #seq(tag, "pre") then
        match data {
          case Pair(op, sub) => Pair("pre", Pair(op, resolveE(sub)))
        }
      else if #seq(tag, "tup") then
        Pair("tup", resolveArgs(data))
      else if #seq(tag, "match") then
        match data {
          case Pair(scrutE, arms) =>
            let re = resolveE(scrutE) in
            let rec rArms = (as) =>
              match as {
                case Nil => Nil
                case Cons(arm, rest) =>
                  match arm {
                    case Pair(pat, body) =>
                      let rpat = match pat {
                        case Pair(ptag, pdata) =>
                          if #seq(ptag, "gpat") then
                            match pdata {
                              case Pair(basePat, guard) => Pair("gpat", Pair(basePat, resolveE(guard)))
                            }
                          else pat
                      } in
                      Cons(Pair(rpat, resolveE(body)), rArms(rest))
                  }
              } in
            Pair("match", Pair(re, rArms(arms)))
        }
      else if #seq(tag, "lam") then
        -- KC11: anonymous function  params => body
        match data {
          case Pair(params, body) => Pair("lam", Pair(params, resolveE(body)))
        }
      else if #seq(tag, "block") then
        -- KC9: resolve each block item
        let rec resolveBlock = (ss) =>
          match ss {
            case Nil => Nil
            case Cons(s, rest) =>
              match s {
                case Pair(stag, sdata) =>
                  if #seq(stag, "val") then
                    match sdata {
                      case Pair(name, expr) =>
                        -- Register array/list vars NOW so subsequent stmts dispatch correctly
                        let rb = resolveE(expr) in
                        let _reg = if isArrayConstruction(rb) then
                          #cell.set(arrVarsCell, Cons(name, #cell.get(arrVarsCell)))
                        else () in
                        let _reg2 = if isListConstruction(rb) then
                          #cell.set(listVarsCell, Cons(name, #cell.get(listVarsCell)))
                        else () in
                        -- `val m = summon[TC[A]]` (abstract given): register m as a summon alias so the
                        -- rest of the block dispatches m.method/m.field via the active ctx for tc.
                        let _reg3 = match rb {
                          case Pair(rbt, rbtc) => if #seq(rbt, "summon_tc") then registerSummonAlias(name, rbtc) else ()
                        } in
                        Cons(Pair("val", Pair(name, rb)), resolveBlock(rest))
                    }
                  else if #seq(stag, "var") then
                    match sdata {
                      case Pair(name, expr) =>
                        -- Register map vars NOW so subsequent stmts in this block can dispatch correctly
                        let rb = resolveE(expr) in
                        let _reg = if isMapConstruction(rb) then
                          #cell.set(mapVarsCell, Cons(name, #cell.get(mapVarsCell)))
                        else () in
                        Cons(Pair("var", Pair(name, rb)), resolveBlock(rest))
                    }
                  else if #seq(stag, "def") then
                    match sdata {
                      case Pair(name, rest2) =>
                        match rest2 {
                          case Pair(params, body) =>
                            Cons(Pair("def", Pair(name, Pair(params, resolveE(body)))), resolveBlock(rest))
                        }
                    }
                  else if #seq(stag, "while") then
                    match sdata {
                      case Pair(cond, body) =>
                        Cons(Pair("while", Pair(resolveE(cond), resolveE(body))), resolveBlock(rest))
                    }
                  else if #seq(stag, "assign") then
                    match sdata {
                      case Pair(name, expr) =>
                        Cons(Pair("assign", Pair(name, resolveE(expr))), resolveBlock(rest))
                    }
                  else if #seq(stag, "return") then
                    Cons(Pair("return", resolveE(sdata)), resolveBlock(rest))
                  else if #seq(stag, "expr") then
                    Cons(Pair("expr", resolveE(sdata)), resolveBlock(rest))
                  else if #seq(stag, "idx_assign") then
                    match sdata {
                      case Pair(lhs, rhs) =>
                        Cons(Pair("idx_assign", Pair(resolveE(lhs), resolveE(rhs))), resolveBlock(rest))
                    }
                  else if #seq(stag, "tuppat") then
                    match sdata {
                      case Pair(names, expr) =>
                        Cons(Pair("tuppat", Pair(names, resolveE(expr))), resolveBlock(rest))
                    }
                  else Cons(s, resolveBlock(rest))
              }
          } in
        Pair("block", resolveBlock(data))
      else
        expr
  }

-- ── KC4: de Bruijn lowering ─────────────────────────────────────────────────

-- Lower a list of expressions with the same scope
def lowerArgs = (scope, args) =>
  match args { case Nil => Nil case Cons(e, rest) => Cons(lowerE(scope, e), lowerArgs(scope, rest)) }

-- Lower a tuple literal. A source 2-tuple `(a, b)` is tagged "Tuple2" to match
-- the scalameta bridge (which uses TupleN) and Scala's `(a, b)` rendering — the
-- shared VM Show renders any "TupleN" as `(a, b)`. The "Pair" tag is reserved for
-- `a -> b` arrows and mira's own tuples, which keep their `Pair(a, b)` rendering.
-- 3+ tuples are flat Tuple${N} (line below). Tuple2/Pair pattern arms accept both.
def lowerTuple = (scope, elems) =>
  match elems {
    case Nil => IrLit(IrUnit)
    case Cons(a, rest1) =>
      match rest1 {
        case Nil => lowerE(scope, a)
        case Cons(b, rest2) =>
          match rest2 {
            case Nil =>
              IrCtor("Tuple2", Cons(lowerE(scope, a), Cons(lowerE(scope, b), Nil)))
            case Cons(c, rest3) =>
              -- K62.20: 3+ tuples are FLAT Tuple${N} ctors (matching the front's Tuple${N}
              -- patterns from parsePat AND the scalameta bridge's Tuple${N}), NOT nested
              -- Pairs — otherwise `case (a,b,c)` (a Tuple3 pattern) never matched the value
              -- `Pair(a, Pair(b,c))` and `._2`/`._3` returned the inner pair / no-arm'd.
              let rec lowerAll = (es) =>
                match es {
                  case Nil => Nil
                  case Cons(e, more) => Cons(lowerE(scope, e), lowerAll(more))
                } in
              IrCtor(#sconcat("Tuple", #i->str(lenL(elems))), lowerAll(elems))
          }
      }
  }

-- A bare application `f(args)` inside a case-class method body is a SIBLING call
-- when `f` names another method of the same case class and isn't shadowed by a
-- local/param. Returns the mangled `Tag_f` global name, else "" (not a sibling call).
def caseSiblingGlobal = (scope, fname) =>
  match #cell.get(caseSelfCtxCell) {
    case Nil => ""
    case Pair(tag, siblings) =>
      match lookupVarOpt(scope, fname) {
        case Some(shadow) => ""
        case None => if memberOfL(fname, siblings) then #sconcat(tag, #sconcat("_", fname)) else ""
      }
  }

-- Lower a single expression node; first resolves known KC6 intrinsics
def lowerE = (scope, rawExpr) =>
  let expr = resolveE(rawExpr) in
  match expr {
    case Pair(tag, data) =>
      if #seq(tag, "ctorap") then
        match data {
          case Pair(name, args) => IrCtor(name, lowerArgs(scope, cellWrapCtorArgs(name, args)))
        }
      else if #seq(tag, "prim") then
        match data {
          case Pair(op, args) =>
            if #seq(op, "_list_head") then
              match args { case Cons(xs, xsRest) =>
                IrApp(IrGlobal("__list_head"), Cons(lowerE(scope, xs), Nil)) }
            else if #seq(op, "_list_tail") then
              match args { case Cons(xs, xsRest) =>
                IrApp(IrGlobal("__list_tail"), Cons(lowerE(scope, xs), Nil)) }
            else if #seq(op, "_list_isEmpty") then
              match args { case Cons(xs, xsRest) =>
                IrApp(IrGlobal("__list_isEmpty"), Cons(lowerE(scope, xs), Nil)) }
            else if #seq(op, "_list_nonEmpty") then
              match args { case Cons(xs, xsRest) =>
                IrApp(IrGlobal("__list_nonEmpty"), Cons(lowerE(scope, xs), Nil)) }
            else if #seq(op, "_str_toInt") then
              match args { case Cons(s, sRest) =>
                IrApp(IrGlobal("__str_toInt"), Cons(lowerE(scope, s), Nil)) }
            else
              IrPrim(op, lowerArgs(scope, args))
        }
      else if #seq(tag, "int") then
        IrLit(IrInt(parseI(data)))
      else if #seq(tag, "float") then
        match #str->f(data) {
          case Some(d) => IrLit(IrFloat(d))
          case None    => IrLit(IrFloat(0.0))
        }
      else if #seq(tag, "str") then
        IrLit(IrStr(data))
      else if #seq(tag, "bool") then
        IrLit(IrBool(if #seq(data, "true") then true else false))
      else if #seq(tag, "parameterless_app") then
        IrApp(IrGlobal(data), Nil)
      else if #seq(tag, "summon_tc") then
        -- summon[TC] in VALUE position (val m = summon[TC]) — a given is a set of globals, not a
        -- single value; emit a loud unbound so it fails visibly rather than silently miscompiling.
        IrGlobal(#sconcat("__summon_value_", data))
      else if #seq(tag, "var") then
        -- KC10: check for mutable var ("@name" or "@@name" in scope → cell.get/lcell.get)
        let plain = lookupVar(scope, data) in
        match plain {
          case IrGlobal(gname) =>
            -- Check long cell (@@) first, then regular cell (@)
            let llName = #sconcat("@@", data) in
            match lookupVarOpt(scope, llName) {
              case Some(lcellRef) => IrPrim("lcell.get", Cons(lcellRef, Nil))
              case None =>
                let cellName = #sconcat("@", data) in
                let cellRef = lookupVar(scope, cellName) in
                match cellRef {
                  case IrLocal(ci) => IrPrim("cell.get", Cons(IrLocal(ci), Nil))
                  case IrGlobal(ng) =>
                    -- K62.6b: a top-level `var` reference → cell.get(global name__cell)
                    if isTopVar(data) then
                      IrPrim("cell.get", Cons(IrGlobal(#sconcat(data, "__cell")), Nil))
                    else if isTopVal(data) then
                      IrPrim("cell.get", Cons(IrGlobal(#sconcat(data, "__cell")), Nil))
                    else if isActiveOwnerVar(data) then
                      IrPrim("cell.get",
                        Cons(IrGlobal(#sconcat(#cell.get(kc7bOwnerPrefixCell),
                          #sconcat(data, "__cell"))), Nil))
                    else if isActiveOwnerMember(data) then
                      IrGlobal(#sconcat(#cell.get(kc7bOwnerPrefixCell), data))
                    else if #seq(data, "this") then
                      -- `this` inside a (case-)class method body is the receiver
                      -- DataV, bound as `__self`; `this.field`/`this.method` then
                      -- flow through the normal sel/method dispatch.
                      match lookupVarOpt(scope, "__self") {
                        case Some(s) => s
                        case None => IrGlobal(data)
                      }
                    else if isCurrentVarField(data) then
                      -- A mutable `var` field read inside a method: the field stores
                      -- a cell, so read its current value via cell.get(_sel_f(__self)).
                      IrPrim("cell.get",
                        Cons(IrApp(IrGlobal(#sconcat("_sel_", data)),
                               Cons(lookupVar(scope, "__self"), Nil)), Nil))
                    else if isCurrentLazyField(data) then
                      -- A `lazy val` field read inside a method: force+memoize.
                      IrPrim("__lazyForce__",
                        Cons(IrApp(IrGlobal(#sconcat("_sel_", data)),
                               Cons(lookupVar(scope, "__self"), Nil)), Nil))
                    else if #i.gt(#slen(caseSiblingGlobal(scope, data)), 0) then
                      -- A bare reference to a NULLARY sibling method inside a
                      -- (case-)class body (`def describe = area.toString`) calls it
                      -- with `__self` — the applied form `sibling(args)` is handled
                      -- in the app case.
                      IrApp(IrGlobal(caseSiblingGlobal(scope, data)),
                        Cons(lookupVar(scope, "__self"), Nil))
                    else IrGlobal(data)
                }
            }
          case IrLocal(li) => IrLocal(li)
        }
      else if #seq(tag, "uid") then
        if isTopVal(data) then
          IrPrim("cell.get", Cons(IrGlobal(#sconcat(data, "__cell")), Nil))
        else if isTopVar(data) then
          IrPrim("cell.get", Cons(IrGlobal(#sconcat(data, "__cell")), Nil))
        -- A CAPITALIZED bare reference to the enclosing object's own `val`/`def`
        -- member (a constant like `VerticalTab`, `Start`, `Empty`) — mirror the `id`
        -- case, which had these checks. Without them the uid fell straight to
        -- `IrGlobal(data)` → `unbound global`. (Nested types / enum cases are NOT in
        -- staticMemberNames, so they still resolve to their hoisted global.)
        else if isActiveOwnerVar(data) then
          IrPrim("cell.get",
            Cons(IrGlobal(#sconcat(#cell.get(kc7bOwnerPrefixCell),
              #sconcat(data, "__cell"))), Nil))
        else if isActiveOwnerMember(data) then
          IrGlobal(#sconcat(#cell.get(kc7bOwnerPrefixCell), data))
        else IrGlobal(data)
      else if #seq(tag, "tup") then
        lowerTuple(scope, data)
      else if #seq(tag, "if") then
        match data {
          case Pair(cond, rest) =>
            match rest {
              case Pair(thn, els) =>
                IrIf(lowerE(scope, cond), lowerE(scope, thn), lowerE(scope, els))
            }
        }
      else if #seq(tag, "inf") then
        match data {
          case Pair(op, lr) =>
            match lr {
              case Pair(l, r) =>
                let lv = lowerE(scope, l) in
                let rv = lowerE(scope, r) in
                if #seq(op, "+")  then IrPrim("__arith__", Cons(IrLit(IrStr("+")), Cons(lv, Cons(rv, Nil))))
                else if #seq(op, "-")  then IrPrim("__arith__", Cons(IrLit(IrStr("-")), Cons(lv, Cons(rv, Nil))))
                else if #seq(op, "*")  then IrPrim("__arith__", Cons(IrLit(IrStr("*")), Cons(lv, Cons(rv, Nil))))
                else if #seq(op, "/")  then IrPrim("__arith__", Cons(IrLit(IrStr("/")), Cons(lv, Cons(rv, Nil))))
                else if #seq(op, "%")  then IrPrim("__arith__", Cons(IrLit(IrStr("%")), Cons(lv, Cons(rv, Nil))))
                -- K62.16: ==/!= lower to the STRUCTURAL __eq__ prim, not i.eq. i.eq's VM
                -- compile path (Runtime.scala:1725) coerces operands via asInt, so string
                -- `"a"=="a"` crashed (expected Int). __eq__ (Runtime.scala:2174) is value
                -- equality over all types (StrV/IntV/FloatV/BoolV/DataV). Trade-off: an int
                -- ==/!= loop condition no longer matches the i.eq JIT fast-path (falls to the
                -- correct general interpreter) — measured conformance-neutral.
                else if #seq(op, "==") then IrPrim("__eq__", Cons(lv, Cons(rv, Nil)))
                else if #seq(op, "<")  then IrPrim("__arith__", Cons(IrLit(IrStr("<")), Cons(lv, Cons(rv, Nil))))
                else if #seq(op, "++") then IrPrim("__arith__", Cons(IrLit(IrStr("++")), Cons(lv, Cons(rv, Nil))))
                else if #seq(op, ":+") then
                  IrPrim("__arith__", Cons(IrLit(IrStr(":+")), Cons(lv, Cons(rv, Nil))))
                else if #seq(op, "::")  then IrCtor("Cons", Cons(lv, Cons(rv, Nil)))
                else if #seq(op, "->")  then IrCtor("Pair", Cons(lv, Cons(rv, Nil)))
                else if #seq(op, "!")   then
                  IrPrim("__arith__", Cons(IrLit(IrStr("!")), Cons(lv, Cons(rv, Nil))))
                else if #seq(op, "&")  then IrPrim("i.and", Cons(lv, Cons(rv, Nil)))
                else if #seq(op, "|")  then
                  -- Imported extension ownership is rebuilt over the assembled
                  -- module closure. CoreIR is type-erased here, so retain the
                  -- exact extension closure and let the shared runtime keep
                  -- Int | Int primitive while dispatching every other shape to
                  -- the extension.
                  if isExtensionMethod(op) then
                    IrPrim("__arithExt__",
                      Cons(IrLit(IrStr(op)),
                        Cons(lv, Cons(rv, Cons(IrGlobal(op), Nil)))))
                  else IrPrim("i.or", Cons(lv, Cons(rv, Nil)))
                else if #seq(op, "^")  then IrPrim("i.xor", Cons(lv, Cons(rv, Nil)))
                else if #seq(op, "<<")  then IrPrim("i.shl",  Cons(lv, Cons(rv, Nil)))
                else if #seq(op, ">>")  then IrPrim("i.shr",  Cons(lv, Cons(rv, Nil)))
                else if #seq(op, ">>>") then IrPrim("i.ushr", Cons(lv, Cons(rv, Nil)))
                else if #seq(op, "&&") then IrIf(lv, rv, IrLit(IrBool(false)))
                else if #seq(op, "||") then IrIf(lv, IrLit(IrBool(true)), rv)
                else if #seq(op, "!=") then
                  IrIf(IrPrim("__eq__", Cons(lv, Cons(rv, Nil))), IrLit(IrBool(false)), IrLit(IrBool(true)))
                else if #seq(op, "<=") then
                  IrPrim("__arith__", Cons(IrLit(IrStr("<=")), Cons(lv, Cons(rv, Nil))))
                else if #seq(op, ">")  then
                  IrPrim("__arith__", Cons(IrLit(IrStr(">")), Cons(lv, Cons(rv, Nil))))
                else if #seq(op, ">=") then
                  IrPrim("__arith__", Cons(IrLit(IrStr(">=")), Cons(lv, Cons(rv, Nil))))
                else if #seq(op, ":=") then
                  -- DSL assign operator: `a := b` is Scala `a.:=(b)` (a method on the
                  -- LHS building a setting/attr), NOT a var store. Route to __method__.
                  IrPrim("__method__", Cons(IrLit(IrStr(":=")), Cons(lv, Cons(rv, Nil))))
                else
                  -- User-defined symbolic operator. Receiver-aware extension
                  -- dispatch is a later slice; an explicit global call keeps
                  -- this path honest instead of silently becoming Int addition.
                  IrApp(IrGlobal(op), Cons(lv, Cons(rv, Nil)))
            }
        }
      else if #seq(tag, "pre") then
        match data {
          case Pair(op, sub) =>
            let sv = lowerE(scope, sub) in
            if #seq(op, "-") then IrPrim("i.sub", Cons(IrLit(IrInt(0)), Cons(sv, Nil)))
            else if #seq(op, "!") then IrIf(sv, IrLit(IrBool(false)), IrLit(IrBool(true)))
            else if #seq(op, "~") then IrPrim("i.not", Cons(sv, Nil))
            else sv
        }
      else if #seq(tag, "app") then
        match data {
          case Pair(fn, args) =>
            -- KC5: auto-inject given instances for context dict params
            let injArgs = injectGivens(fn, args) in
            -- KC5-mono: rewrite a 1-ctx-TC typeclass call to its specialised copy (`fn` unchanged else)
            let fnM = match monoInstanceFor(fn, args) { case None => fn case Some(nm) => Pair("var", nm) } in
            -- Check if calling a registered array var with a single index → arr.get
            match fnM {
              case Pair(ftag, fname) =>
                if #seq(ftag, "var") then
                  if #i.gt(#slen(caseSiblingGlobal(scope, fname)), 0) then
                    -- Sibling method call inside a case-class body: dispatch to the
                    -- mangled `Tag_method` global with `__self` prepended.
                    IrApp(IrGlobal(caseSiblingGlobal(scope, fname)),
                      Cons(lookupVar(scope, "__self"), lowerArgs(scope, injArgs)))
                  else if #seq(fname, "println") then
                    match injArgs {
                      case Nil => IrPrim("io.println", Cons(IrLit(IrStr("")), Nil))
                      case _ => IrApp(lowerE(scope, fn), lowerArgs(scope, injArgs))
                    }
                  else if isArrVar(fname) then
                    match injArgs {
                      case Cons(idx, idxRest) =>
                        match idxRest {
                          case Nil =>
                            IrPrim("arr.get", Cons(lowerE(scope, fn), Cons(lowerE(scope, idx), Nil)))
                          case _ =>
                            IrApp(lowerE(scope, fn), lowerArgs(scope, injArgs))
                        }
                      case _ =>
                        IrApp(lowerE(scope, fn), lowerArgs(scope, injArgs))
                    }
                  -- Trailing-vararg packing runs HERE (once per Ir node), not in
                  -- resolveE: resolveE is re-applied top-down by lowerE at every level,
                  -- so packing there compounded into a nested list ([[[…]]]). lowerE's
                  -- app→IrApp step is terminal (Ir nodes are never re-lowered), so a
                  -- single pack is idempotent. packVarargsArgs is a no-op for non-vararg
                  -- callees; for a `T*` def it folds the trailing args into one Cons-list.
                  else IrApp(lowerE(scope, fnM), lowerArgs(scope, packVarargsArgs(fname, injArgs)))
                else IrApp(lowerE(scope, fn), lowerArgs(scope, injArgs))
            }
        }
      else if #seq(tag, "sel") then
        -- field selection not resolved by KC6: emit placeholder
        match data {
          case Pair(obj, field) =>
            IrApp(IrGlobal(#sconcat("_sel_", field)), Cons(lowerE(scope, obj), Nil))
        }
      else if #seq(tag, "match") then
        match data {
          case Pair(scrutE, arms) => lowerMatch(scope, scrutE, arms)
        }
      else if #seq(tag, "lam") then
        -- KC11: (params) => body  →  IrLam(n, body_lowered)
        match data {
          case Pair(params, body) =>
            let n = lenL(params) in
            let lamScope = appendL(revL(params), scope) in
            -- A parsed partial-function literal is exactly a one-argument
            -- self-scrutinee match (`__pf => __pf match { ... }`). Preserve
            -- that root identity for effect handlers: simple constructor arms
            -- become a direct Match(Local(0), ...), while general patterns use
            -- the same private selected/miss markers as FrontendBridge.
            if #i.eq(n, 1) then
              match params {
                case Cons(param, paramRest) =>
                  match paramRest {
                    case Nil =>
                      match body {
                        case Pair(bodyTag, bodyData) =>
                          if #seq(bodyTag, "match") then
                            match bodyData {
                              case Pair(scrutinee, arms) =>
                                if isVarNamed(scrutinee, param) then
                                  IrLam(1, lowerHandlerMatch(lamScope, param, arms))
                                else IrLam(n, lowerE(lamScope, body))
                            }
                          else IrLam(n, lowerE(lamScope, body))
                      }
                    case _ => IrLam(n, lowerE(lamScope, body))
                  }
              }
            else IrLam(n, lowerE(lamScope, body))
        }
      else if #seq(tag, "return") then
        -- `return e` in EXPRESSION position (e.g. `if c then return x else y`, inside a
        -- while/match). Evaluating the value in place can't unwind the enclosing loop —
        -- throw a non-local return caught by the def-body's `__with_return__` wrap.
        let _mark = #cell.set(defHasReturnCell, true) in
        IrPrim("__throw_return__", Cons(lowerE(scope, data), Nil))
      else if #seq(tag, "block") then
        lowerBlock(scope, data)
      else if #seq(tag, "sel_assign") then
        -- `obj.field = rhs`: a mutable `var` field is a cell → cell.set on
        -- `_sel_field(obj)`. A non-var field is an immutable-write error.
        match data {
          case Pair(objE, fr) =>
            match fr {
              case Pair(field, rhs) =>
                if isAnyVarField(field) then
                  IrPrim("cell.set",
                    Cons(IrApp(IrGlobal(#sconcat("_sel_", field)),
                           Cons(lowerE(scope, objE), Nil)),
                      Cons(lowerE(scope, rhs), Nil)))
                else IrGlobal("_err")
            }
        }
      else if #seq(tag, "assign") then
        -- assignment in expression position (e.g. then-branch of if-then)
        -- Mirrors the lowerBlock assign case: long cell (@@name) first, then @name.
        -- (Missing @@ check here emitted a bogus IrGlobal("@x") — the T5.1 bug.)
        match data {
          case Pair(name, expr) =>
            if isCurrentVarField(name) then
              -- Write to a mutable `var` field inside a method: cell.set on the
              -- field's cell (`_sel_name(__self)`).
              IrPrim("cell.set",
                Cons(IrApp(IrGlobal(#sconcat("_sel_", name)),
                       Cons(lookupVar(scope, "__self"), Nil)),
                  Cons(lowerE(scope, expr), Nil)))
            else
            let llName = #sconcat("@@", name) in
            match lookupVarOpt(scope, llName) {
              case Some(lcellRef) =>
                IrPrim("lcell.set", Cons(lcellRef, Cons(lowerE(scope, expr), Nil)))
              case None =>
                let cellName = #sconcat("@", name) in
                match lookupVarOpt(scope, cellName) {
                  case Some(cellRef) =>
                    IrPrim("cell.set", Cons(cellRef, Cons(lowerE(scope, expr), Nil)))
                  case None =>
                    -- K62.6b: assignment to a top-level var → cell.set(global name__cell)
                    if isTopVar(name) then
                      IrPrim("cell.set", Cons(IrGlobal(#sconcat(name, "__cell")), Cons(lowerE(scope, expr), Nil)))
                    else if isActiveOwnerVar(name) then
                      IrPrim("cell.set", Cons(IrGlobal(#sconcat(#cell.get(kc7bOwnerPrefixCell),
                        #sconcat(name, "__cell"))), Cons(lowerE(scope, expr), Nil)))
                    else IrPrim("cell.set", Cons(lookupVar(scope, cellName), Cons(lowerE(scope, expr), Nil)))
                }
            }
        }
      else
        IrLit(IrUnit)
  }

-- ── KC6: injected runtime helpers ────────────────────────────────────────────
-- These are IrDef Data values injected into every program's def list.
-- De Bruijn indexing: in IrLam(n, body), last param = local 0.
-- In IrArm(tag, k, body), last bound field = local 0 (all k fields shift outer scope by k).

-- _sel_map(obj, f) — polymorphic map over List, Option, Either
-- IrLam(2): f=local0, obj=local1
-- IrLetRec: go=local0, f=local1, obj=local2
-- go=IrLam(1): xs=local0; go=local1, f=local2, obj=local3
-- Cons arm (2 fields): t=local0, h=local1, xs=local2, go=local3, f=local4
-- 1-field arms (Some/Right/Left): v=local0, xs=local1, go=local2, f=local3
-- 0-field arms (Nil/None): xs=local0, go=local1, f=local2
-- _sel_map extended for LazyCons/LazyNil (lazy list map returns lazy list)
-- LazyCons arm (2 fields): thunk=local0, h=local1; go=local3, f=local4
--   → LazyCons(f(h), () => go(thunk()))
def selMapDef =
  IrDef("_sel_map",
    IrLam(2,
      IrLetRec(
        Cons(IrLam(1,
          IrMatch(IrLocal(0),
            Cons(IrArm("Nil", 0, IrCtor("Nil", Nil)),
            Cons(IrArm("Cons", 2,
              IrCtor("Cons",
                Cons(IrApp(IrLocal(4), Cons(IrLocal(1), Nil)),
                Cons(IrApp(IrLocal(3), Cons(IrLocal(0), Nil)),
                Nil)))),
            Cons(IrArm("LazyCons", 2,
              IrCtor("LazyCons",
                Cons(IrApp(IrLocal(4), Cons(IrLocal(1), Nil)),
                Cons(IrLam(0, IrApp(IrLocal(3), Cons(IrApp(IrLocal(0), Nil), Nil))),
                Nil)))),
            Cons(IrArm("LazyNil", 0, IrCtor("LazyNil", Nil)),
            Cons(IrArm("Some", 1,
              IrCtor("Some", Cons(IrApp(IrLocal(3), Cons(IrLocal(0), Nil)), Nil))),
            Cons(IrArm("None", 0, IrCtor("None", Nil)),
            Cons(IrArm("Right", 1,
              IrCtor("Right", Cons(IrApp(IrLocal(3), Cons(IrLocal(0), Nil)), Nil))),
            Cons(IrArm("Left", 1, IrCtor("Left", Cons(IrLocal(0), Nil))),
            Nil)))))))),
            Some(IrPrim("__method__",
              Cons(IrLit(IrStr("map")),
              Cons(IrLocal(0), Cons(IrLocal(2), Nil))))))),
        Nil),
        IrApp(IrLocal(0), Cons(IrLocal(2), Nil)))))

-- _sel_foreach(list, f) — iterate list for side effects; return Unit
-- lam(2): f=local0, list=local1
-- letrec go: go=local0, f=local1, list=local2
-- go=lam(1): xs=local0, go=local1, f=local2
-- Cons arm (2 fields): t=local0, h=local1; xs=local2, go=local3, f=local4
-- Inside IrLet([f(h)]) body the env shifts by 1:
--   f(h)_result=local0, t=local1, h=local2, xs=local3, go=local4, f=local5
def selForeachDef =
  IrDef("_sel_foreach",
    IrLam(2,
      IrLetRec(
        Cons(IrLam(1,
          IrMatch(IrLocal(0),
            Cons(IrArm("Nil", 0, IrLit(IrUnit)),
            Cons(IrArm("Cons", 2,
              IrLet(Cons(IrApp(IrLocal(4), Cons(IrLocal(1), Nil)), Nil),
                IrApp(IrLocal(4), Cons(IrLocal(1), Nil)))),
            Nil)),
            Some(IrPrim("__method__",
              Cons(IrLit(IrStr("foreach")),
              Cons(IrLocal(0), Cons(IrLocal(2), Nil))))))),
        Nil),
        IrApp(IrLocal(0), Cons(IrLocal(2), Nil)))))

-- _sel_flatMap(obj, f) — flatMap over Option/Either
-- lam(2): f=local0, obj=local1
-- Some arm (1 field): v=local0, f=local1 → f(v)
-- None arm (0 fields): f=local0 → None
-- Right arm (1 field): v=local0, f=local1 → f(v)
-- Left arm (1 field): e=local0, f=local1 → Left(e)
def selFlatMapDef =
  IrDef("_sel_flatMap",
    IrLam(2,
      IrMatch(IrLocal(1),
        Cons(IrArm("Some", 1, IrApp(IrLocal(1), Cons(IrLocal(0), Nil))),
        Cons(IrArm("None", 0, IrCtor("None", Nil)),
        Cons(IrArm("Right", 1, IrApp(IrLocal(1), Cons(IrLocal(0), Nil))),
        Cons(IrArm("Left", 1, IrCtor("Left", Cons(IrLocal(0), Nil))),
        Nil)))),
        -- Structural ADTs stay fast; opaque/provider receivers dispatch dynamically.
        Some(IrPrim("__method__",
          Cons(IrLit(IrStr("flatMap")),
          Cons(IrLocal(1), Cons(IrLocal(0), Nil))))))))

-- _sel_fold(either, fa, fb) — Either.fold; IrLam(3): fb=local0, fa=local1, either=local2
-- Left arm (1 field): v=local0, fb=local1, fa=local2 → fa(v)
-- Right arm (1 field): v=local0, fb=local1, fa=local2 → fb(v)
def selFoldDef =
  IrDef("_sel_fold",
    IrLam(3,
      IrMatch(IrLocal(2),
        Cons(IrArm("Left", 1, IrApp(IrLocal(2), Cons(IrLocal(0), Nil))),
        Cons(IrArm("Right", 1, IrApp(IrLocal(1), Cons(IrLocal(0), Nil))),
        Nil)),
        Some(IrPrim("__method__",
          Cons(IrLit(IrStr("fold")),
          Cons(IrLocal(2), Cons(IrLocal(1), Cons(IrLocal(0), Nil)))))))))

-- _sel_getOrElse(opt, default) — Option.getOrElse
-- IrLam(2): default=local0, opt=local1
-- Some arm (1 field): v=local0 → v
-- default case (None): local0 = default
def selGetOrElseDef =
  IrDef("_sel_getOrElse",
    IrLam(2,
      IrMatch(IrLocal(1),
        Cons(IrArm("Some", 1, IrLocal(0)), Nil),
        Some(IrLocal(0)))))

-- _sel_filter(list, f) = keep elements where f(elem) is true
-- Same scope chain as _sel_map; Cons arm: t=local0, h=local1; go=local3, f=local4
def selFilterDef =
  IrDef("_sel_filter",
    IrLam(2,
      IrLetRec(
        Cons(IrLam(1,
          IrMatch(IrLocal(0),
            Cons(IrArm("Nil", 0, IrCtor("Nil", Nil)),
            Cons(IrArm("Cons", 2,
              IrIf(IrApp(IrLocal(4), Cons(IrLocal(1), Nil)),
                IrCtor("Cons",
                  Cons(IrLocal(1),
                  Cons(IrApp(IrLocal(3), Cons(IrLocal(0), Nil)), Nil))),
                IrApp(IrLocal(3), Cons(IrLocal(0), Nil)))),
            Nil)),
            Some(IrPrim("__method__",
              Cons(IrLit(IrStr("filter")),
              Cons(IrLocal(0), Cons(IrLocal(2), Nil))))))),
        Nil),
        IrApp(IrLocal(0), Cons(IrLocal(2), Nil)))))

-- _sel_foldLeft(list, z) returns fun(f) => foldLeft f z list
-- lam(2): z=local0, list=local1
-- lam(1): f=local0, z=local1, list=local2
-- letrec go: go=local0, f=local1, z=local2, list=local3
-- go=lam(2): acc=local0, xs=local1; go=local2, f=local3, z=local4, list=local5
-- Cons arm (2 fields): t=local0, h=local1; acc=local2, xs=local3, go=local4, f=local5
def selFoldLeftDef =
  IrDef("_sel_foldLeft",
    IrLam(2,
      IrLam(1,
        IrLetRec(
          Cons(IrLam(2,
            IrMatch(IrLocal(1),
              Cons(IrArm("Nil", 0, IrLocal(0)),
              Cons(IrArm("Cons", 2,
                IrApp(IrLocal(4),
                  Cons(IrLocal(0),
                  Cons(IrApp(IrLocal(5),
                    Cons(IrLocal(2), Cons(IrLocal(1), Nil))),
                  Nil)))),
              Nil)), None)),
          Nil),
          IrApp(IrLocal(0), Cons(IrLocal(3), Cons(IrLocal(2), Nil)))))))

-- __list_head(xs): Cons(t,h) => h (fast list path). K62.28: `.head` is ambiguous with no type
-- info — a Cons list's first element OR a case-class field literally named `head` (busi Ref(name,
-- head)). The default delegates to the runtime __method__, which returns the head element for a
-- list, resolves a `head`-named field on a DataV via the field-name registry, and errors cleanly
-- on Nil (was `match: no arm`). — Cons arm: t=local0, h=local1
def listHeadDef =
  IrDef("__list_head",
    IrLam(1,
      IrMatch(IrLocal(0),
        Cons(IrArm("Cons", 2, IrLocal(1)), Nil),
        Some(IrPrim("__method__",
          Cons(IrLit(IrStr("head")), Cons(IrLocal(0), Nil)))))))

-- __list_tail(xs): Cons(t,h) => t (fast list path); default delegates to __method__ for a
-- `tail`-named field / clean errors, symmetric with __list_head (K62.28). Cons arm: t=local0
def listTailDef =
  IrDef("__list_tail",
    IrLam(1,
      IrMatch(IrLocal(0),
        Cons(IrArm("Cons", 2, IrLocal(0)), Nil),
        Some(IrPrim("__method__",
          Cons(IrLit(IrStr("tail")), Cons(IrLocal(0), Nil)))))))

-- __list_isEmpty(xs): true if Nil OR None; otherwise delegate to the runtime __method__
-- isEmpty (K62.27) so MapV/StrV/ArrayBuffer answer correctly (was a flat `false`, so
-- Map.empty.isEmpty / "".isEmpty were wrong). .isEmpty lowers here for List AND Option AND
-- everything else (no type info at lowering time); Nil/None (K62.21) stay a fast literal.
def listIsEmptyDef =
  IrDef("__list_isEmpty",
    IrLam(1,
      IrMatch(IrLocal(0),
        Cons(IrArm("Nil", 0, IrLit(IrBool(true))),
        Cons(IrArm("None", 0, IrLit(IrBool(true))), Nil)),
        Some(IrPrim("__method__",
          Cons(IrLit(IrStr("isEmpty")), Cons(IrLocal(0), Nil)))))))

-- __list_nonEmpty(xs): false if Nil OR None; otherwise NOT(isEmpty) via the runtime isEmpty
-- op (MapV has no nonEmpty handler, but every collection answers isEmpty). K62.27.
def listNonEmptyDef =
  IrDef("__list_nonEmpty",
    IrLam(1,
      IrMatch(IrLocal(0),
        Cons(IrArm("Nil", 0, IrLit(IrBool(false))),
        Cons(IrArm("None", 0, IrLit(IrBool(false))), Nil)),
        Some(IrIf(IrPrim("__method__",
          Cons(IrLit(IrStr("isEmpty")), Cons(IrLocal(0), Nil))),
          IrLit(IrBool(false)), IrLit(IrBool(true)))))))

-- __str_toInt(s): parse s as integer, default 0 on failure
def strToIntDef =
  IrDef("__str_toInt",
    IrLam(1,
      IrMatch(IrPrim("str->i", Cons(IrLocal(0), Nil)),
        Cons(IrArm("Some", 1, IrLocal(0)), Nil),
        Some(IrLit(IrInt(0))))))

-- ── KC7: match lowering + case class ────────────────────────────────────────

-- Build [IrLocal(n-1), IrLocal(n-2), ..., IrLocal(0)] for IrCtor arg list
-- Called with (0, n, Nil): i counts up, each prepend builds descending list
def buildCtorArgs = (i, n, acc) =>
  if #i.eq(i, n) then acc
  else buildCtorArgs(#i.add(i, 1), n, Cons(IrLocal(i), acc))

-- Lower a match expression to IrLet(scrutinee) + IrMatch(local0, arms, default)
-- letScope: __scr__ = local0; outer vars shift by 1
-- armScope: revL(patVars) ++ letScope  (arity fields shift letScope by arity)
-- vpat default: Cons(varName, outerScope)  (var = local0 = scrutinee)
-- wpat default: lowerE(letScope, body)
-- K62.10: nested constructor patterns. cpat fields are sub-pattern nodes
-- (vpat/wpat/cpat/lpat). A field binds a local; a nested cpat field is matched by an
-- inner IrMatch on that local. lpat (literal) sub-fields bind a fresh temp and are NOT
-- checked (ssc0 IrMatch has no per-arm guards / same-tag arms; graceful — no crash).
def npTemp = (i) => #sconcat("__np", #i->str(i))

def fldBinder = (fld, idx) =>
  match fld { case Pair(ftag, fdata) =>
    if #seq(ftag, "vpat") then fdata
    else if #seq(ftag, "wpat") then "_"
    else if #seq(ftag, "tpat") then
      match fdata { case Pair(basePat, typeHead) => fldBinder(basePat, idx) }
    else npTemp(idx) }

def fldBinders = (fields) =>
  let rec go = (fs, idx) =>
    match fs {
      case Nil => Nil
      case Cons(f, rest) => Cons(fldBinder(f, idx), go(rest, #i.add(idx, 1)))
    } in
  go(fields, 0)

-- obligations Pair(localPos, cpat) for each NESTED field (field i at local n-1-i).
def fldObligations = (fields, n) =>
  let rec go = (fs, idx) =>
    match fs {
      case Nil => Nil
      case Cons(f, rest) =>
        match f { case Pair(ftag, fdata) =>
          if #seq(ftag, "cpat") then
            Cons(Pair(#i.sub(#i.sub(n, 1), idx), f), go(rest, #i.add(idx, 1)))
          else go(rest, #i.add(idx, 1))
        }
    } in
  go(fields, 0)

-- Ordered field refinements additionally retain literal equality and typed
-- nominal checks. Unlike a nested constructor they add no locals: the field's
-- existing arm local is tested in place, and a typed vpat is already exposed by
-- fldBinder at that position.
def fldRefinedObligations = (fields, n) =>
  let rec go = (fs, idx) =>
    match fs {
      case Nil => Nil
      case Cons(f, rest) =>
        match f { case Pair(ftag, fdata) =>
          if #seq(ftag, "cpat") then
            Cons(Pair(#i.sub(#i.sub(n, 1), idx), f), go(rest, #i.add(idx, 1)))
          else if #seq(ftag, "lpat") then
            Cons(Pair(#i.sub(#i.sub(n, 1), idx), f), go(rest, #i.add(idx, 1)))
          else if #seq(ftag, "tpat") then
            Cons(Pair(#i.sub(#i.sub(n, 1), idx), f), go(rest, #i.add(idx, 1)))
          else go(rest, #i.add(idx, 1))
        }
    } in
  go(fields, 0)

def shiftObs = (obs, d) =>
  match obs {
    case Nil => Nil
    case Cons(ob, rest) =>
      match ob { case Pair(pos, sp) => Cons(Pair(#i.add(pos, d), sp), shiftObs(rest, d)) }
  }

-- A source-level 2-tuple is Pair/2 when emitted by the self-hosted lowerer, but
-- collection/provider values inherited from the JVM boundary use Tuple2/2.
-- Expand only source tuple patterns here; the CoreIR matcher must keep arbitrary
-- constructor tags exact because Pair is also an internal bootstrap ADT.
def ctorPatternArms = (ctorName, arity, body) =>
  if #seq(ctorName, "Pair") then
    if #i.eq(arity, 2) then
      Cons(IrArm("Pair", 2, body), Cons(IrArm("Tuple2", 2, body), Nil))
    else Cons(IrArm(ctorName, arity, body), Nil)
  else Cons(IrArm(ctorName, arity, body), Nil)

-- Discharge nested-match obligations left-to-right (each inner match prepends its
-- sub-binders to the scope and shifts the remaining obligations), then lower the body.
def dischargeObs = (obs, scope, body) =>
  match obs {
    case Nil => lowerE(scope, body)
    case Cons(ob, rest) =>
      match ob { case Pair(pos, sp) =>
        match sp { case Pair(sptag, spdata) =>
          match spdata { case Pair(subctor, subs) =>
            let m = lenL(subs) in
            let innerScope = appendL(revL(fldBinders(subs)), scope) in
            let subObs = fldObligations(subs, m) in
            let restShifted = shiftObs(rest, m) in
            IrMatch(IrLocal(pos),
              ctorPatternArms(subctor, m,
                dischargeObs(appendL(subObs, restShifted), innerScope, body)),
              None)
          } }
      }
  }

-- Ordered nested-pattern lowering. `successScope` exposes binders from the
-- current source arm; `failureScope` has dummy binders at the same depths so a
-- failed nested tag cannot leak names while outer locals keep their indices.
-- `scrutPos` points at the once-evaluated original scrutinee in both scopes.
def dischargeObsOr = (obs, successScope, failureScope, scrutPos, body, fallbackArms) =>
  match obs {
    case Nil => lowerE(successScope, body)
    case Cons(ob, rest) =>
      match ob { case Pair(pos, sp) =>
        match sp { case Pair(sptag, spdata) =>
          if #seq(sptag, "cpat") then
            match spdata { case Pair(subctor, subs) =>
              let m = lenL(subs) in
              let innerSuccess = appendL(revL(fldBinders(subs)), successScope) in
              let innerFailure = appendL(revL(guardDummyBinders(subs)), failureScope) in
              let subObs = fldRefinedObligations(subs, m) in
              let restShifted = shiftObs(rest, m) in
              let successBody = dischargeObsOr(
                appendL(subObs, restShifted), innerSuccess, innerFailure,
                #i.add(scrutPos, m), body, fallbackArms) in
              let failureBody = lowerOrderedGuardArms(failureScope, scrutPos, fallbackArms) in
              IrMatch(IrLocal(pos), ctorPatternArms(subctor, m, successBody), Some(failureBody))
            }
          else if #seq(sptag, "lpat") then
            match spdata { case Pair(ty, v) =>
              IrIf(IrPrim("__eq__", Cons(IrLocal(pos), Cons(litPatIr(ty, v), Nil))),
                dischargeObsOr(rest, successScope, failureScope, scrutPos, body, fallbackArms),
                lowerOrderedGuardArms(failureScope, scrutPos, fallbackArms))
            }
          else if #seq(sptag, "tpat") then
            match spdata { case Pair(basePat, typeHead) =>
              IrIf(typedTagTest(IrLocal(pos), typeHead),
                dischargeObsOr(rest, successScope, failureScope, scrutPos, body, fallbackArms),
                lowerOrderedGuardArms(failureScope, scrutPos, fallbackArms))
            }
          else dischargeObsOr(rest, successScope, failureScope, scrutPos, body, fallbackArms)
        }
      }
  }

-- K62.26: like dischargeObsOr, but checks a GUARD once ALL nested obligations are
-- discharged (all binders in scope). guard-false falls through to fallbackArms exactly
-- like a nested-pattern mismatch (lowerOrderedGuardArms on failureScope at the current
-- scrutPos — the dummy-binder padding keeps IrLocal(scrutPos) on the original scrutinee).
-- For a FLAT pattern obs=Nil immediately → IrIf(guard, body, fallback), identical to the
-- old flat gpat/cpat lowering (backward compatible).
def dischargeObsOrGuard = (obs, successScope, failureScope, scrutPos, guard, body, fallbackArms) =>
  match obs {
    case Nil =>
      IrIf(lowerE(successScope, guard),
        lowerE(successScope, body),
        lowerOrderedGuardArms(failureScope, scrutPos, fallbackArms))
    case Cons(ob, rest) =>
      match ob { case Pair(pos, sp) =>
        match sp { case Pair(sptag, spdata) =>
          if #seq(sptag, "cpat") then
            match spdata { case Pair(subctor, subs) =>
              let m = lenL(subs) in
              let innerSuccess = appendL(revL(fldBinders(subs)), successScope) in
              let innerFailure = appendL(revL(guardDummyBinders(subs)), failureScope) in
              let subObs = fldRefinedObligations(subs, m) in
              let restShifted = shiftObs(rest, m) in
              let successBody = dischargeObsOrGuard(
                appendL(subObs, restShifted), innerSuccess, innerFailure,
                #i.add(scrutPos, m), guard, body, fallbackArms) in
              let failureBody = lowerOrderedGuardArms(failureScope, scrutPos, fallbackArms) in
              IrMatch(IrLocal(pos), ctorPatternArms(subctor, m, successBody), Some(failureBody))
            }
          else if #seq(sptag, "lpat") then
            match spdata { case Pair(ty, v) =>
              IrIf(IrPrim("__eq__", Cons(IrLocal(pos), Cons(litPatIr(ty, v), Nil))),
                dischargeObsOrGuard(rest, successScope, failureScope, scrutPos,
                  guard, body, fallbackArms),
                lowerOrderedGuardArms(failureScope, scrutPos, fallbackArms))
            }
          else if #seq(sptag, "tpat") then
            match spdata { case Pair(basePat, typeHead) =>
              IrIf(typedTagTest(IrLocal(pos), typeHead),
                dischargeObsOrGuard(rest, successScope, failureScope, scrutPos,
                  guard, body, fallbackArms),
                lowerOrderedGuardArms(failureScope, scrutPos, fallbackArms))
            }
          else dischargeObsOrGuard(rest, successScope, failureScope, scrutPos,
            guard, body, fallbackArms)
        }
      }
  }

-- K62.14: LITERAL patterns (`case 0` / `case 'x'` [char = int code] / `case "s"` /
-- `case true`) are EQUALITY tests, not catch-all binders. The front emits ("lpat",
-- Pair(ty, v)); before this the lower dropped them into the vpat/wpat default arm, so
-- `case 0 => a; case _ => b` always took the last default (b). hasLpat detects a literal
-- match; lowerLitArms builds an IrIf fallthrough (structural __eq__ vs each literal, a
-- vpat/wpat terminates the chain). Ctor arms in a literal match (type-invalid, but kept
-- safe) become a one-arm IrMatch with the rest as its default.
def hasLpat = (arms) =>
  match arms {
    case Nil => false
    case Cons(arm, rest) =>
      match arm { case Pair(pat, body) =>
        match pat { case Pair(ptag, pdata) =>
          if #seq(ptag, "lpat") then true else hasLpat(rest) } }
  }

def litPatIr = (ty, v) =>
  if #seq(ty, "int") then IrLit(IrInt(parseI(v)))
  else if #seq(ty, "str") then IrLit(IrStr(v))
  else if #seq(ty, "bool") then IrLit(IrBool(if #seq(v, "true") then true else false))
  else match #str->f(v) { case Some(d) => IrLit(IrFloat(d)) case None => IrLit(IrFloat(0.0)) }

def lowerLitArms = (scope, letScope, arms) =>
  match arms {
    case Nil => IrLit(IrUnit)
    case Cons(arm, rest) =>
      match arm { case Pair(pat, body) =>
        match pat { case Pair(ptag, pdata) =>
          if #seq(ptag, "lpat") then
            match pdata { case Pair(ty, v) =>
              IrIf(IrPrim("__eq__", Cons(IrLocal(0), Cons(litPatIr(ty, v), Nil))),
                   lowerE(letScope, body),
                   lowerLitArms(scope, letScope, rest)) }
          else if #seq(ptag, "vpat") then
            lowerE(Cons(pdata, scope), body)
          else if #seq(ptag, "cpat") then
            match pdata { case Pair(ctorName, fields) =>
              let armScope = appendL(revL(fldBinders(fields)), letScope) in
              let armBody = dischargeObs(fldObligations(fields, lenL(fields)), armScope, body) in
              IrMatch(IrLocal(0), ctorPatternArms(ctorName, lenL(fields), armBody),
                      Some(lowerLitArms(scope, letScope, rest))) }
          else lowerE(letScope, body) } }
  }

def hasGuardPat = (arms) =>
  match arms {
    case Nil => false
    case Cons(arm, rest) =>
      match arm { case Pair(pat, body) =>
        match pat { case Pair(ptag, pdata) =>
          if #seq(ptag, "gpat") then true else hasGuardPat(rest) } }
  }

def hasTypedPat = (arms) =>
  match arms {
    case Nil => false
    case Cons(arm, rest) =>
      match arm { case Pair(pat, body) =>
        match pat { case Pair(ptag, pdata) =>
          if #seq(ptag, "tpat") then true
          else if #seq(ptag, "gpat") then
            match pdata { case Pair(basePat, guard) =>
              match basePat { case Pair(btag, bdata) =>
                if #seq(btag, "tpat") then true else hasTypedPat(rest) } }
          else hasTypedPat(rest) } }
  }

-- All child tags of a nominal supertype: case classes that `extends` it
-- (subtypeRegCell) plus, if it is an enum, every case name (enumCasesCell). An
-- empty result ⇒ `typeHead` is a leaf tag, so the ascription stays an exact test.
def subtypeChildren = (parent) =>
  let rec goReg = (xs) =>
    match xs {
      case Nil => Nil
      case Cons(e, t) =>
        match e { case Pair(p, child) =>
          if #seq(p, parent) then Cons(child, goReg(t)) else goReg(t) }
    } in
  let rec goEnum = (cs) =>
    match cs {
      case Nil => Nil
      case Cons(c, t) => match c { case Pair(cn, params) => Cons(cn, goEnum(t)) }
    } in
  append(goReg(#cell.get(subtypeRegCell)), goEnum(enumCasesOf(parent)))

def isTagExact = (scrut, tag) =>
  IrPrim("__isTag__",
    Cons(scrut, Cons(IrLit(IrStr(tag)), Cons(IrLit(IrInt(#i.sub(0, 1))), Nil))))

-- OR of exact tag tests over the child tags — mirrors the scalameta bridge's
-- `_: Circle | _: Square` expansion (identical to how `||` lowers). `scrut` is a
-- simple IrLocal at every call site, so repeating it is safe.
def orTagTests = (scrut, tags) =>
  match tags {
    case Nil => IrLit(IrBool(false))
    case Cons(tag, rest) =>
      match rest {
        case Nil => isTagExact(scrut, tag)
        case Cons(h, t) =>
          IrIf(isTagExact(scrut, tag), IrLit(IrBool(true)), orTagTests(scrut, rest))
      }
  }

-- A typed binder retains only its portable outer nominal ADT tag. Constructor
-- arity is intentionally unconstrained: type arguments and field layout are
-- erased, while the nominal tag remains observable on every target. A SUPERTYPE
-- (sealed trait / enum) expands to an OR over its child tags, because the VM's
-- __isTag__ is an EXACT tag test with no subtype resolution.
def typedTagTest = (scrut, typeHead) =>
  let subs = subtypeChildren(typeHead) in
  match subs {
    case Nil => isTagExact(scrut, typeHead)
    case Cons(h, t) => orTagTests(scrut, subs)
  }

def fieldsHaveNestedPat = (fields) =>
  match fields {
    case Nil => false
    case Cons(field, rest) =>
      match field { case Pair(ftag, fdata) =>
        if #seq(ftag, "cpat") then true
        else if #seq(ftag, "lpat") then true
        else if #seq(ftag, "tpat") then true
        else fieldsHaveNestedPat(rest) }
  }

def hasNestedPat = (arms) =>
  match arms {
    case Nil => false
    case Cons(arm, rest) =>
      match arm { case Pair(pat, body) =>
        match pat { case Pair(ptag, pdata) =>
          if #seq(ptag, "cpat") then
            match pdata { case Pair(ctorName, fields) =>
              if fieldsHaveNestedPat(fields) then true else hasNestedPat(rest) }
          else hasNestedPat(rest)
        }
      }
  }

def hasBindPat = (arms) =>
  match arms {
    case Nil => false
    case Cons(arm, rest) =>
      match arm { case Pair(pat, body) =>
        match pat { case Pair(ptag, pdata) =>
          if #seq(ptag, "bpat") then true else hasBindPat(rest)
        }
      }
  }

def guardDummyBinders = (fields) =>
  match fields {
    case Nil => Nil
    case Cons(field, rest) => Cons("__guard_field__", guardDummyBinders(rest))
  }

-- Ordered arm lowering used when binder/wildcard guards are present. `scope`
-- contains the once-evaluated scrutinee at `scrutPos`; constructor fall-through
-- reuses that local instead of evaluating the source expression again.
def lowerOrderedGuardArms = (scope, scrutPos, arms) =>
  match arms {
    case Nil => IrLit(IrUnit)
    case Cons(arm, rest) =>
      match arm { case Pair(pat, body) =>
        match pat { case Pair(ptag, pdata) =>
          if #seq(ptag, "gpat") then
            match pdata { case Pair(basePat, guard) =>
              match basePat { case Pair(btag, bdata) =>
                if #seq(btag, "vpat") then
                  let boundScope = Cons(bdata, scope) in
                  let fallbackScope = Cons("__guard_scrut__", scope) in
                  IrLet(Cons(IrLocal(scrutPos), Nil),
                    IrIf(lowerE(boundScope, guard), lowerE(boundScope, body),
                      lowerOrderedGuardArms(fallbackScope, #i.add(scrutPos, 1), rest)))
                else if #seq(btag, "cpat") then
                  match bdata { case Pair(ctorName, fields) =>
                    let arity = lenL(fields) in
                    let armScope = appendL(revL(fldBinders(fields)), scope) in
                    let failedScope = appendL(revL(guardDummyBinders(fields)), scope) in
                    -- Discharge nested/literal/typed field obligations before the guard so
                    -- every binder is in scope and every refinement wins before side effects.
                    let armBody = dischargeObsOrGuard(
                      fldRefinedObligations(fields, arity), armScope, failedScope,
                      #i.add(scrutPos, arity), guard, body, rest) in
                    IrMatch(IrLocal(scrutPos),
                      ctorPatternArms(ctorName, arity, armBody),
                      Some(lowerOrderedGuardArms(scope, scrutPos, rest)))
                  }
                else if #seq(btag, "tpat") then
                  match bdata { case Pair(basePat, typeHead) =>
                    match basePat { case Pair(tbaseTag, tbaseData) =>
                      if #seq(tbaseTag, "vpat") then
                        let boundScope = Cons(tbaseData, scope) in
                        let failedScope = Cons("__typed_scrut__", scope) in
                        let fallback = lowerOrderedGuardArms(
                          failedScope, #i.add(scrutPos, 1), rest) in
                        IrLet(Cons(IrLocal(scrutPos), Nil),
                          IrIf(typedTagTest(IrLocal(0), typeHead),
                            IrIf(lowerE(boundScope, guard), lowerE(boundScope, body), fallback),
                            fallback))
                      else
                        IrIf(typedTagTest(IrLocal(scrutPos), typeHead),
                          IrIf(lowerE(scope, guard), lowerE(scope, body),
                            lowerOrderedGuardArms(scope, scrutPos, rest)),
                          lowerOrderedGuardArms(scope, scrutPos, rest))
                    }
                  }
                else if #seq(btag, "lpat") then
                  -- `case LIT if guard =>` — test the literal AND the guard (the
                  -- old `else` applied only the guard, so any scrutinee matched).
                  match bdata { case Pair(ty, v) =>
                    IrIf(IrPrim("__eq__", Cons(IrLocal(scrutPos), Cons(litPatIr(ty, v), Nil))),
                      IrIf(lowerE(scope, guard), lowerE(scope, body),
                        lowerOrderedGuardArms(scope, scrutPos, rest)),
                      lowerOrderedGuardArms(scope, scrutPos, rest))
                  }
                else
                  IrIf(lowerE(scope, guard), lowerE(scope, body),
                    lowerOrderedGuardArms(scope, scrutPos, rest))
              }
            }
          else if #seq(ptag, "lpat") then
            match pdata { case Pair(ty, v) =>
              IrIf(IrPrim("__eq__", Cons(IrLocal(scrutPos), Cons(litPatIr(ty, v), Nil))),
                lowerE(scope, body), lowerOrderedGuardArms(scope, scrutPos, rest))
            }
          else if #seq(ptag, "vpat") then
            IrLet(Cons(IrLocal(scrutPos), Nil), lowerE(Cons(pdata, scope), body))
          else if #seq(ptag, "tpat") then
            match pdata { case Pair(basePat, typeHead) =>
              match basePat { case Pair(btag, bdata) =>
                if #seq(btag, "vpat") then
                  let boundScope = Cons(bdata, scope) in
                  let failedScope = Cons("__typed_scrut__", scope) in
                  let fallback = lowerOrderedGuardArms(
                    failedScope, #i.add(scrutPos, 1), rest) in
                  IrLet(Cons(IrLocal(scrutPos), Nil),
                    IrIf(typedTagTest(IrLocal(0), typeHead),
                      lowerE(boundScope, body), fallback))
                else
                  IrIf(typedTagTest(IrLocal(scrutPos), typeHead),
                    lowerE(scope, body), lowerOrderedGuardArms(scope, scrutPos, rest))
              }
            }
          else if #seq(ptag, "cpat") then
            match pdata { case Pair(ctorName, fields) =>
              let arity = lenL(fields) in
              let armScope = appendL(revL(fldBinders(fields)), scope) in
              let failedScope = appendL(revL(guardDummyBinders(fields)), scope) in
              let armBody = dischargeObsOr(
                fldRefinedObligations(fields, arity), armScope, failedScope,
                #i.add(scrutPos, arity), body, rest) in
              IrMatch(IrLocal(scrutPos),
                ctorPatternArms(ctorName, arity, armBody),
                Some(lowerOrderedGuardArms(scope, scrutPos, rest)))
            }
          else if #seq(ptag, "bpat") then
            match pdata { case Pair(alias, innerPat) =>
              match innerPat { case Pair(innerTag, innerData) =>
                if #seq(innerTag, "cpat") then
                  match innerData { case Pair(ctorName, fields) =>
                    let arity = lenL(fields) in
                    let fieldScope = appendL(revL(fldBinders(fields)), scope) in
                    let failedFieldScope = appendL(revL(guardDummyBinders(fields)), scope) in
                    let boundScope = Cons(alias, fieldScope) in
                    let failedBoundScope = Cons("__bind_alias__", failedFieldScope) in
                    let shiftedObs = shiftObs(fldRefinedObligations(fields, arity), 1) in
                    let armBody = IrLet(
                      Cons(IrLocal(#i.add(scrutPos, arity)), Nil),
                      dischargeObsOr(
                        shiftedObs, boundScope, failedBoundScope,
                        #i.add(#i.add(scrutPos, arity), 1), body, rest)) in
                    IrMatch(IrLocal(scrutPos),
                      ctorPatternArms(ctorName, arity, armBody),
                      Some(lowerOrderedGuardArms(scope, scrutPos, rest)))
                  }
                else lowerOrderedGuardArms(scope, scrutPos, rest)
              }
            }
          else lowerE(scope, body)
        }
      }
  }

def altPatArms = (pats, body) =>
  match pats {
    case Nil => Nil
    case Cons(pat, rest) => Cons(Pair(pat, body), altPatArms(rest, body))
  }

-- Alternation under a guard: `A | B if g => body` → each alternative keeps the
-- SAME guard (`A if g => body`, `B if g => body`). Alternatives are disjoint, so
-- distributing the guard is equivalent to Scala's guard-after-alternation.
def gAltPatArms = (alts, guard, body) =>
  match alts {
    case Nil => Nil
    case Cons(pat, rest) =>
      Cons(Pair(Pair("gpat", Pair(pat, guard)), body), gAltPatArms(rest, guard, body))
  }

def expandAltArms = (arms) =>
  match arms {
    case Nil => Nil
    case Cons(arm, rest) =>
      match arm { case Pair(pat, body) =>
        match pat { case Pair(ptag, pdata) =>
          if #seq(ptag, "apat") then
            appendL(altPatArms(pdata, body), expandAltArms(rest))
          else if #seq(ptag, "gpat") then
            match pdata { case Pair(basePat, guard) =>
              match basePat { case Pair(btag, bdata) =>
                if #seq(btag, "apat") then
                  appendL(gAltPatArms(bdata, guard, body), expandAltArms(rest))
                else Cons(arm, expandAltArms(rest)) } }
          else Cons(arm, expandAltArms(rest))
        }
      }
  }

-- Handler-root qualification is intentionally a FRONTEND rule, not a runtime
-- search through arbitrary Let/nested matches. The parser represents every
-- partial-function literal as `lam([p], match(var(p), arms))`; these helpers
-- preserve that exact provenance while ordinary invocation keeps ordinary PF
-- semantics (selected is a no-op and miss is the normal exhaustive-match error
-- without an active handler probe).
def isVarNamed = (expr, name) =>
  match expr {
    case Pair(tag, data) => if #seq(tag, "var") then #seq(data, name) else false
  }

def hasAltPat = (arms) =>
  match arms {
    case Nil => false
    case Cons(arm, rest) =>
      match arm { case Pair(pat, body) =>
        match pat { case Pair(ptag, pdata) =>
          if #seq(ptag, "apat") then true
          else if #seq(ptag, "gpat") then
            match pdata { case Pair(basePat, guard) =>
              match basePat { case Pair(btag, bdata) =>
                if #seq(btag, "apat") then true else hasAltPat(rest) } }
          else hasAltPat(rest) } }
  }

def hasNamedCatchAll = (arms) =>
  match arms {
    case Nil => false
    case Cons(arm, rest) =>
      match arm { case Pair(pat, body) =>
        match pat { case Pair(ptag, pdata) =>
          if #seq(ptag, "vpat") then
            if #seq(pdata, "_") then hasNamedCatchAll(rest) else true
          else hasNamedCatchAll(rest) } }
  }

def stringMember = (needle, values) =>
  match values {
    case Nil => false
    case Cons(value, rest) =>
      if #seq(needle, value) then true else stringMember(needle, rest)
  }

def hasDuplicateCtorPat = (arms) =>
  let rec go = (remaining, seen) =>
    match remaining {
      case Nil => false
      case Cons(arm, rest) =>
        match arm { case Pair(pat, body) =>
          match pat { case Pair(ptag, pdata) =>
            if #seq(ptag, "cpat") then
              match pdata { case Pair(ctorName, fields) =>
                if stringMember(ctorName, seen) then true
                else go(rest, Cons(ctorName, seen)) }
            else go(rest, seen) } }
    } in
  go(arms, Nil)

def handlerSelectedExpr = (eventName) =>
  Pair("prim", Pair("__handler_dispatch_selected__",
    Cons(Pair("var", eventName), Nil)))

def handlerMissExpr = (eventName) =>
  Pair("prim", Pair("__handler_dispatch_miss__",
    Cons(Pair("var", eventName), Nil)))

def handlerSelectedBody = (eventName, body) =>
  Pair("block",
    Cons(Pair("expr", handlerSelectedExpr(eventName)),
      Cons(Pair("expr", body), Nil)))

def markHandlerBodies = (eventName, arms) =>
  match arms {
    case Nil => Nil
    case Cons(arm, rest) =>
      match arm { case Pair(pat, body) =>
        Cons(Pair(pat, handlerSelectedBody(eventName, body)),
          markHandlerBodies(eventName, rest)) }
  }

def handlerMarkedArms = (eventName, arms) =>
  let fallback = Pair(
    Pair("vpat", "__handler_dispatch_fallback__"),
    handlerMissExpr(eventName)) in
  appendL(markHandlerBodies(eventName, arms), Cons(fallback, Nil))

-- Direct simple-constructor lowering deliberately omits lowerMatch's synthetic
-- once-evaluated scrutinee Let: the lambda parameter already IS Local(0).
-- Pattern fields extend the runtime environment directly, so their body scope
-- is fields ++ the original lambda scope (no phantom scrutinee binder).
def lowerDirectHandlerMatch = (scope, arms) =>
  let rec procArms = (armsLeft, irAcc, defAcc) =>
    match armsLeft {
      case Nil => Pair(irAcc, defAcc)
      case Cons(arm, rest) =>
        match arm { case Pair(pat, body) =>
          match pat { case Pair(ptag, pdata) =>
            if #seq(ptag, "cpat") then
              match pdata { case Pair(ctorName, fields) =>
                let armScope = appendL(revL(fldBinders(fields)), scope) in
                let armBody = dischargeObs(
                  fldObligations(fields, lenL(fields)), armScope, body) in
                procArms(rest,
                  appendL(irAcc, ctorPatternArms(ctorName, lenL(fields), armBody)),
                  defAcc) }
            else if #seq(ptag, "vpat") then
              procArms(rest, irAcc, Some(lowerE(scope, body)))
            else procArms(rest, irAcc, Some(lowerE(scope, body))) } }
    } in
  match procArms(arms, Nil, None) {
    case Pair(irArms, defOpt) => IrMatch(IrLocal(0), irArms, defOpt)
  }

def lowerHandlerMatch = (scope, eventName, arms) =>
  let flatArms = expandAltArms(arms) in
  let general =
    if hasBindPat(flatArms) then true
    else if hasGuardPat(flatArms) then true
    else if hasTypedPat(flatArms) then true
    else if hasNestedPat(flatArms) then true
    else if hasLpat(flatArms) then true
    else if hasAltPat(arms) then true
    else if hasNamedCatchAll(flatArms) then true
    else hasDuplicateCtorPat(flatArms) in
  if general then
    lowerMatch(scope, Pair("var", eventName), handlerMarkedArms(eventName, arms))
  else lowerDirectHandlerMatch(scope, flatArms)

def lowerMatch = (scope, scrutinee, arms) =>
  let eIr = lowerE(scope, scrutinee) in
  let letScope = Cons("__scr__", scope) in
  let flatArms = expandAltArms(arms) in
  if hasBindPat(flatArms) then
    IrLet(Cons(eIr, Nil), lowerOrderedGuardArms(letScope, 0, flatArms))
  else if hasGuardPat(flatArms) then
    IrLet(Cons(eIr, Nil), lowerOrderedGuardArms(letScope, 0, flatArms))
  else if hasTypedPat(flatArms) then
    IrLet(Cons(eIr, Nil), lowerOrderedGuardArms(letScope, 0, flatArms))
  else if hasNestedPat(flatArms) then
    IrLet(Cons(eIr, Nil), lowerOrderedGuardArms(letScope, 0, flatArms))
  else if hasLpat(flatArms) then
    IrLet(Cons(eIr, Nil), lowerLitArms(scope, letScope, flatArms))
  else
  let rec procArms = (armsLeft, irAcc, defAcc) =>
    match armsLeft {
      case Nil => Pair(irAcc, defAcc)
      case Cons(arm, rest) =>
        match arm {
          case Pair(pat, body) =>
            match pat {
              case Pair(ptag, pdata) =>
                if #seq(ptag, "cpat") then
                  match pdata {
                    case Pair(ctorName, fields) =>
                      let armScope = appendL(revL(fldBinders(fields)), letScope) in
                      let armBody = dischargeObs(fldObligations(fields, lenL(fields)), armScope, body) in
                      let irArms = ctorPatternArms(ctorName, lenL(fields), armBody) in
                      procArms(rest, appendL(irAcc, irArms), defAcc)
                  }
                else if #seq(ptag, "vpat") then
                  let defScope = Cons(pdata, scope) in
                  procArms(rest, irAcc, Some(lowerE(defScope, body)))
                else
                  procArms(rest, irAcc, Some(lowerE(letScope, body)))
            }
        }
    } in
  let result = procArms(flatArms, Nil, None) in
  match result {
    case Pair(irArms, defOpt) =>
      match irArms {
        case Nil =>
          -- No ctor arms: skip IrMatch (would crash on non-Data scrutinee).
          -- vpat/wpat defaults already embed lowerE(...) directly.
          match defOpt {
            case Some(defBody) => IrLet(Cons(eIr, Nil), defBody)
            case None => eIr
          }
        case _ =>
          IrLet(Cons(eIr, Nil), IrMatch(IrLocal(0), irArms, defOpt))
      }
  }

-- Generate IrDef list for a case class: constructor def + field accessor defs
-- Constructor: IrDef(name, IrLam(n, IrCtor(name, [IrLocal(n-1)..IrLocal(0)])))
-- Accessor _sel_f: IrLam(1, IrMatch(IrLocal(0), [IrArm(name,n,IrLocal(fieldIdx))], None))
-- In IrArm(name, n, body): last field = local0, first field = local(n-1)
-- Body-declared var/lazy fields (classBodyFieldsCell = [Pair(tag,[Pair(nm,Pair(init,kind))])]).
def classBodyFields = (tag) =>
  let rec go = (rs) =>
    match rs {
      case Nil => Nil
      case Cons(r, rest) => match r { case Pair(t, bf) => if #seq(t, tag) then bf else go(rest) }
    } in
  go(#cell.get(classBodyFieldsCell))
def bodyFieldNames = (bfs) =>
  match bfs {
    case Nil => Nil
    case Cons(bf, rest) => match bf { case Pair(nm, ik) => Cons(nm, bodyFieldNames(rest)) }
  }
-- Names of lazy body fields of a class (for memoized access routing).
def classLazyFields = (tag) =>
  let rec go = (bfs) =>
    match bfs {
      case Nil => Nil
      case Cons(bf, rest) =>
        match bf { case Pair(nm, ik) => match ik { case Pair(init, kind) =>
          if #seq(kind, "lazy") then Cons(nm, go(rest)) else go(rest) } }
    } in
  go(classBodyFields(tag))
def isAnyLazyField = (name) =>
  let rec go = (rs) =>
    match rs {
      case Nil => false
      case Cons(r, rest) => match r { case Pair(t, bf) =>
        if memberOfL(name, classLazyFields(t)) then true else go(rest) }
    } in
  go(#cell.get(classBodyFieldsCell))
def isCurrentLazyField = (name) =>
  match #cell.get(caseSelfCtxCell) {
    case Nil => false
    case Pair(tag, sibs) => memberOfL(name, classLazyFields(tag))
  }
def mapLookupVar = (scope, names) =>
  match names {
    case Nil => Nil
    case Cons(nm, rest) => Cons(lookupVar(scope, nm), mapLookupVar(scope, rest))
  }
-- Build the constructor body: bind each body field (in decl order, seeing ctor
-- params + earlier fields) then IrCtor with all fields. A `var` field is a cell; a
-- `lazy` field is a cell holding a `__lazyThunk__(() => init)` (forced+memoized on access).
def synthCtorBody = (name, allFields, bodyFields, scope) =>
  match bodyFields {
    case Nil => IrCtor(name, mapLookupVar(scope, allFields))
    case Cons(bf, rest) =>
      match bf { case Pair(fname, ik) =>
        match ik { case Pair(init, kind) =>
          let initIR = lowerE(scope, init) in
          let wrapped =
            if #seq(kind, "var") then IrPrim("cell.new", Cons(initIR, Nil))
            else if #seq(kind, "lazy") then
              IrPrim("cell.new", Cons(IrCtor("__lazyThunk__", Cons(IrLam(0, initIR), Nil)), Nil))
            else initIR in
          IrLet(Cons(wrapped, Nil), synthCtorBody(name, allFields, rest, Cons(fname, scope)))
        }
      }
  }
def lowerCaseCls = (name, params) =>
  let n = lenL(params) in
  -- K62.15: emit ONLY the constructor def here. The `_sel_<field>` accessors are generated
  -- ONCE per unique field name (merged across every ctor that shares it) in
  -- buildMergedAccessors, so two case classes with a common field (`Person(name,…)` +
  -- `Student(name,…)`) no longer overwrite each other's accessor → `.name` works on both.
  match classBodyFields(name) {
    case Nil =>
      let ctorArgs = buildCtorArgs(0, n, Nil) in
      Cons(IrDef(name, IrLam(n, IrCtor(name, ctorArgs))), Nil)
    case Cons(bfh, bft) =>
      -- Body var/lazy fields: synthesize a constructor that computes them.
      let bodyFields = Cons(bfh, bft) in
      let allFields = append(params, bodyFieldNames(bodyFields)) in
      Cons(IrDef(name, IrLam(n, synthCtorBody(name, allFields, bodyFields, revL(params)))), Nil)
  }

def derivedValueNames = (typeName, derives) =>
  match derives {
    case Nil => Nil
    case Cons(tc, rest) =>
      Cons(derivedDefName(tc, typeName), derivedValueNames(typeName, rest))
  }

def lowerProductMetadata = (typeName, fieldNames, fieldTypes, derives) =>
  let mirror = IrCtor("Mirror",
    Cons(IrLit(IrStr(typeName)),
      Cons(strListIr(fieldNames), Cons(strListIr(fieldTypes), Nil)))) in
  Cons(IrDef(mirrorDefName(typeName), mirror), Nil)

-- Derived dictionaries are top-level immutable values, initialized in source
-- order after preceding vars/vals and cached in the same cell-backed ABI. This
-- prevents an eager IrDef from running TC.derived before earlier initializers.
def derivedInitIrs = (typeName, derives) =>
  match derives {
    case Nil => Nil
    case Cons(tc, rest) =>
      let name = derivedDefName(tc, typeName) in
      let value = IrApp(IrGlobal(#sconcat(tc, "_derived")),
        Cons(IrGlobal(mirrorDefName(typeName)), Nil)) in
      Cons(IrPrim("cell.set",
        Cons(IrGlobal(#sconcat(name, "__cell")), Cons(value, Nil))),
        derivedInitIrs(typeName, rest))
  }

-- K62.13: lower an `enum` decl into constructor defs. A nullary case is a VALUE
-- (IrDef name = IrCtor name []) so a bare reference (`North`) → IrGlobal → the ctor
-- value (correct for `case North =>` matches). A parametrized case reuses lowerCaseCls
-- (ctor function + `_sel_<field>` accessors), identical to a case class.
def lowerEnum = (name, cases) =>
  match cases {
    case Nil => Nil
    case Cons(c, rest) =>
      match c {
        case Pair(cname, params) =>
          let defs = match params {
            case Nil => Cons(IrDef(cname, IrCtor(cname, Nil)), Nil)
            case Cons(h, t) => lowerCaseCls(cname, params)
          } in
          append(defs, lowerEnum(name, rest))
      }
  }

-- ── KC9: block expression lowering ──────────────────────────────────────────
-- Blocks: { val x=e; def f(p)=b; sideEffect; result }
-- val → IrLet; def → IrLetRec (with self-reference via letrec scope); expr → IrLet discard or result

-- Names of a consecutive local-def group (each `Pair("def", Pair(name, Pair(params, body)))`).
def defGroupNames = (defs) =>
  match defs {
    case Nil => Nil
    case Cons(d, rest) =>
      match d { case Pair(dt, dd) => match dd { case Pair(name, r) => Cons(name, defGroupNames(rest)) } }
  }
-- Lower each def in the group to its IrLam under the SHARED letrecScope (so every def
-- in the group sees every other — mutual + forward references).
def defGroupLams = (defs, letrecScope) =>
  match defs {
    case Nil => Nil
    case Cons(d, rest) =>
      match d { case Pair(dt, dd) => match dd { case Pair(name, r) =>
        match r { case Pair(params, body) =>
          -- Wrap a local nested def in `__with_return__` iff it uses a non-local `return`
          -- (same save/reset/restore as top-level defs; local defs like MarkdownBlocks'
          -- `parseReferenceDefinition` reach here via the shared-IrLetRec group path).
          let prevHR = #cell.get(defHasReturnCell) in
          let _rstHR = #cell.set(defHasReturnCell, false) in
          let bodyIr = lowerE(appendL(revL(params), letrecScope), body) in
          let hadRet = #cell.get(defHasReturnCell) in
          let _rst2HR = #cell.set(defHasReturnCell, prevHR) in
          let finalBody = if hadRet then wrapReturn(bodyIr) else bodyIr in
          Cons(IrLam(lenL(params), finalBody),
               defGroupLams(rest, letrecScope)) } } }
  }

def lowerBlock = (scope, stmts) =>
  match stmts {
    case Nil => IrLit(IrUnit)
    case Cons(s, rest) =>
      match s {
        case Pair(tag, data) =>
          if #seq(tag, "val") then
            match data {
              case Pair(name, expr) =>
                -- Track array/vector variables for indexed-read lowering
                let rb = resolveE(expr) in
                -- `val m = summon[TC[A]]` (abstract given) has no value; its m.method/m.field uses were
                -- already rewritten to <instance>_<member> during resolveBlock. Drop the binding.
                match rb {
                  case Pair(rbt, rbd) =>
                    if #seq(rbt, "summon_tc") then lowerBlock(scope, rest)
                    else
                      let _reg = if isArrayConstruction(rb) then
                        #cell.set(arrVarsCell, Cons(name, #cell.get(arrVarsCell)))
                      else () in
                      IrLet(Cons(lowerE(scope, expr), Nil), lowerBlock(Cons(name, scope), rest))
                }
            }
          else if #seq(tag, "var") then
            -- KC10: mutable var x = e → cell.new(e), bound as "@x" in scope
            -- Optimization: if init is integer literal, use lcell.new (LongCellV) and "@@x" scope
            -- This avoids IntV boxing on every iteration in tight arithmetic loops.
            match data {
              case Pair(name, expr) =>
                -- Track map variables for .updated/.getOrElse dispatch
                let rb = resolveE(expr) in
                let _reg = if isMapConstruction(rb) then
                  #cell.set(mapVarsCell, Cons(name, #cell.get(mapVarsCell)))
                else () in
                if isIntLitExpr(expr) then
                  -- Integer literal init: use long cell (no IntV boxing per store)
                  let lcellExpr = IrPrim("lcell.new", Cons(lowerE(scope, expr), Nil)) in
                  IrLet(Cons(lcellExpr, Nil), lowerBlock(Cons(#sconcat("@@", name), scope), rest))
                else
                  let cellExpr = IrPrim("cell.new", Cons(lowerE(scope, expr), Nil)) in
                  IrLet(Cons(cellExpr, Nil), lowerBlock(Cons(#sconcat("@", name), scope), rest))
            }
          else if #seq(tag, "idx_assign") then
            -- a(idx) = rhs  →  arr.set(a, idx, rhs)
            match data {
              case Pair(lhs, rhs) =>
                match lhs {
                  case Pair(ltag, ldata) =>
                    match ldata {
                      case Pair(arrFn, idxArgs) =>
                        match idxArgs {
                          case Cons(idxE, idxRest) =>
                            let setE = IrPrim("arr.set",
                              Cons(lowerE(scope, arrFn),
                              Cons(lowerE(scope, idxE),
                              Cons(lowerE(scope, rhs), Nil)))) in
                            match rest {
                              case Nil => setE
                              case _ => IrSeq(Cons(setE, Cons(lowerBlock(scope, rest), Nil)))
                            }
                        }
                    }
                }
            }
          else if #seq(tag, "assign") then
            -- KC10: x = expr → cell.set(cell_ref, val)
            -- Use IrSeq instead of IrLet to avoid env-array allocation per assign.
            -- For long cell vars (@@name), use lcell.set to avoid IntV boxing per store.
            match data {
              case Pair(name, expr) =>
                let setExpr =
                  if isCurrentVarField(name) then
                    -- Mutable `var` field write inside a method body: cell.set on
                    -- `_sel_name(__self)`.
                    IrPrim("cell.set",
                      Cons(IrApp(IrGlobal(#sconcat("_sel_", name)),
                             Cons(lookupVar(scope, "__self"), Nil)),
                        Cons(lowerE(scope, expr), Nil)))
                  else
                  let llName = #sconcat("@@", name) in
                  match lookupVarOpt(scope, llName) {
                  case Some(lcellRef) =>
                    -- Long cell: use lcell.set (body evaluated as raw Long in FastCode path)
                    IrPrim("lcell.set", Cons(lcellRef, Cons(lowerE(scope, expr), Nil)))
                  case None =>
                    let cellName = #sconcat("@", name) in
                    match lookupVarOpt(scope, cellName) {
                      case Some(cellRef) =>
                        IrPrim("cell.set", Cons(cellRef, Cons(lowerE(scope, expr), Nil)))
                      case None =>
                        -- K62.6b: assignment to a top-level var → cell.set(global name__cell)
                        if isTopVar(name) then
                          IrPrim("cell.set", Cons(IrGlobal(#sconcat(name, "__cell")), Cons(lowerE(scope, expr), Nil)))
                        else if isActiveOwnerVar(name) then
                          IrPrim("cell.set", Cons(IrGlobal(#sconcat(#cell.get(kc7bOwnerPrefixCell),
                            #sconcat(name, "__cell"))), Cons(lowerE(scope, expr), Nil)))
                        else IrPrim("cell.set", Cons(lookupVar(scope, cellName), Cons(lowerE(scope, expr), Nil)))
                    }
                } in
                match rest {
                  case Nil => setExpr
                  case _ => IrSeq(Cons(setExpr, Cons(lowerBlock(scope, rest), Nil)))
                }
            }
          else if #seq(tag, "while") then
            -- KC10: while (cond) body → IrWhile(cond, body)
            -- No $go$ in scope: body uses caller's scope directly (no letrec overhead)
            match data {
              case Pair(cond, body) =>
                let condIr = lowerE(scope, cond) in
                let bodyIr = lowerE(scope, body) in
                let loopExpr = IrWhile(condIr, bodyIr) in
                match rest {
                  case Nil => loopExpr
                  case _ => IrLet(Cons(loopExpr, Nil), lowerBlock(Cons("_blk_", scope), rest))
                }
            }
          else if #seq(tag, "def") then
            -- CONSECUTIVE local defs share ONE IrLetRec so they are MUTUALLY visible
            -- (Scala local defs allow forward/mutual references). Each used to be its
            -- own single-fn letrec, so `a` calling a later `b` was `unbound global: b`.
            -- letrecScope = the group's names in reverse (runtime pushes them in order,
            -- last = Local(0)); each lam body/scope adds its params on top.
            let rec splitDefs = (ss, acc) =>
              match ss {
                case Nil => Pair(revL(acc), Nil)
                case Cons(x, xs) =>
                  match x { case Pair(xt, xd) =>
                    if #seq(xt, "def") then splitDefs(xs, Cons(x, acc))
                    else Pair(revL(acc), ss) }
              } in
            match splitDefs(Cons(s, rest), Nil) {
              case Pair(defs, remaining) =>
                let names = defGroupNames(defs) in
                let letrecScope = appendL(revL(names), scope) in
                let lams = defGroupLams(defs, letrecScope) in
                IrLetRec(lams, lowerBlock(letrecScope, remaining))
            }
          else if #seq(tag, "return") then
            -- A bare `return e` statement. As a non-local throw it exits the def even
            -- when this block is a loop/branch body (a plain value would just be the
            -- discarded body value and the loop would continue).
            let _mark = #cell.set(defHasReturnCell, true) in
            IrPrim("__throw_return__", Cons(lowerE(scope, data), Nil))
          else if #seq(tag, "expr") then
            match rest {
              case Nil =>
                -- Last item: it IS the block result
                lowerE(scope, data)
              case _ =>
                -- Check for if (cond) return e  →  IrIf(cond, e, rest_block)
                -- (ssc0 can't pattern-match string literals; use #seq guards)
                match data {
                  case Pair(dtag, ifData) =>
                    if #seq(dtag, "if") then
                      match ifData {
                        case Pair(cond, branches) =>
                          match branches {
                            case Pair(thn, els) =>
                              match thn {
                                case Pair(rtag, retVal) =>
                                  if #seq(rtag, "return") then
                                    -- `if cond then return e; rest` → when cond, throw a
                                    -- non-local return (unwinds loops correctly); else `rest`.
                                    let _mark = #cell.set(defHasReturnCell, true) in
                                    IrIf(lowerE(scope, cond),
                                      IrPrim("__throw_return__", Cons(lowerE(scope, retVal), Nil)),
                                      lowerBlock(scope, rest))
                                  else
                                    IrLet(Cons(lowerE(scope, data), Nil), lowerBlock(Cons("_blk_", scope), rest))
                              }
                          }
                      }
                    else
                      -- Side-effect: evaluate + discard
                      IrLet(Cons(lowerE(scope, data), Nil), lowerBlock(Cons("_blk_", scope), rest))
                }
            }
          else if #seq(tag, "tuppat") then
            -- val (n1, n2, …) = expr  →  evaluate expr once, then bind every
            -- component through the matching portable tuple selector. Each new
            -- binding shifts the saved tuple deeper in the de Bruijn scope, so
            -- resolve it by name instead of retaining a stale local index.
            match data {
              case Pair(names, expr) =>
                let rec bindTuple = (ns, idx, bindScope) =>
                  match ns {
                    case Nil => lowerBlock(bindScope, rest)
                    case Cons(nm, more) =>
                      IrLet(
                        Cons(IrApp(IrGlobal(#sconcat("_sel__", #i->str(idx))),
                          Cons(lookupVar(bindScope, "__tup"), Nil)), Nil),
                        bindTuple(more, #i.add(idx, 1), Cons(nm, bindScope)))
                  } in
                IrLet(Cons(lowerE(scope, expr), Nil),
                  bindTuple(names, 1, Cons("__tup", scope)))
            }
          else lowerBlock(scope, rest)
      }
  }

-- ── Statement lowering ────────────────────────────────────────────────────────

-- Lower a statement to a list of IrDef nodes (case class → multiple defs)
def lowerStmtToList = (stmt) =>
  match stmt {
    case Pair(tag, data) =>
      if #seq(tag, "def") then
        match data {
          case Pair(name, rest) =>
            match rest {
              case Pair(params, body) =>
                let scope = revL(params) in
                -- A top-level extension method that ALSO has given-body instances is emitted under
                -- `name__ext_default` so the bare `name` dispatcher can delegate to it (else it would
                -- be clobbered by the dispatcher). Given-body defs are prefixed, so never match here.
                let emitName = if extNeedsMangle(name) then #sconcat(name, "__ext_default") else name in
                -- KC5b: set active ctx for summon dispatch within this def body
                let prevCtx = #cell.get(kc5ActiveCtxCell) in
                let _setCtx = #cell.set(kc5ActiveCtxCell, computeActiveCtx(params)) in
                let _resetAlias = #cell.set(summonAliasCell, Nil) in
                let resolvedBody = resolveE(body) in
                -- Reset the return flag, lower this body, then wrap it in
                -- `__with_return__` iff a non-local `return` was emitted (save/restore so
                -- a nested def's returns don't leak; a return in a LAMBDA within this def
                -- DOES set the flag → this def catches it = correct non-local semantics).
                let prevHR = #cell.get(defHasReturnCell) in
                let _rstHR = #cell.set(defHasReturnCell, false) in
                let bodyIr = match resolvedBody {
                  case Pair(btag, bdata) =>
                    if #seq(btag, "block") then lowerBlock(scope, bdata)
                    else lowerE(scope, resolvedBody)
                } in
                let hadRet = #cell.get(defHasReturnCell) in
                let _rst2HR = #cell.set(defHasReturnCell, prevHR) in
                let finalBody = if hadRet then wrapReturn(bodyIr) else bodyIr in
                let ir = IrDef(emitName, IrLam(lenL(params), finalBody)) in
                let _restCtx = #cell.set(kc5ActiveCtxCell, prevCtx) in
                Cons(ir, Nil)
            }
        }
      else if #seq(tag, "val") then
        match data {
          case Pair(name, body) =>
            -- Track top-level array/vector globals for indexed-read lowering
            let rb = resolveE(body) in
            let _reg = if isArrayConstruction(rb) then
              #cell.set(arrVarsCell, Cons(name, #cell.get(arrVarsCell)))
            else () in
            -- The cell definition is emitted by topValCellDefs; initialization
            -- belongs to the entry so it interleaves with expression statements.
            Nil
        }
      else if #seq(tag, "given") then
        -- KC5: given emits as a regular IrDef val
        match data {
          case Pair(gname, rest2) =>
            match rest2 {
              case Pair(typeStr, body) =>
                Cons(IrDef(gname, lowerE(Nil, body)), Nil)
            }
        }
      else if #seq(tag, "casecls") then
        match data {
          case Pair(name, caseMeta) =>
            match caseMeta {
              case Pair(params, typeAndDerives) =>
                match typeAndDerives {
                  case Pair(types, derives) =>
                    appendL(lowerCaseCls(name, params),
                      lowerProductMetadata(name, params, types, derives))
                }
            }
        }
      else if #seq(tag, "caseobj") then
        Cons(IrDef(data, IrCtor(data, Nil)), Nil)
      else if #seq(tag, "enum") then
        -- K62.13: expand each enum case into ctor def(s)
        match data {
          case Pair(name, cases) => lowerEnum(name, cases)
        }
      else if #seq(tag, "object") then
        -- KC7b: object O { def f(x) = ... } → IrDef("O_f", IrLam(1, ...))
        match data {
          case Pair(name, stmts) =>
            -- register as known object for static dispatch on lowercase names
            let _reg = #cell.set(kc7bObjectsCell, Cons(name, #cell.get(kc7bObjectsCell))) in
            let prefix = #sconcat(name, "_") in
            let _ownerPrefix = #cell.set(kc7bOwnerPrefixCell, prefix) in
            let _ownerMembers = #cell.set(kc7bOwnerMembersCell, staticMemberNames(stmts)) in
            let _ownerVars = #cell.set(kc7bOwnerVarsCell, ownerVarNames(stmts)) in
            let rec prefixDefs = (ss) =>
              match ss {
                case Nil => Nil
                case Cons(s, rest) =>
                  match s {
                    case Pair(stag, sdata) =>
                      if #seq(stag, "def") then
                        match sdata {
                          case Pair(dname, drest) =>
                            match drest {
                              case Pair(dparams, dbody) =>
                                -- Match given-object semantics: a declaration
                                -- without parameters is a static property,
                                -- while a declaration with parameters remains
                                -- an owned function.
                                let pfxName = #sconcat(prefix, dname) in
                                -- Mirror `f`'s call-site default entry under `O_f` so
                                -- `O.f(a)` with omitted trailing defaults synthesizes them.
                                let _aliasDflt = aliasFuncDefault(dname, pfxName, lenL(dparams)) in
                                let lowered =
                                  if #i.eq(lenL(dparams), 0) then
                                    -- `def f` (no parens → parseDef wraps the body
                                    -- `parameterless`) is a static PROPERTY, eager. But
                                    -- `def f()` (empty parens → normal body) is a 0-arg
                                    -- METHOD that must be CALLED, not eager-eval'd — e.g.
                                    -- `WorkerProtocol.handleMessages(): Unit = receive{…}`
                                    -- must stay a fn (else `receive` runs at def time,
                                    -- outside runActors). Emit IrLam(0,…) for the latter.
                                    (match dbody { case Pair(btag, bdata) =>
                                      if #seq(btag, "parameterless") then
                                        Cons(IrDef(pfxName, lowerE(Nil, dbody)), Nil)
                                      else
                                        Cons(IrDef(pfxName, IrLam(0, lowerE(Nil, dbody))), Nil) })
                                  else
                                    let prefixed = Pair("def", Pair(pfxName, drest)) in
                                    lowerStmtToList(prefixed) in
                                appendL(lowered, prefixDefs(rest))
                            }
                        }
                      else if #seq(stag, "var") then
                        -- Mutable object member → an owner-prefixed global cell
                        -- (`Owner_name__cell`), initialized at def time. Reads/writes
                        -- inside the object's methods route here (isActiveOwnerVar).
                        match sdata {
                          case Pair(vname, vinit) =>
                            let cellDef = IrDef(#sconcat(prefix, #sconcat(vname, "__cell")),
                                            IrPrim("cell.new", Cons(lowerE(Nil, vinit), Nil))) in
                            appendL(Cons(cellDef, Nil), prefixDefs(rest))
                        }
                      else if #seq(stag, "val") then
                        -- Immutable value member → an eager owner-prefixed global
                        -- (`Owner_name`), like a `given` or a parameterless `def`
                        -- property. Fixes `Owner.name` value access (e.g.
                        -- `SourcePosition.Start`, `DialectRegistry.empty`).
                        match sdata {
                          case Pair(vname, vbody) =>
                            appendL(Cons(IrDef(#sconcat(prefix, vname), lowerE(Nil, vbody)), Nil),
                                    prefixDefs(rest))
                        }
                      -- A TYPE declaration nested in the object body (`object O: case
                      -- class Inner(…)` / `enum E: …`). v2 types are global and
                      -- tag-based, so lower it as a top-level type — the object prefix
                      -- doesn't apply to a nested type; `Inner(…)`/`.field` resolve
                      -- globally. Without this the decl was dropped → `unbound global`.
                      else if #seq(stag, "casecls") then
                        appendL(lowerStmtToList(s), prefixDefs(rest))
                      else if #seq(stag, "enum") then
                        appendL(lowerStmtToList(s), prefixDefs(rest))
                      else if #seq(stag, "caseobj") then
                        appendL(lowerStmtToList(s), prefixDefs(rest))
                      else prefixDefs(rest)
                  }
              } in
            let loweredMembers = prefixDefs(stmts) in
            let _clearOwnerPrefix = #cell.set(kc7bOwnerPrefixCell, "") in
            let _clearOwnerMembers = #cell.set(kc7bOwnerMembersCell, Nil) in
            let _clearOwnerVars = #cell.set(kc7bOwnerVarsCell, Nil) in
            loweredMembers
        }
      else if #seq(tag, "given_obj") then
        -- KC5+KC7b: given name: T with { defs } → emit prefixed defs plus the
        -- same portable method-object value used by the compatibility bridge.
        match data {
          case Pair(name, rest2) =>
            match rest2 {
              case Pair(typeStr, stmts) =>
                let _reg = #cell.set(kc7bObjectsCell, Cons(name, #cell.get(kc7bObjectsCell))) in
                let prefix = #sconcat(name, "_") in
                let _ownerPrefix = #cell.set(kc7bOwnerPrefixCell, prefix) in
                let _ownerMembers = #cell.set(kc7bOwnerMembersCell, staticMemberNames(stmts)) in
                let rec prefixDefs = (ss) =>
                  match ss {
                    case Nil => Nil
                    case Cons(s2, rest3) =>
                      match s2 {
                        case Pair(stag, sdata) =>
                          if #seq(stag, "def") then
                            match sdata {
                              case Pair(dname, drest) =>
                                match drest {
                                  case Pair(dparams, dbody) =>
                                    -- 0-param method = a value (e.g. def empty = 0); emit as val
                                    -- N-param method = a function; emit as def
                                    let pfxName = #sconcat(prefix, dname) in
                                    let lowered =
                                      if #i.eq(lenL(dparams), 0) then
                                        Cons(IrDef(pfxName, lowerE(Nil, dbody)), Nil)
                                      else
                                        let prefixed = Pair("def", Pair(pfxName, drest)) in
                                        lowerStmtToList(prefixed) in
                                    appendL(lowered, prefixDefs(rest3))
                                }
                            }
                          else prefixDefs(rest3)
                      }
                  } in
                -- Emit prefixed members for direct/summon dispatch, then a
                -- first-class dictionary for explicit arguments/value flow.
                let loweredMembers = prefixDefs(stmts) in
                let _clearOwnerPrefix = #cell.set(kc7bOwnerPrefixCell, "") in
                let _clearOwnerMembers = #cell.set(kc7bOwnerMembersCell, Nil) in
                let dictionary = IrPrim("__mk_method_obj__", staticMemberObjectArgs(prefix, stmts)) in
                appendL(loweredMembers, Cons(IrDef(name, dictionary), Nil))
            }
        }
      else if #seq(tag, "effect_decl") then
        match data {
          case Pair(name, rest2) =>
            match rest2 {
              case Pair(isMulti, stmts) =>
                let rec lowerOps = (ss) =>
                  match ss {
                    case Nil => Nil
                    case Cons(s2, more) =>
                      match s2 {
                        case Pair(stag, sdata) =>
                          if #seq(stag, "def") then
                            match sdata {
                              case Pair(opName, opRest) =>
                                match opRest {
                                  case Pair(params, ignoredBody) =>
                                    let scope = revL(params) in
                                    let rec paramExprs = (ps) =>
                                      match ps {
                                        case Nil => Nil
                                        case Cons(p, pt) => Cons(Pair("var", p), paramExprs(pt))
                                      } in
                                    let label = #sconcat(name, #sconcat(".", opName)) in
                                    let operationArgs = lowerArgs(scope, paramExprs(params)) in
                                    let body =
                                      if isMulti then
                                        IrPrim("effect.perform",
                                          Cons(IrLit(IrStr(label)), operationArgs))
                                      else
                                        IrPrim("effect.perform.oneshot",
                                          Cons(IrLit(IrStr(name)),
                                            Cons(IrLit(IrStr(opName)), operationArgs))) in
                                    Cons(IrDef(#sconcat(name, #sconcat("_", opName)),
                                      IrLam(lenL(params), body)), lowerOps(more))
                                }
                            }
                          else lowerOps(more)
                      }
                  } in
                lowerOps(stmts)
            }
        }
      else if #seq(tag, "multi_effect") then
        Nil
      else if #seq(tag, "tuppat") then
        -- Like ordinary top-level vals, tuple bindings are cell-backed and
        -- initialized once from the entry in document order.
        Nil
      else Nil
  }

-- Lower all statements to a flat list of IrDef nodes
def lowerStmts = (stmts) =>
  match stmts {
    case Nil => Nil
    case Cons(s, rest) =>
      appendL(lowerStmtToList(s), lowerStmts(rest))
  }

-- ── Built-in defs ─────────────────────────────────────────────────────────────

def printlnDef = IrDef("println", IrLam(1, IrPrim("io.println", Cons(IrLocal(0), Nil))))
def printDef   = IrDef("print",   IrLam(1, IrPrim("io.print", Cons(IrLocal(0), Nil))))
def mathDef    = IrDef("math", IrPrim("__math_obj__", Nil))

-- Exception constructors: `new RuntimeException("msg")` (== `RuntimeException("msg")`) → the value
-- DataV("RuntimeException", [msg]); `.getMessage` returns the message (Runtime methodOp). Enables
-- `throw new RuntimeException(m)` + `catch { case e: RuntimeException => e.getMessage }`.
def excCtorDef = (name) => IrDef(name, IrLam(1, IrCtor(name, Cons(IrLocal(0), Nil))))
def exceptionDefs =
  Cons(excCtorDef("RuntimeException"),
  Cons(excCtorDef("Exception"),
  Cons(excCtorDef("IllegalArgumentException"),
  Cons(excCtorDef("IllegalStateException"),
  Cons(excCtorDef("NoSuchElementException"),
  Cons(excCtorDef("UnsupportedOperationException"), Nil))))))

-- ── Tuple accessors: ._1 through ._4 ─────────────────────────────────────────
-- Pair(a,b): 2 fields, local(0)=b local(1)=a
-- Tuple4(a,b,c,d): 4 fields, local(0)=d local(1)=c local(2)=b local(3)=a
def sel1Def =
  IrDef("_sel__1",
    IrLam(1,
      IrMatch(IrLocal(0),
        Cons(IrArm("Pair",   2, IrLocal(1)),
        Cons(IrArm("Tuple2", 2, IrLocal(1)),
        Cons(IrArm("Tuple3", 3, IrLocal(2)),
        Cons(IrArm("Tuple4", 4, IrLocal(3)),
        Nil)))), None)))

def sel2Def =
  IrDef("_sel__2",
    IrLam(1,
      IrMatch(IrLocal(0),
        Cons(IrArm("Pair",   2, IrLocal(0)),
        Cons(IrArm("Tuple2", 2, IrLocal(0)),
        Cons(IrArm("Tuple3", 3, IrLocal(1)),
        Cons(IrArm("Tuple4", 4, IrLocal(2)),
        Nil)))), None)))

def sel3Def =
  IrDef("_sel__3",
    IrLam(1,
      IrMatch(IrLocal(0),
        Cons(IrArm("Tuple3", 3, IrLocal(0)),
        Cons(IrArm("Tuple4", 4, IrLocal(1)),
        Nil)), None)))

def sel4Def =
  IrDef("_sel__4",
    IrLam(1,
      IrMatch(IrLocal(0),
        Cons(IrArm("Tuple4", 4, IrLocal(0)), Nil), None)))

-- ── String methods ────────────────────────────────────────────────────────────
-- _sel_split(obj, delim) → str.split
def selSplitDef =
  IrDef("_sel_split",
    IrLam(2, IrPrim("str.split", Cons(IrLocal(1), Cons(IrLocal(0), Nil)))))

-- _sel_trim(obj) → str.trim  (0 extra args)
def selTrimDef =
  IrDef("_sel_trim",
    IrLam(1, IrPrim("str.trim", Cons(IrLocal(0), Nil))))

-- _sel_replace(obj, from, to) → str.replace  (obj=local2, from=local1, to=local0)
def selReplaceDef =
  IrDef("_sel_replace",
    IrLam(3, IrPrim("str.replace", Cons(IrLocal(2), Cons(IrLocal(1), Cons(IrLocal(0), Nil))))))

-- _sel_mkString(obj, sep) → join list with separator
-- IrLam(2): sep=local0, obj=local1
-- IrLetRec: go=local0, sep=local1, obj=local2; call=go(obj)
-- go IrLam(1): xs=local0, go=local1, sep=local2, obj=local3
-- Cons arm (2 fields): tail=local0, head=local1, xs=local2, go=local3, sep=local4, obj=local5
-- inner Nil arm body: head is local1 (0-field arm, no shift)
-- inner default: sconcat(head=local1, sconcat(sep=local4, go(tail=local0)))
-- sconcat(x, "") converts x to string via anyStr (correct for any element)
def selMkStringDef =
  let nilArm  = IrArm("Nil", 0, IrLit(IrStr(""))) in
  let consBody =
    IrMatch(IrLocal(0),
      Cons(IrArm("Nil", 0,
        IrPrim("sconcat", Cons(IrLocal(1), Cons(IrLit(IrStr("")), Nil)))),
      Nil),
      Some(IrPrim("sconcat",
        Cons(IrLocal(1),
        Cons(IrPrim("sconcat",
          Cons(IrLocal(4),
          Cons(IrApp(IrLocal(3), Cons(IrLocal(0), Nil)),
          Nil))),
        Nil))))) in
  let consArm = IrArm("Cons", 2, consBody) in
  -- ForeignV(ArrayBuffer) receiver (Array.tabulate/fill result) is not Nil/Cons, so the
  -- List-only go() match would crash ("scrutinee not Data: <foreign>"). Route the non-list
  -- case to the runtime __method__, which handles mkString on isList (List AND ArrayBuffer)
  -- with anyStr rendering. goBody scope: local0=receiver(x), local2=sep. Lists are unaffected
  -- (Nil/Cons arms still win); only Arrays hit this default. K62.24.
  let arrFallback = IrPrim("__method__",
    Cons(IrLit(IrStr("mkString")), Cons(IrLocal(0), Cons(IrLocal(2), Nil)))) in
  let goBody  = IrMatch(IrLocal(0), Cons(nilArm, Cons(consArm, Nil)), Some(arrFallback)) in
  IrDef("_sel_mkString",
    IrLam(2,
      IrLetRec(
        Cons(IrLam(1, goBody), Nil),
        IrApp(IrLocal(0), Cons(IrLocal(2), Nil)))))

-- Check whether a main def with 0 params exists
def hasZeroArgMain = (stmts) =>
  match stmts {
    case Nil => false
    case Cons(s, rest) =>
      match s {
        case Pair(tag, data) =>
          if #seq(tag, "def") then
            match data {
              case Pair(name, rest2) =>
                if #seq(name, "main") then
                  match rest2 {
                    case Pair(params, bodyIgnored) =>
                      match params {
                        case Nil => true
                        case Cons(p, ps) => false
                      }
                  }
                else hasZeroArgMain(rest)
            }
          else hasZeroArgMain(rest)
      }
  }

-- _sel_until(lo, hi) — range [lo, hi)
-- IrLam(2): hi=local0, lo=local1
-- IrLetRec: go=local0, hi=local1, lo=local2
-- go=IrLam(1): i=local0, go=local1, hi=local2, lo=local3
-- T5.7: tail-recursive (accumulator, built high→low so no reverse); the old
-- Cons(i, go(i+1)) shape was NON-tail and stack-overflowed on (1 to 10000).
-- go = IrLam(2): acc=local0, i=local1; then go=local2, hi=local3, lo=local4
-- K62.6c: String.takeWhile/dropWhile(p) — scan chars while p(code) holds.
-- IrLam(2): p=local0, s=local1. LetRec scan(i): local0=i local1=scan local2=p local3=s.
-- scan(i) = if i < slen(s) then (if p(s[i]) then scan(i+1) else i) else i.
-- takeWhile → sslice(s, 0, scan(0)); dropWhile → sslice(s, scan(0), slen(s)).
def scanWhileLam =
  IrLam(1,
    IrIf(IrPrim("i.lt", Cons(IrLocal(0), Cons(IrPrim("slen", Cons(IrLocal(3), Nil)), Nil))),
      IrIf(IrApp(IrLocal(2), Cons(IrPrim("scodeAt", Cons(IrLocal(3), Cons(IrLocal(0), Nil))), Nil)),
        IrApp(IrLocal(1), Cons(IrPrim("i.add", Cons(IrLocal(0), Cons(IrLit(IrInt(1)), Nil))), Nil)),
        IrLocal(0)),
      IrLocal(0)))
def selTakeWhileDef =
  IrDef("_sel_takeWhile",
    IrLam(2,
      IrLetRec(Cons(scanWhileLam, Nil),
        IrPrim("sslice", Cons(IrLocal(2), Cons(IrLit(IrInt(0)),
          Cons(IrApp(IrLocal(0), Cons(IrLit(IrInt(0)), Nil)), Nil)))))))
def selDropWhileDef =
  IrDef("_sel_dropWhile",
    IrLam(2,
      IrLetRec(Cons(scanWhileLam, Nil),
        IrPrim("sslice", Cons(IrLocal(2),
          Cons(IrApp(IrLocal(0), Cons(IrLit(IrInt(0)), Nil)),
          Cons(IrPrim("slen", Cons(IrLocal(2), Nil)), Nil)))))))

def selUntilDef =
  IrDef("_sel_until",
    IrLam(2,
      IrLetRec(
        Cons(IrLam(2,
          IrIf(IrPrim("i.lt", Cons(IrLocal(1), Cons(IrLocal(4), Nil))),
            IrLocal(0),
            IrApp(IrLocal(2),
              Cons(IrPrim("i.sub", Cons(IrLocal(1), Cons(IrLit(IrInt(1)), Nil))),
              Cons(IrCtor("Cons", Cons(IrLocal(1), Cons(IrLocal(0), Nil))),
              Nil))))),
        Nil),
        IrApp(IrLocal(0),
          Cons(IrPrim("i.sub", Cons(IrLocal(1), Cons(IrLit(IrInt(1)), Nil))),
          Cons(IrCtor("Nil", Nil),
          Nil))))))

-- _sel_to(lo, hi) — range [lo, hi] inclusive
-- Same shape as _sel_until but uses i.gt
-- T5.7: tail-recursive accumulator like _sel_until, but hi is INCLUSIVE (start at hi)
def selToDef =
  IrDef("_sel_to",
    IrLam(2,
      IrLetRec(
        Cons(IrLam(2,
          IrIf(IrPrim("i.lt", Cons(IrLocal(1), Cons(IrLocal(4), Nil))),
            IrLocal(0),
            IrApp(IrLocal(2),
              Cons(IrPrim("i.sub", Cons(IrLocal(1), Cons(IrLit(IrInt(1)), Nil))),
              Cons(IrCtor("Cons", Cons(IrLocal(1), Cons(IrLocal(0), Nil))),
              Nil))))),
        Nil),
        IrApp(IrLocal(0),
          Cons(IrLocal(1),
          Cons(IrCtor("Nil", Nil),
          Nil))))))

-- Bench.opaque(x) — identity for benchmarking (prevents constant-folding)
def benchOpaqueDef =
  IrDef("Bench_opaque", IrLam(1, IrLocal(0)))

-- _arr_fill(xs: List) → mutable ArrayBuffer — pushes each element in order
-- IrLam(1): xs=local(0)
-- IrLet([arr.new]): arr=local(0), xs=local(1)
-- IrLetRec([IrLam(2, go_body)]): go=local(0), arr=local(1), xs=local(2)
-- IrApp(go, [xs, arr])
-- go lam (2 params): arr=local(0), lst=local(1), go=local(2)
-- Cons arm (2 fields): t=local(0), h=local(1); arr=local(2), lst=local(3), go=local(4)
-- After IrLet([arr.push]): unit=local(0), t=local(1), h=local(2), arr=local(3), lst=local(4), go=local(5)
-- → go(t, arr)
def arrFillDef =
  let nilArm = IrArm("Nil", 0, IrLocal(0)) in
  let pushExpr = IrPrim("arr.push", Cons(IrLocal(2), Cons(IrLocal(1), Nil))) in
  let afterPush = IrApp(IrLocal(5), Cons(IrLocal(1), Cons(IrLocal(3), Nil))) in
  let consBody = IrLet(Cons(pushExpr, Nil), afterPush) in
  let consArm = IrArm("Cons", 2, consBody) in
  let goBody = IrMatch(IrLocal(1), Cons(nilArm, Cons(consArm, Nil)), None) in
  IrDef("_arr_fill",
    IrLam(1,
      IrLet(Cons(IrPrim("arr.new", Nil), Nil),
        IrLetRec(
          Cons(IrLam(2, goBody), Nil),
          IrApp(IrLocal(0), Cons(IrLocal(2), Cons(IrLocal(1), Nil)))))))

-- LazyList_from(n) — infinite lazy stream starting at n
-- IrLam(1): n=local(0)
-- IrLetRec([from_lam]): from=local(0), n=local(1)
-- → from(n) = IrApp(local(0), [local(1)])
-- from_lam IrLam(1): n_cur=local(0), from=local(1), n_outer=local(2)
-- → LazyCons(n_cur, thunk)
-- thunk IrLam(0) captures env; inside: n_cur=local(0), from=local(1)
-- → from(n_cur + 1)
def lazyListFromDef =
  IrDef("LazyList_from",
    IrLam(1,
      IrLetRec(
        Cons(IrLam(1,
          IrCtor("LazyCons",
            Cons(IrLocal(0),
            Cons(IrLam(0,
              IrApp(IrLocal(1),
                Cons(IrPrim("i.add", Cons(IrLocal(0), Cons(IrLit(IrInt(1)), Nil))),
                Nil))),
            Nil)))),
        Nil),
        IrApp(IrLocal(0), Cons(IrLocal(1), Nil)))))

-- _sel_take(xs, k) — take first k elements from a List or LazyList
-- IrLam(2): k=local(0), xs=local(1)
-- IrLetRec([take_lam]): take=local(0), k=local(1), xs=local(2)
-- → take(xs, k) = IrApp(local(0), [local(2), local(1)])
-- take_lam IrLam(2): n=local(0), lst=local(1), take=local(2)
-- → if n<=0 then Nil else match lst
-- LazyCons arm (2 fields): thunk=local(0), h=local(1); n=local(2), lst=local(3), take=local(4)
--   → Cons(h, take(thunk(), n-1))
-- Cons arm (2 fields): t=local(0), h=local(1); n=local(2), lst=local(3), take=local(4)
--   → Cons(h, take(t, n-1))
def selTakeDef =
  let lazyConsBody =
    IrCtor("Cons",
      Cons(IrLocal(1),
      Cons(IrApp(IrLocal(4),
        Cons(IrApp(IrLocal(0), Nil),
        Cons(IrPrim("i.sub", Cons(IrLocal(2), Cons(IrLit(IrInt(1)), Nil))),
        Nil))),
      Nil))) in
  let consBody =
    IrCtor("Cons",
      Cons(IrLocal(1),
      Cons(IrApp(IrLocal(4),
        Cons(IrLocal(0),
        Cons(IrPrim("i.sub", Cons(IrLocal(2), Cons(IrLit(IrInt(1)), Nil))),
        Nil))),
      Nil))) in
  let matchExpr =
    IrMatch(IrLocal(1),
      Cons(IrArm("LazyCons", 2, lazyConsBody),
      Cons(IrArm("LazyNil", 0, IrCtor("Nil", Nil)),
      Cons(IrArm("Cons", 2, consBody),
      Cons(IrArm("Nil", 0, IrCtor("Nil", Nil)),
      Nil)))),
      None) in
  let takeBody = IrIf(IrPrim("i.le", Cons(IrLocal(0), Cons(IrLit(IrInt(0)), Nil))), IrCtor("Nil", Nil), matchExpr) in
  IrDef("_sel_take",
    IrLam(2,
      IrLetRec(
        Cons(IrLam(2, takeBody), Nil),
        IrApp(IrLocal(0), Cons(IrLocal(2), Cons(IrLocal(1), Nil))))))

-- _sel_sum(xs: List[Int]) → sum of elements (tail-recursive accumulator)
-- IrLam(1): xs=local(0)
-- IrLetRec([go_lam]): go=local(0), xs=local(1)
-- → go(xs, 0) = IrApp(local(0), [local(1), IrLit(0)])
-- go_lam IrLam(2): acc=local(0), lst=local(1), go=local(2)
-- Nil arm: return acc = local(0)
-- Cons arm (2 fields): t=local(0), h=local(1); acc=local(2), lst=local(3), go=local(4)
--   → go(t, acc + h)
def selSumDef =
  let nilArm = IrArm("Nil", 0, IrLocal(0)) in
  let consBody = IrApp(IrLocal(4),
    Cons(IrLocal(0),
    Cons(IrPrim("i.add", Cons(IrLocal(2), Cons(IrLocal(1), Nil))),
    Nil))) in
  let consArm = IrArm("Cons", 2, consBody) in
  let goBody = IrMatch(IrLocal(1), Cons(nilArm, Cons(consArm, Nil)), None) in
  IrDef("_sel_sum",
    IrLam(1,
      IrLetRec(
        Cons(IrLam(2, goBody), Nil),
        IrApp(IrLocal(0), Cons(IrLocal(1), Cons(IrLit(IrInt(0)), Nil))))))

-- _sel_mapUpdated(m, k, v) — mutate HashMap m[k]=v, return m
-- IrLam(3): v=local(0), k=local(1), m=local(2)
-- IrLet([map.put(m, k, v)]): unit=local(0), v=local(1), k=local(2), m=local(3)
-- → local(3) = m
def selMapUpdatedDef =
  IrDef("_sel_mapUpdated",
    IrLam(3,
      IrLet(Cons(IrPrim("map.put", Cons(IrLocal(2), Cons(IrLocal(1), Cons(IrLocal(0), Nil)))), Nil),
        IrLocal(3))))

-- _sel_mapGetOrElse(m, k, d) — map.get(m, k) → Some(v)→v, None→d
-- IrLam(3): d=local(0), k=local(1), m=local(2)
-- map.get(m, k) → Some(v) or None
-- Some arm (1 field): v=local(0) → local(0) = v
-- None arm (0 fields): d=local(0) → local(0) = d
def selMapGetOrElseDef =
  IrDef("_sel_mapGetOrElse",
    IrLam(3,
      IrMatch(
        IrPrim("map.get", Cons(IrLocal(2), Cons(IrLocal(1), Nil))),
        Cons(IrArm("Some", 1, IrLocal(0)),
        Cons(IrArm("None", 0, IrLocal(0)),
        Nil)),
        None)))

-- runLogger(thunk) — call the thunk, return its result (effect-pure: Logger effects are no-ops)
-- IrLam(1): thunk=local(0)
-- → thunk()
def runLoggerDef =
  IrDef("runLogger", IrLam(1, IrApp(IrLocal(0), Nil)))

-- __streamBuf — global mutable cell holding current stream elements (Nil when not in runStream)
def streamBufDef =
  IrDef("__streamBuf", IrPrim("cell.new", Cons(IrCtor("Nil", Nil), Nil)))

-- Stream_emit(x) — push x to the front of __streamBuf
-- IrLam(1): x=local(0)
-- → cell.set(__streamBuf, Cons(x, cell.get(__streamBuf)))
def streamEmitDef =
  IrDef("Stream_emit",
    IrLam(1,
      IrPrim("cell.set",
        Cons(IrGlobal("__streamBuf"),
        Cons(IrCtor("Cons",
          Cons(IrLocal(0),
          Cons(IrPrim("cell.get", Cons(IrGlobal("__streamBuf"), Nil)),
          Nil))),
        Nil)))))

-- runStream(thunk) — set up buffer, run thunk, collect emitted values, return Pair(list, ())
-- IrLam(1): thunk=L0
-- let old = cell.get(__streamBuf)   → old=L0, thunk=L1
-- let _ = cell.set(__streamBuf, Nil) → _=L0, old=L1, thunk=L2
-- let _ = thunk()                    → _=L0, _=L1, old=L2, thunk=L3
-- let collected = cell.get(__streamBuf) → collected=L0, _=L1, _=L2, old=L3, thunk=L4
-- let _ = cell.set(__streamBuf, old) → _=L0, collected=L1, _=L2, _=L3, old=L4, thunk=L5
-- → Pair(collected, ())  = Pair(L1, unit)
def runStreamDef =
  IrDef("runStream",
    IrLam(1,
      IrLet(Cons(IrPrim("cell.get", Cons(IrGlobal("__streamBuf"), Nil)), Nil),
        IrLet(Cons(IrPrim("cell.set",
          Cons(IrGlobal("__streamBuf"), Cons(IrCtor("Nil", Nil), Nil))), Nil),
          IrLet(Cons(IrApp(IrLocal(2), Nil), Nil),
            IrLet(Cons(IrPrim("cell.get", Cons(IrGlobal("__streamBuf"), Nil)), Nil),
              IrLet(Cons(IrPrim("cell.set",
                Cons(IrGlobal("__streamBuf"), Cons(IrLocal(3), Nil))), Nil),
                IrCtor("Pair",
                  Cons(IrLocal(1),
                  Cons(IrLit(IrUnit),
                  Nil))))))))))

-- _sel_runToList(src) — src is already a collected list, return it
def selRunToListDef =
  IrDef("_sel_runToList", IrLam(1, IrLocal(0)))

-- _sel_toList(src) — ranges/lists are already Cons-lists here, so identity
def selToListDef =
  IrDef("_sel_toList", IrLam(1, IrLocal(0)))

-- _sel_length(lst) — tail-recursive list length; falls back to slen for strings/arrays
-- IrLam(1): lst=L0
-- IrLetRec: go=L0, lst=L1; call go(lst, 0) = IrApp(L0, [L1, lit(0)])
-- go=IrLam(2): L0=acc, L1=xs, L2=go
--   Nil arm (0 fields): return acc=L0
--   Cons arm (2 fields): t=L0, h=L1; acc=L2, go=L4 → go(t, acc+1)
--   default: slen(xs=L1) for strings and arrays
def selLengthDef =
  IrDef("_sel_length",
    IrLam(1,
      IrLetRec(
        Cons(IrLam(2,
          IrMatch(IrLocal(1),
            Cons(IrArm("Nil", 0, IrLocal(0)),
            Cons(IrArm("Cons", 2,
              IrApp(IrLocal(4),
                Cons(IrLocal(0),
                Cons(IrPrim("i.add", Cons(IrLocal(2), Cons(IrLit(IrInt(1)), Nil))),
                Nil)))),
            Nil)),
            Some(IrPrim("slen", Cons(IrLocal(1), Nil))))),
        Nil),
        IrApp(IrLocal(0), Cons(IrLocal(1), Cons(IrLit(IrInt(0)), Nil))))))

-- Effect handler cell: Bump_tick_cell holds current () => Int handler (default: () => 1)
def bumpTickCellDef =
  IrDef("Bump_tick_cell", IrPrim("cell.new", Cons(IrLam(0, IrLit(IrInt(1))), Nil)))

-- Bump_tick() — calls the handler stored in Bump_tick_cell
-- IrLam(0, IrApp(cell.get(Bump_tick_cell), []))
def bumpTickDef =
  IrDef("Bump_tick",
    IrLam(0,
      IrApp(IrPrim("cell.get", Cons(IrGlobal("Bump_tick_cell"), Nil)), Nil)))

-- KV9: _list_concat(xs, ys) — List append (xs ++ ys)
-- IrLam(2): local(0)=ys, local(1)=xs
-- IrLetRec: go=local(0), ys=local(1), xs=local(2); call go(xs)=go(local(2))
-- go=IrLam(1): xs2=local(0), go=local(1), ys=local(2)
-- Nil arm: return ys=local(2)
-- Cons arm (2 fields: t=local0, h=local1): Cons(h, go(t))
def listConcatDef =
  IrDef("_list_concat",
    IrLam(2,
      IrLetRec(
        Cons(IrLam(1,
          IrMatch(IrLocal(0),
            Cons(IrArm("Nil", 0, IrLocal(2)),
            Cons(IrArm("Cons", 2,
              IrCtor("Cons",
                Cons(IrLocal(1),
                Cons(IrApp(IrLocal(3), Cons(IrLocal(0), Nil)), Nil)))),
            Nil)), None)),
        Nil),
        IrApp(IrLocal(0), Cons(IrLocal(2), Nil)))))

-- KV9: _list_flatMap(xs, f) — concatMap: flatMap for List monad
-- IrLam(2): local(0)=f, local(1)=xs
-- IrLetRec: go=local(0), f=local(1), xs=local(2); call go(xs)=go(local(2))
-- go=IrLam(1): xs2=local(0), go=local(1), f=local(2)
-- Nil arm: return Nil
-- Cons arm (2 fields: t=local0, h=local1): _list_concat(f(h), go(t))
def listFlatMapDef =
  IrDef("_list_flatMap",
    IrLam(2,
      IrLetRec(
        Cons(IrLam(1,
          IrMatch(IrLocal(0),
            Cons(IrArm("Nil", 0, IrCtor("Nil", Nil)),
            Cons(IrArm("Cons", 2,
              IrApp(IrGlobal("_list_concat"),
                Cons(IrApp(IrLocal(4), Cons(IrLocal(1), Nil)),
                Cons(IrApp(IrLocal(3), Cons(IrLocal(0), Nil)),
                Nil)))),
            Nil)), None)),
        Nil),
        IrApp(IrLocal(0), Cons(IrLocal(2), Nil)))))

-- All injected KC6 helpers
def kc6Defs =
  Cons(bumpTickCellDef,
  Cons(bumpTickDef,
  Cons(selMapDef,
  Cons(selForeachDef,
