-- Backend driver: ssc0 SOURCE -> Rust. Reuses the shared codegen (lib/backend-rust-gen.ssc0) and
-- only adds the ssc0 front (ssc0c). toRust = parse ssc0 -> IrProg Data -> genRProg.
import "ssc0c.ssc0"
import "backend-rust-gen.ssc0"

def toRust = (src) => genRProg(compileModule(parseTop(lex(src))))
