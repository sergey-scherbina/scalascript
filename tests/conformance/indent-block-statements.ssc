## Statement AST

```scalascript
// print expr
case class PrintStmt(expr: String)

// varName = expr
case class AssignStmt(name: String, expr: String)

// if cond:\n  body
case class IfStmt(cond: String, body: List[Any])

// while cond:\n  body
case class WhileStmt(cond: String, body: List[Any])

// for var in expr:\n  body
case class ForStmt(varName: String, expr: String, body: List[Any])
```

## Parsers

```scalascript
// Horizontal whitespace.
val hspace: Parser[Any] = Parser.regex("[ \t]*")

// An expression: everything on the line after the keyword (simplified).
val expr: Parser[Any] = Parser.regex("[^\n:]+").map(s => s.trim)

// A print statement: "print <expr>"
val printStmt: Parser[Any] =
  (Parser.string("print") ~> whitespace1 ~> expr)
    .map(e => PrintStmt(e.asInstanceOf[String]))

// An assignment: "<ident> = <expr>"
val assignStmt: Parser[Any] =
  (identifier <~ hspace <~ Parser.char('=') <~ hspace ~ expr)
    .map(pair => AssignStmt(pair._1.asInstanceOf[String], pair._2.asInstanceOf[String]))

// Forward-declared statement parser (recursive for nested blocks).
var stmtRef: Parser[Any] = Parser.fail("stmtRef not initialized")

// A body block: one or more statements at a deeper indent level.
// The deeperIndent guard is checked once; then the block parser
// repeatedly requires sameIndent before each item.
def bodyBlock(parentLevel: Int): Parser[Any] =
  Parser.readCtx { ctx =>
    val childLevel = parentLevel + 2   // 2-space indent convention
    stmtRef.block.withIndent(childLevel)
  }

// if <cond>:\n  <body>
val ifStmt: Parser[Any] =
  Parser.readCtx { ctx =>
    val level = ctx match
      case ic: IndentContext => ic.currentLevel
      case _                 => 1
    (Parser.string("if") ~> whitespace1 ~> expr <~ hspace <~ Parser.char(':') <~
      Parser.char('\n') ~
      bodyBlock(level))
      .map(pair => IfStmt(pair._1.asInstanceOf[String], pair._2.asInstanceOf[List[Any]]))
  }

// while <cond>:\n  <body>
val whileStmt: Parser[Any] =
  Parser.readCtx { ctx =>
    val level = ctx match
      case ic: IndentContext => ic.currentLevel
      case _                 => 1
    (Parser.string("while") ~> whitespace1 ~> expr <~ hspace <~ Parser.char(':') <~
      Parser.char('\n') ~
      bodyBlock(level))
      .map(pair => WhileStmt(pair._1.asInstanceOf[String], pair._2.asInstanceOf[List[Any]]))
  }

// for <ident> in <expr>:\n  <body>
val forStmt: Parser[Any] =
  Parser.readCtx { ctx =>
    val level = ctx match
      case ic: IndentContext => ic.currentLevel
      case _                 => 1
    (Parser.string("for") ~> whitespace1 ~> identifier <~ whitespace1 <~
      Parser.string("in") <~ whitespace1 ~ expr <~ hspace <~ Parser.char(':') <~
      Parser.char('\n') ~
      bodyBlock(level))
      .map(pair => ForStmt(pair._1.asInstanceOf[String], pair._2.asInstanceOf[String], pair._3.asInstanceOf[List[Any]]))
  }

// Initialize stmtRef (mutual recursion).
stmtRef = (ifStmt | whileStmt | forStmt | printStmt | assignStmt).named("statement")

// A program: one or more top-level statements at column 1.
val program: Parser[Any] =
  stmtRef.block.withIndent(1)
```

## Helper

```scalascript
def showStmt(s: Any, indent: Int): Unit =
  val pad = " " * indent
  s match
    case PrintStmt(e)           => println(pad + "print " + e)
    case AssignStmt(n, e)       => println(pad + n + " = " + e)
    case IfStmt(c, body)        =>
      println(pad + "if " + c + ":")
      body.foreach(b => showStmt(b, indent + 2))
    case WhileStmt(c, body)     =>
      println(pad + "while " + c + ":")
      body.foreach(b => showStmt(b, indent + 2))
    case ForStmt(v, e, body)    =>
      println(pad + "for " + v + " in " + e + ":")
      body.foreach(b => showStmt(b, indent + 2))
    case _                      => println(pad + s.toString)
```

## Test inputs

```scalascript
val prog1 = """x = 10
y = 20
print x"""

val prog2 = """x = 0
if x == 0:
  print zero
  x = 1
print done"""
```

## Run tests

```scalascript
// Test 1 — simple assignments and print
program.parseLayoutWith(prog1, IndentContext.at(1)) match
  case ParseOk(stmts, _, _) =>
    println("test1: " + stmts.asInstanceOf[List[Any]].length + " statement(s)")
    stmts.asInstanceOf[List[Any]].foreach(s => showStmt(s, 0))
  case ParseErr(e) =>
    println("test1 FAIL: " + e.message)

// Test 2 — if block
program.parseLayoutWith(prog2, IndentContext.at(1)) match
  case ParseOk(stmts, _, _) =>
    println("test2: " + stmts.asInstanceOf[List[Any]].length + " statement(s)")
    stmts.asInstanceOf[List[Any]].foreach(s => showStmt(s, 0))
  case ParseErr(e) =>
    println("test2 FAIL: " + e.message)
```

## Expected output

```
test1: 3 statement(s)
x = 10
y = 20
print x
test2: 3 statement(s)
x = 0
if x == 0:
  print zero
  x = 1
print done
```
