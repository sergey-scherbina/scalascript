#!/usr/bin/env bash
# Mock ssc for scripted testing — empty artifact dir case.
set -euo pipefail
if [ "$1" != "generate-facade" ]; then
  echo "[mock-ssc] unknown command: $1" >&2
  exit 1
fi
OUTPUT_DIR="$4"
mkdir -p "${OUTPUT_DIR}"
echo "[mock-ssc] generate-facade: no legacy facade entries found; nothing written." >&2
