def extHasBodyD(ts, d) = if isEmpty(ts) then false else extHasBodyTok(hd(ts), tl(ts), d)
def extHasBodyTok(t, rest, d) = if d == 0 then (if isTok(t, 2, 20) then true else (if isTok(t, 2, 1) then false else (if isTok(t, 2, 52) then false else (if isTok(t, 2, 29) then false else (if isOpenNest(t) then extHasBodyD(rest, 1) else extHasBodyD(rest, 0)))))) else (if isOpenNest(t) then extHasBodyD(rest, d + 1) else (if isCloseNest(t) then extHasBodyD(rest, d - 1) else extHasBodyD(rest, d)))
