name: pg-listen-notify
description: PostgreSQL LISTEN/NOTIFY receive side — Db.pgListen + Db.getNotifications on a held connection (busi df-6).
databases:
  default:
    url: "jdbc:postgresql://localhost:5432/postgres?user=postgres&password=postgres"
