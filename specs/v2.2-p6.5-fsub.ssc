def isWord(t, w) = if fst(t) == 1 then snd(t) == w else false
def isTraitHead(ts) = if isWord(hd(ts), "trait") then true else (if isWord(hd(ts), "sealed") then isWord(hd(tl(ts)), "trait") else false)
