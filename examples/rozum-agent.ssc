---
name: rozum-agent-demo
version: 0.1.0
description: Self-contained std.agent demo against a fake OpenAI-compatible rozum gateway.
---

# Rozum Agent Demo

[AgentEndpoint, RunOptions, agentTool, runAgent, toolOk, objectSchema](std/agent.ssc)
[jsonValue, jStr, jNum, jField, jObj](std/json.ssc)
[route, serveAsync, stop, httpRetry, Request, Response](std/http.ssc)

```scalascript
val port = 19694
var calls = 0

route("POST", "/v1/chat/completions") { req =>
  calls = calls + 1
  if calls == 1 then
    Response(
      200,
      Map("Content-Type" -> "application/json"),
      """{"choices":[{"finish_reason":"tool_calls","message":{"role":"assistant","tool_calls":[{"id":"call_1","type":"function","function":{"name":"post_transaction","arguments":"{\"amount\":125,\"memo\":\"office supplies\"}"}}]}}]}"""
    )
  else
    Response(
      200,
      Map("Content-Type" -> "application/json"),
      """{"choices":[{"finish_reason":"stop","message":{"role":"assistant","content":"Posted the transaction."}}]}"""
    )
}

serveAsync(port)
httpRetry(20, 50)

val schema = objectSchema(
  jObj(List(
    jField("amount", jObj(List(jField("type", jStr("integer"))))),
    jField("memo", jObj(List(jField("type", jStr("string")))))
  )),
  List("amount", "memo")
)

val postTransaction = agentTool(
  "post_transaction",
  "Post one validated accounting transaction.",
  schema
) { argsJson =>
  val args = jsonValue(argsJson)
  val amount = args.get("amount").asInt
  val memo = args.get("memo").asString
  toolOk(jObj(List(
    jField("status", jStr("posted")),
    jField("amount", jNum(amount.toString)),
    jField("memo", jStr(memo))
  )))
}

val result = runAgent(
  AgentEndpoint("http://localhost:" + port),
  "local-tool-model",
  "You are a careful accounting assistant.",
  "Post the office supplies transaction.",
  List(postTransaction),
  RunOptions(maxSteps = 4)
)

println(result.stop)
println(result.text)
println(result.operations.length)

stop()
```
