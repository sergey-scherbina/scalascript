def extTypeTags(th, cx) = if th == "List" then Cons("Cons", Cons("Nil", Nil)) else (if th == "Option" then Cons("Some", Cons("None", Nil)) else (if th == "Either" then Cons("Left", Cons("Right", Nil)) else (if th == "Tuple2" then Cons("Pair", Cons("Tuple2", Nil)) else extTypeTagsUser(th, cx))))
