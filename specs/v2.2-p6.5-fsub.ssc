def givenMethodObj(gname, ms, cx) = "(def " ++ gname ++ " (prim __mk_method_obj__" ++ givenObjArgs(gname, ms, cx) ++ "))"
def givenObjArgs(gname, ms, cx) = ms match { case Nil => "" case h :: t => givenObjArg1(gname, h, cx) ++ givenObjArgs(gname, t, cx) }
def givenObjArg1(gname, m, cx) = m match { case (kind, nt) => if kind == "var" then "" else (nt match { case (mname, toks) => " (lit (str " ++ dqOf(cx) ++ mname ++ dqOf(cx) ++ ")) (global " ++ gname ++ "_" ++ mname ++ ")" }) }
