# SclJet SQL query layer

A small SQL front end over the storage engine. `tokenize` lexes SQL text; `parseSelect`
builds a `SelectStmt` AST for `SELECT (*|cols) FROM table [WHERE col op literal]`;
`executeSelect` resolves the columns from the table's `CREATE TABLE` text, cursors the
rows, applies the filter, and projects the result. `queryImage(dbBytes, sql)` opens a
database image and returns the result rows; `renderRows` formats them like the sqlite3
CLI (`a|b|c` per row, NULL blank) for differential testing.

[ByteSlice, ByteError, SqliteValue, SqlNull, SqlInteger, SqlReal, SqlText, SqlBlob, ReadonlyDatabase, SchemaEntry, StorageRecord, DecodedRecord, RecordField, DecodedText, RowidTableTree, RecordKeyTree, openReadonly, openReadonlyRoot, readonlyFirst, readonlyNext, closeReadonly, ReadonlyCursorStep, ReadonlyBtreeCursor, SqliteError, SqliteOpenOptions, SqliteLimits, OpenReadOnly, StrictSqlite, JournalDelete, SyncFull, encodeRecord, openMutablePager, mutableCommit, mutableGet, mutablePut, MutablePager, PagerCommit, pagerInsertBalanced, pagerDeleteBalanced, readLeafCells, leafInsertCell, rebuildLeafPage, LeafCell, byteSliceSlice, byteSliceToList, byteSliceGet, writeU32Be, IndexEntry, buildIndexTree, sortIndexEntries, IndexTreeBytes, buildSingleTableIndexed, KeyedRawRow, SchemaIndex, SchemaTable, descendToLeaf, decodeVarint, VarintRead, decodeRecord, readU16Be, readU32Be, ByteRead](index.ssc)
[ImageVfs, fieldValueAt](mutate.ssc)

```scalascript
// ── Lexer ──

// `bound` carries a value bound to a `?` parameter (see bindParams). A "param" token holds the
// 1-based ordinal in `num`; after binding it becomes a "bound" token whose `bound` is the value.
// The default keeps every existing `Token(k, t, n)` construction valid (no arity churn).
case class Token(kind: String, text: String, num: Long, bound: Option[SqliteValue] = None)

// Bounds-safe: returns -1 past the end, so loop conditions like
// `i < n && isDigit(charCode(s, i))` are safe even though `&&` does not
// short-circuit in the interpreter.
def charCode(s: String, i: Int): Int = if i >= 0 && i < s.length then s.charAt(i).toInt else -1
def isWs(c: Int): Boolean = c == 32 || c == 9 || c == 10 || c == 13
def isDigit(c: Int): Boolean = c >= 48 && c <= 57
def isAlpha(c: Int): Boolean = (c >= 65 && c <= 90) || (c >= 97 && c <= 122) || c == 95
def isAlnum(c: Int): Boolean = isAlpha(c) || isDigit(c)

def upperStr(s: String): String =
  var i = 0
  var out = ""
  while i < s.length do
    val c = charCode(s, i)
    out = out + (if c >= 97 && c <= 122 then (c - 32).toChar.toString else s.charAt(i).toString)
    i = i + 1
  out

def lowerStr(s: String): String =
  var i = 0
  var out = ""
  while i < s.length do
    val c = charCode(s, i)
    out = out + (if c >= 65 && c <= 90 then (c + 32).toChar.toString else s.charAt(i).toString)
    i = i + 1
  out

def reverseTokens(items: List[Token], acc: List[Token]): List[Token] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

def tokenize(sql: String): Either[String, List[Token]] =
  var i = 0
  val n = sql.length
  var toksRev: List[Token] = Nil
  var err: Option[String] = None
  var paramMax = 0L
  while i < n && err.isEmpty do
    val c = charCode(sql, i)
    if isWs(c) then i = i + 1
    else if isDigit(c) then
      // Integer digits accumulate into both a Long (num) and a Double (dval); if a `.digit`
      // fraction follows, emit a REAL literal (value carried in `bound`), else an integer.
      var num = 0L
      var dval = 0.0
      while i < n && isDigit(charCode(sql, i)) do
        val dg = charCode(sql, i) - 48
        num = num * 10L + dg.toLong
        dval = dval * 10.0 + dg.toDouble
        i = i + 1
      if charCode(sql, i) == 46 && isDigit(charCode(sql, i + 1)) then
        i = i + 1
        var scale = 1.0
        while i < n && isDigit(charCode(sql, i)) do
          val dg = charCode(sql, i) - 48
          dval = dval * 10.0 + dg.toDouble
          scale = scale * 10.0
          i = i + 1
        toksRev = Token("real", "", 0L, Some(SqlReal(dval / scale))) :: toksRev
      else toksRev = Token("num", "", num) :: toksRev
    else if isAlpha(c) then
      var word = ""
      while i < n && isAlnum(charCode(sql, i)) do
        word = word + sql.charAt(i).toString
        i = i + 1
      // qualified name `a.b` becomes one ident token "a.b"
      if charCode(sql, i) == 46 && isAlpha(charCode(sql, i + 1)) then
        word = word + "."
        i = i + 1
        while i < n && isAlnum(charCode(sql, i)) do
          word = word + sql.charAt(i).toString
          i = i + 1
      toksRev = Token("ident", word, 0L) :: toksRev
    else if c == 39 then
      // '…' string literal, '' is an escaped quote
      i = i + 1
      var str = ""
      var closed = false
      while i < n && !closed do
        if charCode(sql, i) == 39 then
          if i + 1 < n && charCode(sql, i + 1) == 39 then
            str = str + "'"
            i = i + 2
          else
            closed = true
            i = i + 1
        else
          str = str + sql.charAt(i).toString
          i = i + 1
      if !closed then err = Some("unterminated string literal")
      else toksRev = Token("str", str, 0L) :: toksRev
    else if c == 42 then
      toksRev = Token("star", "*", 0L) :: toksRev
      i = i + 1
    else if c == 44 then
      toksRev = Token("comma", ",", 0L) :: toksRev
      i = i + 1
    else if c == 40 then
      toksRev = Token("lparen", "(", 0L) :: toksRev
      i = i + 1
    else if c == 41 then
      toksRev = Token("rparen", ")", 0L) :: toksRev
      i = i + 1
    else if c == 61 then
      toksRev = Token("op", "=", 0L) :: toksRev
      i = i + 1
    else if c == 60 then
      // < , <= , <>
      if i + 1 < n && charCode(sql, i + 1) == 61 then
        toksRev = Token("op", "<=", 0L) :: toksRev
        i = i + 2
      else if i + 1 < n && charCode(sql, i + 1) == 62 then
        toksRev = Token("op", "<>", 0L) :: toksRev
        i = i + 2
      else
        toksRev = Token("op", "<", 0L) :: toksRev
        i = i + 1
    else if c == 62 then
      if i + 1 < n && charCode(sql, i + 1) == 61 then
        toksRev = Token("op", ">=", 0L) :: toksRev
        i = i + 2
      else
        toksRev = Token("op", ">", 0L) :: toksRev
        i = i + 1
    else if c == 33 then
      if i + 1 < n && charCode(sql, i + 1) == 61 then
        toksRev = Token("op", "!=", 0L) :: toksRev
        i = i + 2
      else err = Some("unexpected '!' without '='")
    else if c == 43 then
      toksRev = Token("op", "+", 0L) :: toksRev
      i = i + 1
    else if c == 45 then
      toksRev = Token("op", "-", 0L) :: toksRev
      i = i + 1
    else if c == 47 then
      toksRev = Token("op", "/", 0L) :: toksRev
      i = i + 1
    else if c == 37 then
      toksRev = Token("op", "%", 0L) :: toksRev
      i = i + 1
    else if c == 124 then
      // `||` string concatenation
      if i + 1 < n && charCode(sql, i + 1) == 124 then
        toksRev = Token("op", "||", 0L) :: toksRev
        i = i + 2
      else err = Some("unexpected '|' (did you mean '||'?)")
    else if c == 63 then
      // '?' positional parameter. Bare '?' takes the next ordinal; '?NNN' is explicit (sqlite
      // semantics: a later bare '?' resumes after the largest ordinal seen). Bound later by bindParams.
      i = i + 1
      if i < n && isDigit(charCode(sql, i)) then
        var ord = 0L
        while i < n && isDigit(charCode(sql, i)) do
          ord = ord * 10L + (charCode(sql, i) - 48).toLong
          i = i + 1
        if ord > paramMax then paramMax = ord
        toksRev = Token("param", "?", ord) :: toksRev
      else
        paramMax = paramMax + 1L
        toksRev = Token("param", "?", paramMax) :: toksRev
    else if c == 59 then
      i = i + 1
    else err = Some("unexpected character '" + sql.charAt(i).toString + "'")
  err match
    case Some(message) => Left(message)
    case None => Right(reverseTokens(toksRev, Nil))

// 1-based lookup into the bound-parameter list (params(idx-1)); strict — an unset ordinal errors.
def paramAt(params: List[SqliteValue], idx: Long): Either[String, SqliteValue] =
  var r = params
  var k = idx
  while r.nonEmpty && k > 1L do
    r = r.tail
    k = k - 1L
  if r.isEmpty then Left("parameter " + idx.toString + " is not set")
  else Right(r.head)

// Replace every "param" token with a "bound" token carrying its resolved value (a `?`-parameter
// binding pass, run once between tokenize and parse). Keeps the parser pure/un-parameterized: a
// bound value reaches parseExprAtom/litValue as an SxLit, indistinguishable from an inline literal,
// preserving full storage-class fidelity (integer/real/text/blob/NULL) with no string interpolation.
def bindParams(toks: List[Token], params: List[SqliteValue]): Either[String, List[Token]] =
  var r = toks
  var accRev: List[Token] = Nil
  var err: Option[String] = None
  while r.nonEmpty && err.isEmpty do
    val t = r.head
    if t.kind == "param" then
      paramAt(params, t.num) match
        case Left(message) => err = Some(message)
        case Right(v) => accRev = Token("bound", "", 0L, Some(v)) :: accRev
    else accRev = t :: accRev
    r = r.tail
  err match
    case Some(message) => Left(message)
    case None => Right(reverseTokens(accRev, Nil))

// ── Parser: SELECT (*|cols) FROM table [WHERE …] ──

// Scalar expression tree over columns and literals — used both in projections and in WHERE.
// SxBin's op covers arithmetic (+ - * /), concatenation (||) AND comparisons (= <> < > <= >=,
// which yield 1/0/NULL like sqlite). SxCase is `CASE [operand] WHEN … THEN … [ELSE …] END`.
sealed trait SxNode
case class SxCol(name: String) extends SxNode
case class SxLit(value: SqliteValue) extends SxNode
case class SxNeg(inner: SxNode) extends SxNode
case class SxBin(op: String, left: SxNode, right: SxNode) extends SxNode
case class SxCall(func: String, args: List[SxNode]) extends SxNode
case class SxNot(inner: SxNode) extends SxNode
// An aggregate embedded in an expression (COUNT(*)+1, MAX(x)-MIN(x)); evaluated over a group.
case class SxAgg(func: String, arg: String, distinct: Boolean) extends SxNode
case class SxWhen(cond: SxNode, result: SxNode)
case class SxCase(operand: Option[SxNode], whens: List[SxWhen], elseExpr: Option[SxNode]) extends SxNode

// A WHERE predicate. The left operand is a bare column (`column`, `leftExpr=None`) or a computed
// expression (`leftExpr=Some`); the right operand of a scalar comparison is a literal (`value`,
// `rightExpr=None`) or an expression / another column (`rightExpr=Some`). `values` carries the
// multi-operand list for BETWEEN/IN; `value` also holds the LIKE pattern.
// `subTokens` (defaulted empty) carries an EXISTS/NOT EXISTS subquery's tokens (op "exists"/"notexists");
// evaluated per outer row with the outer table's qualified columns substituted (correlated subquery).
case class Condition(column: String, op: String, value: SqliteValue, values: List[SqliteValue], leftExpr: Option[SxNode], rightExpr: Option[SxNode], subTokens: List[Token] = Nil)
// leftOuter keeps unmatched left rows; rightOuter (defaulted) keeps unmatched right rows. Both → FULL.
case class JoinSpec(table: String, leftCol: String, op: String, rightCol: String, leftOuter: Boolean, rightOuter: Boolean = false)
case class HavingCond(item: ProjItem, op: String, value: SqliteValue)
case class SelectStmt(star: Boolean, projection: List[ProjItem], table: String, where: List[List[Condition]], orderBy: List[OrderKey], limit: Int, offset: Int, groupBy: List[String], joins: List[JoinSpec], having: Option[HavingCond], distinct: Boolean)

def isKw(token: Token, word: String): Boolean = token.kind == "ident" && upperStr(token.text) == word

// Bounds-safe token inspection. The interpreter's `&&`/`||` do NOT short-circuit, so
// guards like `toks.nonEmpty && toks.head.kind == …` would index `.head` on an empty
// list — these never touch `.head` when the list is empty.
def tkKind(toks: List[Token]): String = if toks.isEmpty then "" else toks.head.kind
def tkText(toks: List[Token]): String = if toks.isEmpty then "" else toks.head.text
def tkIsKw(toks: List[Token], word: String): Boolean = if toks.isEmpty then false else isKw(toks.head, word)

def reverseStrings(items: List[String], acc: List[String]): List[String] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

def parseColumnList(toks: List[String], remaining: List[Token]): Either[String, (List[String], List[Token])] =
  var accRev = toks
  var rest = remaining
  var done = false
  var result: Option[Either[String, (List[String], List[Token])]] = None
  while !done && result.isEmpty do
    if tkKind(rest) != "ident" then result = Some(Left("expected column name"))
    else
      accRev = rest.head.text :: accRev
      rest = rest.tail
      if tkKind(rest) == "comma" then rest = rest.tail
      else done = true
  result match
    case Some(r) => r
    case None => Right((reverseStrings(accRev, Nil), rest))

def litValue(token: Token): Either[String, SqliteValue] =
  if token.kind == "num" then Right(SqlInteger(token.num))
  else if token.kind == "str" then Right(SqlText(token.text))
  else if token.kind == "real" then token.bound match
    case Some(v) => Right(v)
    case None => Left("real token without a value")
  else if token.kind == "bound" then token.bound match
    case Some(v) => Right(v)
    case None => Left("bound token without a value")
  else Left("expected a literal in WHERE")

// Parse an optional `WHERE col op literal`; returns the condition (or None) and the
// tokens after it (for a trailing ORDER BY / LIMIT). A non-WHERE token is left in place.
// A bare column stays name-based (so the join path resolves it via joinColValue); any
// compound expression is carried as an SxNode. Returns (column, leftExpr).
def condLeftOf(node: SxNode): Option[SxNode] = node match
  case SxCol(_) => None
  case _ => Some(node)

def condColOf(node: SxNode): String = node match
  case SxCol(n) => n
  case _ => ""

// One predicate: `<expr> op <expr>`, `<expr> IS [NOT] NULL`, `<expr> BETWEEN lo AND hi`,
// `<expr> [NOT] IN ( … )`, or `<expr> [NOT] LIKE pat`. The left operand (and, for a scalar
// comparison, the right operand) may be any arithmetic expression, a column, or a literal.
// `[NOT] EXISTS ( subquery )` → an exists/notexists Condition carrying the subquery tokens.
def parseExistsCond(toks: List[Token], op: String): Either[String, (Condition, List[Token])] =
  if tkKind(toks) != "lparen" then Left("expected '(' after EXISTS")
  else splitParenGroup(toks.tail) match
    case None => Left("unbalanced parentheses in EXISTS")
    case Some(sp) => Right((Condition("", op, SqlNull, Nil, None, None, sp._1), sp._2))

def parseCondition(toks: List[Token]): Either[String, (Condition, List[Token])] =
  if tkIsKw(toks, "EXISTS") then parseExistsCond(toks.tail, "exists")
  else if tkIsKw(toks, "NOT") && tkIsKw(toks.tail, "EXISTS") then parseExistsCond(toks.tail.tail, "notexists")
  else parseExprAdd(toks) match
    case Left(message) => Left(message)
    case Right(le) =>
      val lnode = le._1
      val after = le._2
      val col = condColOf(lnode)
      val lopt = condLeftOf(lnode)
      if tkIsKw(after, "IS") then
        val afterIs = after.tail
        if tkIsKw(afterIs, "NOT") then
          if !tkIsKw(afterIs.tail, "NULL") then Left("expected NULL after IS NOT")
          else Right((Condition(col, "notnull", SqlNull, Nil, lopt, None), afterIs.tail.tail))
        else if tkIsKw(afterIs, "NULL") then Right((Condition(col, "isnull", SqlNull, Nil, lopt, None), afterIs.tail))
        else Left("expected NULL after IS")
      else if tkIsKw(after, "NOT") then
        // Nested (not `&&`): the interpreter's `&&` does NOT short-circuit, so
        // `tkIsKw(after,"NOT") && tkIsKw(after.tail,…)` would evaluate `after.tail` on an
        // empty list (e.g. a bare `WHERE <expr>`) and crash. Here after.tail is safe (after="NOT").
        if tkIsKw(after.tail, "IN") then
          if tkKind(after.tail.tail) == "lparen" && tkIsKw(after.tail.tail.tail, "SELECT") then splitParenGroup(after.tail.tail.tail) match
            case None => Left("unbalanced parentheses in NOT IN subquery")
            case Some(sp) => Right((Condition(col, "notinsubq", SqlNull, Nil, lopt, None, sp._1), sp._2))
          else parseValueList(after.tail.tail) match
            case Left(message) => Left(message)
            case Right(vl) => Right((Condition(col, "notin", SqlNull, vl._1, lopt, None), vl._2))
        else if tkIsKw(after.tail, "LIKE") then
          if after.length < 3 then Left("NOT LIKE needs a pattern")
          else litValue(after.tail.tail.head) match
            case Left(message) => Left(message)
            case Right(pat) => Right((Condition(col, "notlike", pat, Nil, lopt, None), after.tail.tail.tail))
        else Left("expected IN or LIKE after NOT")
      else if tkIsKw(after, "LIKE") then
        if after.length < 2 then Left("LIKE needs a pattern")
        else litValue(after.tail.head) match
          case Left(message) => Left(message)
          case Right(pat) => Right((Condition(col, "like", pat, Nil, lopt, None), after.tail.tail))
      else if tkIsKw(after, "IN") then
        if tkKind(after.tail) == "lparen" && tkIsKw(after.tail.tail, "SELECT") then splitParenGroup(after.tail.tail) match
          case None => Left("unbalanced parentheses in IN subquery")
          case Some(sp) => Right((Condition(col, "insubq", SqlNull, Nil, lopt, None, sp._1), sp._2))
        else parseValueList(after.tail) match
          case Left(message) => Left(message)
          case Right(vl) => Right((Condition(col, "in", SqlNull, vl._1, lopt, None), vl._2))
      else if tkIsKw(after, "BETWEEN") then
        if after.length < 4 then Left("BETWEEN needs: col BETWEEN lo AND hi")
        else if !tkIsKw(after.tail.tail, "AND") then Left("expected AND in BETWEEN")
        else litValue(after.tail.head) match
          case Left(message) => Left(message)
          case Right(lo) => litValue(after.tail.tail.tail.head) match
            case Left(message) => Left(message)
            case Right(hi) => Right((Condition(col, "between", SqlNull, lo :: hi :: Nil, lopt, None), after.tail.tail.tail.tail))
      else if tkKind(after) != "op" then
        // A bare boolean expression, e.g. `WHERE flag` or `WHERE CASE … END` — kept as a
        // truthiness test (non-zero / numeric-looking); the tokens after it are left for the
        // AND/OR chain. Only a compound left side lands here (a bare column is `col`, `leftExpr`).
        Right((Condition(col, "truthy", SqlNull, Nil, lopt, None), after))
      else
        val op = after.head
        if tkKind(after.tail) == "lparen" && tkIsKw(after.tail.tail, "SELECT") then splitParenGroup(after.tail.tail) match
          case None => Left("unbalanced parentheses in scalar subquery")
          case Some(sp) => Right((Condition(col, op.text, SqlNull, Nil, lopt, None, sp._1), sp._2))
        else parseExprAdd(after.tail) match
          case Left(message) => Left(message)
          case Right(re) =>
            val rnode = re._1
            val rval = rnode match
              case SxLit(v) => v
              case _ => SqlNull
            val ropt = rnode match
              case SxLit(_) => None
              case _ => Some(rnode)
            Right((Condition(col, op.text, rval, Nil, lopt, ropt), re._2))

def reverseConds(items: List[Condition], acc: List[Condition]): List[Condition] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

def reverseCondGroups(items: List[List[Condition]], acc: List[List[Condition]]): List[List[Condition]] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

// A chain of conditions joined by AND / OR → OR-of-ANDs (AND binds tighter than OR).
def parseConditionChain(toks: List[Token]): Either[String, (List[List[Condition]], List[Token])] =
  parseCondition(toks) match
    case Left(message) => Left(message)
    case Right(first) =>
      var groupsRev: List[List[Condition]] = Nil
      var curRev: List[Condition] = first._1 :: Nil
      var rest = first._2
      var err: Option[String] = None
      var done = false
      while !done && err.isEmpty do
        if tkIsKw(rest, "AND") then
          parseCondition(rest.tail) match
            case Left(message) => err = Some(message)
            case Right(next) =>
              curRev = next._1 :: curRev
              rest = next._2
        else if tkIsKw(rest, "OR") then
          groupsRev = reverseConds(curRev, Nil) :: groupsRev
          parseCondition(rest.tail) match
            case Left(message) => err = Some(message)
            case Right(next) =>
              curRev = next._1 :: Nil
              rest = next._2
        else done = true
      err match
        case Some(message) => Left(message)
        case None => Right((reverseCondGroups(reverseConds(curRev, Nil) :: groupsRev, Nil), rest))

// Optional `WHERE <condition chain>`; an empty result means no filter.
def parseWhere(toks: List[Token]): Either[String, (List[List[Condition]], List[Token])] =
  if !tkIsKw(toks, "WHERE") then Right((Nil, toks))
  else parseConditionChain(toks.tail)

// An ORDER BY key: a scalar expression (a bare column is just `SxCol`) and its direction.
case class OrderKey(expr: SxNode, desc: Boolean)

def reverseKeys(items: List[OrderKey], acc: List[OrderKey]): List[OrderKey] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

// Parse optional `ORDER BY col [ASC|DESC] [, col [ASC|DESC]]*` then optional
// `LIMIT n [OFFSET m]`. Returns the order keys (empty = none), limit (-1 = none), offset.
def parseOrderLimit(toks: List[Token]): Either[String, (List[OrderKey], Int, Int)] =
  var rest = toks
  var keysRev: List[OrderKey] = Nil
  var limit = -1
  var offset = 0
  var err: Option[String] = None
  if tkIsKw(rest, "ORDER") then
    rest = rest.tail
    if !tkIsKw(rest, "BY") then err = Some("expected BY after ORDER")
    else
      rest = rest.tail
      var moreKeys = true
      while moreKeys && err.isEmpty do
        parseExpr(rest) match
          case Left(message) =>
            err = Some(message)
            moreKeys = false
          case Right(ep) =>
            rest = ep._2
            var desc = false
            if tkIsKw(rest, "DESC") then
              desc = true
              rest = rest.tail
            else if tkIsKw(rest, "ASC") then rest = rest.tail
            else desc = false
            keysRev = OrderKey(ep._1, desc) :: keysRev
            if tkKind(rest) == "comma" then rest = rest.tail
            else moreKeys = false
  if err.isEmpty && tkIsKw(rest, "LIMIT") then
    rest = rest.tail
    if tkKind(rest) != "num" then err = Some("expected a number after LIMIT")
    else
      limit = rest.head.num.toInt
      rest = rest.tail
      if tkIsKw(rest, "OFFSET") then
        rest = rest.tail
        if tkKind(rest) != "num" then err = Some("expected a number after OFFSET")
        else
          offset = rest.head.num.toInt
          rest = rest.tail
  err match
    case Some(message) => Left(message)
    case None => Right((reverseKeys(keysRev, Nil), limit, offset))

// ── Aggregate projection: COUNT(*) / COUNT(col) / SUM / MIN / MAX / AVG / TOTAL ──

case class AggItem(func: String, column: String, distinct: Boolean)

def isAggFunc(name: String): Boolean =
  val u = upperStr(name)
  u == "COUNT" || u == "SUM" || u == "MIN" || u == "MAX" || u == "AVG" || u == "TOTAL"

def isAggStart(toks: List[Token]): Boolean =
  if toks.isEmpty then false
  else if toks.head.kind != "ident" then false
  else if !isAggFunc(toks.head.text) then false
  else tkKind(toks.tail) == "lparen"

def reverseAggs(items: List[AggItem], acc: List[AggItem]): List[AggItem] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

def parseAggregates(toks: List[Token]): Either[String, (List[AggItem], List[Token])] =
  var rest = toks
  var accRev: List[AggItem] = Nil
  var err: Option[String] = None
  var done = false
  while !done && err.isEmpty do
    if tkKind(rest) != "ident" then err = Some("expected an aggregate function")
    else
      val func = rest.head.text
      val afterFunc = rest.tail
      if tkKind(afterFunc) != "lparen" then err = Some("expected '(' after " + func)
      else
        val afterParen = afterFunc.tail
        val argResult: Option[(String, List[Token])] =
          if tkKind(afterParen) == "star" then Some(("*", afterParen.tail))
          else if tkKind(afterParen) == "ident" then Some((afterParen.head.text, afterParen.tail))
          else None
        argResult match
          case None => err = Some("expected a column or * inside the aggregate")
          case Some(argPair) =>
            val afterArg = argPair._2
            if tkKind(afterArg) != "rparen" then err = Some("expected ')' in the aggregate")
            else
              accRev = AggItem(func, argPair._1, false) :: accRev
              val afterRparen = afterArg.tail
              if tkKind(afterRparen) == "comma" then rest = afterRparen.tail
              else
                rest = afterRparen
                done = true
  err match
    case Some(message) => Left(message)
    case None => Right((reverseAggs(accRev, Nil), rest))

// Parse the projection: `*`, an aggregate list, or a plain column / expression list.
// A projection item: a plain column (`isAgg=false`, `name` = column, `expr=None`), an aggregate
// (`isAgg=true`, `func` = COUNT/SUM/…, `name` = its argument column or `*`), or a computed scalar
// expression (`expr=Some(e)`, evaluated per row).
case class ProjItem(isAgg: Boolean, func: String, name: String, distinct: Boolean, expr: Option[SxNode])

def reverseProj(items: List[ProjItem], acc: List[ProjItem]): List[ProjItem] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

// ── Scalar expression parser (precedence: unary -, then * /, then + -) ──

def reverseSxNodes(items: List[SxNode], acc: List[SxNode]): List[SxNode] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

// Parse a comma-separated argument list; `toks` starts just after the `(` and the closing
// `)` is consumed. An empty list (`f()`) is allowed here; each argument is a full expression.
def parseCallArgs(toks: List[Token]): Either[String, (List[SxNode], List[Token])] =
  if tkKind(toks) == "rparen" then Right((Nil, toks.tail))
  else
    var rest = toks
    var accRev: List[SxNode] = Nil
    var err: Option[String] = None
    var done = false
    while !done && err.isEmpty do
      parseExpr(rest) match
        case Left(message) => err = Some(message)
        case Right(ep) =>
          accRev = ep._1 :: accRev
          rest = ep._2
          if tkKind(rest) == "comma" then rest = rest.tail
          else if tkKind(rest) == "rparen" then
            rest = rest.tail
            done = true
          else err = Some("expected ',' or ')' in function arguments")
    err match
      case Some(message) => Left(message)
      case None => Right((reverseSxNodes(accRev, Nil), rest))

def reverseWhens(items: List[SxWhen], acc: List[SxWhen]): List[SxWhen] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

// `CASE [operand] WHEN cond THEN result [WHEN …]* [ELSE result] END`. `toks` starts after CASE.
// With an operand each WHEN value is equality-compared to it (simple form); without, each WHEN
// is a boolean condition (searched form). Conditions/results are full expressions.
def parseCaseWhens(operand: Option[SxNode], toks: List[Token]): Either[String, (SxNode, List[Token])] =
  var rest = toks
  var accRev: List[SxWhen] = Nil
  var err: Option[String] = None
  var done = false
  while !done && err.isEmpty do
    if tkIsKw(rest, "WHEN") then
      parseExpr(rest.tail) match
        case Left(message) => err = Some(message)
        case Right(cnd) =>
          if !tkIsKw(cnd._2, "THEN") then err = Some("expected THEN in CASE")
          else parseExpr(cnd._2.tail) match
            case Left(message) => err = Some(message)
            case Right(res) =>
              accRev = SxWhen(cnd._1, res._1) :: accRev
              rest = res._2
    else done = true
  err match
    case Some(message) => Left(message)
    case None =>
      if accRev.isEmpty then Left("CASE needs at least one WHEN")
      else if tkIsKw(rest, "ELSE") then
        parseExpr(rest.tail) match
          case Left(message) => Left(message)
          case Right(e) =>
            if !tkIsKw(e._2, "END") then Left("expected END in CASE")
            else Right((SxCase(operand, reverseWhens(accRev, Nil), Some(e._1)), e._2.tail))
      else if !tkIsKw(rest, "END") then Left("expected END in CASE")
      else Right((SxCase(operand, reverseWhens(accRev, Nil), None), rest.tail))

def parseCase(toks: List[Token]): Either[String, (SxNode, List[Token])] =
  if tkIsKw(toks, "WHEN") then parseCaseWhens(None, toks)
  else parseExprAdd(toks) match
    case Left(message) => Left(message)
    case Right(op) => parseCaseWhens(Some(op._1), op._2)

def parseExprAtom(toks: List[Token]): Either[String, (SxNode, List[Token])] =
  if tkKind(toks) == "lparen" then
    parseExpr(toks.tail) match
      case Left(message) => Left(message)
      case Right(inner) =>
        if tkKind(inner._2) != "rparen" then Left("expected ')' in expression")
        else Right((inner._1, inner._2.tail))
  else if tkKind(toks) == "op" && tkText(toks) == "-" then
    parseExprAtom(toks.tail) match
      case Left(message) => Left(message)
      case Right(a) => Right((SxNeg(a._1), a._2))
  else if tkIsKw(toks, "CASE") then parseCase(toks.tail)
  else if tkKind(toks) == "num" then Right((SxLit(SqlInteger(toks.head.num)), toks.tail))
  else if tkKind(toks) == "str" then Right((SxLit(SqlText(toks.head.text)), toks.tail))
  else if tkKind(toks) == "real" then toks.head.bound match
    case Some(v) => Right((SxLit(v), toks.tail))
    case None => Left("real token without a value")
  else if tkKind(toks) == "bound" then toks.head.bound match
    case Some(v) => Right((SxLit(v), toks.tail))
    case None => Left("bound token without a value")
  else if tkKind(toks) == "ident" then
    // `COUNT(…)` etc. = an aggregate node; `f(…)` = a scalar function call; else a column.
    if tkKind(toks.tail) == "lparen" then
      if isAggFunc(toks.head.text) then parseAggNode(toks.head.text, toks.tail.tail)
      else parseCallArgs(toks.tail.tail) match
        case Left(message) => Left(message)
        case Right(ap) => Right((SxCall(upperStr(toks.head.text), ap._1), ap._2))
    else Right((SxCol(toks.head.text), toks.tail))
  else Left("expected an expression operand")

// `FUNC( [DISTINCT] (*|column) )` as an expression node; `toks` starts after the `(`.
def parseAggNode(func: String, toks: List[Token]): Either[String, (SxNode, List[Token])] =
  val distinct = tkIsKw(toks, "DISTINCT")
  val afterD = if distinct then toks.tail else toks
  val argRes: Option[(String, List[Token])] =
    if tkKind(afterD) == "star" then Some(("*", afterD.tail))
    else if tkKind(afterD) == "ident" then Some((afterD.head.text, afterD.tail))
    else None
  argRes match
    case None => Left("expected a column or * inside the aggregate")
    case Some(ap) =>
      if tkKind(ap._2) != "rparen" then Left("expected ')' in the aggregate")
      else Right((SxAgg(upperStr(func), ap._1, distinct), ap._2.tail))

// `||` string concatenation binds tighter than `* /` (sqlite precedence), so it sits
// between the multiplicative level and the atoms.
def parseExprConcat(toks: List[Token]): Either[String, (SxNode, List[Token])] =
  parseExprAtom(toks) match
    case Left(message) => Left(message)
    case Right(first) =>
      var acc = first._1
      var rest = first._2
      var err: Option[String] = None
      var done = false
      while !done && err.isEmpty do
        if tkKind(rest) == "op" && tkText(rest) == "||" then
          parseExprAtom(rest.tail) match
            case Left(message) => err = Some(message)
            case Right(nx) =>
              acc = SxBin("||", acc, nx._1)
              rest = nx._2
        else done = true
      err match
        case Some(message) => Left(message)
        case None => Right((acc, rest))

def parseExprMul(toks: List[Token]): Either[String, (SxNode, List[Token])] =
  parseExprConcat(toks) match
    case Left(message) => Left(message)
    case Right(first) =>
      var acc = first._1
      var rest = first._2
      var err: Option[String] = None
      var done = false
      while !done && err.isEmpty do
        val k = tkKind(rest)
        val t = tkText(rest)
        if k == "star" || (k == "op" && (t == "/" || t == "%")) then
          val opStr = if k == "star" then "*" else t
          parseExprConcat(rest.tail) match
            case Left(message) => err = Some(message)
            case Right(nx) =>
              acc = SxBin(opStr, acc, nx._1)
              rest = nx._2
        else done = true
      err match
        case Some(message) => Left(message)
        case None => Right((acc, rest))

def parseExprAdd(toks: List[Token]): Either[String, (SxNode, List[Token])] =
  parseExprMul(toks) match
    case Left(message) => Left(message)
    case Right(first) =>
      var acc = first._1
      var rest = first._2
      var err: Option[String] = None
      var done = false
      while !done && err.isEmpty do
        val k = tkKind(rest)
        val t = tkText(rest)
        if k == "op" && (t == "+" || t == "-") then
          parseExprMul(rest.tail) match
            case Left(message) => err = Some(message)
            case Right(nx) =>
              acc = SxBin(t, acc, nx._1)
              rest = nx._2
        else done = true
      err match
        case Some(message) => Left(message)
        case None => Right((acc, rest))

def isCompareOp(t: String): Boolean =
  t == "=" || t == "==" || t == "<>" || t == "!=" || t == "<" || t == ">" || t == "<=" || t == ">="

// The lowest expression precedence: a single comparison yielding 1/0/NULL (sqlite treats a
// comparison as an expression). WHERE operands deliberately use parseExprAdd (below this) so
// `WHERE a > b` is still parsed by parseCondition rather than swallowed as one expression.
def parseExprCompare(toks: List[Token]): Either[String, (SxNode, List[Token])] =
  parseExprAdd(toks) match
    case Left(message) => Left(message)
    case Right(first) =>
      val rest0 = first._2
      if tkKind(rest0) == "op" && isCompareOp(tkText(rest0)) then
        parseExprAdd(rest0.tail) match
          case Left(message) => Left(message)
          case Right(second) => Right((SxBin(tkText(rest0), first._1, second._1), second._2))
      else Right((first._1, rest0))

// Boolean layers below comparison (sqlite precedence: OR < AND < NOT < comparison).
def parseExprNot(toks: List[Token]): Either[String, (SxNode, List[Token])] =
  if tkIsKw(toks, "NOT") then
    parseExprNot(toks.tail) match
      case Left(message) => Left(message)
      case Right(inner) => Right((SxNot(inner._1), inner._2))
  else parseExprCompare(toks)

def parseExprAnd(toks: List[Token]): Either[String, (SxNode, List[Token])] =
  parseExprNot(toks) match
    case Left(message) => Left(message)
    case Right(first) =>
      var acc = first._1
      var rest = first._2
      var err: Option[String] = None
      var done = false
      while !done && err.isEmpty do
        if tkIsKw(rest, "AND") then
          parseExprNot(rest.tail) match
            case Left(message) => err = Some(message)
            case Right(nx) =>
              acc = SxBin("AND", acc, nx._1)
              rest = nx._2
        else done = true
      err match
        case Some(message) => Left(message)
        case None => Right((acc, rest))

def parseExprOr(toks: List[Token]): Either[String, (SxNode, List[Token])] =
  parseExprAnd(toks) match
    case Left(message) => Left(message)
    case Right(first) =>
      var acc = first._1
      var rest = first._2
      var err: Option[String] = None
      var done = false
      while !done && err.isEmpty do
        if tkIsKw(rest, "OR") then
          parseExprAnd(rest.tail) match
            case Left(message) => err = Some(message)
            case Right(nx) =>
              acc = SxBin("OR", acc, nx._1)
              rest = nx._2
        else done = true
      err match
        case Some(message) => Left(message)
        case None => Right((acc, rest))

def parseExpr(toks: List[Token]): Either[String, (SxNode, List[Token])] = parseExprOr(toks)

def parseProjItem(toks: List[Token]): Either[String, (ProjItem, List[Token])] =
  // Parse the whole item as an expression, then normalize the shape:
  //   a lone column   → plain name-based item (GROUP BY / ORDER BY / DISTINCT still work);
  //   a lone aggregate → the backward-compatible isAgg item (existing group execution);
  //   anything else    → a computed expression (may contain aggregates → group-evaluated).
  parseExpr(toks) match
    case Left(message) => Left(message)
    case Right(ep) => ep._1 match
      case SxCol(nm) => Right((ProjItem(false, "", nm, false, None), ep._2))
      case SxAgg(func, arg, distinct) => Right((ProjItem(true, func, arg, distinct, None), ep._2))
      case other => Right((ProjItem(false, "", "", false, Some(other)), ep._2))

def parseProjectionList(toks: List[Token]): Either[String, (List[ProjItem], List[Token])] =
  var rest = toks
  var accRev: List[ProjItem] = Nil
  var err: Option[String] = None
  var done = false
  while !done && err.isEmpty do
    parseProjItem(rest) match
      case Left(message) => err = Some(message)
      case Right(pair) =>
        accRev = pair._1 :: accRev
        rest = pair._2
        if tkKind(rest) == "comma" then rest = rest.tail
        else done = true
  err match
    case Some(message) => Left(message)
    case None => Right((reverseProj(accRev, Nil), rest))

def parseProjection(toks: List[Token]): Either[String, (Boolean, List[ProjItem], List[Token])] =
  if tkKind(toks) == "star" then Right((true, Nil, toks.tail))
  else parseProjectionList(toks) match
    case Left(message) => Left(message)
    case Right(pair) => Right((false, pair._1, pair._2))

// Parse optional `GROUP BY col [, col]*`; returns the group columns (empty = none).
def parseGroupBy(toks: List[Token]): Either[String, (List[String], List[Token])] =
  if !tkIsKw(toks, "GROUP") then Right((Nil, toks))
  else
    val afterGroup = toks.tail
    if !tkIsKw(afterGroup, "BY") then Left("expected BY after GROUP")
    else
      var rest = afterGroup.tail
      var accRev: List[String] = Nil
      var err: Option[String] = None
      var more = true
      while more && err.isEmpty do
        if tkKind(rest) != "ident" then
          err = Some("expected column after GROUP BY")
          more = false
        else
          accRev = rest.head.text :: accRev
          rest = rest.tail
          if tkKind(rest) == "comma" then rest = rest.tail
          else more = false
      err match
        case Some(message) => Left(message)
        case None => Right((reverseStrings(accRev, Nil), rest))

// Optional `[INNER | LEFT [OUTER]] JOIN ident ON col op col`; returns the join spec + rest.
def parseJoin(toks: List[Token]): Either[String, (Option[JoinSpec], List[Token])] =
  var leftOuter = false
  var rightOuter = false
  var afterKw = toks
  if tkIsKw(afterKw, "LEFT") then
    leftOuter = true
    afterKw = afterKw.tail
    if tkIsKw(afterKw, "OUTER") then afterKw = afterKw.tail
  else if tkIsKw(afterKw, "RIGHT") then
    rightOuter = true
    afterKw = afterKw.tail
    if tkIsKw(afterKw, "OUTER") then afterKw = afterKw.tail
  else if tkIsKw(afterKw, "FULL") then
    leftOuter = true
    rightOuter = true
    afterKw = afterKw.tail
    if tkIsKw(afterKw, "OUTER") then afterKw = afterKw.tail
  else if tkIsKw(afterKw, "INNER") then afterKw = afterKw.tail
  if !tkIsKw(afterKw, "JOIN") then Right((None, toks))
  else
    val afterJoin = afterKw.tail
    if tkKind(afterJoin) != "ident" then Left("expected a table after JOIN")
    else
      val jtable = afterJoin.head.text
      val afterJt = afterJoin.tail
      if !tkIsKw(afterJt, "ON") then Left("expected ON after the JOIN table")
      else
        val afterOn = afterJt.tail
        if afterOn.length < 3 then Left("ON needs: col op col")
        else
          val l = afterOn.head
          val o = afterOn.tail.head
          val rc = afterOn.tail.tail.head
          if l.kind != "ident" then Left("expected a column in ON")
          else if o.kind != "op" then Left("expected a comparison operator in ON")
          else if rc.kind != "ident" then Left("expected a column in ON")
          else Right((Some(JoinSpec(jtable, l.text, o.text, rc.text, leftOuter, rightOuter)), afterOn.tail.tail.tail))

// A chain of JOIN clauses (0, 1, or more) — supports 2-, 3-, … table joins.
def parseJoins(toks: List[Token]): Either[String, (List[JoinSpec], List[Token])] =
  var rest = toks
  var accRev: List[JoinSpec] = Nil
  var err: Option[String] = None
  var done = false
  while !done && err.isEmpty do
    parseJoin(rest) match
      case Left(message) => err = Some(message)
      case Right(jp) => jp._1 match
        case None => done = true
        case Some(spec) =>
          accRev = spec :: accRev
          rest = jp._2
  err match
    case Some(message) => Left(message)
    case None => Right((accRev.reverse, rest))

// Parse optional `HAVING (agg|col) op literal` (evaluated per group after aggregation).
// The HAVING left side is an aggregate or a bare column and must STOP before the comparison
// operator (unlike a projection item, which now parses a full expression incl. comparisons).
def parseHavingItem(toks: List[Token]): Either[String, (ProjItem, List[Token])] =
  // Parse with parseExprAdd (aggregates + arithmetic, NO comparison) so the HAVING item stops
  // before the comparison operator, then normalize its shape like parseProjItem.
  parseExprAdd(toks) match
    case Left(message) => Left(message)
    case Right(ep) => ep._1 match
      case SxCol(nm) => Right((ProjItem(false, "", nm, false, None), ep._2))
      case SxAgg(func, arg, distinct) => Right((ProjItem(true, func, arg, distinct, None), ep._2))
      case other => Right((ProjItem(false, "", "", false, Some(other)), ep._2))

def parseHaving(toks: List[Token]): Either[String, (Option[HavingCond], List[Token])] =
  if !tkIsKw(toks, "HAVING") then Right((None, toks))
  else parseHavingItem(toks.tail) match
    case Left(message) => Left(message)
    case Right(itemPair) =>
      val afterItem = itemPair._2
      if afterItem.length < 2 then Left("HAVING needs: expr op value")
      else
        val op = afterItem.head
        val lit = afterItem.tail.head
        if op.kind != "op" then Left("expected a comparison operator in HAVING")
        else litValue(lit) match
          case Left(message) => Left(message)
          case Right(value) => Right((Some(HavingCond(itemPair._1, op.text, value)), afterItem.tail.tail))

def parseSelect(toks: List[Token]): Either[String, SelectStmt] =
  if !tkIsKw(toks, "SELECT") then Left("expected SELECT")
  else
    val afterSelectKw = toks.tail
    val distinct = tkIsKw(afterSelectKw, "DISTINCT")
    val afterSelect = if distinct || tkIsKw(afterSelectKw, "ALL") then afterSelectKw.tail else afterSelectKw
    parseProjection(afterSelect) match
      case Left(message) => Left(message)
      case Right(proj) =>
        val afterCols = proj._3
        if !tkIsKw(afterCols, "FROM") then
          // `SELECT <exprs>` with no FROM → a single computed row (table = "").
          Right(SelectStmt(proj._1, proj._2, "", Nil, Nil, -1, 0, Nil, Nil, None, distinct))
        else
          val afterFrom = afterCols.tail
          if tkKind(afterFrom) != "ident" then Left("expected table name")
          else parseJoins(afterFrom.tail) match
            case Left(message) => Left(message)
            case Right(jpair) => parseWhere(jpair._2) match
              case Left(message) => Left(message)
              case Right(wpair) => parseGroupBy(wpair._2) match
                case Left(message) => Left(message)
                case Right(gpair) => parseHaving(gpair._2) match
                  case Left(message) => Left(message)
                  case Right(hpair) => parseOrderLimit(hpair._2) match
                    case Left(message) => Left(message)
                    case Right(ol) => Right(SelectStmt(proj._1, proj._2, afterFrom.head.text, wpair._1, ol._1, ol._2, ol._3, gpair._1, jpair._1, hpair._1, distinct))

// ── Column names from the table's CREATE TABLE text ──

/** Column names of a `CREATE TABLE t(col type, …)` statement: the first identifier of
 *  each top-level (paren-depth 1) comma group after the opening `(`. */
def tableColumns(sql: String): List[String] =
  tokenize(sql) match
    case Left(_) => Nil
    case Right(toks) =>
      var r = toks
      // advance to the first '('
      while r.nonEmpty && tkKind(r) != "lparen" do r = r.tail
      if r.isEmpty then Nil
      else
        r = r.tail
        var depth = 1
        var expectName = true
        var accRev: List[String] = Nil
        while r.nonEmpty && depth > 0 do
          val t = r.head
          if t.kind == "lparen" then depth = depth + 1
          else if t.kind == "rparen" then depth = depth - 1
          else if t.kind == "comma" && depth == 1 then expectName = true
          else if depth == 1 && expectName && t.kind == "ident" then
            accRev = t.text :: accRev
            expectName = false
          if depth > 0 then r = r.tail
        reverseStrings(accRev, Nil)

// A column whose declared type is exactly `INTEGER PRIMARY KEY [AUTOINCREMENT]` is an alias for the
// rowid (SQLite semantics): its value IS the rowid. `INT`/`BIGINT PRIMARY KEY` do NOT qualify.
def isIpkType(idents: List[String]): Boolean =
  if idents.isEmpty then false
  else if upperStr(idents.head) != "INTEGER" then false
  else
    val rest = idents.tail
    if rest.isEmpty then false
    else if upperStr(rest.head) != "PRIMARY" then false
    else
      val rest2 = rest.tail
      if rest2.isEmpty then false
      else upperStr(rest2.head) == "KEY"

// 0-based index of the INTEGER PRIMARY KEY column in a CREATE TABLE, or -1 if none. Scans column
// definitions like tableColumns, but also collects each column's post-name type/constraint idents.
def ipkColumnIndex(sql: String): Int =
  tokenize(sql) match
    case Left(_) => -1
    case Right(toks) =>
      var r = toks
      while r.nonEmpty && tkKind(r) != "lparen" do r = r.tail
      if r.isEmpty then -1
      else
        r = r.tail
        var depth = 1
        var colIdx = -1
        var expectName = true
        var haveName = false
        var typeRev: List[String] = Nil
        var result = -1
        while r.nonEmpty && depth > 0 && result < 0 do
          val t = r.head
          if t.kind == "lparen" then depth = depth + 1
          else if t.kind == "rparen" then
            depth = depth - 1
            if depth == 0 && haveName && isIpkType(reverseStrings(typeRev, Nil)) then result = colIdx
          else if t.kind == "comma" && depth == 1 then
            if haveName && isIpkType(reverseStrings(typeRev, Nil)) then result = colIdx
            expectName = true
            haveName = false
            typeRev = Nil
          else if depth == 1 && expectName && t.kind == "ident" then
            colIdx = colIdx + 1
            expectName = false
            haveName = true
          else if depth == 1 && haveName && t.kind == "ident" then
            typeRev = t.text :: typeRev
          if depth > 0 then r = r.tail
        result

// ── INTEGER PRIMARY KEY = rowid alias: materialise the rowid into the IPK column ──
//
// In real SQLite an INTEGER PRIMARY KEY column is an ALIAS for the rowid: the record stores NULL for
// it and the value lives in the rowid, so every read of that column returns the rowid and the stored
// field is IGNORED. Without this, a file written by real SQLite reads back NULL (→ 0 through the
// typed getters) for every IPK column — silent wrong data (BUGS.md scljet-ipk-rowid-alias-not-substituted).
//
// The substitution happens ONCE per query, on the decoded row set, so every downstream reader —
// projection, WHERE, ORDER BY, GROUP BY, aggregates, joins, DISTINCT — goes through `fieldValueAt`
// and sees the rowid without any of them needing to know about the alias.
//
// Only the DECODED value is replaced; `serialType` and `encoded` are carried over from the original
// field untouched, so `reconstructRecordBytes` (which rebuilds the on-disk payload from exactly those
// two) still reproduces the original bytes. A normalized record is therefore safe to hand to the
// write path — it cannot corrupt a re-encode.
def ipkSubstituteField(fields: List[RecordField], idx: Int, id: Long): List[RecordField] =
  var r = fields
  var i = 0
  var accRev: List[RecordField] = Nil
  while r.nonEmpty do
    val f = r.head
    accRev = (if i == idx then RecordField(f.serialType, f.encoded, Some(SqlInteger(id)), None) else f) :: accRev
    i = i + 1
    r = r.tail
  reverseFields(accRev, Nil)

def reverseFields(items: List[RecordField], acc: List[RecordField]): List[RecordField] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

// One row: replace the IPK column's decoded value with the rowid. A record with no rowid (not a
// rowid table) or too few fields to hold `ipkIdx` is returned unchanged.
def ipkNormalizeRecord(rec: StorageRecord, ipkIdx: Int): StorageRecord =
  if ipkIdx < 0 || ipkIdx >= rec.record.fields.length then rec
  else rec.rowid match
    case None => rec
    case Some(id) =>
      StorageRecord(Some(id), DecodedRecord(rec.record.headerBytes, rec.record.bodyBytes,
        ipkSubstituteField(rec.record.fields, ipkIdx, id)))

def ipkNormalizeRows(rows: List[StorageRecord], ipkIdx: Int): List[StorageRecord] =
  if ipkIdx < 0 then rows
  else
    var r = rows
    var accRev: List[StorageRecord] = Nil
    while r.nonEmpty do
      accRev = ipkNormalizeRecord(r.head, ipkIdx) :: accRev
      r = r.tail
    reverseRecords(accRev, Nil)

def reverseRecords(items: List[StorageRecord], acc: List[StorageRecord]): List[StorageRecord] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

// ── Executor ──

def sqlOptions(): SqliteOpenOptions = SqliteOpenOptions(OpenReadOnly, StrictSqlite, JournalDelete, SyncFull, 0L, 16, false,
  SqliteLimits(1000000L, 100, 100, 100, 100, 10, 1000000L, 100, 100, 1000L, 1000000L, 2, 1000L, 100, 1000000L))

def cpToString(cps: List[Int]): String =
  var r = cps
  var s = ""
  while r.nonEmpty do
    s = s + r.head.toChar.toString
    r = r.tail
  s

def columnIndex(colNames: List[String], name: String): Int =
  val target = upperStr(name)
  var r = colNames
  var i = 0
  var found = -1
  while r.nonEmpty && found < 0 do
    if upperStr(r.head) == target then found = i
    i = i + 1
    r = r.tail
  found

// Drop a table qualifier (`t.col` → `col`); in a single-table query any qualifier refers to that table.
def stripQualifier(name: String): String =
  val d = indexOfDot(name)
  if d < 0 then name else substr(name, d + 1, name.length)

/** The value of column `name` in a row (`rowid` is the implicit rowid; a `t.col` qualifier is dropped). */
def rowValue(rec: StorageRecord, colNames: List[String], name: String): SqliteValue =
  val bare = stripQualifier(name)
  if upperStr(bare) == "ROWID" then
    rec.rowid match
      case Some(id) => SqlInteger(id)
      case None => SqlNull
  else
    val idx = columnIndex(colNames, bare)
    if idx < 0 then SqlNull else fieldValueAt(rec.record, idx)

// ── Scalar expression evaluation (SQL numeric arithmetic) ──

def isIntValue(v: SqliteValue): Boolean = v match
  case SqlInteger(_) => true
  case _ => false

def intPayload(v: SqliteValue): Long = v match
  case SqlInteger(x) => x
  case _ => 0L

// Long arithmetic seeded from a `0L`/`1L` literal so the ssc→JS backend emits its BigInt-safe
// `_arith` path (native `x op y` would fail when a DB-decoded small int is a JS Number and the
// other operand a BigInt literal — the same reason SUM accumulates via `intSum + x`).
def longAdd(a: Long, b: Long): Long =
  var s = 0L
  s = s + a
  s = s + b
  s

def longSub(a: Long, b: Long): Long =
  var s = 0L
  s = s + a
  s = s - b
  s

def longMul(a: Long, b: Long): Long =
  var s = 1L
  s = s * a
  s = s * b
  s

def longDiv(a: Long, b: Long): Long =
  var s = 0L
  s = s + a
  s = s / b
  s

def longMod(a: Long, b: Long): Long =
  var s = 0L
  s = s + a
  s = s % b
  s

def longIsZero(a: Long): Boolean =
  var s = 0L
  s = s + a
  s == 0L

// Value → Long for integer modulo: exact for integers, truncating for reals (sqlite converts
// `%` operands to integers). The real path parses the integer part of the text form (BigInt-safe).
def toLongVal(v: SqliteValue): Long =
  if isIntValue(v) then intPayload(v)
  else
    var s = 0L
    s = s + parseIntStr(coerceText(v))
    s

// Value → Double via the same accumulation the working AVG/SUM use (`d + x.toDouble`).
def realOf(v: SqliteValue): Double =
  var d = 0.0
  v match
    case SqlInteger(x) => d = d + x.toDouble
    case SqlReal(x) => d = d + x
    case _ => d = d
  d

def negateValue(v: SqliteValue): SqliteValue = v match
  case SqlInteger(x) => SqlInteger(0L - x)
  case SqlReal(x) => SqlReal(0.0 - x)
  case _ => SqlNull

// `||` string concatenation: NULL if either side is NULL, else the text forms joined.
def concatValue(a: SqliteValue, b: SqliteValue): SqliteValue =
  if isNullValue(a) || isNullValue(b) then SqlNull
  else SqlText(coerceText(a) + coerceText(b))

// A comparison as a value: 1/0, or NULL if either side is NULL (sqlite semantics).
def compareValue(op: String, a: SqliteValue, b: SqliteValue): SqliteValue =
  if isNullValue(a) || isNullValue(b) then SqlNull
  else
    val nop = if op == "==" then "=" else op
    if condMatches(nop, sqlCompare(a, b)) then SqlInteger(1L) else SqlInteger(0L)

// Truthiness for CASE searched WHEN / boolean context: non-zero number (or numeric-looking text).
def isTruthy(v: SqliteValue): Boolean = v match
  case SqlInteger(x) => x != 0L
  case SqlReal(x) => x != 0.0
  case SqlText(s) => parseIntStr(s) != 0
  case _ => false

// Three-valued boolean: -1 = NULL/unknown, 0 = false, 1 = true.
def boolState(v: SqliteValue): Int =
  if isNullValue(v) then -1 else if isTruthy(v) then 1 else 0

def andValue(a: SqliteValue, b: SqliteValue): SqliteValue =
  val af = boolState(a)
  val bf = boolState(b)
  if af == 0 || bf == 0 then SqlInteger(0L)
  else if af < 0 || bf < 0 then SqlNull
  else SqlInteger(1L)

def orValue(a: SqliteValue, b: SqliteValue): SqliteValue =
  val af = boolState(a)
  val bf = boolState(b)
  if af == 1 || bf == 1 then SqlInteger(1L)
  else if af < 0 || bf < 0 then SqlNull
  else SqlInteger(0L)

def notValue(v: SqliteValue): SqliteValue =
  if isNullValue(v) then SqlNull
  else if isTruthy(v) then SqlInteger(0L) else SqlInteger(1L)

// Arithmetic: integer result when both operands are integers (with truncating integer
// division), otherwise real; NULL if either operand is NULL or on divide-by-zero (as sqlite).
// `||` (concat) and comparisons (→ 1/0/NULL) are handled first, before the numeric ops.
def arithValue(op: String, a: SqliteValue, b: SqliteValue): SqliteValue =
  if op == "||" then concatValue(a, b)
  else if op == "AND" then andValue(a, b)
  else if op == "OR" then orValue(a, b)
  else if isCompareOp(op) then compareValue(op, a, b)
  else if isNullValue(a) || isNullValue(b) then SqlNull
  else if op == "%" then
    // Modulo is always integer in sqlite (operands converted); NULL on a zero divisor.
    val y = toLongVal(b)
    if longIsZero(y) then SqlNull else SqlInteger(longMod(toLongVal(a), y))
  else if isIntValue(a) && isIntValue(b) then
    val x = intPayload(a)
    val y = intPayload(b)
    if op == "+" then SqlInteger(longAdd(x, y))
    else if op == "-" then SqlInteger(longSub(x, y))
    else if op == "*" then SqlInteger(longMul(x, y))
    else if longIsZero(y) then SqlNull
    else SqlInteger(longDiv(x, y))
  else
    val x = realOf(a)
    val y = realOf(b)
    if op == "+" then SqlReal(x + y)
    else if op == "-" then SqlReal(x - y)
    else if op == "*" then SqlReal(x * y)
    else if y == 0.0 then SqlNull
    else SqlReal(x / y)

def absValue(v: SqliteValue): SqliteValue = v match
  case SqlInteger(x) => if x < 0L then SqlInteger(0L - x) else SqlInteger(x)
  case SqlReal(x) => if x < 0.0 then SqlReal(0.0 - x) else SqlReal(x)
  case _ => SqlNull

def firstNonNull(args: List[SqliteValue]): SqliteValue =
  var r = args
  var found: SqliteValue = SqlNull
  var done = false
  while r.nonEmpty && !done do
    if isNullValue(r.head) then r = r.tail
    else
      found = r.head
      done = true
  found

def argAt(args: List[SqliteValue], idx: Int): SqliteValue = listNth(args, idx)

// Numeric value as a plain Int for string indexing. We parse the digits from the TEXT form
// with plain Int arithmetic (no BigInt): `Long.toInt` mislowers to `Math.trunc(BigInt)` and
// `.toDouble` lowers unpredictably (identity vs dispatch) — both crash on JS since a DB int can
// be a JS Number while a literal is a BigInt. `n = n*10 + digit` stays in JS Number arithmetic.
def parseIntStr(s: String): Int =
  var i = 0
  var neg = false
  if charCode(s, 0) == 45 then
    neg = true
    i = 1
  var n = 0
  var done = false
  while i < s.length && !done do
    val c = charCode(s, i)
    if c >= 48 && c <= 57 then
      n = n * 10 + (c - 48)
      i = i + 1
    else done = true
  if neg then 0 - n else n

def toIntVal(v: SqliteValue): Int = parseIntStr(coerceText(v))

// chars 0-based [lo, hi) as a new string (empty if lo >= hi).
def sliceStr(s: String, lo: Int, hi: Int): String =
  var i = lo
  var out = ""
  while i < hi do
    out = out + s.charAt(i).toString
    i = i + 1
  out

// SUBSTR(s, y[, z]) — 1-based; y<0 counts from the right; the kept window is the 1-based
// indices in [y, y+z) (or [y, n] with no z), clamped to the string. charCode is bounds-safe.
def substrValue(s: String, yIn: Int, hasLen: Boolean, z: Int): String =
  val n = s.length
  val y = if yIn < 0 then n + yIn + 1 else yIn
  val lo = if y < 1 then 1 else y
  val hiRaw = if hasLen then y + z - 1 else n
  val hi = if hiRaw > n then n else hiRaw
  sliceStr(s, lo - 1, hi)

def charInSet(c: Int, chars: String): Boolean =
  var i = 0
  var found = false
  while i < chars.length && !found do
    if charCode(chars, i) == c then found = true
    i = i + 1
  found

def ltrimCount(s: String, chars: String): Int =
  var i = 0
  while i < s.length && charInSet(charCode(s, i), chars) do i = i + 1
  i

def rtrimEnd(s: String, chars: String): Int =
  var j = s.length
  while j > 0 && charInSet(charCode(s, j - 1), chars) do j = j - 1
  j

def matchesAt(s: String, at: Int, sub: String): Boolean =
  var k = 0
  var ok = true
  while k < sub.length && ok do
    if charCode(s, at + k) != charCode(sub, k) then ok = false
    k = k + 1
  ok

def replaceStr(s: String, from: String, to: String): String =
  if from.length == 0 then s
  else
    val n = s.length
    val fn = from.length
    var i = 0
    var out = ""
    while i < n do
      if matchesAt(s, i, from) then
        out = out + to
        i = i + fn
      else
        out = out + s.charAt(i).toString
        i = i + 1
    out

// TRIM / LTRIM / RTRIM with an optional trim-char set (default a single space).
def trimFn(args: List[SqliteValue], doLeft: Boolean, doRight: Boolean): SqliteValue =
  val a = argAt(args, 0)
  if isNullValue(a) then SqlNull
  else if args.length >= 2 && isNullValue(argAt(args, 1)) then SqlNull
  else
    val s = coerceText(a)
    val chars = if args.length >= 2 then coerceText(argAt(args, 1)) else " "
    val lo = if doLeft then ltrimCount(s, chars) else 0
    val hi = if doRight then rtrimEnd(s, chars) else s.length
    SqlText(sliceStr(s, lo, hi))

// Scalar SQL functions over already-evaluated argument values. NULL argument → NULL
// (except COALESCE, which returns the first non-null); `func` is upper-cased at parse time.
def evalCall(func: String, args: List[SqliteValue]): SqliteValue =
  val f = upperStr(func)
  if f == "UPPER" then
    val a = argAt(args, 0)
    if isNullValue(a) then SqlNull else SqlText(upperStr(coerceText(a)))
  else if f == "LOWER" then
    val a = argAt(args, 0)
    if isNullValue(a) then SqlNull else SqlText(lowerStr(coerceText(a)))
  else if f == "LENGTH" then
    val a = argAt(args, 0)
    if isNullValue(a) then SqlNull else SqlInteger(coerceText(a).length.toLong)
  else if f == "ABS" then absValue(argAt(args, 0))
  else if f == "COALESCE" then firstNonNull(args)
  else if f == "SUBSTR" || f == "SUBSTRING" then
    val a = argAt(args, 0)
    if isNullValue(a) then SqlNull
    else
      val s = coerceText(a)
      val y = toIntVal(argAt(args, 1))
      if args.length >= 3 then SqlText(substrValue(s, y, true, toIntVal(argAt(args, 2))))
      else SqlText(substrValue(s, y, false, 0))
  else if f == "TRIM" then trimFn(args, true, true)
  else if f == "LTRIM" then trimFn(args, true, false)
  else if f == "RTRIM" then trimFn(args, false, true)
  else if f == "REPLACE" then
    val a = argAt(args, 0)
    val b = argAt(args, 1)
    val cc = argAt(args, 2)
    if isNullValue(a) || isNullValue(b) || isNullValue(cc) then SqlNull
    else SqlText(replaceStr(coerceText(a), coerceText(b), coerceText(cc)))
  else SqlNull

def evalArgs(args: List[SxNode], rec: StorageRecord, colNames: List[String]): List[SqliteValue] =
  var r = args
  var accRev: List[SqliteValue] = Nil
  while r.nonEmpty do
    accRev = evalExpr(r.head, rec, colNames) :: accRev
    r = r.tail
  reverseValues(accRev, Nil)

// CASE over a single-table row: pick the first matching WHEN (operand-equality for the simple
// form, truthiness for the searched form), else the ELSE result, else NULL.
def evalCaseSingle(operand: Option[SxNode], whens: List[SxWhen], elseExpr: Option[SxNode], rec: StorageRecord, colNames: List[String]): SqliteValue =
  var r = whens
  var out: Option[SqliteValue] = None
  operand match
    case Some(opExpr) =>
      val opVal = evalExpr(opExpr, rec, colNames)
      while r.nonEmpty && out.isEmpty do
        if sqlCompare(opVal, evalExpr(r.head.cond, rec, colNames)) == 0 then out = Some(evalExpr(r.head.result, rec, colNames))
        r = r.tail
    case None =>
      while r.nonEmpty && out.isEmpty do
        if isTruthy(evalExpr(r.head.cond, rec, colNames)) then out = Some(evalExpr(r.head.result, rec, colNames))
        r = r.tail
  out match
    case Some(v) => v
    case None => elseExpr match
      case Some(e) => evalExpr(e, rec, colNames)
      case None => SqlNull

def evalExpr(e: SxNode, rec: StorageRecord, colNames: List[String]): SqliteValue = e match
  case SxCol(name) => rowValue(rec, colNames, name)
  case SxLit(v) => v
  case SxNeg(inner) => negateValue(evalExpr(inner, rec, colNames))
  case SxBin(op, l, r) => arithValue(op, evalExpr(l, rec, colNames), evalExpr(r, rec, colNames))
  case SxCall(func, args) => evalCall(func, evalArgs(args, rec, colNames))
  case SxNot(inner) => notValue(evalExpr(inner, rec, colNames))
  case SxAgg(_, _, _) => SqlNull
  case SxCase(operand, whens, elseExpr) => evalCaseSingle(operand, whens, elseExpr, rec, colNames)

// Same evaluation over a join row: column references resolve across both tables (qualified or bare).
def evalArgsJoin(args: List[SxNode], recA: StorageRecord, colsA: List[String], tableA: String, recBOpt: Option[StorageRecord], colsB: List[String], tableB: String): List[SqliteValue] =
  var r = args
  var accRev: List[SqliteValue] = Nil
  while r.nonEmpty do
    accRev = evalExprJoin(r.head, recA, colsA, tableA, recBOpt, colsB, tableB) :: accRev
    r = r.tail
  reverseValues(accRev, Nil)

def evalCaseJoin(operand: Option[SxNode], whens: List[SxWhen], elseExpr: Option[SxNode], recA: StorageRecord, colsA: List[String], tableA: String, recBOpt: Option[StorageRecord], colsB: List[String], tableB: String): SqliteValue =
  var r = whens
  var out: Option[SqliteValue] = None
  operand match
    case Some(opExpr) =>
      val opVal = evalExprJoin(opExpr, recA, colsA, tableA, recBOpt, colsB, tableB)
      while r.nonEmpty && out.isEmpty do
        if sqlCompare(opVal, evalExprJoin(r.head.cond, recA, colsA, tableA, recBOpt, colsB, tableB)) == 0 then out = Some(evalExprJoin(r.head.result, recA, colsA, tableA, recBOpt, colsB, tableB))
        r = r.tail
    case None =>
      while r.nonEmpty && out.isEmpty do
        if isTruthy(evalExprJoin(r.head.cond, recA, colsA, tableA, recBOpt, colsB, tableB)) then out = Some(evalExprJoin(r.head.result, recA, colsA, tableA, recBOpt, colsB, tableB))
        r = r.tail
  out match
    case Some(v) => v
    case None => elseExpr match
      case Some(e) => evalExprJoin(e, recA, colsA, tableA, recBOpt, colsB, tableB)
      case None => SqlNull

def evalExprJoin(e: SxNode, recA: StorageRecord, colsA: List[String], tableA: String, recBOpt: Option[StorageRecord], colsB: List[String], tableB: String): SqliteValue = e match
  case SxCol(name) => joinColValue(recA, colsA, tableA, recBOpt, colsB, tableB, name)
  case SxLit(v) => v
  case SxNeg(inner) => negateValue(evalExprJoin(inner, recA, colsA, tableA, recBOpt, colsB, tableB))
  case SxBin(op, l, r) => arithValue(op, evalExprJoin(l, recA, colsA, tableA, recBOpt, colsB, tableB), evalExprJoin(r, recA, colsA, tableA, recBOpt, colsB, tableB))
  case SxCall(func, args) => evalCall(func, evalArgsJoin(args, recA, colsA, tableA, recBOpt, colsB, tableB))
  case SxNot(inner) => notValue(evalExprJoin(inner, recA, colsA, tableA, recBOpt, colsB, tableB))
  case SxAgg(_, _, _) => SqlNull
  case SxCase(operand, whens, elseExpr) => evalCaseJoin(operand, whens, elseExpr, recA, colsA, tableA, recBOpt, colsB, tableB)

// Compare two values for WHERE: numeric if both numeric, text if both text, else by
// storage-class order (NULL < number < text < blob).
def valueClassOf(v: SqliteValue): Int = v match
  case SqlNull => 0
  case SqlInteger(_) => 1
  case SqlReal(_) => 1
  case SqlText(_) => 2
  case SqlBlob(_) => 3

def numOf(v: SqliteValue): Double = v match
  case SqlInteger(x) => x.toDouble
  case SqlReal(x) => x
  case _ => 0.0

def textOf(v: SqliteValue): String = v match
  case SqlText(s) => s
  case _ => ""

def sqlCompare(a: SqliteValue, b: SqliteValue): Int =
  val ca = valueClassOf(a)
  val cb = valueClassOf(b)
  if ca != cb then (if ca < cb then -1 else 1)
  else if ca == 1 then
    val na = numOf(a)
    val nb = numOf(b)
    if na < nb then -1 else if na > nb then 1 else 0
  else if ca == 2 then
    val ta = textOf(a)
    val tb = textOf(b)
    if ta < tb then -1 else if ta > tb then 1 else 0
  else 0

def condMatches(op: String, cmp: Int): Boolean =
  if op == "=" then cmp == 0
  else if op == "<>" || op == "!=" then cmp != 0
  else if op == "<" then cmp < 0
  else if op == ">" then cmp > 0
  else if op == "<=" then cmp <= 0
  else if op == ">=" then cmp >= 0
  else false

def isNullValue(v: SqliteValue): Boolean = v match
  case SqlNull => true
  case _ => false

def valueInList(v: SqliteValue, values: List[SqliteValue]): Boolean =
  var r = values
  var found = false
  while r.nonEmpty && !found do
    if sqlCompare(v, r.head) == 0 then found = true
    r = r.tail
  found

// Text form of a value for LIKE (sqlite coerces numbers to their text form).
def coerceText(v: SqliteValue): String = v match
  case SqlText(s) => s
  case SqlInteger(x) => x.toString
  case SqlReal(x) => renderReal(x)
  case _ => ""

// SQL LIKE: `%` = any run (incl. empty), `_` = any single char; ASCII case-insensitive,
// no ESCAPE clause. Iterative two-pointer wildcard match with `%`-backtracking. charCode
// is bounds-safe (-1 past end), so the guards work despite the interpreter's non-short-circuit &&.
def likeMatch(textRaw: String, patRaw: String): Boolean =
  val s = upperStr(textRaw)
  val p = upperStr(patRaw)
  val n = s.length
  val m = p.length
  var i = 0
  var j = 0
  var starIdx = -1
  var matchIdx = 0
  var failed = false
  while i < n && !failed do
    val pc = charCode(p, j)
    val sc = charCode(s, i)
    if j < m && (pc == 95 || pc == sc) then
      i = i + 1
      j = j + 1
    else if j < m && pc == 37 then
      starIdx = j
      matchIdx = i
      j = j + 1
    else if starIdx >= 0 then
      j = starIdx + 1
      matchIdx = matchIdx + 1
      i = matchIdx
    else failed = true
  if failed then false
  else
    var jj = j
    while charCode(p, jj) == 37 do jj = jj + 1
    jj == m

// Evaluate one predicate given the already-resolved left value `v` and right value `rv`
// (`rv` is the RHS of a scalar comparison, or the LIKE pattern; unused by IS/BETWEEN/IN).
// Shared by single-table (condHolds) and join (joinCondHolds) evaluation.
def predHolds(cond: Condition, v: SqliteValue, rv: SqliteValue): Boolean =
  if cond.op == "truthy" then isTruthy(v)
  else if cond.op == "isnull" then isNullValue(v)
  else if cond.op == "notnull" then isNullValue(v) == false
  else if cond.op == "between" then
    if isNullValue(v) then false
    else sqlCompare(v, cond.values.head) >= 0 && sqlCompare(v, cond.values.tail.head) <= 0
  else if cond.op == "in" then
    if isNullValue(v) then false else valueInList(v, cond.values)
  else if cond.op == "notin" then
    if isNullValue(v) then false else valueInList(v, cond.values) == false
  else if cond.op == "like" then
    if isNullValue(v) then false else likeMatch(coerceText(v), coerceText(rv))
  else if cond.op == "notlike" then
    if isNullValue(v) then false else likeMatch(coerceText(v), coerceText(rv)) == false
  else condMatches(cond.op, sqlCompare(v, rv))

// The right-hand value of a scalar comparison / LIKE: an expression is evaluated, otherwise
// the parsed literal in `value`.
def condRightSingle(cond: Condition, rec: StorageRecord, colNames: List[String]): SqliteValue =
  cond.rightExpr match
    case Some(e) => evalExpr(e, rec, colNames)
    case None => cond.value

def condLeftSingle(cond: Condition, rec: StorageRecord, colNames: List[String]): SqliteValue =
  cond.leftExpr match
    case Some(e) => evalExpr(e, rec, colNames)
    case None => rowValue(rec, colNames, cond.column)

def condHolds(cond: Condition, rec: StorageRecord, colNames: List[String]): Boolean =
  predHolds(cond, condLeftSingle(cond, rec, colNames), condRightSingle(cond, rec, colNames))

def andGroupHolds(group: List[Condition], rec: StorageRecord, colNames: List[String]): Boolean =
  var r = group
  var all = true
  while r.nonEmpty && all do
    if !condHolds(r.head, rec, colNames) then all = false
    r = r.tail
  all

// where = OR-of-ANDs; an empty clause means no filter (always true).
def whereHolds(where: List[List[Condition]], rec: StorageRecord, colNames: List[String]): Boolean =
  if where.isEmpty then true
  else
    var r = where
    var any = false
    while r.nonEmpty && !any do
      if andGroupHolds(r.head, rec, colNames) then any = true
      r = r.tail
    any

def projItemNames(items: List[ProjItem]): List[String] =
  var r = items
  var accRev: List[String] = Nil
  while r.nonEmpty do
    accRev = r.head.name :: accRev
    r = r.tail
  reverseStrings(accRev, Nil)

// Project a plain (non-aggregate) row: `*` = all columns, else each projection item —
// a bare column by name or a computed scalar expression evaluated against the row.
def projectRow(rec: StorageRecord, colNames: List[String], stmt: SelectStmt): List[SqliteValue] =
  if stmt.star then
    var r = colNames
    var accRev: List[SqliteValue] = Nil
    while r.nonEmpty do
      accRev = rowValue(rec, colNames, r.head) :: accRev
      r = r.tail
    reverseValues(accRev, Nil)
  else
    var r = stmt.projection
    var accRev: List[SqliteValue] = Nil
    while r.nonEmpty do
      val item = r.head
      val v = item.expr match
        case Some(e) => evalExpr(e, rec, colNames)
        case None => rowValue(rec, colNames, item.name)
      accRev = v :: accRev
      r = r.tail
    reverseValues(accRev, Nil)

// Does an expression tree contain an aggregate node anywhere?
def anyExprHasAgg(items: List[SxNode]): Boolean =
  var r = items
  var found = false
  while r.nonEmpty do
    if exprHasAgg(r.head) then found = true
    r = r.tail
  found

def whensHaveAgg(whens: List[SxWhen]): Boolean =
  var r = whens
  var found = false
  while r.nonEmpty do
    if exprHasAgg(r.head.cond) then found = true
    if exprHasAgg(r.head.result) then found = true
    r = r.tail
  found

def optHasAgg(o: Option[SxNode]): Boolean = o match
  case Some(e) => exprHasAgg(e)
  case None => false

def exprHasAgg(e: SxNode): Boolean = e match
  case SxAgg(_, _, _) => true
  case SxNeg(inner) => exprHasAgg(inner)
  case SxNot(inner) => exprHasAgg(inner)
  case SxBin(_, l, r) => exprHasAgg(l) || exprHasAgg(r)
  case SxCall(_, args) => anyExprHasAgg(args)
  case SxCase(operand, whens, elseExpr) => optHasAgg(operand) || whensHaveAgg(whens) || optHasAgg(elseExpr)
  case _ => false

def projItemHasAgg(item: ProjItem): Boolean =
  if item.isAgg then true
  else item.expr match
    case Some(e) => exprHasAgg(e)
    case None => false

def projHasAgg(items: List[ProjItem]): Boolean =
  var r = items
  var found = false
  while r.nonEmpty do
    if projItemHasAgg(r.head) then found = true
    r = r.tail
  found

def groupKeysOf(groupCols: List[String]): List[OrderKey] =
  var r = groupCols
  var accRev: List[OrderKey] = Nil
  while r.nonEmpty do
    accRev = OrderKey(SxCol(r.head), false) :: accRev
    r = r.tail
  reverseKeys(accRev, Nil)

def groupKeyEqual(a: StorageRecord, b: StorageRecord, colNames: List[String], groupCols: List[String]): Boolean =
  var r = groupCols
  var eq = true
  while r.nonEmpty && eq do
    if sqlCompare(rowValue(a, colNames, r.head), rowValue(b, colNames, r.head)) != 0 then eq = false
    r = r.tail
  eq

def reverseGroups(items: List[List[StorageRecord]], acc: List[List[StorageRecord]]): List[List[StorageRecord]] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

// Partition sorted rows into consecutive same-group runs.
def groupPartition(sorted: List[StorageRecord], colNames: List[String], groupCols: List[String]): List[List[StorageRecord]] =
  var r = sorted
  var curRev: List[StorageRecord] = Nil
  var groupsRev: List[List[StorageRecord]] = Nil
  while r.nonEmpty do
    if curRev.isEmpty then curRev = r.head :: Nil
    else if groupKeyEqual(curRev.head, r.head, colNames, groupCols) then curRev = r.head :: curRev
    else
      groupsRev = reverseStorage(curRev, Nil) :: groupsRev
      curRev = r.head :: Nil
    r = r.tail
  val groups = if curRev.nonEmpty then reverseStorage(curRev, Nil) :: groupsRev else groupsRev
  reverseGroups(groups, Nil)

// One output row for a group: each projection item is either an aggregate over the group
// or a bare column (the group's first row's value; NULL for an empty group).
// Evaluate an expression over a GROUP: an aggregate node reduces the whole group, a bare column
// takes the group's first row (sqlite's bare-column-in-aggregate rule), everything else recurses.
def evalArgsGroup(args: List[SxNode], group: List[StorageRecord], colNames: List[String]): List[SqliteValue] =
  var r = args
  var accRev: List[SqliteValue] = Nil
  while r.nonEmpty do
    accRev = evalExprGroup(r.head, group, colNames) :: accRev
    r = r.tail
  reverseValues(accRev, Nil)

def evalCaseGroup(operand: Option[SxNode], whens: List[SxWhen], elseExpr: Option[SxNode], group: List[StorageRecord], colNames: List[String]): SqliteValue =
  var r = whens
  var out: Option[SqliteValue] = None
  operand match
    case Some(opExpr) =>
      val opVal = evalExprGroup(opExpr, group, colNames)
      while r.nonEmpty && out.isEmpty do
        if sqlCompare(opVal, evalExprGroup(r.head.cond, group, colNames)) == 0 then out = Some(evalExprGroup(r.head.result, group, colNames))
        r = r.tail
    case None =>
      while r.nonEmpty && out.isEmpty do
        if isTruthy(evalExprGroup(r.head.cond, group, colNames)) then out = Some(evalExprGroup(r.head.result, group, colNames))
        r = r.tail
  out match
    case Some(v) => v
    case None => elseExpr match
      case Some(e) => evalExprGroup(e, group, colNames)
      case None => SqlNull

def evalExprGroup(e: SxNode, group: List[StorageRecord], colNames: List[String]): SqliteValue = e match
  case SxCol(name) => if group.isEmpty then SqlNull else rowValue(group.head, colNames, name)
  case SxLit(v) => v
  case SxNeg(inner) => negateValue(evalExprGroup(inner, group, colNames))
  case SxBin(op, l, r) => arithValue(op, evalExprGroup(l, group, colNames), evalExprGroup(r, group, colNames))
  case SxCall(func, args) => evalCall(func, evalArgsGroup(args, group, colNames))
  case SxNot(inner) => notValue(evalExprGroup(inner, group, colNames))
  case SxAgg(func, arg, distinct) => computeAgg(AggItem(func, arg, distinct), group, colNames)
  case SxCase(operand, whens, elseExpr) => evalCaseGroup(operand, whens, elseExpr, group, colNames)

def projectGroupRow(group: List[StorageRecord], colNames: List[String], items: List[ProjItem]): List[SqliteValue] =
  var r = items
  var accRev: List[SqliteValue] = Nil
  while r.nonEmpty do
    val item = r.head
    val v = if item.isAgg then computeAgg(AggItem(item.func, item.name, item.distinct), group, colNames)
      else item.expr match
        case Some(e) => evalExprGroup(e, group, colNames)
        case None => if group.isEmpty then SqlNull else rowValue(group.head, colNames, item.name)
    accRev = v :: accRev
    r = r.tail
  reverseValues(accRev, Nil)

def mapGroups(groups: List[List[StorageRecord]], colNames: List[String], items: List[ProjItem]): List[List[SqliteValue]] =
  var r = groups
  var accRev: List[List[SqliteValue]] = Nil
  while r.nonEmpty do
    accRev = projectGroupRow(r.head, colNames, items) :: accRev
    r = r.tail
  var out: List[List[SqliteValue]] = Nil
  while accRev.nonEmpty do
    out = accRev.head :: out
    accRev = accRev.tail
  out

def dropValueRows(rows: List[List[SqliteValue]], n: Int): List[List[SqliteValue]] =
  var r = rows
  var i = 0
  while i < n && r.nonEmpty do
    r = r.tail
    i = i + 1
  r

def takeValueRows(rows: List[List[SqliteValue]], n: Int): List[List[SqliteValue]] =
  var r = rows
  var i = 0
  var accRev: List[List[SqliteValue]] = Nil
  while i < n && r.nonEmpty do
    accRev = r.head :: accRev
    r = r.tail
    i = i + 1
  var out: List[List[SqliteValue]] = Nil
  while accRev.nonEmpty do
    out = accRev.head :: out
    accRev = accRev.tail
  out

def limitValueRows(rows: List[List[SqliteValue]], limit: Int, offset: Int): List[List[SqliteValue]] =
  val afterOffset = dropValueRows(rows, offset)
  if limit < 0 then afterOffset else takeValueRows(afterOffset, limit)

def valEqual(a: SqliteValue, b: SqliteValue): Boolean =
  valueClassOf(a) == valueClassOf(b) && sqlCompare(a, b) == 0

def rowEqual(ra: List[SqliteValue], rb: List[SqliteValue]): Boolean =
  var x = ra
  var y = rb
  var eq = true
  while x.nonEmpty && y.nonEmpty && eq do
    if !valEqual(x.head, y.head) then eq = false
    x = x.tail
    y = y.tail
  eq && x.isEmpty && y.isEmpty

def rowInList(rows: List[List[SqliteValue]], row: List[SqliteValue]): Boolean =
  var r = rows
  var found = false
  while r.nonEmpty && !found do
    if rowEqual(r.head, row) then found = true
    r = r.tail
  found

// Remove duplicate result rows, keeping first appearance (NULLs compare equal).
def dedupRows(rows: List[List[SqliteValue]]): List[List[SqliteValue]] =
  var r = rows
  var seenRev: List[List[SqliteValue]] = Nil
  while r.nonEmpty do
    if !rowInList(seenRev, r.head) then seenRev = r.head :: seenRev
    r = r.tail
  var out: List[List[SqliteValue]] = Nil
  while seenRev.nonEmpty do
    out = seenRev.head :: out
    seenRev = seenRev.tail
  out

// HAVING: evaluate the aggregate/column expression over the group, compare to the literal.
def havingHolds(having: Option[HavingCond], group: List[StorageRecord], colNames: List[String]): Boolean = having match
  case None => true
  case Some(hc) =>
    val lv = if hc.item.isAgg then computeAgg(AggItem(hc.item.func, hc.item.name, hc.item.distinct), group, colNames)
      else hc.item.expr match
        case Some(e) => evalExprGroup(e, group, colNames)
        case None => if group.isEmpty then SqlNull else rowValue(group.head, colNames, hc.item.name)
    condMatches(hc.op, sqlCompare(lv, hc.value))

def filterGroups(groups: List[List[StorageRecord]], having: Option[HavingCond], colNames: List[String]): List[List[StorageRecord]] =
  var r = groups
  var accRev: List[List[StorageRecord]] = Nil
  while r.nonEmpty do
    if havingHolds(having, r.head, colNames) then accRev = r.head :: accRev
    r = r.tail
  reverseGroups(accRev, Nil)

// Like collectRows, but returns at most `maxRows` rows that satisfy `where`, stopping the scan as
// soon as that many matches are found. For a LIMIT query with no ORDER BY / aggregate / DISTINCT the
// output order is scan order, so the first `offset+limit` matches are exactly what the full scan
// would keep — identical result, but the table tail is never read (LIMIT pushdown / early exit).
// `ipkIdx` (-1 = none) is the INTEGER PRIMARY KEY column: each row is IPK-normalized (rowid
// materialised into that column) BEFORE the WHERE is applied, so a filter on the IPK matches.
def collectRowsLimited(db: ReadonlyDatabase, cursor: ReadonlyBtreeCursor, where: List[List[Condition]], colNames: List[String], maxRows: Int, ipkIdx: Int): Either[SqliteError, List[StorageRecord]] =
  readonlyFirst(db, cursor) match
    case Left(error) => Left(error)
    case Right(firstStep) =>
      var d = firstStep.database
      var c = firstStep.cursor
      var row = firstStep.row
      var accRev: List[StorageRecord] = Nil
      var count = 0
      var err: Option[SqliteError] = None
      var done = false
      if maxRows <= 0 then done = true
      while !done && err.isEmpty do
        row match
          case None => done = true
          case Some(rec0) =>
            val rec = ipkNormalizeRecord(rec0, ipkIdx)
            val matched = whereHolds(where, rec, colNames)
            accRev = if matched then rec :: accRev else accRev
            count = if matched then count + 1 else count
            if count >= maxRows then done = true
            else readonlyNext(d, c) match
              case Left(error) => err = Some(error)
              case Right(step) =>
                d = step.database
                c = step.cursor
                row = step.row
      err match
        case Some(error) => Left(error)
        case None => Right(accRev.reverse)

def collectRows(db: ReadonlyDatabase, cursor: ReadonlyBtreeCursor): Either[SqliteError, List[StorageRecord]] =
  readonlyFirst(db, cursor) match
    case Left(error) => Left(error)
    case Right(firstStep) =>
      var d = firstStep.database
      var c = firstStep.cursor
      var row = firstStep.row
      var accRev: List[StorageRecord] = Nil
      var err: Option[SqliteError] = None
      var done = false
      while !done && err.isEmpty do
        row match
          case None => done = true
          case Some(rec) =>
            accRev = rec :: accRev
            readonlyNext(d, c) match
              case Left(error) => err = Some(error)
              case Right(step) =>
                d = step.database
                c = step.cursor
                row = step.row
      err match
        case Some(error) => Left(error)
        case None =>
          var out: List[StorageRecord] = Nil
          var rr = accRev
          while rr.nonEmpty do
            out = rr.head :: out
            rr = rr.tail
          Right(out)

def findTable(db: ReadonlyDatabase, name: String): Option[SchemaEntry] =
  val target = upperStr(name)
  var r = db.schema.entries
  var found: Option[SchemaEntry] = None
  while r.nonEmpty && found.isEmpty do
    val e = r.head
    if e.rootPage.isDefined && upperStr(cpToString(e.name.codePoints)) == target then found = Some(e)
    r = r.tail
  found

def reverseStorage(items: List[StorageRecord], acc: List[StorageRecord]): List[StorageRecord] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

def takeStorage(rows: List[StorageRecord], n: Int): List[StorageRecord] =
  var r = rows
  var i = 0
  var accRev: List[StorageRecord] = Nil
  while i < n && r.nonEmpty do
    accRev = r.head :: accRev
    r = r.tail
    i = i + 1
  reverseStorage(accRev, Nil)

def dropStorage(rows: List[StorageRecord], n: Int): List[StorageRecord] =
  var r = rows
  var i = 0
  while i < n && r.nonEmpty do
    r = r.tail
    i = i + 1
  r

def filterRows(rows: List[StorageRecord], where: List[List[Condition]], colNames: List[String]): List[StorageRecord] =
  var r = rows
  var accRev: List[StorageRecord] = Nil
  while r.nonEmpty do
    if whereHolds(where, r.head, colNames) then accRev = r.head :: accRev
    r = r.tail
  reverseStorage(accRev, Nil)

// ── Correlated EXISTS: a WHERE containing a [NOT] EXISTS subquery, evaluated per outer row ──
def hasExistsCond(where: List[List[Condition]]): Boolean =
  var g = where
  var found = false
  while g.nonEmpty && !found do
    var r = g.head
    while r.nonEmpty && !found do
      if r.head.subTokens.nonEmpty then found = true
      r = r.tail
    g = g.tail
  found

def exactValueToken(v: SqliteValue): Token = Token("bound", "", 0L, Some(v))

// Replace qualified outer-table references (outerTable.col) in a subquery's tokens with the current
// outer row's value (a bound literal token). Bare/other refs resolve to the inner table unchanged.
def substituteOuterRefs(subTokens: List[Token], outerTable: String, colNames: List[String], rec: StorageRecord): List[Token] =
  val ot = upperStr(outerTable)
  var r = subTokens
  var accRev: List[Token] = Nil
  while r.nonEmpty do
    val t = r.head
    val repl =
      if t.kind == "ident" then
        val dot = indexOfDot(t.text)
        if dot < 0 then t
        else if upperStr(substr(t.text, 0, dot)) != ot then t
        else
          val colPart = substr(t.text, dot + 1, t.text.length)
          if columnIndex(colNames, colPart) < 0 then t
          else exactValueToken(rowValue(rec, colNames, colPart))
      else t
    accRev = repl :: accRev
    r = r.tail
  reverseTokens(accRev, Nil)

// EXISTS: substitute the outer refs, run the subquery against the open db, true iff it returns a row.
def existsHolds(db: ReadonlyDatabase, subTokens: List[Token], outerTable: String, colNames: List[String], rec: StorageRecord): Boolean =
  val sub = substituteOuterRefs(subTokens, outerTable, colNames, rec)
  parseSelect(sub) match
    case Left(_) => false
    case Right(stmt) =>
      if stmt.table == "" then executeNoFrom(stmt) match
        case Right(rows) => rows.nonEmpty
        case Left(_) => false
      else executeSelect(db, stmt) match
        case Right(rows) => rows.nonEmpty
        case Left(_) => false

// `col [NOT] IN (subquery)`: substitute the outer refs, run the subquery, test membership of the left
// value in its first column.
def inSubqHolds(db: ReadonlyDatabase, cond: Condition, rec: StorageRecord, colNames: List[String], outerTable: String): Boolean =
  val colVal = condLeftSingle(cond, rec, colNames)
  val sub = substituteOuterRefs(cond.subTokens, outerTable, colNames, rec)
  parseSelect(sub) match
    case Left(_) => false
    case Right(stmt) =>
      val rowsE = if stmt.table == "" then executeNoFrom(stmt) else executeSelect(db, stmt)
      rowsE match
        case Left(_) => false
        case Right(rows) => valueInList(colVal, firstColumn(rows))

def isCmpOp(op: String): Boolean =
  op == "=" || op == "<>" || op == "!=" || op == "<" || op == "<=" || op == ">" || op == ">="

// The scalar of a subquery result = the first row's first column (NULL if it returned no rows).
def scalarSubqValue(rows: List[List[SqliteValue]]): SqliteValue =
  if rows.isEmpty then SqlNull
  else if rows.head.isEmpty then SqlNull
  else rows.head.head

// `col <cmp> (subquery)`: substitute the outer refs, run the subquery, compare the left value with its
// scalar. A NULL either side makes the comparison unknown (false), as in SQL.
def scalarSubqHolds(db: ReadonlyDatabase, cond: Condition, rec: StorageRecord, colNames: List[String], outerTable: String): Boolean =
  val colVal = condLeftSingle(cond, rec, colNames)
  val sub = substituteOuterRefs(cond.subTokens, outerTable, colNames, rec)
  parseSelect(sub) match
    case Left(_) => false
    case Right(stmt) =>
      val rowsE = if stmt.table == "" then executeNoFrom(stmt) else executeSelect(db, stmt)
      rowsE match
        case Left(_) => false
        case Right(rows) =>
          val scalar = scalarSubqValue(rows)
          if isNullValue(colVal) || isNullValue(scalar) then false
          else condMatches(cond.op, sqlCompare(colVal, scalar))

def condHoldsCtx(db: ReadonlyDatabase, cond: Condition, rec: StorageRecord, colNames: List[String], outerTable: String): Boolean =
  if cond.op == "exists" then existsHolds(db, cond.subTokens, outerTable, colNames, rec)
  else if cond.op == "notexists" then existsHolds(db, cond.subTokens, outerTable, colNames, rec) == false
  else if cond.op == "insubq" then inSubqHolds(db, cond, rec, colNames, outerTable)
  else if cond.op == "notinsubq" then inSubqHolds(db, cond, rec, colNames, outerTable) == false
  else if cond.subTokens.nonEmpty && isCmpOp(cond.op) then scalarSubqHolds(db, cond, rec, colNames, outerTable)
  else condHolds(cond, rec, colNames)

def andGroupHoldsCtx(db: ReadonlyDatabase, group: List[Condition], rec: StorageRecord, colNames: List[String], outerTable: String): Boolean =
  var r = group
  var all = true
  while r.nonEmpty && all do
    if !condHoldsCtx(db, r.head, rec, colNames, outerTable) then all = false
    r = r.tail
  all

def whereHoldsCtx(db: ReadonlyDatabase, where: List[List[Condition]], rec: StorageRecord, colNames: List[String], outerTable: String): Boolean =
  if where.isEmpty then true
  else
    var r = where
    var any = false
    while r.nonEmpty && !any do
      if andGroupHoldsCtx(db, r.head, rec, colNames, outerTable) then any = true
      r = r.tail
    any

def filterRowsCtx(db: ReadonlyDatabase, rows: List[StorageRecord], where: List[List[Condition]], colNames: List[String], outerTable: String): List[StorageRecord] =
  var r = rows
  var accRev: List[StorageRecord] = Nil
  while r.nonEmpty do
    if whereHoldsCtx(db, where, r.head, colNames, outerTable) then accRev = r.head :: accRev
    r = r.tail
  reverseStorage(accRev, Nil)

// Lexicographic comparison over the ORDER BY key list (per-key ASC/DESC).
def recCompare(a: StorageRecord, b: StorageRecord, colNames: List[String], keys: List[OrderKey]): Int =
  var r = keys
  var result = 0
  while r.nonEmpty && result == 0 do
    val ok = r.head
    val cmp = sqlCompare(evalExpr(ok.expr, a, colNames), evalExpr(ok.expr, b, colNames))
    result = if ok.desc then 0 - cmp else cmp
    r = r.tail
  result

// Iterative merge (stable: left wins ties).
def mergeStorage(a: List[StorageRecord], b: List[StorageRecord], colNames: List[String], keys: List[OrderKey]): List[StorageRecord] =
  var ra = a
  var rb = b
  var accRev: List[StorageRecord] = Nil
  while ra.nonEmpty && rb.nonEmpty do
    if recCompare(ra.head, rb.head, colNames, keys) <= 0 then
      accRev = ra.head :: accRev
      ra = ra.tail
    else
      accRev = rb.head :: accRev
      rb = rb.tail
  while ra.nonEmpty do
    accRev = ra.head :: accRev
    ra = ra.tail
  while rb.nonEmpty do
    accRev = rb.head :: accRev
    rb = rb.tail
  reverseStorage(accRev, Nil)

// Stable merge sort; recursion depth is log(n).
def sortStorage(rows: List[StorageRecord], colNames: List[String], keys: List[OrderKey]): List[StorageRecord] =
  val n = rows.length
  if n <= 1 then rows
  else
    val half = n / 2
    mergeStorage(sortStorage(takeStorage(rows, half), colNames, keys), sortStorage(dropStorage(rows, half), colNames, keys), colNames, keys)

def applyLimitOffset(rows: List[StorageRecord], limit: Int, offset: Int): List[StorageRecord] =
  val afterOffset = dropStorage(rows, offset)
  if limit < 0 then afterOffset else takeStorage(afterOffset, limit)

def countNonNull(rows: List[StorageRecord], colNames: List[String], col: String): Long =
  var r = rows
  var cnt = 0L
  while r.nonEmpty do
    rowValue(r.head, colNames, col) match
      case SqlNull => cnt = cnt
      case _ => cnt = cnt + 1L
    r = r.tail
  cnt

def sumColumn(rows: List[StorageRecord], colNames: List[String], col: String, alwaysReal: Boolean): SqliteValue =
  var r = rows
  var intSum = 0L
  var realSum = 0.0
  var hasReal = false
  var cnt = 0
  while r.nonEmpty do
    rowValue(r.head, colNames, col) match
      case SqlInteger(x) =>
        intSum = intSum + x
        realSum = realSum + x.toDouble
        cnt = cnt + 1
      case SqlReal(x) =>
        realSum = realSum + x
        hasReal = true
        cnt = cnt + 1
      case _ => cnt = cnt
    r = r.tail
  if alwaysReal then SqlReal(realSum)
  else if cnt == 0 then SqlNull
  else if hasReal then SqlReal(realSum) else SqlInteger(intSum)

def avgColumn(rows: List[StorageRecord], colNames: List[String], col: String): SqliteValue =
  var r = rows
  var realSum = 0.0
  var cnt = 0
  while r.nonEmpty do
    rowValue(r.head, colNames, col) match
      case SqlInteger(x) =>
        realSum = realSum + x.toDouble
        cnt = cnt + 1
      case SqlReal(x) =>
        realSum = realSum + x
        cnt = cnt + 1
      case _ => cnt = cnt
    r = r.tail
  if cnt == 0 then SqlNull else SqlReal(realSum / cnt.toDouble)

def minMaxColumn(rows: List[StorageRecord], colNames: List[String], col: String, wantMax: Boolean): SqliteValue =
  var r = rows
  var best: Option[SqliteValue] = None
  while r.nonEmpty do
    val v = rowValue(r.head, colNames, col)
    v match
      case SqlNull => best = best
      case _ => best match
        case None => best = Some(v)
        case Some(cur) =>
          val cmp = sqlCompare(v, cur)
          val take = if wantMax then cmp > 0 else cmp < 0
          if take then best = Some(v)
    r = r.tail
  best match
    case Some(v) => v
    case None => SqlNull

// Distinct-preserving copy of `vals` (first occurrence kept; equality via sqlCompare).
def dedupValues(vals: List[SqliteValue]): List[SqliteValue] =
  var r = vals
  var seenRev: List[SqliteValue] = Nil
  while r.nonEmpty do
    if !valueInList(r.head, seenRev) then seenRev = r.head :: seenRev
    r = r.tail
  reverseValues(seenRev, Nil)

def extractColumnValues(rows: List[StorageRecord], colNames: List[String], col: String): List[SqliteValue] =
  var r = rows
  var accRev: List[SqliteValue] = Nil
  while r.nonEmpty do
    accRev = rowValue(r.head, colNames, col) :: accRev
    r = r.tail
  reverseValues(accRev, Nil)

def computeAgg(agg: AggItem, rows: List[StorageRecord], colNames: List[String]): SqliteValue =
  val f = upperStr(agg.func)
  if agg.distinct then
    // COUNT/SUM/AVG(DISTINCT col) aggregate over the distinct non-null values.
    aggregateValues(f, dedupValues(extractColumnValues(rows, colNames, agg.column)))
  else if f == "COUNT" then
    if agg.column == "*" then SqlInteger(rows.length.toLong)
    else SqlInteger(countNonNull(rows, colNames, agg.column))
  else if f == "SUM" then sumColumn(rows, colNames, agg.column, false)
  else if f == "TOTAL" then sumColumn(rows, colNames, agg.column, true)
  else if f == "AVG" then avgColumn(rows, colNames, agg.column)
  else if f == "MIN" then minMaxColumn(rows, colNames, agg.column, false)
  else if f == "MAX" then minMaxColumn(rows, colNames, agg.column, true)
  else SqlNull

def computeAggregates(aggs: List[AggItem], rows: List[StorageRecord], colNames: List[String]): List[SqliteValue] =
  var r = aggs
  var accRev: List[SqliteValue] = Nil
  while r.nonEmpty do
    accRev = computeAgg(r.head, rows, colNames) :: accRev
    r = r.tail
  reverseValues(accRev, Nil)

// ── Inner join (nested loop, qualified column resolution) ──

def substr(s: String, from: Int, to: Int): String =
  var i = from
  var out = ""
  while i < to do
    out = out + s.charAt(i).toString
    i = i + 1
  out

// Split `a.b` into ("a","b"); a bare name gives (name, "").
def dotSplit(name: String): (String, String) =
  var i = 0
  var pos = -1
  while i < name.length && pos < 0 do
    if name.charAt(i).toInt == 46 then pos = i
    i = i + 1
  if pos < 0 then (name, "")
  else (substr(name, 0, pos), substr(name, pos + 1, name.length))

// The B-side value, or NULL when B is absent (an unmatched row of a LEFT JOIN).
def bValue(recBOpt: Option[StorageRecord], colsB: List[String], col: String): SqliteValue = recBOpt match
  case Some(rb) => rowValue(rb, colsB, col)
  case None => SqlNull

def joinColValue(recA: StorageRecord, colsA: List[String], tableA: String, recBOpt: Option[StorageRecord], colsB: List[String], tableB: String, name: String): SqliteValue =
  val parts = dotSplit(name)
  if parts._2 != "" then
    if upperStr(parts._1) == upperStr(tableA) then rowValue(recA, colsA, parts._2)
    else if upperStr(parts._1) == upperStr(tableB) then bValue(recBOpt, colsB, parts._2)
    else SqlNull
  else
    if columnIndex(colsA, name) >= 0 then rowValue(recA, colsA, name)
    else if columnIndex(colsB, name) >= 0 then bValue(recBOpt, colsB, name)
    else if upperStr(name) == "ROWID" then rowValue(recA, colsA, name)
    else SqlNull

def joinCondLeft(cond: Condition, recA: StorageRecord, colsA: List[String], tableA: String, recBOpt: Option[StorageRecord], colsB: List[String], tableB: String): SqliteValue =
  cond.leftExpr match
    case Some(e) => evalExprJoin(e, recA, colsA, tableA, recBOpt, colsB, tableB)
    case None => joinColValue(recA, colsA, tableA, recBOpt, colsB, tableB, cond.column)

def joinCondRight(cond: Condition, recA: StorageRecord, colsA: List[String], tableA: String, recBOpt: Option[StorageRecord], colsB: List[String], tableB: String): SqliteValue =
  cond.rightExpr match
    case Some(e) => evalExprJoin(e, recA, colsA, tableA, recBOpt, colsB, tableB)
    case None => cond.value

def joinCondHolds(cond: Condition, recA: StorageRecord, colsA: List[String], tableA: String, recBOpt: Option[StorageRecord], colsB: List[String], tableB: String): Boolean =
  predHolds(cond, joinCondLeft(cond, recA, colsA, tableA, recBOpt, colsB, tableB), joinCondRight(cond, recA, colsA, tableA, recBOpt, colsB, tableB))

def joinAndGroupHolds(group: List[Condition], recA: StorageRecord, colsA: List[String], tableA: String, recBOpt: Option[StorageRecord], colsB: List[String], tableB: String): Boolean =
  var r = group
  var all = true
  while r.nonEmpty && all do
    if !joinCondHolds(r.head, recA, colsA, tableA, recBOpt, colsB, tableB) then all = false
    r = r.tail
  all

def joinWhereHolds(where: List[List[Condition]], recA: StorageRecord, colsA: List[String], tableA: String, recBOpt: Option[StorageRecord], colsB: List[String], tableB: String): Boolean =
  if where.isEmpty then true
  else
    var r = where
    var any = false
    while r.nonEmpty && !any do
      if joinAndGroupHolds(r.head, recA, colsA, tableA, recBOpt, colsB, tableB) then any = true
      r = r.tail
    any

def joinProjectRow(recA: StorageRecord, colsA: List[String], tableA: String, recBOpt: Option[StorageRecord], colsB: List[String], tableB: String, stmt: SelectStmt): List[SqliteValue] =
  var accRev: List[SqliteValue] = Nil
  if stmt.star then
    var ca = colsA
    while ca.nonEmpty do
      accRev = rowValue(recA, colsA, ca.head) :: accRev
      ca = ca.tail
    var cb = colsB
    while cb.nonEmpty do
      accRev = bValue(recBOpt, colsB, cb.head) :: accRev
      cb = cb.tail
  else
    var r = projItemNames(stmt.projection)
    while r.nonEmpty do
      accRev = joinColValue(recA, colsA, tableA, recBOpt, colsB, tableB, r.head) :: accRev
      r = r.tail
  reverseValues(accRev, Nil)

def joinTableRows(db: ReadonlyDatabase, table: String): Either[String, (List[String], List[StorageRecord])] =
  findTable(db, table) match
    case None => Left("no such table: " + table)
    case Some(entry) =>
      val cols = entry.sql match
        case Some(text) => tableColumns(cpToString(text.codePoints))
        case None => Nil
      val root = entry.rootPage match
        case Some(p) => p
        case None => 0L
      openReadonlyRoot(db, root, RowidTableTree) match
        case Left(error) => Left(error.message)
        case Right(cursor) => collectRows(db, cursor) match
          case Left(error) => Left(error.message)
          // IPK-normalize here (the single row source for BOTH the 2-table and the N-table join),
          // so an ON / WHERE / projection on a joined table's IPK sees the rowid.
          case Right(rows) => Right((cols, ipkNormalizeRows(rows, tableIpkIndex(db, table))))

case class JoinPair(recA: StorageRecord, recBOpt: Option[StorageRecord])

def reversePairs(items: List[JoinPair], acc: List[JoinPair]): List[JoinPair] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

// ── Aggregate over a pre-extracted value list (used by the join aggregate path) ──

def countNonNullValues(vals: List[SqliteValue]): Long =
  var r = vals
  var cnt = 0L
  while r.nonEmpty do
    r.head match
      case SqlNull => cnt = cnt
      case _ => cnt = cnt + 1L
    r = r.tail
  cnt

def sumValues(vals: List[SqliteValue], alwaysReal: Boolean): SqliteValue =
  var r = vals
  var intSum = 0L
  var realSum = 0.0
  var hasReal = false
  var cnt = 0
  while r.nonEmpty do
    r.head match
      case SqlInteger(x) =>
        intSum = intSum + x
        realSum = realSum + x.toDouble
        cnt = cnt + 1
      case SqlReal(x) =>
        realSum = realSum + x
        hasReal = true
        cnt = cnt + 1
      case _ => cnt = cnt
    r = r.tail
  if alwaysReal then SqlReal(realSum)
  else if cnt == 0 then SqlNull
  else if hasReal then SqlReal(realSum) else SqlInteger(intSum)

def avgValues(vals: List[SqliteValue]): SqliteValue =
  var r = vals
  var realSum = 0.0
  var cnt = 0
  while r.nonEmpty do
    r.head match
      case SqlInteger(x) =>
        realSum = realSum + x.toDouble
        cnt = cnt + 1
      case SqlReal(x) =>
        realSum = realSum + x
        cnt = cnt + 1
      case _ => cnt = cnt
    r = r.tail
  if cnt == 0 then SqlNull else SqlReal(realSum / cnt.toDouble)

def minMaxValues(vals: List[SqliteValue], wantMax: Boolean): SqliteValue =
  var r = vals
  var best: Option[SqliteValue] = None
  while r.nonEmpty do
    val v = r.head
    v match
      case SqlNull => best = best
      case _ => best match
        case None => best = Some(v)
        case Some(cur) =>
          val cmp = sqlCompare(v, cur)
          val take = if wantMax then cmp > 0 else cmp < 0
          if take then best = Some(v)
    r = r.tail
  best match
    case Some(v) => v
    case None => SqlNull

def aggregateValues(func: String, vals: List[SqliteValue]): SqliteValue =
  if func == "COUNT" then SqlInteger(countNonNullValues(vals))
  else if func == "SUM" then sumValues(vals, false)
  else if func == "TOTAL" then sumValues(vals, true)
  else if func == "AVG" then avgValues(vals)
  else if func == "MIN" then minMaxValues(vals, false)
  else if func == "MAX" then minMaxValues(vals, true)
  else SqlNull

def joinPairValue(pair: JoinPair, colsA: List[String], tableA: String, colsB: List[String], tableB: String, name: String): SqliteValue =
  joinColValue(pair.recA, colsA, tableA, pair.recBOpt, colsB, tableB, name)

def extractPairValues(pairs: List[JoinPair], colsA: List[String], tableA: String, colsB: List[String], tableB: String, col: String): List[SqliteValue] =
  var r = pairs
  var accRev: List[SqliteValue] = Nil
  while r.nonEmpty do
    accRev = joinPairValue(r.head, colsA, tableA, colsB, tableB, col) :: accRev
    r = r.tail
  reverseValues(accRev, Nil)

def joinAggValue(func: String, arg: String, distinct: Boolean, pairs: List[JoinPair], colsA: List[String], tableA: String, colsB: List[String], tableB: String): SqliteValue =
  val f = upperStr(func)
  val vals = extractPairValues(pairs, colsA, tableA, colsB, tableB, arg)
  if distinct then aggregateValues(f, dedupValues(vals))
  else if f == "COUNT" && arg == "*" then SqlInteger(pairs.length.toLong)
  else aggregateValues(f, vals)

// Group evaluation over a join's matched pairs (the join analogue of evalExprGroup).
def evalArgsGroupJoin(args: List[SxNode], pairs: List[JoinPair], colsA: List[String], tableA: String, colsB: List[String], tableB: String): List[SqliteValue] =
  var r = args
  var accRev: List[SqliteValue] = Nil
  while r.nonEmpty do
    accRev = evalExprGroupJoin(r.head, pairs, colsA, tableA, colsB, tableB) :: accRev
    r = r.tail
  reverseValues(accRev, Nil)

def evalCaseGroupJoin(operand: Option[SxNode], whens: List[SxWhen], elseExpr: Option[SxNode], pairs: List[JoinPair], colsA: List[String], tableA: String, colsB: List[String], tableB: String): SqliteValue =
  var r = whens
  var out: Option[SqliteValue] = None
  operand match
    case Some(opExpr) =>
      val opVal = evalExprGroupJoin(opExpr, pairs, colsA, tableA, colsB, tableB)
      while r.nonEmpty && out.isEmpty do
        if sqlCompare(opVal, evalExprGroupJoin(r.head.cond, pairs, colsA, tableA, colsB, tableB)) == 0 then out = Some(evalExprGroupJoin(r.head.result, pairs, colsA, tableA, colsB, tableB))
        r = r.tail
    case None =>
      while r.nonEmpty && out.isEmpty do
        if isTruthy(evalExprGroupJoin(r.head.cond, pairs, colsA, tableA, colsB, tableB)) then out = Some(evalExprGroupJoin(r.head.result, pairs, colsA, tableA, colsB, tableB))
        r = r.tail
  out match
    case Some(v) => v
    case None => elseExpr match
      case Some(e) => evalExprGroupJoin(e, pairs, colsA, tableA, colsB, tableB)
      case None => SqlNull

def evalExprGroupJoin(e: SxNode, pairs: List[JoinPair], colsA: List[String], tableA: String, colsB: List[String], tableB: String): SqliteValue = e match
  case SxCol(name) => if pairs.isEmpty then SqlNull else joinPairValue(pairs.head, colsA, tableA, colsB, tableB, name)
  case SxLit(v) => v
  case SxNeg(inner) => negateValue(evalExprGroupJoin(inner, pairs, colsA, tableA, colsB, tableB))
  case SxBin(op, l, r) => arithValue(op, evalExprGroupJoin(l, pairs, colsA, tableA, colsB, tableB), evalExprGroupJoin(r, pairs, colsA, tableA, colsB, tableB))
  case SxCall(func, args) => evalCall(func, evalArgsGroupJoin(args, pairs, colsA, tableA, colsB, tableB))
  case SxNot(inner) => notValue(evalExprGroupJoin(inner, pairs, colsA, tableA, colsB, tableB))
  case SxAgg(func, arg, distinct) => joinAggValue(func, arg, distinct, pairs, colsA, tableA, colsB, tableB)
  case SxCase(operand, whens, elseExpr) => evalCaseGroupJoin(operand, whens, elseExpr, pairs, colsA, tableA, colsB, tableB)

def computeJoinAgg(item: ProjItem, pairs: List[JoinPair], colsA: List[String], tableA: String, colsB: List[String], tableB: String): SqliteValue =
  if item.isAgg then joinAggValue(item.func, item.name, item.distinct, pairs, colsA, tableA, colsB, tableB)
  else item.expr match
    case Some(e) => evalExprGroupJoin(e, pairs, colsA, tableA, colsB, tableB)
    case None =>
      if pairs.isEmpty then SqlNull else joinPairValue(pairs.head, colsA, tableA, colsB, tableB, item.name)

def computeJoinAggregates(projection: List[ProjItem], pairs: List[JoinPair], colsA: List[String], tableA: String, colsB: List[String], tableB: String): List[SqliteValue] =
  var r = projection
  var accRev: List[SqliteValue] = Nil
  while r.nonEmpty do
    accRev = computeJoinAgg(r.head, pairs, colsA, tableA, colsB, tableB) :: accRev
    r = r.tail
  reverseValues(accRev, Nil)

def takePairs(pairs: List[JoinPair], n: Int): List[JoinPair] =
  var r = pairs
  var i = 0
  var accRev: List[JoinPair] = Nil
  while i < n && r.nonEmpty do
    accRev = r.head :: accRev
    r = r.tail
    i = i + 1
  reversePairs(accRev, Nil)

def dropPairs(pairs: List[JoinPair], n: Int): List[JoinPair] =
  var r = pairs
  var i = 0
  while i < n && r.nonEmpty do
    r = r.tail
    i = i + 1
  r

def pairOrderCompare(a: JoinPair, b: JoinPair, colsA: List[String], tableA: String, colsB: List[String], tableB: String, keys: List[OrderKey]): Int =
  var r = keys
  var result = 0
  while r.nonEmpty && result == 0 do
    val ok = r.head
    val cmp = sqlCompare(evalExprJoin(ok.expr, a.recA, colsA, tableA, a.recBOpt, colsB, tableB), evalExprJoin(ok.expr, b.recA, colsA, tableA, b.recBOpt, colsB, tableB))
    result = if ok.desc then 0 - cmp else cmp
    r = r.tail
  result

def mergePairs(a: List[JoinPair], b: List[JoinPair], colsA: List[String], tableA: String, colsB: List[String], tableB: String, keys: List[OrderKey]): List[JoinPair] =
  var ra = a
  var rb = b
  var accRev: List[JoinPair] = Nil
  while ra.nonEmpty && rb.nonEmpty do
    if pairOrderCompare(ra.head, rb.head, colsA, tableA, colsB, tableB, keys) <= 0 then
      accRev = ra.head :: accRev
      ra = ra.tail
    else
      accRev = rb.head :: accRev
      rb = rb.tail
  while ra.nonEmpty do
    accRev = ra.head :: accRev
    ra = ra.tail
  while rb.nonEmpty do
    accRev = rb.head :: accRev
    rb = rb.tail
  reversePairs(accRev, Nil)

def sortPairsBy(pairs: List[JoinPair], colsA: List[String], tableA: String, colsB: List[String], tableB: String, keys: List[OrderKey]): List[JoinPair] =
  val n = pairs.length
  if n <= 1 then pairs
  else
    val half = n / 2
    mergePairs(sortPairsBy(takePairs(pairs, half), colsA, tableA, colsB, tableB, keys), sortPairsBy(dropPairs(pairs, half), colsA, tableA, colsB, tableB, keys), colsA, tableA, colsB, tableB, keys)

def reversePairGroups(items: List[List[JoinPair]], acc: List[List[JoinPair]]): List[List[JoinPair]] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

def pairGroupEqual(a: JoinPair, b: JoinPair, colsA: List[String], tableA: String, colsB: List[String], tableB: String, groupCols: List[String]): Boolean =
  var r = groupCols
  var eq = true
  while r.nonEmpty && eq do
    if sqlCompare(joinPairValue(a, colsA, tableA, colsB, tableB, r.head), joinPairValue(b, colsA, tableA, colsB, tableB, r.head)) != 0 then eq = false
    r = r.tail
  eq

def partitionPairs(sorted: List[JoinPair], colsA: List[String], tableA: String, colsB: List[String], tableB: String, groupCols: List[String]): List[List[JoinPair]] =
  var r = sorted
  var curRev: List[JoinPair] = Nil
  var groupsRev: List[List[JoinPair]] = Nil
  while r.nonEmpty do
    if curRev.isEmpty then curRev = r.head :: Nil
    else if pairGroupEqual(curRev.head, r.head, colsA, tableA, colsB, tableB, groupCols) then curRev = r.head :: curRev
    else
      groupsRev = reversePairs(curRev, Nil) :: groupsRev
      curRev = r.head :: Nil
    r = r.tail
  val groups = if curRev.nonEmpty then reversePairs(curRev, Nil) :: groupsRev else groupsRev
  reversePairGroups(groups, Nil)

def havingHoldsPairs(having: Option[HavingCond], group: List[JoinPair], colsA: List[String], tableA: String, colsB: List[String], tableB: String): Boolean = having match
  case None => true
  case Some(hc) => condMatches(hc.op, sqlCompare(computeJoinAgg(hc.item, group, colsA, tableA, colsB, tableB), hc.value))

def filterPairGroups(groups: List[List[JoinPair]], having: Option[HavingCond], colsA: List[String], tableA: String, colsB: List[String], tableB: String): List[List[JoinPair]] =
  var r = groups
  var accRev: List[List[JoinPair]] = Nil
  while r.nonEmpty do
    if havingHoldsPairs(having, r.head, colsA, tableA, colsB, tableB) then accRev = r.head :: accRev
    r = r.tail
  reversePairGroups(accRev, Nil)

def mapPairGroups(groups: List[List[JoinPair]], projection: List[ProjItem], colsA: List[String], tableA: String, colsB: List[String], tableB: String): List[List[SqliteValue]] =
  var r = groups
  var accRev: List[List[SqliteValue]] = Nil
  while r.nonEmpty do
    accRev = computeJoinAggregates(projection, r.head, colsA, tableA, colsB, tableB) :: accRev
    r = r.tail
  var out: List[List[SqliteValue]] = Nil
  while accRev.nonEmpty do
    out = accRev.head :: out
    accRev = accRev.tail
  out

def joinExecute(db: ReadonlyDatabase, stmt: SelectStmt, spec: JoinSpec): Either[String, List[List[SqliteValue]]] =
  joinTableRows(db, stmt.table) match
    case Left(message) => Left(message)
    case Right(a) => joinTableRows(db, spec.table) match
      case Left(message) => Left(message)
      case Right(b) =>
        val colsA = a._1
        val rowsA = a._2
        val colsB = b._1
        val rowsB = b._2
        var ra = rowsA
        var pairsRev: List[JoinPair] = Nil
        while ra.nonEmpty do
          var rb = rowsB
          var matched = false
          while rb.nonEmpty do
            val rbOpt: Option[StorageRecord] = Some(rb.head)
            val lv = joinColValue(ra.head, colsA, stmt.table, rbOpt, colsB, spec.table, spec.leftCol)
            val rv = joinColValue(ra.head, colsA, stmt.table, rbOpt, colsB, spec.table, spec.rightCol)
            if condMatches(spec.op, sqlCompare(lv, rv)) then
              matched = true
              if joinWhereHolds(stmt.where, ra.head, colsA, stmt.table, rbOpt, colsB, spec.table) then
                pairsRev = JoinPair(ra.head, rbOpt) :: pairsRev
            rb = rb.tail
          if spec.leftOuter && !matched then
            val noneB: Option[StorageRecord] = None
            if joinWhereHolds(stmt.where, ra.head, colsA, stmt.table, noneB, colsB, spec.table) then
              pairsRev = JoinPair(ra.head, noneB) :: pairsRev
          ra = ra.tail
        // RIGHT / FULL: keep each right-table row that no left row matched (on the ON), left side NULL.
        if spec.rightOuter then
          var rb2 = rowsB
          while rb2.nonEmpty do
            var ra2 = rowsA
            var bMatched = false
            while ra2.nonEmpty do
              val rbOpt2: Option[StorageRecord] = Some(rb2.head)
              val lv2 = joinColValue(ra2.head, colsA, stmt.table, rbOpt2, colsB, spec.table, spec.leftCol)
              val rv2 = joinColValue(ra2.head, colsA, stmt.table, rbOpt2, colsB, spec.table, spec.rightCol)
              if condMatches(spec.op, sqlCompare(lv2, rv2)) then bMatched = true
              ra2 = ra2.tail
            if !bMatched then
              val nullA = nullRow()
              val rbOptN: Option[StorageRecord] = Some(rb2.head)
              if joinWhereHolds(stmt.where, nullA, colsA, stmt.table, rbOptN, colsB, spec.table) then
                pairsRev = JoinPair(nullA, rbOptN) :: pairsRev
            rb2 = rb2.tail
        val pairs = reversePairs(pairsRev, Nil)
        if stmt.groupBy.nonEmpty then
          val sortedForGroup = sortPairsBy(pairs, colsA, stmt.table, colsB, spec.table, groupKeysOf(stmt.groupBy))
          val groups = filterPairGroups(partitionPairs(sortedForGroup, colsA, stmt.table, colsB, spec.table, stmt.groupBy), stmt.having, colsA, stmt.table, colsB, spec.table)
          Right(limitValueRows(mapPairGroups(groups, stmt.projection, colsA, stmt.table, colsB, spec.table), stmt.limit, stmt.offset))
        else if projHasAgg(stmt.projection) then Right(computeJoinAggregates(stmt.projection, pairs, colsA, stmt.table, colsB, spec.table) :: Nil)
        else
          var pp = if stmt.orderBy.isEmpty then pairs else sortPairsBy(pairs, colsA, stmt.table, colsB, spec.table, stmt.orderBy)
          var resultRev: List[List[SqliteValue]] = Nil
          while pp.nonEmpty do
            resultRev = joinProjectRow(pp.head.recA, colsA, stmt.table, pp.head.recBOpt, colsB, spec.table, stmt) :: resultRev
            pp = pp.tail
          var out: List[List[SqliteValue]] = Nil
          while resultRev.nonEmpty do
            out = resultRev.head :: out
            resultRev = resultRev.tail
          val deduped = if stmt.distinct then dedupRows(out) else out
          Right(limitValueRows(deduped, stmt.limit, stmt.offset))

// ── N-table inner join (3+ tables): a general list-of-rows model ──
// A joined row is a list of StorageRecords, one per table, parallel to `tables`. Column
// references resolve across all bound tables (qualified `t.col` → that table; bare → the first
// table having the column). Supports projection / WHERE / ORDER BY / DISTINCT / LIMIT and inner
// joins only; aggregates, GROUP BY, HAVING and outer joins over 3+ tables are a follow-up (the
// full-featured 2-table path still handles single joins).

case class JoinTable(cols: List[String], tableName: String, rows: List[StorageRecord])

def indexOfDot(s: String): Int =
  var i = 0
  var found = -1
  while i < s.length && found < 0 do
    if charCode(s, i) == 46 then found = i
    i = i + 1
  found

// The bound row for a table name (parallel walk of `tables` and `joinRow`).
def multiColValue(joinRow: List[StorageRecord], tables: List[JoinTable], name: String): SqliteValue =
  val dot = indexOfDot(name)
  if dot >= 0 then
    val tbl = upperStr(substr(name, 0, dot))
    val col = substr(name, dot + 1, name.length)
    var ts = tables
    var rs = joinRow
    var out = SqlNull
    var done = false
    while ts.nonEmpty && rs.nonEmpty && !done do
      if upperStr(ts.head.tableName) == tbl then
        val idx = columnIndex(ts.head.cols, col)
        out = if idx < 0 then SqlNull else fieldValueAt(rs.head.record, idx)
        done = true
      ts = ts.tail
      rs = rs.tail
    out
  else
    var ts = tables
    var rs = joinRow
    var out = SqlNull
    var done = false
    while ts.nonEmpty && rs.nonEmpty && !done do
      val idx = columnIndex(ts.head.cols, name)
      if idx >= 0 then
        out = fieldValueAt(rs.head.record, idx)
        done = true
      ts = ts.tail
      rs = rs.tail
    out

def evalArgsMulti(args: List[SxNode], joinRow: List[StorageRecord], tables: List[JoinTable]): List[SqliteValue] =
  var r = args
  var accRev: List[SqliteValue] = Nil
  while r.nonEmpty do
    accRev = evalExprMulti(r.head, joinRow, tables) :: accRev
    r = r.tail
  reverseValues(accRev, Nil)

def evalCaseMulti(operand: Option[SxNode], whens: List[SxWhen], elseExpr: Option[SxNode], joinRow: List[StorageRecord], tables: List[JoinTable]): SqliteValue =
  var r = whens
  var out: Option[SqliteValue] = None
  operand match
    case Some(opExpr) =>
      val opVal = evalExprMulti(opExpr, joinRow, tables)
      while r.nonEmpty && out.isEmpty do
        if sqlCompare(opVal, evalExprMulti(r.head.cond, joinRow, tables)) == 0 then out = Some(evalExprMulti(r.head.result, joinRow, tables))
        r = r.tail
    case None =>
      while r.nonEmpty && out.isEmpty do
        if isTruthy(evalExprMulti(r.head.cond, joinRow, tables)) then out = Some(evalExprMulti(r.head.result, joinRow, tables))
        r = r.tail
  out match
    case Some(v) => v
    case None => elseExpr match
      case Some(e) => evalExprMulti(e, joinRow, tables)
      case None => SqlNull

def evalExprMulti(e: SxNode, joinRow: List[StorageRecord], tables: List[JoinTable]): SqliteValue = e match
  case SxCol(name) => multiColValue(joinRow, tables, name)
  case SxLit(v) => v
  case SxNeg(inner) => negateValue(evalExprMulti(inner, joinRow, tables))
  case SxBin(op, l, r) => arithValue(op, evalExprMulti(l, joinRow, tables), evalExprMulti(r, joinRow, tables))
  case SxCall(func, args) => evalCall(func, evalArgsMulti(args, joinRow, tables))
  case SxNot(inner) => notValue(evalExprMulti(inner, joinRow, tables))
  case SxAgg(_, _, _) => SqlNull
  case SxCase(operand, whens, elseExpr) => evalCaseMulti(operand, whens, elseExpr, joinRow, tables)

def multiCondHolds(cond: Condition, joinRow: List[StorageRecord], tables: List[JoinTable]): Boolean =
  val lv = cond.leftExpr match
    case Some(e) => evalExprMulti(e, joinRow, tables)
    case None => multiColValue(joinRow, tables, cond.column)
  val rv = cond.rightExpr match
    case Some(e) => evalExprMulti(e, joinRow, tables)
    case None => cond.value
  predHolds(cond, lv, rv)

def multiAndGroup(group: List[Condition], joinRow: List[StorageRecord], tables: List[JoinTable]): Boolean =
  var r = group
  var all = true
  while r.nonEmpty && all do
    if !multiCondHolds(r.head, joinRow, tables) then all = false
    r = r.tail
  all

def multiWhereHolds(where: List[List[Condition]], joinRow: List[StorageRecord], tables: List[JoinTable]): Boolean =
  if where.isEmpty then true
  else
    var r = where
    var any = false
    while r.nonEmpty && !any do
      if multiAndGroup(r.head, joinRow, tables) then any = true
      r = r.tail
    any

// ON `leftCol op rightCol` over the bound tables.
def onHolds(joinRow: List[StorageRecord], tables: List[JoinTable], spec: JoinSpec): Boolean =
  condMatches(spec.op, sqlCompare(multiColValue(joinRow, tables, spec.leftCol), multiColValue(joinRow, tables, spec.rightCol)))

def wrapSingletons(rows: List[StorageRecord]): List[List[StorageRecord]] =
  var r = rows
  var accRev: List[List[StorageRecord]] = Nil
  while r.nonEmpty do
    accRev = (r.head :: Nil) :: accRev
    r = r.tail
  accRev.reverse

// A NULL-extended row for an unmatched LEFT-join side: an empty record, so `fieldValueAt`
// (hence `multiColValue`) returns SqlNull for every column of that table.
def nullRow(): StorageRecord = StorageRecord(None, DecodedRecord(0, 0, Nil))

// Extend each partial join-row with every row of the next table that satisfies the ON.
// For a LEFT join, a partial that matched no next-table row is kept once, NULL-extended.
def nullList(n: Int): List[StorageRecord] =
  var i = 0
  var acc: List[StorageRecord] = Nil
  while i < n do
    acc = nullRow() :: acc
    i = i + 1
  acc

def extendPartials(partials: List[List[StorageRecord]], nextRows: List[StorageRecord], boundTables: List[JoinTable], spec: JoinSpec): List[List[StorageRecord]] =
  var ps = partials
  var accRev: List[List[StorageRecord]] = Nil
  while ps.nonEmpty do
    var nr = nextRows
    var matched = false
    while nr.nonEmpty do
      val candidate = ps.head ++ (nr.head :: Nil)
      val hit = onHolds(candidate, boundTables, spec)
      accRev = if hit then candidate :: accRev else accRev
      matched = if hit then true else matched
      nr = nr.tail
    accRev = if spec.leftOuter && !matched then (ps.head ++ (nullRow() :: Nil)) :: accRev else accRev
    ps = ps.tail
  // RIGHT / FULL: keep each next-table row that no partial matched, previous tables NULL-extended.
  if spec.rightOuter then
    val prefixWidth = boundTables.length - 1
    var nr2 = nextRows
    while nr2.nonEmpty do
      var pp = partials
      var anyMatch = false
      while pp.nonEmpty do
        if onHolds(pp.head ++ (nr2.head :: Nil), boundTables, spec) then anyMatch = true
        pp = pp.tail
      accRev = if anyMatch then accRev else (nullList(prefixWidth) ++ (nr2.head :: Nil)) :: accRev
      nr2 = nr2.tail
  accRev.reverse

def buildJoinRows(tables: List[JoinTable], joins: List[JoinSpec]): List[List[StorageRecord]] =
  var partials = wrapSingletons(tables.head.rows)
  var boundTables = tables.head :: Nil
  var restTables = tables.tail
  var restJoins = joins
  while restTables.nonEmpty && restJoins.nonEmpty do
    val nextTable = restTables.head
    boundTables = boundTables ++ (nextTable :: Nil)
    partials = extendPartials(partials, nextTable.rows, boundTables, restJoins.head)
    restTables = restTables.tail
    restJoins = restJoins.tail
  partials

// Project one joined row: `*` = every column of every table in order, else each projection item.
def projectMultiRow(joinRow: List[StorageRecord], tables: List[JoinTable], stmt: SelectStmt): List[SqliteValue] =
  if stmt.star then
    var ts = tables
    var rs = joinRow
    var accRev: List[SqliteValue] = Nil
    while ts.nonEmpty && rs.nonEmpty do
      var i = 0
      while i < ts.head.cols.length do
        accRev = fieldValueAt(rs.head.record, i) :: accRev
        i = i + 1
      ts = ts.tail
      rs = rs.tail
    reverseValues(accRev, Nil)
  else
    var r = stmt.projection
    var accRev: List[SqliteValue] = Nil
    while r.nonEmpty do
      val item = r.head
      val v = item.expr match
        case Some(e) => evalExprMulti(e, joinRow, tables)
        case None => multiColValue(joinRow, tables, item.name)
      accRev = v :: accRev
      r = r.tail
    reverseValues(accRev, Nil)

def multiRowCompare(a: List[StorageRecord], b: List[StorageRecord], tables: List[JoinTable], keys: List[OrderKey]): Int =
  var r = keys
  var result = 0
  while r.nonEmpty && result == 0 do
    val ok = r.head
    val cmp = sqlCompare(evalExprMulti(ok.expr, a, tables), evalExprMulti(ok.expr, b, tables))
    result = if ok.desc then 0 - cmp else cmp
    r = r.tail
  result

def mergeMultiRows(a: List[List[StorageRecord]], b: List[List[StorageRecord]], tables: List[JoinTable], keys: List[OrderKey]): List[List[StorageRecord]] =
  var ra = a
  var rb = b
  var accRev: List[List[StorageRecord]] = Nil
  while ra.nonEmpty && rb.nonEmpty do
    if multiRowCompare(ra.head, rb.head, tables, keys) <= 0 then
      accRev = ra.head :: accRev
      ra = ra.tail
    else
      accRev = rb.head :: accRev
      rb = rb.tail
  while ra.nonEmpty do
    accRev = ra.head :: accRev
    ra = ra.tail
  while rb.nonEmpty do
    accRev = rb.head :: accRev
    rb = rb.tail
  accRev.reverse

def sortMultiRows(rows: List[List[StorageRecord]], tables: List[JoinTable], keys: List[OrderKey]): List[List[StorageRecord]] =
  if rows.isEmpty || rows.tail.isEmpty then rows
  else
    val half = rows.length / 2
    mergeMultiRows(sortMultiRows(takeMultiRows(rows, half), tables, keys), sortMultiRows(dropMultiRows(rows, half), tables, keys), tables, keys)

def takeMultiRows(rows: List[List[StorageRecord]], n: Int): List[List[StorageRecord]] =
  var r = rows
  var i = 0
  var accRev: List[List[StorageRecord]] = Nil
  while i < n && r.nonEmpty do
    accRev = r.head :: accRev
    r = r.tail
    i = i + 1
  accRev.reverse

def dropMultiRows(rows: List[List[StorageRecord]], n: Int): List[List[StorageRecord]] =
  var r = rows
  var i = 0
  while i < n && r.nonEmpty do
    r = r.tail
    i = i + 1
  r

def readJoinTables(db: ReadonlyDatabase, names: List[String]): Either[String, List[JoinTable]] =
  var r = names
  var accRev: List[JoinTable] = Nil
  var err: Option[String] = None
  while r.nonEmpty && err.isEmpty do
    joinTableRows(db, r.head) match
      case Left(message) => err = Some(message)
      case Right(t) => accRev = JoinTable(t._1, r.head, t._2) :: accRev
    r = r.tail
  err match
    case Some(message) => Left(message)
    case None => Right(accRev.reverse)

def joinTableNames(stmt: SelectStmt): List[String] =
  var r = stmt.joins
  var accRev: List[String] = Nil
  while r.nonEmpty do
    accRev = r.head.table :: accRev
    r = r.tail
  stmt.table :: accRev.reverse

// ── Aggregates / GROUP BY / HAVING over an N-table join (a group is a list of joined rows) ──

def extractMultiValues(group: List[List[StorageRecord]], tables: List[JoinTable], col: String): List[SqliteValue] =
  var r = group
  var accRev: List[SqliteValue] = Nil
  while r.nonEmpty do
    accRev = multiColValue(r.head, tables, col) :: accRev
    r = r.tail
  reverseValues(accRev, Nil)

def multiAggValue(func: String, arg: String, distinct: Boolean, group: List[List[StorageRecord]], tables: List[JoinTable]): SqliteValue =
  val f = upperStr(func)
  val vals = extractMultiValues(group, tables, arg)
  if distinct then aggregateValues(f, dedupValues(vals))
  else if f == "COUNT" && arg == "*" then SqlInteger(group.length.toLong)
  else aggregateValues(f, vals)

def evalArgsMultiGroup(args: List[SxNode], group: List[List[StorageRecord]], tables: List[JoinTable]): List[SqliteValue] =
  var r = args
  var accRev: List[SqliteValue] = Nil
  while r.nonEmpty do
    accRev = evalExprMultiGroup(r.head, group, tables) :: accRev
    r = r.tail
  reverseValues(accRev, Nil)

def evalCaseMultiGroup(operand: Option[SxNode], whens: List[SxWhen], elseExpr: Option[SxNode], group: List[List[StorageRecord]], tables: List[JoinTable]): SqliteValue =
  var r = whens
  var out: Option[SqliteValue] = None
  operand match
    case Some(opExpr) =>
      val opVal = evalExprMultiGroup(opExpr, group, tables)
      while r.nonEmpty && out.isEmpty do
        if sqlCompare(opVal, evalExprMultiGroup(r.head.cond, group, tables)) == 0 then out = Some(evalExprMultiGroup(r.head.result, group, tables))
        r = r.tail
    case None =>
      while r.nonEmpty && out.isEmpty do
        if isTruthy(evalExprMultiGroup(r.head.cond, group, tables)) then out = Some(evalExprMultiGroup(r.head.result, group, tables))
        r = r.tail
  out match
    case Some(v) => v
    case None => elseExpr match
      case Some(e) => evalExprMultiGroup(e, group, tables)
      case None => SqlNull

// Evaluate an expression over a group of joined rows: an aggregate reduces the whole group, a bare
// column takes the group's first joined row.
def evalExprMultiGroup(e: SxNode, group: List[List[StorageRecord]], tables: List[JoinTable]): SqliteValue = e match
  case SxCol(name) => if group.isEmpty then SqlNull else multiColValue(group.head, tables, name)
  case SxLit(v) => v
  case SxNeg(inner) => negateValue(evalExprMultiGroup(inner, group, tables))
  case SxBin(op, l, r) => arithValue(op, evalExprMultiGroup(l, group, tables), evalExprMultiGroup(r, group, tables))
  case SxCall(func, args) => evalCall(func, evalArgsMultiGroup(args, group, tables))
  case SxNot(inner) => notValue(evalExprMultiGroup(inner, group, tables))
  case SxAgg(func, arg, distinct) => multiAggValue(func, arg, distinct, group, tables)
  case SxCase(operand, whens, elseExpr) => evalCaseMultiGroup(operand, whens, elseExpr, group, tables)

def projectMultiGroupRow(group: List[List[StorageRecord]], tables: List[JoinTable], stmt: SelectStmt): List[SqliteValue] =
  var r = stmt.projection
  var accRev: List[SqliteValue] = Nil
  while r.nonEmpty do
    val item = r.head
    val v = if item.isAgg then multiAggValue(item.func, item.name, item.distinct, group, tables)
      else item.expr match
        case Some(e) => evalExprMultiGroup(e, group, tables)
        case None => if group.isEmpty then SqlNull else multiColValue(group.head, tables, item.name)
    accRev = v :: accRev
    r = r.tail
  reverseValues(accRev, Nil)

def multiGroupEqual(a: List[StorageRecord], b: List[StorageRecord], tables: List[JoinTable], groupCols: List[String]): Boolean =
  var r = groupCols
  var eq = true
  while r.nonEmpty && eq do
    if sqlCompare(multiColValue(a, tables, r.head), multiColValue(b, tables, r.head)) != 0 then eq = false
    r = r.tail
  eq

// Partition rows (already sorted by the group columns) into consecutive equal-key runs.
// All-if/else expressions (no bare `if … then <assign>`, which the interpreter mishandles).
def partitionMultiRows(sortedRows: List[List[StorageRecord]], tables: List[JoinTable], groupCols: List[String]): List[List[List[StorageRecord]]] =
  var r = sortedRows
  var groupsRev: List[List[List[StorageRecord]]] = Nil
  var curRev: List[List[StorageRecord]] = Nil
  while r.nonEmpty do
    val startNew = if curRev.isEmpty then true else !multiGroupEqual(curRev.head, r.head, tables, groupCols)
    groupsRev = if startNew && curRev.nonEmpty then curRev.reverse :: groupsRev else groupsRev
    curRev = if startNew then r.head :: Nil else r.head :: curRev
    r = r.tail
  val groups = if curRev.isEmpty then groupsRev else curRev.reverse :: groupsRev
  groups.reverse

def havingHoldsMulti(having: Option[HavingCond], group: List[List[StorageRecord]], tables: List[JoinTable]): Boolean = having match
  case None => true
  case Some(hc) =>
    val lv = if hc.item.isAgg then multiAggValue(hc.item.func, hc.item.name, hc.item.distinct, group, tables)
      else hc.item.expr match
        case Some(e) => evalExprMultiGroup(e, group, tables)
        case None => if group.isEmpty then SqlNull else multiColValue(group.head, tables, hc.item.name)
    condMatches(hc.op, sqlCompare(lv, hc.value))

def multiJoinExecute(db: ReadonlyDatabase, stmt: SelectStmt): Either[String, List[List[SqliteValue]]] =
  readJoinTables(db, joinTableNames(stmt)) match
    case Left(message) => Left(message)
    case Right(tables) =>
      val allRows = buildJoinRows(tables, stmt.joins)
      var jr = allRows
      var keptRev: List[List[StorageRecord]] = Nil
      while jr.nonEmpty do
        if multiWhereHolds(stmt.where, jr.head, tables) then keptRev = jr.head :: keptRev
        jr = jr.tail
      val kept = keptRev.reverse
      if stmt.groupBy.nonEmpty then
        val groups = partitionMultiRows(sortMultiRows(kept, tables, groupKeysOf(stmt.groupBy)), tables, stmt.groupBy)
        var g = groups
        var rowsRev: List[List[SqliteValue]] = Nil
        while g.nonEmpty do
          if havingHoldsMulti(stmt.having, g.head, tables) then rowsRev = projectMultiGroupRow(g.head, tables, stmt) :: rowsRev
          g = g.tail
        Right(limitValueRows(rowsRev.reverse, stmt.limit, stmt.offset))
      else if projHasAgg(stmt.projection) then Right(projectMultiGroupRow(kept, tables, stmt) :: Nil)
      else
        val ordered = if stmt.orderBy.isEmpty then kept else sortMultiRows(kept, tables, stmt.orderBy)
        var r = ordered
        var outRev: List[List[SqliteValue]] = Nil
        while r.nonEmpty do
          outRev = projectMultiRow(r.head, tables, stmt) :: outRev
          r = r.tail
        val deduped = if stmt.distinct then dedupRows(outRev.reverse) else outRev.reverse
        Right(limitValueRows(deduped, stmt.limit, stmt.offset))

def executeSelect(db: ReadonlyDatabase, stmt: SelectStmt): Either[String, List[List[SqliteValue]]] =
  if stmt.joins.isEmpty then executeSelectSingle(db, stmt)
  else if stmt.joins.length == 1 then joinExecute(db, stmt, stmt.joins.head)
  else multiJoinExecute(db, stmt)

def executeSelectSingle(db: ReadonlyDatabase, stmt: SelectStmt): Either[String, List[List[SqliteValue]]] =
  findTable(db, stmt.table) match
    case None => Left("no such table: " + stmt.table)
    case Some(entry) =>
      val colNames = entry.sql match
        case Some(text) => tableColumns(cpToString(text.codePoints))
        case None => Nil
      val root = entry.rootPage match
        case Some(p) => p
        case None => 0L
      openReadonlyRoot(db, root, RowidTableTree) match
        case Left(error) => Left(error.message)
        case Right(cursor) =>
          // LIMIT pushdown: a plain LIMIT query (no ORDER BY / aggregate / GROUP BY / DISTINCT) keeps
          // rows in scan order, so we only need the first `offset+limit` matches — stop the scan there.
          val fastLimit = stmt.orderBy.isEmpty && stmt.groupBy.isEmpty && !projHasAgg(stmt.projection) && !stmt.distinct && stmt.limit >= 0 && !hasExistsCond(stmt.where)
          if fastLimit then executeSelectLimited(db, cursor, stmt, colNames)
          else executeSelectFullScan(db, cursor, stmt, colNames)

// LIMIT-pushdown path: collect only the first offset+limit matching rows (already filtered), then
// project and apply LIMIT/OFFSET. Byte-identical to the full scan for a plain LIMIT query.
def executeSelectLimited(db: ReadonlyDatabase, cursor: ReadonlyBtreeCursor, stmt: SelectStmt, colNames: List[String]): Either[String, List[List[SqliteValue]]] =
  // NOTE: collectRowsLimited applies the WHERE itself while scanning, so the IPK substitution has to
  // reach it too — it takes `ipkIdx` and normalizes each row before matching (see collectRowsLimited).
  val ipkIdx = tableIpkIndex(db, stmt.table)
  collectRowsLimited(db, cursor, stmt.where, colNames, stmt.offset + stmt.limit, ipkIdx) match
    case Left(error) => Left(error.message)
    case Right(matched) =>
      var r = matched
      var accRev: List[List[SqliteValue]] = Nil
      while r.nonEmpty do
        accRev = projectRow(r.head, colNames, stmt) :: accRev
        r = r.tail
      Right(limitValueRows(accRev.reverse, stmt.limit, stmt.offset))

// Full-scan path: read the whole table, filter, then group/aggregate/order/project/limit.
// Finish a single-table query from a row set: filter, then group/aggregate/order/project/limit.
// Shared by the full-scan path and the rowid point-lookup (which supplies 0/1 rows).
def finishRows(db: ReadonlyDatabase, rows: List[StorageRecord], colNames: List[String], stmt: SelectStmt): Either[String, List[List[SqliteValue]]] =
  // Materialise the rowid into the IPK column BEFORE filtering: WHERE/ORDER BY/aggregates all read
  // the record, so substituting only at projection time would leave `WHERE id = 7` matching nothing.
  val normalized = ipkNormalizeRows(rows, tableIpkIndex(db, stmt.table))
  val filtered = filterRowsCtx(db, normalized, stmt.where, colNames, stmt.table)
  if stmt.groupBy.nonEmpty then
    val sortedForGroup = sortStorage(filtered, colNames, groupKeysOf(stmt.groupBy))
    val groups = filterGroups(groupPartition(sortedForGroup, colNames, stmt.groupBy), stmt.having, colNames)
    Right(limitValueRows(mapGroups(groups, colNames, stmt.projection), stmt.limit, stmt.offset))
  else if projHasAgg(stmt.projection) then Right(projectGroupRow(filtered, colNames, stmt.projection) :: Nil)
  else
    val sorted = if stmt.orderBy.isEmpty then filtered else sortStorage(filtered, colNames, stmt.orderBy)
    var r = sorted
    var accRev: List[List[SqliteValue]] = Nil
    while r.nonEmpty do
      accRev = projectRow(r.head, colNames, stmt) :: accRev
      r = r.tail
    var projected: List[List[SqliteValue]] = Nil
    while accRev.nonEmpty do
      projected = accRev.head :: projected
      accRev = accRev.tail
    val deduped = if stmt.distinct then dedupRows(projected) else projected
    Right(limitValueRows(deduped, stmt.limit, stmt.offset))

def executeSelectFullScan(db: ReadonlyDatabase, cursor: ReadonlyBtreeCursor, stmt: SelectStmt, colNames: List[String]): Either[String, List[List[SqliteValue]]] =
  collectRows(db, cursor) match
    case Left(error) => Left(error.message)
    case Right(rows) => finishRows(db, rows, colNames, stmt)

// `SELECT <exprs>` with no FROM: evaluate each projection item against an empty row (no columns).
def executeNoFrom(stmt: SelectStmt): Either[String, List[List[SqliteValue]]] =
  var r = stmt.projection
  var accRev: List[SqliteValue] = Nil
  while r.nonEmpty do
    val item = r.head
    val v = item.expr match
      case Some(e) => evalExprValues(e, Nil, Nil)
      case None => SqlNull
    accRev = v :: accRev
    r = r.tail
  Right(reverseValues(accRev, Nil) :: Nil)

// ── Non-correlated subqueries: evaluate `( SELECT … )` and splice its result back as tokens ──
// A `( SELECT … )` after IN becomes a value list `( v1, v2, … )`; anywhere else it is a scalar
// (the first value of the first row). The subquery must not reference the outer query
// (non-correlated); integer/text results only. Runs as a pre-pass before parse, and recurses so
// nested subqueries resolve too.

// Split the paren group whose opening `(` was just consumed: returns (inner tokens, tokens after
// the matching `)`), or None if unbalanced.
def splitParenGroup(afterLparen: List[Token]): Option[(List[Token], List[Token])] =
  var r = afterLparen
  var depth = 0
  var innerRev: List[Token] = Nil
  var result: Option[(List[Token], List[Token])] = None
  while r.nonEmpty && result.isEmpty do
    val t = r.head
    if t.kind == "rparen" && depth == 0 then result = Some((innerRev, r.tail))
    else
      if t.kind == "lparen" then depth = depth + 1
      else if t.kind == "rparen" then depth = depth - 1
      innerRev = t :: innerRev
      r = r.tail
  result match
    case Some(pair) => Some((pair._1.reverse, pair._2))
    case None => None

def valueToken(v: SqliteValue): Token = v match
  case SqlInteger(x) => Token("num", "", x)
  case SqlText(s) => Token("str", s, 0L)
  case SqlReal(x) => Token("num", "", x.toLong)
  case _ => Token("num", "", 0L)

def valueListTokens(values: List[SqliteValue]): List[Token] =
  var r = values
  var accRev: List[Token] = Nil
  var first = true
  while r.nonEmpty do
    // if/else EXPRESSION, not a bare `if … then <assign>` (the interpreter skips that form).
    accRev = if first then accRev else Token("comma", ",", 0L) :: accRev
    accRev = valueToken(r.head) :: accRev
    first = false
    r = r.tail
  (Token("lparen", "(", 0L) :: Nil) ++ accRev.reverse ++ (Token("rparen", ")", 0L) :: Nil)

def scalarValueTokens(values: List[SqliteValue]): List[Token] =
  if values.isEmpty then Token("num", "", 0L) :: Nil
  else valueToken(values.head) :: Nil

def firstColumn(rows: List[List[SqliteValue]]): List[SqliteValue] =
  var r = rows
  var accRev: List[SqliteValue] = Nil
  while r.nonEmpty do
    accRev = (if r.head.isEmpty then SqlNull else r.head.head) :: accRev
    r = r.tail
  accRev.reverse

def evalSubquery(dbBytes: ByteSlice, inner: List[Token]): Either[String, List[SqliteValue]] =
  resolveSubqueries(dbBytes, inner) match
    case Left(message) => Left(message)
    case Right(resolved) => parseSelect(resolved) match
      case Left(message) => Left(message)
      case Right(stmt) =>
        if stmt.table == "" then executeNoFrom(stmt) match
          case Left(message) => Left(message)
          case Right(rows) => Right(firstColumn(rows))
        else openReadonly(ImageVfs(dbBytes), "image.db", sqlOptions()) match
          case Left(error) => Left(error.message)
          case Right(db) => executeSelect(db, stmt) match
            case Left(message) => Left(message)
            case Right(rows) => Right(firstColumn(rows))

// True iff the token just before a `(SELECT` is EXISTS — such a subquery is correlated (references the
// outer row) and must NOT be pre-resolved here; parseCondition captures it as an exists Condition.
def prevIsExists(prefixRev: List[Token]): Boolean =
  if prefixRev.isEmpty then false else isKw(prefixRev.head, "EXISTS")

// The first top-level (depth-0) FROM table name in a token stream, or "" — the outer query's table.
def firstFromTable(toks: List[Token]): String =
  var r = toks
  var depth = 0
  var found = ""
  while r.nonEmpty && found == "" do
    val t = r.head
    if t.kind == "lparen" then depth = depth + 1
    else if t.kind == "rparen" then depth = depth - 1
    else if depth == 0 && isKw(t, "FROM") then
      if tkKind(r.tail) == "ident" then found = r.tail.head.text
    r = r.tail
  found

// True iff a subquery's tokens contain a qualified reference to `outerTable` (outerTable.col) — i.e. it
// is correlated and must be evaluated per outer row, not pre-resolved.
def referencesOuterTable(innerToks: List[Token], outerTable: String): Boolean =
  if outerTable == "" then false
  else
    val ot = upperStr(outerTable)
    var r = innerToks
    var found = false
    while r.nonEmpty && !found do
      val t = r.head
      if t.kind == "ident" then
        val dot = indexOfDot(t.text)
        if dot >= 0 then
          if upperStr(substr(t.text, 0, dot)) == ot then found = true
      r = r.tail
    found

def resolveSubqueries(dbBytes: ByteSlice, toks: List[Token]): Either[String, List[Token]] =
  val outerTable = firstFromTable(toks)
  var prefixRev: List[Token] = Nil
  var r = toks
  var atSpan = false
  while r.nonEmpty && !atSpan do
    if r.head.kind == "lparen" && tkIsKw(r.tail, "SELECT") then
      if prevIsExists(prefixRev) then
        prefixRev = r.head :: prefixRev
        r = r.tail
      else splitParenGroup(r.tail) match
        case None => atSpan = true
        case Some(sp) =>
          if referencesOuterTable(sp._1, outerTable) then
            prefixRev = r.head :: prefixRev
            r = r.tail
          else atSpan = true
    else
      prefixRev = r.head :: prefixRev
      r = r.tail
  if !atSpan then Right(toks)
  else splitParenGroup(r.tail) match
    case None => Left("unbalanced parentheses in a subquery")
    case Some(sp) => evalSubquery(dbBytes, sp._1) match
      case Left(message) => Left(message)
      case Right(values) =>
        val inCtx = if prefixRev.isEmpty then false else isKw(prefixRev.head, "IN")
        val subst = if inCtx then valueListTokens(values) else scalarValueTokens(values)
        resolveSubqueries(dbBytes, prefixRev.reverse ++ subst ++ sp._2)

def sqlLimits(): SqliteLimits =
  SqliteLimits(1000000L, 100, 100, 100, 100, 10, 1000000L, 100, 100, 1000L, 1000000L, 2, 1000L, 100, 1000000L)

// ── rowid point-lookup: an O(log n) B-tree seek for `WHERE rowid = K` / `WHERE ipk = K` ──
// The result of a seek. SeekFallback means "cannot seek safely, full-scan instead".
sealed trait RowidSeek
case class SeekHit(record: StorageRecord) extends RowidSeek
case object SeekMiss extends RowidSeek
case object SeekFallback extends RowidSeek

def nthName(names: List[String], idx: Int): String =
  var r = names
  var k = idx
  while r.nonEmpty && k > 0 do
    r = r.tail
    k = k - 1
  if idx < 0 then "" else if r.isEmpty then "" else r.head

def findCellByRowid(cells: List[LeafCell], rowid: Long): Option[LeafCell] =
  var r = cells
  var found: Option[LeafCell] = None
  while r.nonEmpty && found.isEmpty do
    if r.head.rowid == rowid then found = Some(r.head)
    r = r.tail
  found

// Decode the found cell's local payload into a StorageRecord. OVERFLOW-SAFE: a payload larger than
// the local threshold (usable - 35) spans overflow pages the readLeafCells reader does not follow,
// so we fall back to the full scan (which decodes overflow correctly). readLeafCells already having
// succeeded means payloadLen.toInt is a valid local length (mirrors readLeafCellAt).
def seekDecodeCell(cellOpt: Option[LeafCell], threshold: Int, db: ReadonlyDatabase, rowid: Long): RowidSeek =
  cellOpt match
    case None => SeekMiss
    case Some(cell) => ByteSlice.fromList(cell.bytes) match
      case Left(_) => SeekFallback
      case Right(cellSlice) => decodeVarint(cellSlice, 0) match
        case Left(_) => SeekFallback
        case Right(VarintRead(plValue, _, plNext)) =>
          if plValue.toInt > threshold then SeekFallback
          else decodeVarint(cellSlice, plNext) match
            case Left(_) => SeekFallback
            case Right(VarintRead(_, _, ridNext)) => byteSliceSlice(cellSlice, ridNext, plValue.toInt) match
              case Left(_) => SeekFallback
              case Right(payload) => decodeRecord(payload, db.schema.encoding, db.schema.format, sqlLimits()) match
                case Left(_) => SeekFallback
                case Right(rec) => SeekHit(StorageRecord(Some(rowid), rec))

// Seek one rowid via a B-tree descent (reuses the write layer's descendToLeaf); overflow/failure → fallback.
def seekRowidRecord(dbBytes: ByteSlice, db: ReadonlyDatabase, root: Int, pageSize: Int, rowid: Long): RowidSeek =
  val reserved = byteSliceGet(dbBytes, 20) match
    case Right(v) => v
    case Left(_) => 0
  val threshold = pageSize - reserved - 35
  val pager = openMutablePager(dbBytes, pageSize, pageSize)
  descendToLeaf(pager, root, rowid) match
    case Left(_) => SeekFallback
    case Right(leafPage) =>
      val ho = if leafPage == 1 then 100 else 0
      mutableGet(pager, leafPage) match
        case Left(_) => SeekFallback
        case Right(pageBytes) => readLeafCells(pageBytes, ho) match
          case Left(_) => SeekFallback
          case Right(cells) => seekDecodeCell(findCellByRowid(cells, rowid), threshold, db, rowid)

// A WHERE of exactly one equality `column = <literal>` → (column, value); else None.
def extractColEq(where: List[List[Condition]]): Option[(String, SqliteValue)] =
  if where.length != 1 then None
  else
    val group = where.head
    if group.length != 1 then None
    else
      val cond = group.head
      if cond.op == "=" && cond.leftExpr.isEmpty && cond.rightExpr.isEmpty then Some((cond.column, cond.value))
      else None

def longOfValue(v: SqliteValue): Option[Long] = v match
  case SqlInteger(x) => Some(x)
  case _ => None

// An index on `table` whose FIRST key column is `colName` → (indexRoot, #keyColumns). The index
// record is [keycols…, rowid], so #keyColumns is the field index of the rowid.
def indexForColumn(db: ReadonlyDatabase, table: String, colName: String): Option[(Long, Int)] =
  val target = upperStr(table)
  val colU = upperStr(colName)
  var r = db.schema.entries
  var found: Option[(Long, Int)] = None
  while r.nonEmpty && found.isEmpty do
    val e = r.head
    val isIndex = e.kind match
      case SchemaIndex => true
      case _ => false
    if isIndex && upperStr(cpToString(e.tableName.codePoints)) == target then
      val cols = e.sql match
        case Some(t) => indexSqlColumns(cpToString(t.codePoints))
        case None => Nil
      if cols.nonEmpty then
        if upperStr(cols.head) == colU then e.rootPage match
          case Some(rp) => found = Some((rp, cols.length))
          case None => found = found
    r = r.tail
  found

def indexRowidOf(record: DecodedRecord, numKeyCols: Int): Long =
  fieldValueAt(record, numKeyCols) match
    case SqlInteger(x) => x
    case _ => 0L

// A key predicate for an index seek: an equality (lo==hi, both inclusive) or an open/closed range.
// `None` bound = unbounded on that side (`col > K` has hi = None; `col < K` has lo = None).
case class IndexRange(lo: Option[SqliteValue], hi: Option[SqliteValue], loIncl: Boolean, hiIncl: Boolean)

// Does a (non-NULL) key satisfy the range? NULL keys never match a comparison/range (SQL semantics).
def keyInRange(key: SqliteValue, range: IndexRange): Boolean =
  if isNullValue(key) then false
  else
    val loOk = range.lo match
      case None => true
      case Some(l) => if range.loIncl then sqlCompare(key, l) >= 0 else sqlCompare(key, l) > 0
    val hiOk = range.hi match
      case None => true
      case Some(h) => if range.hiIncl then sqlCompare(key, h) <= 0 else sqlCompare(key, h) < 0
    loOk && hiOk

// True once the walk has passed the range's high bound (so the ordered walk can stop early).
def pastHigh(key: SqliteValue, range: IndexRange): Boolean =
  range.hi match
    case None => false
    case Some(h) => if range.hiIncl then sqlCompare(key, h) > 0 else sqlCompare(key, h) >= 0

// Ordered fallback: walk the index B-tree in key order collecting the rowids whose first key column
// is in `range`; stop once past the high bound (indexes are BINARY-sorted, matching sqlCompare).
// Used when the O(log n) descent bails (overflow divider/leaf, unexpected page). Entries are visited
// in (key, rowid) order.
def indexWalkRowids(db: ReadonlyDatabase, indexRoot: Long, numKeyCols: Int, range: IndexRange): Either[String, List[Long]] =
  openReadonlyRoot(db, indexRoot, RecordKeyTree) match
    case Left(error) => Left(error.message)
    case Right(cursor) => readonlyFirst(db, cursor) match
      case Left(error) => Left(error.message)
      case Right(firstStep) =>
        var d = firstStep.database
        var c = firstStep.cursor
        var row = firstStep.row
        var accRev: List[Long] = Nil
        var err: Option[String] = None
        var done = false
        while !done && err.isEmpty do
          row match
            case None => done = true
            case Some(rec) =>
              val kv = fieldValueAt(rec.record, 0)
              if pastHigh(kv, range) then done = true
              else
                accRev = if keyInRange(kv, range) then indexRowidOf(rec.record, numKeyCols) :: accRev else accRev
                readonlyNext(d, c) match
                  case Left(error) => err = Some(error.message)
                  case Right(step) =>
                    d = step.database
                    c = step.cursor
                    row = step.row
        err match
          case Some(message) => Left(message)
          case None => Right(accRev.reverse)

// ── O(log n) index descent: prune to the subtrees whose divider range could contain `key` ──
def pageTypeByte(pageBytes: ByteSlice, ho: Int): Int =
  byteSliceGet(pageBytes, ho) match
    case Right(v) => v
    case Left(_) => -1

def intAt(xs: List[Int], idx: Int): Int =
  var r = xs
  var k = idx
  while r.nonEmpty && k > 0 do
    r = r.tail
    k = k - 1
  if r.isEmpty then 0 else r.head

def dividerAt(xs: List[SqliteValue], idx: Int): SqliteValue =
  var r = xs
  var k = idx
  while r.nonEmpty && k > 0 do
    r = r.tail
    k = k - 1
  if r.isEmpty then SqlNull else r.head

// Reverse `xs` onto `acc` (so revIntAppend([c2,c1,c0], [right]) == [c0,c1,c2,right]).
def revIntAppend(xs: List[Int], acc: List[Int]): List[Int] =
  var r = xs
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

// One index-interior page → (child page numbers, divider first-column values). A divider payload
// that overflows the local threshold → Left (caller falls back to the ordered walk).
// Returns (child page numbers, divider first-columns, divider ROWIDS). In a SQLite index B-tree the
// interior divider cells are REAL entries (each key appears once in the whole tree, not duplicated in
// a leaf), so their rowids must be collected too — not only the leaves'.
def readIndexInterior(pageBytes: ByteSlice, ho: Int, threshold: Int, numKeyCols: Int, db: ReadonlyDatabase): Either[String, (List[Int], List[SqliteValue], List[Long])] =
  readU16Be(pageBytes, ho + 3) match
    case Left(e) => Left(e.message)
    case Right(ByteRead(count, _)) => readU32Be(pageBytes, ho + 8) match
      case Left(e) => Left(e.message)
      case Right(ByteRead(rightChild, _)) =>
        var i = 0
        var childrenRev: List[Int] = Nil
        var dividersRev: List[SqliteValue] = Nil
        var dividerRowidsRev: List[Long] = Nil
        var err: Option[String] = None
        while i < count.toInt && err.isEmpty do
          readU16Be(pageBytes, ho + 12 + 2 * i) match
            case Left(e) => err = Some(e.message)
            case Right(ByteRead(cellPtr, _)) => readU32Be(pageBytes, cellPtr.toInt) match
              case Left(e) => err = Some(e.message)
              case Right(ByteRead(leftChild, _)) => decodeVarint(pageBytes, cellPtr.toInt + 4) match
                case Left(e) => err = Some(e.message)
                case Right(VarintRead(plLen, _, payloadOff)) =>
                  if plLen > threshold.toLong then err = Some("overflow-divider")
                  else byteSliceSlice(pageBytes, payloadOff, plLen.toInt) match
                    case Left(e) => err = Some(e.message)
                    case Right(payload) => decodeRecord(payload, db.schema.encoding, db.schema.format, sqlLimits()) match
                      case Left(_) => err = Some("decode-divider")
                      case Right(rec) =>
                        childrenRev = leftChild.toInt :: childrenRev
                        dividersRev = fieldValueAt(rec, 0) :: dividersRev
                        dividerRowidsRev = indexRowidOf(rec, numKeyCols) :: dividerRowidsRev
          i = i + 1
        err match
          case Some(m) => Left(m)
          case None => Right((revIntAppend(childrenRev, rightChild.toInt :: Nil), reverseValues(dividersRev, Nil), revLongAppend(dividerRowidsRev, Nil)))

// One index-leaf page → the rowids whose first key column is in `range`. Overflow payload → Left.
def readIndexLeafRowids(pageBytes: ByteSlice, ho: Int, threshold: Int, numKeyCols: Int, range: IndexRange, db: ReadonlyDatabase): Either[String, List[Long]] =
  readU16Be(pageBytes, ho + 3) match
    case Left(e) => Left(e.message)
    case Right(ByteRead(count, _)) =>
      var i = 0
      var accRev: List[Long] = Nil
      var err: Option[String] = None
      while i < count.toInt && err.isEmpty do
        readU16Be(pageBytes, ho + 8 + 2 * i) match
          case Left(e) => err = Some(e.message)
          case Right(ByteRead(cellPtr, _)) => decodeVarint(pageBytes, cellPtr.toInt) match
            case Left(e) => err = Some(e.message)
            case Right(VarintRead(plLen, _, payloadOff)) =>
              if plLen > threshold.toLong then err = Some("overflow-leaf")
              else byteSliceSlice(pageBytes, payloadOff, plLen.toInt) match
                case Left(e) => err = Some(e.message)
                case Right(payload) => decodeRecord(payload, db.schema.encoding, db.schema.format, sqlLimits()) match
                  case Left(_) => err = Some("decode-leaf")
                  case Right(rec) =>
                    accRev = if keyInRange(fieldValueAt(rec, 0), range) then indexRowidOf(rec, numKeyCols) :: accRev else accRev
        i = i + 1
      err match
        case Some(m) => Left(m)
        case None => Right(accRev.reverse)

// Descend into child i only if its divider range could overlap `range` (conservative bounds, so
// key runs that straddle a divider are never missed). child i holds keys in (div[i-1], div[i]].
def rangeChildCouldContain(i: Int, nchildren: Int, dividers: List[SqliteValue], range: IndexRange): Boolean =
  val lowerOk =
    if i == 0 then true
    else range.hi match
      case None => true
      case Some(h) => sqlCompare(dividerAt(dividers, i - 1), h) <= 0
  val upperOk =
    if i == nchildren - 1 then true
    else range.lo match
      case None => true
      case Some(l) => sqlCompare(dividerAt(dividers, i), l) >= 0
  lowerOk && upperOk

def longAt(xs: List[Long], idx: Int): Long =
  var r = xs
  var k = idx
  while r.nonEmpty && k > 0 do
    r = r.tail
    k = k - 1
  if r.isEmpty then 0L else r.head

// Recurse into every child whose divider range could contain the query range, AND collect the
// divider entries themselves (real entries in an index B-tree) whose key is in range. Order does not
// matter — indexSeekRowids sorts the result into rowid order.
def descendChildren(pager: MutablePager, children: List[Int], dividers: List[SqliteValue], dividerRowids: List[Long], threshold: Int, numKeyCols: Int, range: IndexRange, db: ReadonlyDatabase): Either[String, List[Long]] =
  var i = 0
  val nchildren = children.length
  var acc: List[Long] = Nil
  var err: Option[String] = None
  while i < nchildren && err.isEmpty do
    val childRes: Either[String, List[Long]] =
      if rangeChildCouldContain(i, nchildren, dividers, range) then indexDescendCollect(pager, intAt(children, i), threshold, numKeyCols, range, db)
      else Right(Nil)
    childRes match
      case Left(m) => err = Some(m)
      case Right(rowids) =>
        val dividerPart = if i < nchildren - 1 && keyInRange(dividerAt(dividers, i), range) then longAt(dividerRowids, i) :: Nil else Nil
        acc = acc ++ rowids ++ dividerPart
    i = i + 1
  err match
    case Some(m) => Left(m)
    case None => Right(acc)

def indexDescendCollect(pager: MutablePager, pageNumber: Int, threshold: Int, numKeyCols: Int, range: IndexRange, db: ReadonlyDatabase): Either[String, List[Long]] =
  mutableGet(pager, pageNumber) match
    case Left(e) => Left(e.message)
    case Right(pageBytes) =>
      val ho = if pageNumber == 1 then 100 else 0
      val kind = pageTypeByte(pageBytes, ho)
      if kind == 10 then readIndexLeafRowids(pageBytes, ho, threshold, numKeyCols, range, db)
      else if kind == 2 then readIndexInterior(pageBytes, ho, threshold, numKeyCols, db) match
        case Left(m) => Left(m)
        case Right(ci) => descendChildren(pager, ci._1, ci._2, ci._3, threshold, numKeyCols, range, db)
      else Left("unexpected index page kind")

// Reverse `xs` onto `acc` (for the sorted-insert splice).
def revLongAppend(xs: List[Long], acc: List[Long]): List[Long] =
  var r = xs
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

// Insert x into an ascending list (non-recursive, so no interp stack overflow on long ranges).
def insertSortedLong(x: Long, sorted: List[Long]): List[Long] =
  var beforeRev: List[Long] = Nil
  var rest = sorted
  var placed = false
  while rest.nonEmpty && !placed do
    if x <= rest.head then placed = true
    else
      beforeRev = rest.head :: beforeRev
      rest = rest.tail
  revLongAppend(beforeRev, x :: rest)

def sortLongsAsc(xs: List[Long]): List[Long] =
  var r = xs
  var out: List[Long] = Nil
  while r.nonEmpty do
    out = insertSortedLong(r.head, out)
    r = r.tail
  out

// Collect the rowids matching `range` via the O(log n) descent; on any bail (overflow / unexpected
// page) fall back to the ordered walk. The result is sorted into ascending rowid order so a range
// seek (whose index order differs from rowid order) produces the same rows as the full scan.
def indexSeekRowids(dbBytes: ByteSlice, db: ReadonlyDatabase, indexRoot: Long, numKeyCols: Int, range: IndexRange, pageSize: Int): Either[String, List[Long]] =
  val reserved = byteSliceGet(dbBytes, 20) match
    case Right(v) => v
    case Left(_) => 0
  val threshold = pageSize - reserved - 35
  indexDescendCollect(openMutablePager(dbBytes, pageSize, pageSize), indexRoot.toInt, threshold, numKeyCols, range, db) match
    case Right(rowids) => Right(sortLongsAsc(rowids))
    case Left(_) => indexWalkRowids(db, indexRoot, numKeyCols, range) match
      case Left(m) => Left(m)
      case Right(rowids) => Right(sortLongsAsc(rowids))

// Point-lookup each rowid → its row; None if any lookup must fall back (overflow) or is missing.
def seekRowsForRowids(dbBytes: ByteSlice, db: ReadonlyDatabase, root: Int, pageSize: Int, rowids: List[Long]): Option[List[StorageRecord]] =
  var r = rowids
  var accRev: List[StorageRecord] = Nil
  var bail = false
  while r.nonEmpty && !bail do
    seekRowidRecord(dbBytes, db, root, pageSize, r.head) match
      case SeekHit(rec) => accRev = rec :: accRev
      case SeekMiss => bail = true
      case SeekFallback => bail = true
    r = r.tail
  if bail then None else Some(accRev.reverse)

def rowidSeekResult(dbBytes: ByteSlice, db: ReadonlyDatabase, root: Int, pageSize: Int, colNames: List[String], stmt: SelectStmt, k: Long): Option[Either[String, List[List[SqliteValue]]]] =
  seekRowidRecord(dbBytes, db, root, pageSize, k) match
    case SeekFallback => None
    case SeekMiss => Some(finishRows(db, Nil, colNames, stmt))
    case SeekHit(rec) => Some(finishRows(db, rec :: Nil, colNames, stmt))

def indexSeekResult(dbBytes: ByteSlice, db: ReadonlyDatabase, root: Int, pageSize: Int, colNames: List[String], stmt: SelectStmt, indexRoot: Long, numKeyCols: Int, range: IndexRange): Option[Either[String, List[List[SqliteValue]]]] =
  indexSeekRowids(dbBytes, db, indexRoot, numKeyCols, range, pageSize) match
    case Left(_) => None
    case Right(rowids) => seekRowsForRowids(dbBytes, db, root, pageSize, rowids) match
      case None => None
      case Some(rows) => Some(finishRows(db, rows, colNames, stmt))

// The index range for a single equality/comparison/BETWEEN condition on `col`; else None.
def rangeOfCond(op: String, value: SqliteValue, values: List[SqliteValue]): Option[IndexRange] =
  if op == "=" then Some(IndexRange(Some(value), Some(value), true, true))
  else if op == ">" then Some(IndexRange(Some(value), None, false, true))
  else if op == ">=" then Some(IndexRange(Some(value), None, true, true))
  else if op == "<" then Some(IndexRange(None, Some(value), true, false))
  else if op == "<=" then Some(IndexRange(None, Some(value), true, true))
  else if op == "between" then
    if values.length >= 2 then Some(IndexRange(Some(values.head), Some(values.tail.head), true, true))
    else None
  else None

// Every indexable condition `col <op> literal(s)` in a single AND-group (no top-level OR). Any one of
// them can drive the seek: a row satisfying the whole AND also satisfies each condition, so a seek on
// one returns a superset that finishRows (which applies the full WHERE) filters down. OR-of-groups
// (where.length > 1) is not seekable this way.
def indexableConds(where: List[List[Condition]]): List[(String, IndexRange)] =
  if where.length != 1 then Nil
  else
    var r = where.head
    var accRev: List[(String, IndexRange)] = Nil
    while r.nonEmpty do
      val cond = r.head
      accRev =
        if cond.leftExpr.isEmpty && cond.rightExpr.isEmpty then rangeOfCond(cond.op, cond.value, cond.values) match
          case Some(range) => (cond.column, range) :: accRev
          case None => accRev
        else accRev
      r = r.tail
    accRev.reverse

// If the range is an equality [v, v] (both inclusive), return v — used for the rowid/IPK seek, which
// is equality-only (a rowid range still full-scans for now).
def rangeEqualityValue(range: IndexRange): Option[SqliteValue] =
  range.lo match
    case None => None
    case Some(l) => range.hi match
      case None => None
      case Some(h) => if range.loIncl && range.hiIncl && valEqual(l, h) then Some(l) else None

// Pick the first seekable condition and run its seek. A rowid/IPK column needs an equality (a rowid
// range still full-scans); any other column needs an index. A non-seekable condition is skipped to
// the next. Returns None if none is seekable or the chosen seek bails (→ full scan).
def chooseSeek(dbBytes: ByteSlice, db: ReadonlyDatabase, root: Int, pageSize: Int, colNames: List[String], stmt: SelectStmt, ipkIdx: Int, conds: List[(String, IndexRange)]): Option[Either[String, List[List[SqliteValue]]]] =
  var r = conds
  var result: Option[Either[String, List[List[SqliteValue]]]] = None
  var stop = false
  while r.nonEmpty && !stop do
    val colName = r.head._1
    val range = r.head._2
    val col = upperStr(colName)
    val isRowidCol = col == "ROWID" || (ipkIdx >= 0 && col == upperStr(nthName(colNames, ipkIdx)))
    if isRowidCol then rangeEqualityValue(range) match
      case Some(v) => longOfValue(v) match
        case Some(k) =>
          result = rowidSeekResult(dbBytes, db, root, pageSize, colNames, stmt, k)
          stop = true
        case None => r = r.tail
      case None => r = r.tail
    else indexForColumn(db, stmt.table, colName) match
      case Some(idx) =>
        result = indexSeekResult(dbBytes, db, root, pageSize, colNames, stmt, idx._1, idx._2, range)
        stop = true
      case None => r = r.tail
  result

// Try an index access path for a single-table query whose WHERE is one AND-group containing at least
// one indexable condition (rowid/IPK equality → table seek, indexed col over a range → index seek).
// The seek returns a superset; finishRows applies the full WHERE. None → use the full scan.
def pointLookup(dbBytes: ByteSlice, stmt: SelectStmt): Option[Either[String, List[List[SqliteValue]]]] =
  if stmt.joins.nonEmpty then None
  else
    val conds = indexableConds(stmt.where)
    if conds.isEmpty then None
    else tableContext(dbBytes, stmt.table) match
      case Left(_) => None
      case Right(ctx) =>
        val db = ctx._1
        val root = ctx._2
        val colNames = ctx._3
        val pageSize = ctx._4
        chooseSeek(dbBytes, db, root, pageSize, colNames, stmt, tableIpkIndex(db, stmt.table), conds)

/** Execute an already-built SelectStmt against a database image (the typed-SQL surface entry —
 *  skips tokenize/parse and runs the same executor path queryImage's tail uses). Tries a rowid
 *  point-lookup first (WHERE rowid=K / WHERE ipk=K), else the normal executor. */
def runSelectStmt(dbBytes: ByteSlice, stmt: SelectStmt): Either[String, List[List[SqliteValue]]] =
  if stmt.table == "" then executeNoFrom(stmt)
  else pointLookup(dbBytes, stmt) match
    case Some(result) => result
    case None => openReadonly(ImageVfs(dbBytes), "image.db", sqlOptions()) match
      case Left(error) => Left(error.message)
      case Right(db) => executeSelect(db, stmt)

/** Run a SELECT against a database image and return the result rows. */
def queryImage(dbBytes: ByteSlice, sql: String): Either[String, List[List[SqliteValue]]] =
  queryImageParams(dbBytes, sql, Nil)

// Parameterized SELECT: tokenize → bindParams → resolveSubqueries → parseSelect → execute. With
// `params = Nil` and no `?` in the SQL, bindParams is an identity pass, so queryImage delegates here.
def queryImageParams(dbBytes: ByteSlice, sql: String, params: List[SqliteValue]): Either[String, List[List[SqliteValue]]] =
  tokenize(sql) match
    case Left(message) => Left(message)
    case Right(toks0) => bindParams(toks0, params) match
      case Left(message) => Left(message)
      case Right(bt) => resolveSubqueries(dbBytes, bt) match
        case Left(message) => Left(message)
        case Right(toks) => parseSelect(toks) match
          case Left(message) => Left(message)
          case Right(stmt) => runSelectStmt(dbBytes, stmt)

// ── DML: INSERT and DELETE through the balanced write path ──

case class InsertStmt(table: String, columns: List[String], rows: List[List[SqliteValue]])
case class DeleteStmt(table: String, where: List[List[Condition]])

def reverseValues(items: List[SqliteValue], acc: List[SqliteValue]): List[SqliteValue] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

/** Parse `( literal [, literal]* )` starting at `toks`; returns the values + the rest. */
def parseValueList(toks: List[Token]): Either[String, (List[SqliteValue], List[Token])] =
  if tkKind(toks) != "lparen" then Left("expected '(' before VALUES list")
  else
    var rest = toks.tail
    var accRev: List[SqliteValue] = Nil
    var result: Option[Either[String, (List[SqliteValue], List[Token])]] = None
    var expectValue = true
    while result.isEmpty do
      if rest.isEmpty then result = Some(Left("unterminated VALUES list"))
      else if rest.head.kind == "rparen" then result = Some(Right((reverseValues(accRev, Nil), rest.tail)))
      else if expectValue then
        litValue(rest.head) match
          case Left(message) => result = Some(Left(message))
          case Right(value) =>
            accRev = value :: accRev
            rest = rest.tail
            expectValue = false
      else if rest.head.kind == "comma" then
        rest = rest.tail
        expectValue = true
      else result = Some(Left("expected ',' or ')' in VALUES list"))
    result match
      case Some(r) => r
      case None => Left("VALUES parse error")

// Optional `( col, col, … )` column list before VALUES; returns the names + the rest.
def parseInsertColumns(toks: List[Token]): Either[String, (List[String], List[Token])] =
  if tkKind(toks) != "lparen" then Right((Nil, toks))
  else
    var rest = toks.tail
    var accRev: List[String] = Nil
    var expectCol = true
    var result: Option[Either[String, (List[String], List[Token])]] = None
    while result.isEmpty do
      if tkKind(rest) == "rparen" then result = Some(Right((reverseStrings(accRev, Nil), rest.tail)))
      else if expectCol && tkKind(rest) == "ident" then
        accRev = rest.head.text :: accRev
        rest = rest.tail
        expectCol = false
      else if !expectCol && tkKind(rest) == "comma" then
        rest = rest.tail
        expectCol = true
      else result = Some(Left("malformed column list"))
    result match
      case Some(r) => r
      case None => Left("column list parse error")

def reverseRows(items: List[List[SqliteValue]], acc: List[List[SqliteValue]]): List[List[SqliteValue]] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

// One or more `( … )` tuples after VALUES, comma-separated (multi-row INSERT).
def parseValueRows(toks: List[Token]): Either[String, (List[List[SqliteValue]], List[Token])] =
  parseValueList(toks) match
    case Left(message) => Left(message)
    case Right(first) =>
      var rowsRev: List[List[SqliteValue]] = first._1 :: Nil
      var rest = first._2
      var err: Option[String] = None
      var done = false
      while !done && err.isEmpty do
        if tkKind(rest) == "comma" then
          parseValueList(rest.tail) match
            case Left(message) => err = Some(message)
            case Right(nxt) =>
              rowsRev = nxt._1 :: rowsRev
              rest = nxt._2
        else done = true
      err match
        case Some(message) => Left(message)
        case None => Right((reverseRows(rowsRev, Nil), rest))

def parseInsert(toks: List[Token]): Either[String, InsertStmt] =
  if !tkIsKw(toks, "INSERT") then Left("expected INSERT")
  else
    val afterInsert = toks.tail
    if !tkIsKw(afterInsert, "INTO") then Left("expected INTO")
    else
      val afterInto = afterInsert.tail
      if tkKind(afterInto) != "ident" then Left("expected table name")
      else
        val table = afterInto.head.text
        parseInsertColumns(afterInto.tail) match
          case Left(message) => Left(message)
          case Right(colPair) =>
            val afterCols = colPair._2
            if !tkIsKw(afterCols, "VALUES") then Left("expected VALUES")
            else parseValueRows(afterCols.tail) match
              case Left(message) => Left(message)
              case Right(valPair) => Right(InsertStmt(table, colPair._1, valPair._1))

def parseDelete(toks: List[Token]): Either[String, DeleteStmt] =
  if !tkIsKw(toks, "DELETE") then Left("expected DELETE")
  else
    val afterDelete = toks.tail
    if !tkIsKw(afterDelete, "FROM") then Left("expected FROM")
    else
      val afterFrom = afterDelete.tail
      if tkKind(afterFrom) != "ident" then Left("expected table name")
      else parseWhere(afterFrom.tail) match
        case Left(message) => Left(message)
        case Right(wpair) => Right(DeleteStmt(afterFrom.head.text, wpair._1))

def maxRowidOf(rows: List[StorageRecord]): Long =
  var r = rows
  var m = 0L
  while r.nonEmpty do
    r.head.rowid match
      case Some(id) => if id > m then m = id
      case None => m = m
    r = r.tail
  m

def matchingRowids(rows: List[StorageRecord], where: List[List[Condition]], colNames: List[String]): List[Long] =
  var r = rows
  var accRev: List[Long] = Nil
  while r.nonEmpty do
    if whereHolds(where, r.head, colNames) then
      r.head.rowid match
        case Some(id) => accRev = id :: accRev
        case None => accRev = accRev
    r = r.tail
  var out: List[Long] = Nil
  while accRev.nonEmpty do
    out = accRev.head :: out
    accRev = accRev.tail
  out

// The column names of a table in an image (from its CREATE TABLE), for result metadata labels.
def imageTableColumns(dbBytes: ByteSlice, table: String): Either[String, List[String]] =
  tableContext(dbBytes, table) match
    case Left(message) => Left(message)
    case Right(ctx) => Right(ctx._3)

// Resolve (rootPage, column names, page size) for a table; open the image read-only.
def tableContext(dbBytes: ByteSlice, table: String): Either[String, (ReadonlyDatabase, Int, List[String], Int)] =
  openReadonly(ImageVfs(dbBytes), "image.db", sqlOptions()) match
    case Left(error) => Left(error.message)
    case Right(db) => findTable(db, table) match
      case None => Left("no such table: " + table)
      case Some(entry) =>
        val root = entry.rootPage match
          case Some(p) => p.toInt
          case None => 0
        val colNames = entry.sql match
          case Some(text) => tableColumns(cpToString(text.codePoints))
          case None => Nil
        Right((db, root, colNames, db.pager.header.pageSize))

def valueAtPos(values: List[SqliteValue], pos: Int): SqliteValue =
  var r = values
  var i = 0
  var out: SqliteValue = SqlNull
  while r.nonEmpty do
    if i == pos then out = r.head
    i = i + 1
    r = r.tail
  out

// Map an explicit column-list INSERT to declared-column order; unnamed columns → NULL.
def reorderInsertValues(insertCols: List[String], values: List[SqliteValue], colNames: List[String]): List[SqliteValue] =
  var r = colNames
  var accRev: List[SqliteValue] = Nil
  while r.nonEmpty do
    val pos = columnIndex(insertCols, r.head)
    val v = if pos < 0 then SqlNull else valueAtPos(values, pos)
    accRev = v :: accRev
    r = r.tail
  reverseValues(accRev, Nil)

// Insert each row (rowid = start, start+1, …) into one pager; returns the pager + last rowid used.
def insertRowsLoop(pager: MutablePager, root: Int, startRowid: Long, rows: List[List[SqliteValue]], columns: List[String], colNames: List[String], pageSize: Int): Either[String, (MutablePager, Long)] =
  var p = pager
  var rid = startRowid
  var r = rows
  var err: Option[String] = None
  while r.nonEmpty && err.isEmpty do
    val insertValues = if columns.isEmpty then r.head else reorderInsertValues(columns, r.head, colNames)
    encodeRecord(insertValues) match
      case Left(error) => err = Some(error.message)
      case Right(record) =>
        pagerInsertBalanced(p, root, rid, record, pageSize) match
          case Left(error) => err = Some(error.message)
          case Right(np) =>
            p = np
            rid = rid + 1L
    r = r.tail
  err match
    case Some(message) => Left(message)
    case None => Right((p, rid - 1L))

// ── Index maintenance for SQL DML (single-table databases with 1+ indexes) ──
// After an INSERT/UPDATE/DELETE on an indexed table, the whole database is rebuilt compactly
// (table + every index, roots reassigned) so no page is orphaned and reference integrity_check
// stays ok. Scoped to single-table databases; a table with no index keeps the fast incremental
// path, and a multi-table database with indexes errors (a documented follow-up).

case class SqlRow(rowid: Long, values: List[SqliteValue])
case class IndexInfo(rawRecord: DecodedRecord, keyColumns: List[Int])

def indexSqlColumns(sqlText: String): List[String] =
  tokenize(sqlText) match
    case Left(_) => Nil
    case Right(toks) => parseCreateIndex(toks) match
      case Left(_) => Nil
      case Right(ci) => ci.columns

// Indexes on a table, optionally excluding one by name (for DROP INDEX). `exceptName == ""`
// keeps all of them.
def tableIndexInfosExcept(db: ReadonlyDatabase, tableName: String, colNames: List[String], exceptName: String): List[IndexInfo] =
  val target = upperStr(tableName)
  val skip = upperStr(exceptName)
  var r = db.schema.entries
  var accRev: List[IndexInfo] = Nil
  while r.nonEmpty do
    val e = r.head
    val isIndex = e.kind match
      case SchemaIndex => true
      case _ => false
    val nm = upperStr(cpToString(e.name.codePoints))
    if isIndex && upperStr(cpToString(e.tableName.codePoints)) == target && !(skip != "" && nm == skip) then
      val cols = e.sql match
        case Some(t) => indexSqlColumns(cpToString(t.codePoints))
        case None => Nil
      accRev = IndexInfo(e.rawRecord, indexColIndices(cols, colNames)) :: accRev
    r = r.tail
  accRev.reverse

def tableIndexInfos(db: ReadonlyDatabase, tableName: String, colNames: List[String]): List[IndexInfo] =
  tableIndexInfosExcept(db, tableName, colNames, "")

def findIndexEntry(db: ReadonlyDatabase, name: String): Option[SchemaEntry] =
  val target = upperStr(name)
  var r = db.schema.entries
  var found: Option[SchemaEntry] = None
  while r.nonEmpty && found.isEmpty do
    val e = r.head
    val isIndex = e.kind match
      case SchemaIndex => true
      case _ => false
    if isIndex && upperStr(cpToString(e.name.codePoints)) == target then found = Some(e)
    r = r.tail
  found

def countTables(db: ReadonlyDatabase): Int =
  var r = db.schema.entries
  var n = 0
  while r.nonEmpty do
    r.head.kind match
      case SchemaTable => n = n + 1
      case _ => n = n
    r = r.tail
  n

def indexRawRecords(infos: List[IndexInfo]): List[DecodedRecord] =
  var r = infos
  var accRev: List[DecodedRecord] = Nil
  while r.nonEmpty do
    accRev = r.head.rawRecord :: accRev
    r = r.tail
  accRev.reverse

def pickColumns(values: List[SqliteValue], keyColumns: List[Int]): List[SqliteValue] =
  var r = keyColumns
  var accRev: List[SqliteValue] = Nil
  while r.nonEmpty do
    accRev = listNth(values, r.head) :: accRev
    r = r.tail
  reverseValues(accRev, Nil)

def sqlRowsToKeyed(rows: List[SqlRow]): Either[String, List[KeyedRawRow]] =
  var r = rows
  var accRev: List[KeyedRawRow] = Nil
  var err: Option[String] = None
  while r.nonEmpty && err.isEmpty do
    encodeRecord(r.head.values) match
      case Left(error) => err = Some(error.message)
      case Right(rec) => accRev = KeyedRawRow(r.head.rowid, byteSliceToList(rec)) :: accRev
    r = r.tail
  err match
    case Some(message) => Left(message)
    case None => Right(accRev.reverse)

def indexEntriesForRows(rows: List[SqlRow], keyColumns: List[Int]): Either[String, List[IndexEntry]] =
  var r = rows
  var accRev: List[IndexEntry] = Nil
  var err: Option[String] = None
  while r.nonEmpty && err.isEmpty do
    val kv = pickColumns(r.head.values, keyColumns)
    encodeRecord(kv ++ (SqlInteger(r.head.rowid) :: Nil)) match
      case Left(error) => err = Some(error.message)
      case Right(rec) => accRev = IndexEntry(kv, r.head.rowid, byteSliceToList(rec)) :: accRev
    r = r.tail
  err match
    case Some(message) => Left(message)
    case None => Right(reverseIndexEntries(accRev, Nil))

def indexEntriesAll(rows: List[SqlRow], infos: List[IndexInfo]): Either[String, List[List[IndexEntry]]] =
  var r = infos
  var accRev: List[List[IndexEntry]] = Nil
  var err: Option[String] = None
  while r.nonEmpty && err.isEmpty do
    indexEntriesForRows(rows, r.head.keyColumns) match
      case Left(message) => err = Some(message)
      case Right(entries) => accRev = entries :: accRev
    r = r.tail
  err match
    case Some(message) => Left(message)
    case None => Right(accRev.reverse)

// Rebuild the whole (single-table) database from the new full row set + its indexes.
def reindexTable(dbBytes: ByteSlice, db: ReadonlyDatabase, tableName: String, newRows: List[SqlRow], infos: List[IndexInfo]): Either[String, ByteSlice] =
  val pageSize = db.pager.header.pageSize
  val cc = toIntVal(SqlInteger(db.pager.header.changeCounter))
  val sc = toIntVal(SqlInteger(db.schema.cookie))
  findTable(db, tableName) match
    case None => Left("no such table: " + tableName)
    case Some(entry) => sqlRowsToKeyed(newRows) match
      case Left(message) => Left(message)
      case Right(keyed) => indexEntriesAll(newRows, infos) match
        case Left(message) => Left(message)
        case Right(entriesPerIndex) => buildSingleTableIndexed(pageSize, cc, sc, entry.rawRecord, indexRawRecords(infos), keyed, entriesPerIndex) match
          case Left(error) => Left(error.message)
          case Right(bytes) => Right(bytes)

def storageToSqlRows(rows: List[StorageRecord], ncols: Int): List[SqlRow] =
  var r = rows
  var accRev: List[SqlRow] = Nil
  while r.nonEmpty do
    val rec = r.head
    val rowid = rec.rowid match
      case Some(id) => id
      case None => 0L
    accRev = SqlRow(rowid, extractValues(rec, ncols)) :: accRev
    r = r.tail
  accRev.reverse

// Replace the idx-th value of a row (0-based); used to write an auto-assigned rowid back into an
// INTEGER PRIMARY KEY column so `SELECT ipk` reads the rowid.
def setValueAt(vals: List[SqliteValue], idx: Int, v: SqliteValue): List[SqliteValue] =
  var r = vals
  var i = 0
  var accRev: List[SqliteValue] = Nil
  while r.nonEmpty do
    accRev = (if i == idx then v else r.head) :: accRev
    i = i + 1
    r = r.tail
  reverseValues(accRev, Nil)

def valueIntOrNone(v: SqliteValue): Option[Long] = v match
  case SqlInteger(x) => Some(x)
  case _ => None

// Assign a rowid to each inserted row. With an INTEGER PRIMARY KEY column (ipkIdx>=0), the rowid is
// that column's integer value when supplied (SQLite's rowid alias); a NULL/absent IPK gets the next
// auto rowid (max seen so far + 1) written back into the column. Without an IPK column, rowids are
// sequential from startAuto (the historical behaviour). An explicit value advances the auto counter.
def assignInsertRowids(valueRows: List[List[SqliteValue]], columns: List[String], colNames: List[String], ipkIdx: Int, startAuto: Long): List[SqlRow] =
  var r = valueRows
  var nextAuto = startAuto
  var accRev: List[SqlRow] = Nil
  while r.nonEmpty do
    val reordered = if columns.isEmpty then r.head else reorderInsertValues(columns, r.head, colNames)
    val explicit = if ipkIdx < 0 then None else valueIntOrNone(valueAtPos(reordered, ipkIdx))
    val rowid = explicit match
      case Some(v) => v
      case None => nextAuto
    val vals = explicit match
      case Some(_) => reordered
      case None => if ipkIdx < 0 then reordered else setValueAt(reordered, ipkIdx, SqlInteger(rowid))
    nextAuto = if rowid >= nextAuto then longAdd(rowid, 1L) else nextAuto
    accRev = SqlRow(rowid, vals) :: accRev
    r = r.tail
  accRev.reverse

// Insert pre-assigned SqlRows (rowid from each row) into one pager; duplicate rowid → error
// (matching a duplicate INTEGER PRIMARY KEY / rowid, via leafInsertCell).
def insertSqlRowsLoop(pager: MutablePager, root: Int, sqlRows: List[SqlRow], pageSize: Int): Either[String, MutablePager] =
  var p = pager
  var r = sqlRows
  var err: Option[String] = None
  while r.nonEmpty && err.isEmpty do
    encodeRecord(r.head.values) match
      case Left(error) => err = Some(error.message)
      case Right(record) =>
        pagerInsertBalanced(p, root, r.head.rowid, record, pageSize) match
          case Left(error) => err = Some(error.message)
          case Right(np) => p = np
    r = r.tail
  err match
    case Some(message) => Left(message)
    case None => Right(p)

// The INTEGER PRIMARY KEY column index for a table (from its CREATE TABLE), or -1.
def tableIpkIndex(db: ReadonlyDatabase, table: String): Int =
  findTable(db, table) match
    case None => -1
    case Some(e) => e.sql match
      case Some(t) => ipkColumnIndex(cpToString(t.codePoints))
      case None => -1

def executeInsert(dbBytes: ByteSlice, stmt: InsertStmt): Either[String, ByteSlice] =
  tableContext(dbBytes, stmt.table) match
    case Left(message) => Left(message)
    case Right(ctx) =>
      val db = ctx._1
      val root = ctx._2
      val colNames = ctx._3
      val pageSize = ctx._4
      openReadonlyRoot(db, root.toLong, RowidTableTree) match
        case Left(error) => Left(error.message)
        case Right(cursor) => collectRows(db, cursor) match
          case Left(error) => Left(error.message)
          case Right(rows) =>
            if stmt.rows.isEmpty then Right(dbBytes)
            else
              val rowid0 = maxRowidOf(rows) + 1L
              val ipkIdx = tableIpkIndex(db, stmt.table)
              val newRows = assignInsertRowids(stmt.rows, stmt.columns, colNames, ipkIdx, rowid0)
              val infos = tableIndexInfos(db, stmt.table, colNames)
              if infos.isEmpty then
                insertSqlRowsLoop(openMutablePager(dbBytes, pageSize, pageSize), root, newRows, pageSize) match
                  case Left(message) => Left(message)
                  case Right(pager) => mutableCommit(pager, 1L) match
                    case Left(error) => Left(error.message)
                    case Right(pc) => Right(pc.pager.image)
              else if countTables(db) != 1 then Left("index maintenance on a multi-table database is not yet supported")
              else reindexTable(dbBytes, db, stmt.table, storageToSqlRows(rows, colNames.length) ++ newRows, infos)

// Rows to be inserted, as SqlRows with assigned sequential rowids (unlisted columns → NULL).
def insertedSqlRows(valueRows: List[List[SqliteValue]], columns: List[String], colNames: List[String], startRowid: Long): List[SqlRow] =
  var r = valueRows
  var rid = startRowid
  var accRev: List[SqlRow] = Nil
  while r.nonEmpty do
    val vals = if columns.isEmpty then r.head else reorderInsertValues(columns, r.head, colNames)
    accRev = SqlRow(rid, vals) :: accRev
    rid = rid + 1L
    r = r.tail
  accRev.reverse

def deleteRowidLoop(pager: MutablePager, root: Int, rowids: List[Long], pageSize: Int): Either[String, MutablePager] =
  var p = pager
  var r = rowids
  var err: Option[String] = None
  while r.nonEmpty && err.isEmpty do
    pagerDeleteBalanced(p, root, r.head, pageSize) match
      case Left(error) => err = Some(error.message)
      case Right(next) => p = next
    r = r.tail
  err match
    case Some(message) => Left(message)
    case None => Right(p)

def executeDelete(dbBytes: ByteSlice, stmt: DeleteStmt): Either[String, ByteSlice] =
  tableContext(dbBytes, stmt.table) match
    case Left(message) => Left(message)
    case Right(ctx) =>
      val db = ctx._1
      val root = ctx._2
      val colNames = ctx._3
      val pageSize = ctx._4
      openReadonlyRoot(db, root.toLong, RowidTableTree) match
        case Left(error) => Left(error.message)
        case Right(cursor) => collectRows(db, cursor) match
          case Left(error) => Left(error.message)
          case Right(rows) =>
            val victims = matchingRowids(rows, stmt.where, colNames)
            if victims.isEmpty then Right(dbBytes)
            else
              val infos = tableIndexInfos(db, stmt.table, colNames)
              if infos.isEmpty then
                deleteRowidLoop(openMutablePager(dbBytes, pageSize, pageSize), root, victims, pageSize) match
                  case Left(message) => Left(message)
                  case Right(pager) => mutableCommit(pager, 1L) match
                    case Left(error) => Left(error.message)
                    case Right(pc) => Right(pc.pager.image)
              else if countTables(db) != 1 then Left("index maintenance on a multi-table database is not yet supported")
              else reindexTable(dbBytes, db, stmt.table, keepSqlRows(rows, colNames.length, victims), infos)

def longInList(x: Long, xs: List[Long]): Boolean =
  var r = xs
  var found = false
  while r.nonEmpty && !found do
    if r.head == x then found = true
    r = r.tail
  found

// Existing rows minus the given rowids, as SqlRows (for index-maintaining DELETE).
def keepSqlRows(rows: List[StorageRecord], ncols: Int, victims: List[Long]): List[SqlRow] =
  var r = rows
  var accRev: List[SqlRow] = Nil
  while r.nonEmpty do
    val rec = r.head
    val rowid = rec.rowid match
      case Some(id) => id
      case None => 0L
    if !longInList(rowid, victims) then accRev = SqlRow(rowid, extractValues(rec, ncols)) :: accRev
    r = r.tail
  accRev.reverse

// ── UPDATE (delete + reinsert at the same rowid — handles any size change) ──

// `SET column = value|expr`: a bare literal keeps `value` (`expr=None`); any compound RHS
// (e.g. `n + 1`, another column) is carried as an SxNode evaluated against the pre-update row.
case class Assignment(column: String, value: SqliteValue, expr: Option[SxNode])
case class UpdateStmt(table: String, assignments: List[Assignment], where: List[List[Condition]])
case class EditRow(rowid: Long, record: ByteSlice)

def reverseAssignments(items: List[Assignment], acc: List[Assignment]): List[Assignment] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

def parseAssignments(toks: List[Token]): Either[String, (List[Assignment], List[Token])] =
  var rest = toks
  var accRev: List[Assignment] = Nil
  var result: Option[Either[String, (List[Assignment], List[Token])]] = None
  while result.isEmpty do
    if rest.length < 3 then result = Some(Left("SET needs column = value"))
    else
      val col = rest.head
      val op = rest.tail.head
      if col.kind != "ident" then result = Some(Left("expected column in SET"))
      else if op.kind != "op" || op.text != "=" then result = Some(Left("expected '=' in SET"))
      else parseExpr(rest.tail.tail) match
        case Left(message) => result = Some(Left(message))
        case Right(ep) =>
          val value = ep._1 match
            case SxLit(x) => x
            case _ => SqlNull
          val eopt = ep._1 match
            case SxLit(_) => None
            case _ => Some(ep._1)
          accRev = Assignment(col.text, value, eopt) :: accRev
          rest = ep._2
          if tkKind(rest) == "comma" then rest = rest.tail
          else result = Some(Right((reverseAssignments(accRev, Nil), rest)))
  result match
    case Some(r) => r
    case None => Left("SET parse error")

def parseUpdate(toks: List[Token]): Either[String, UpdateStmt] =
  if !tkIsKw(toks, "UPDATE") then Left("expected UPDATE")
  else
    val afterUpdate = toks.tail
    if tkKind(afterUpdate) != "ident" then Left("expected table name")
    else
      val table = afterUpdate.head.text
      val afterTable = afterUpdate.tail
      if !tkIsKw(afterTable, "SET") then Left("expected SET")
      else parseAssignments(afterTable.tail) match
        case Left(message) => Left(message)
        case Right(pair) => parseWhere(pair._2) match
          case Left(message) => Left(message)
          case Right(wpair) => Right(UpdateStmt(table, pair._1, wpair._1))

def extractValues(rec: StorageRecord, count: Int): List[SqliteValue] =
  var i = 0
  var accRev: List[SqliteValue] = Nil
  while i < count do
    accRev = fieldValueAt(rec.record, i) :: accRev
    i = i + 1
  reverseValues(accRev, Nil)

def listNth(xs: List[SqliteValue], idx: Int): SqliteValue =
  var r = xs
  var i = idx
  while i > 0 && r.nonEmpty do
    r = r.tail
    i = i - 1
  if r.isEmpty then SqlNull else r.head

def valueByName(values: List[SqliteValue], colNames: List[String], name: String): SqliteValue =
  val idx = columnIndex(colNames, name)
  if idx < 0 then SqlNull else listNth(values, idx)

// Evaluate an expression against a row given as its already-extracted column `values` (used
// for UPDATE SET, where the RHS reads the pre-update row without a StorageRecord).
def evalArgsValues(args: List[SxNode], values: List[SqliteValue], colNames: List[String]): List[SqliteValue] =
  var r = args
  var accRev: List[SqliteValue] = Nil
  while r.nonEmpty do
    accRev = evalExprValues(r.head, values, colNames) :: accRev
    r = r.tail
  reverseValues(accRev, Nil)

def evalCaseValues(operand: Option[SxNode], whens: List[SxWhen], elseExpr: Option[SxNode], values: List[SqliteValue], colNames: List[String]): SqliteValue =
  var r = whens
  var out: Option[SqliteValue] = None
  operand match
    case Some(opExpr) =>
      val opVal = evalExprValues(opExpr, values, colNames)
      while r.nonEmpty && out.isEmpty do
        if sqlCompare(opVal, evalExprValues(r.head.cond, values, colNames)) == 0 then out = Some(evalExprValues(r.head.result, values, colNames))
        r = r.tail
    case None =>
      while r.nonEmpty && out.isEmpty do
        if isTruthy(evalExprValues(r.head.cond, values, colNames)) then out = Some(evalExprValues(r.head.result, values, colNames))
        r = r.tail
  out match
    case Some(v) => v
    case None => elseExpr match
      case Some(e) => evalExprValues(e, values, colNames)
      case None => SqlNull

def evalExprValues(e: SxNode, values: List[SqliteValue], colNames: List[String]): SqliteValue = e match
  case SxCol(name) => valueByName(values, colNames, name)
  case SxLit(v) => v
  case SxNeg(inner) => negateValue(evalExprValues(inner, values, colNames))
  case SxBin(op, l, r) => arithValue(op, evalExprValues(l, values, colNames), evalExprValues(r, values, colNames))
  case SxCall(func, args) => evalCall(func, evalArgsValues(args, values, colNames))
  case SxNot(inner) => notValue(evalExprValues(inner, values, colNames))
  case SxAgg(_, _, _) => SqlNull
  case SxCase(operand, whens, elseExpr) => evalCaseValues(operand, whens, elseExpr, values, colNames)

def findAssignmentItem(assignments: List[Assignment], colName: String): Option[Assignment] =
  val target = upperStr(colName)
  var r = assignments
  var found: Option[Assignment] = None
  while r.nonEmpty do
    if upperStr(r.head.column) == target then found = Some(r.head)
    r = r.tail
  found

// Assignment RHS values are all evaluated against the ORIGINAL row (`values`), so
// `SET a = b, b = a` swaps and `SET n = n + 1` increments, matching sqlite.
def applyAssignments(values: List[SqliteValue], colNames: List[String], assignments: List[Assignment]): List[SqliteValue] =
  var vs = values
  var names = colNames
  var accRev: List[SqliteValue] = Nil
  while vs.nonEmpty do
    val name = if names.nonEmpty then names.head else ""
    findAssignmentItem(assignments, name) match
      case Some(assign) =>
        val nv = assign.expr match
          case Some(e) => evalExprValues(e, values, colNames)
          case None => assign.value
        accRev = nv :: accRev
      case None => accRev = vs.head :: accRev
    vs = vs.tail
    if names.nonEmpty then names = names.tail
  reverseValues(accRev, Nil)

def reverseEdits(items: List[EditRow], acc: List[EditRow]): List[EditRow] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

/** Build (rowid, new record) for every row the WHERE selects. */
def buildUpdateEdits(rows: List[StorageRecord], colNames: List[String], stmt: UpdateStmt): Either[String, List[EditRow]] =
  var r = rows
  var accRev: List[EditRow] = Nil
  var err: Option[String] = None
  while r.nonEmpty && err.isEmpty do
    val rec = r.head
    if whereHolds(stmt.where, rec, colNames) then
      val newValues = applyAssignments(extractValues(rec, colNames.length), colNames, stmt.assignments)
      encodeRecord(newValues) match
        case Left(error) => err = Some(error.message)
        case Right(record) =>
          rec.rowid match
            case Some(id) => accRev = EditRow(id, record) :: accRev
            case None => accRev = accRev
    r = r.tail
  err match
    case Some(message) => Left(message)
    case None => Right(reverseEdits(accRev, Nil))

def applyUpdates(pager: MutablePager, root: Int, edits: List[EditRow], pageSize: Int): Either[String, MutablePager] =
  var p = pager
  var r = edits
  var err: Option[String] = None
  while r.nonEmpty && err.isEmpty do
    val edit = r.head
    pagerDeleteBalanced(p, root, edit.rowid, pageSize) match
      case Left(error) => err = Some(error.message)
      case Right(afterDelete) => pagerInsertBalanced(afterDelete, root, edit.rowid, edit.record, pageSize) match
        case Left(error) => err = Some(error.message)
        case Right(afterInsert) => p = afterInsert
    r = r.tail
  err match
    case Some(message) => Left(message)
    case None => Right(p)

def executeUpdate(dbBytes: ByteSlice, stmt: UpdateStmt): Either[String, ByteSlice] =
  tableContext(dbBytes, stmt.table) match
    case Left(message) => Left(message)
    case Right(ctx) =>
      val db = ctx._1
      val root = ctx._2
      val colNames = ctx._3
      val pageSize = ctx._4
      openReadonlyRoot(db, root.toLong, RowidTableTree) match
        case Left(error) => Left(error.message)
        case Right(cursor) => collectRows(db, cursor) match
          case Left(error) => Left(error.message)
          case Right(rows) =>
            val infos = tableIndexInfos(db, stmt.table, colNames)
            if infos.isEmpty then buildUpdateEdits(rows, colNames, stmt) match
              case Left(message) => Left(message)
              case Right(edits) =>
                if edits.isEmpty then Right(dbBytes)
                else applyUpdates(openMutablePager(dbBytes, pageSize, pageSize), root, edits, pageSize) match
                  case Left(message) => Left(message)
                  case Right(pager) => mutableCommit(pager, 1L) match
                    case Left(error) => Left(error.message)
                    case Right(pc) => Right(pc.pager.image)
            else if countTables(db) != 1 then Left("index maintenance on a multi-table database is not yet supported")
            else reindexTable(dbBytes, db, stmt.table, updatedSqlRows(rows, colNames, stmt), infos)

// Existing rows with WHERE-matched rows' values replaced by the SET assignments (for
// index-maintaining UPDATE — the index entry uses each row's new key).
def updatedSqlRows(rows: List[StorageRecord], colNames: List[String], stmt: UpdateStmt): List[SqlRow] =
  var r = rows
  var accRev: List[SqlRow] = Nil
  while r.nonEmpty do
    val rec = r.head
    val rowid = rec.rowid match
      case Some(id) => id
      case None => 0L
    val vals = extractValues(rec, colNames.length)
    val newVals = if whereHolds(stmt.where, rec, colNames) then applyAssignments(vals, colNames, stmt.assignments) else vals
    accRev = SqlRow(rowid, newVals) :: accRev
    r = r.tail
  accRev.reverse

// ── CREATE TABLE (append a schema row on page 1 + an empty table root) ──

def byteAt(bytes: ByteSlice, off: Int): Int = byteSliceGet(bytes, off) match
  case Right(b) => b
  case Left(_) => 0

def pageSizeOf(bytes: ByteSlice): Int =
  val ps = byteAt(bytes, 16) * 256 + byteAt(bytes, 17)
  if ps == 1 then 65536 else ps

def maxLeafRowid(cells: List[LeafCell]): Long =
  var r = cells
  var m = 0L
  while r.nonEmpty do
    if r.head.rowid > m then m = r.head.rowid
    r = r.tail
  m

def sliceList(bytes: ByteSlice, off: Int, len: Int): List[Int] =
  byteSliceSlice(bytes, off, len) match
    case Right(s) => byteSliceToList(s)
    case Left(_) => Nil

/** `CREATE TABLE ident ( … )` — returns the table name. */
def parseCreate(toks: List[Token]): Either[String, String] =
  if !tkIsKw(toks, "CREATE") then Left("expected CREATE")
  else
    val afterCreate = toks.tail
    if !tkIsKw(afterCreate, "TABLE") then Left("expected TABLE")
    else
      val afterTable = afterCreate.tail
      if tkKind(afterTable) != "ident" then Left("expected table name")
      else Right(afterTable.head.text)

/** Create a table in an existing database: append its `sqlite_schema` row to page 1's
 *  leaf and allocate an empty table root page. The original `sql` text is stored
 *  verbatim (so reference sqlite `.schema` matches). Assumes the page-1 schema leaf
 *  does not overflow (a page-1 split — balance at headerOffset 100 — is a follow-up). */
// ── CREATE INDEX ──

def reverseInts(items: List[Int], acc: List[Int]): List[Int] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

def reverseIndexEntries(items: List[IndexEntry], acc: List[IndexEntry]): List[IndexEntry] =
  var r = items
  var out = acc
  while r.nonEmpty do
    out = r.head :: out
    r = r.tail
  out

// Slice a List[Int] as (offset, length) — the List analogue of sliceList, iterative.
def sliceInts(xs: List[Int], off: Int, len: Int): List[Int] =
  var r = xs
  var i = 0
  while i < off && r.nonEmpty do
    r = r.tail
    i = i + 1
  var taken = 0
  var accRev: List[Int] = Nil
  while taken < len && r.nonEmpty do
    accRev = r.head :: accRev
    r = r.tail
    taken = taken + 1
  reverseInts(accRev, Nil)

case class CreateIndexStmt(indexName: String, tableName: String, columns: List[String])

def parseIndexColumns(toks: List[Token]): Either[String, (List[String], List[Token])] =
  var rest = toks
  var accRev: List[String] = Nil
  var err: Option[String] = None
  var done = false
  while !done && err.isEmpty do
    if tkKind(rest) != "ident" then
      err = Some("expected a column name in the index")
      done = true
    else
      accRev = rest.head.text :: accRev
      rest = rest.tail
      if tkKind(rest) == "comma" then rest = rest.tail
      else if tkKind(rest) == "rparen" then
        rest = rest.tail
        done = true
      else
        err = Some("expected ',' or ')' in the index columns")
        done = true
  err match
    case Some(message) => Left(message)
    case None => Right((reverseStrings(accRev, Nil), rest))

// `CREATE INDEX name ON table ( col [, col]* )`
def parseCreateIndex(toks: List[Token]): Either[String, CreateIndexStmt] =
  if !tkIsKw(toks, "CREATE") then Left("expected CREATE")
  else
    val a1 = toks.tail
    if !tkIsKw(a1, "INDEX") then Left("expected INDEX")
    else if tkKind(a1.tail) != "ident" then Left("expected index name")
    else
      val indexName = a1.tail.head.text
      val a2 = a1.tail.tail
      if !tkIsKw(a2, "ON") then Left("expected ON")
      else if tkKind(a2.tail) != "ident" then Left("expected table name")
      else
        val tableName = a2.tail.head.text
        val a3 = a2.tail.tail
        if tkKind(a3) != "lparen" then Left("expected '(' in CREATE INDEX")
        else parseIndexColumns(a3.tail) match
          case Left(message) => Left(message)
          case Right(cp) => Right(CreateIndexStmt(indexName, tableName, cp._1))

def indexColIndices(cols: List[String], colNames: List[String]): List[Int] =
  var r = cols
  var accRev: List[Int] = Nil
  while r.nonEmpty do
    accRev = columnIndex(colNames, r.head) :: accRev
    r = r.tail
  reverseInts(accRev, Nil)

def keyValuesOfRecord(rec: StorageRecord, keyColumns: List[Int]): List[SqliteValue] =
  var r = keyColumns
  var accRev: List[SqliteValue] = Nil
  while r.nonEmpty do
    accRev = fieldValueAt(rec.record, r.head) :: accRev
    r = r.tail
  reverseValues(accRev, Nil)

// Build one index entry per table row, preserving each row's ACTUAL rowid (the index
// record is `keycols… ++ rowid`, exactly as sqlite lays it out).
def buildIndexEntriesFromRecords(rows: List[StorageRecord], keyColumns: List[Int]): Either[String, List[IndexEntry]] =
  var r = rows
  var accRev: List[IndexEntry] = Nil
  var err: Option[String] = None
  while r.nonEmpty && err.isEmpty do
    val rec = r.head
    val rowid = rec.rowid match
      case Some(id) => id
      case None => 0L
    val keyVals = keyValuesOfRecord(rec, keyColumns)
    encodeRecord(keyVals ++ (SqlInteger(rowid) :: Nil)) match
      case Left(error) => err = Some(error.message)
      case Right(record) => accRev = IndexEntry(keyVals, rowid, byteSliceToList(record)) :: accRev
    r = r.tail
  err match
    case Some(message) => Left(message)
    case None => Right(reverseIndexEntries(accRev, Nil))

// Stage each page of a freshly-built index tree (one ByteSlice.fromList per page keeps the
// JS lists small — no page exceeds pageSize).
def stageIndexPages(pager: MutablePager, bytes: List[Int], startPage: Int, pageCount: Int, pageSize: Int): Either[String, MutablePager] =
  var p = pager
  var i = 0
  var err: Option[String] = None
  while i < pageCount && err.isEmpty do
    ByteSlice.fromList(sliceInts(bytes, i * pageSize, pageSize)) match
      case Left(error) => err = Some(error.message)
      case Right(slice) => p = mutablePut(p, startPage + i, slice)
    i = i + 1
  err match
    case Some(message) => Left(message)
    case None => Right(p)

// Create an index on an existing database: read the table's rows, build the index B-tree at
// a new root page appended at EOF, append its `sqlite_schema` row to page 1, and commit.
// Reference `integrity_check` cross-validates the index against the table.
def executeCreateIndex(dbBytes: ByteSlice, sql: String, stmt: CreateIndexStmt): Either[String, ByteSlice] =
  val pageSize = pageSizeOf(dbBytes)
  openReadonly(ImageVfs(dbBytes), "image.db", sqlOptions()) match
    case Left(error) => Left(error.message)
    case Right(db) => findTable(db, stmt.tableName) match
      case None => Left("no such table: " + stmt.tableName)
      case Some(entry) =>
        val colNames = entry.sql match
          case Some(text) => tableColumns(cpToString(text.codePoints))
          case None => Nil
        val root = entry.rootPage match
          case Some(p) => p
          case None => 0L
        openReadonlyRoot(db, root, RowidTableTree) match
          case Left(error) => Left(error.message)
          case Right(cursor) => collectRows(db, cursor) match
            case Left(error) => Left(error.message)
            case Right(rows) =>
              buildIndexEntriesFromRecords(rows, indexColIndices(stmt.columns, colNames)) match
                case Left(message) => Left(message)
                case Right(unsorted) =>
                  val entries = sortIndexEntries(unsorted)
                  val oldCount = dbBytes.length / pageSize
                  val newRoot = oldCount + 1
                  buildIndexTree(entries, pageSize, newRoot) match
                    case Left(error) => Left(error.message)
                    case Right(indexTree) =>
                      val newPageCount = oldCount + indexTree.pageCount
                      byteSliceSlice(dbBytes, 0, pageSize) match
                        case Left(error) => Left(error.message)
                        case Right(page1) => readLeafCells(page1, 100) match
                          case Left(error) => Left(error.message)
                          case Right(schemaCells) =>
                            val newRowid = maxLeafRowid(schemaCells) + 1L
                            encodeRecord(List(SqlText("index"), SqlText(stmt.indexName), SqlText(stmt.tableName), SqlInteger(newRoot.toLong), SqlText(sql))) match
                              case Left(error) => Left(error.message)
                              case Right(schemaRec) => leafInsertCell(schemaCells, newRowid, schemaRec) match
                                case Left(message) => Left(message)
                                case Right(newCells) => rebuildLeafPage(newCells, pageSize, 100) match
                                  case Left(error) => Left(error.message)
                                  case Right(leafPortion) =>
                                    val newHeader = sliceList(page1, 0, 28) ++ byteSliceToList(writeU32Be(newPageCount.toLong)) ++ sliceList(page1, 32, 68)
                                    ByteSlice.fromList(newHeader ++ leafPortion) match
                                      case Left(error) => Left(error.message)
                                      case Right(newPage1) =>
                                        val pager0 = mutablePut(openMutablePager(dbBytes, pageSize, pageSize), 1, newPage1)
                                        stageIndexPages(pager0, indexTree.bytes, newRoot, indexTree.pageCount, pageSize) match
                                          case Left(message) => Left(message)
                                          case Right(pager1) => mutableCommit(pager1, newRoot.toLong) match
                                            case Left(error) => Left(error.message)
                                            case Right(pc) => Right(pc.pager.image)

def executeCreate(dbBytes: ByteSlice, sql: String, tableName: String): Either[String, ByteSlice] =
  val pageSize = pageSizeOf(dbBytes)
  byteSliceSlice(dbBytes, 0, pageSize) match
    case Left(error) => Left(error.message)
    case Right(page1) => readLeafCells(page1, 100) match
      case Left(error) => Left(error.message)
      case Right(schemaCells) =>
        val newRoot = (dbBytes.length / pageSize) + 1
        val newRowid = maxLeafRowid(schemaCells) + 1L
        encodeRecord(List(SqlText("table"), SqlText(tableName), SqlText(tableName), SqlInteger(newRoot.toLong), SqlText(sql))) match
          case Left(error) => Left(error.message)
          case Right(schemaRec) => leafInsertCell(schemaCells, newRowid, schemaRec) match
            case Left(message) => Left(message)
            case Right(newCells) => rebuildLeafPage(newCells, pageSize, 100) match
              case Left(error) => Left(error.message)
              case Right(leafPortion) =>
                val emptyCells: List[LeafCell] = Nil
                rebuildLeafPage(emptyCells, pageSize, 0) match
                  case Left(error) => Left(error.message)
                  case Right(emptyRoot) =>
                    val newHeader = sliceList(page1, 0, 28) ++ byteSliceToList(writeU32Be(newRoot.toLong)) ++ sliceList(page1, 32, 68)
                    ByteSlice.fromList(newHeader ++ leafPortion) match
                      case Left(error) => Left(error.message)
                      case Right(newPage1) => ByteSlice.fromList(emptyRoot) match
                        case Left(error) => Left(error.message)
                        case Right(emptyRootSlice) =>
                          val staged = mutablePut(mutablePut(openMutablePager(dbBytes, pageSize, pageSize), 1, newPage1), newRoot, emptyRootSlice)
                          mutableCommit(staged, newRoot.toLong) match
                            case Left(error) => Left(error.message)
                            case Right(pc) => Right(pc.pager.image)

/** Run an INSERT, DELETE, UPDATE, or CREATE TABLE against a database image; return the new image. */
// `DROP INDEX [IF EXISTS] name` — returns the index name.
def parseDropIndex(toks: List[Token]): Either[String, String] =
  if !tkIsKw(toks, "DROP") then Left("expected DROP")
  else if !tkIsKw(toks.tail, "INDEX") then Left("expected INDEX after DROP")
  else
    val afterIndex = toks.tail.tail
    val afterIf = if tkIsKw(afterIndex, "IF") && tkIsKw(afterIndex.tail, "EXISTS") then afterIndex.tail.tail else afterIndex
    if tkKind(afterIf) != "ident" then Left("expected index name")
    else Right(afterIf.head.text)

// Drop an index by rebuilding the (single-table) database with the remaining indexes; the
// dropped index's schema row and pages are gone (compact, no orphans → integrity_check ok).
def executeDropIndex(dbBytes: ByteSlice, indexName: String): Either[String, ByteSlice] =
  openReadonly(ImageVfs(dbBytes), "image.db", sqlOptions()) match
    case Left(error) => Left(error.message)
    case Right(db) => findIndexEntry(db, indexName) match
      case None => Left("no such index: " + indexName)
      case Some(idxEntry) =>
        val tableName = cpToString(idxEntry.tableName.codePoints)
        findTable(db, tableName) match
          case None => Left("no such table: " + tableName)
          case Some(tableEntry) =>
            if countTables(db) != 1 then Left("DROP INDEX on a multi-table database is not yet supported")
            else
              val colNames = tableEntry.sql match
                case Some(t) => tableColumns(cpToString(t.codePoints))
                case None => Nil
              val root = tableEntry.rootPage match
                case Some(p) => p
                case None => 0L
              openReadonlyRoot(db, root, RowidTableTree) match
                case Left(error) => Left(error.message)
                case Right(cursor) => collectRows(db, cursor) match
                  case Left(error) => Left(error.message)
                  case Right(rows) => reindexTable(dbBytes, db, tableName, storageToSqlRows(rows, colNames.length), tableIndexInfosExcept(db, tableName, colNames, indexName))

def executeMutation(dbBytes: ByteSlice, sql: String): Either[String, ByteSlice] =
  tokenize(sql) match
    case Left(message) => Left(message)
    case Right(toks0) => resolveSubqueries(dbBytes, toks0) match
     case Left(message) => Left(message)
     case Right(toks) =>
      if toks.isEmpty then Left("empty statement")
      else if isKw(toks.head, "INSERT") then parseInsert(toks) match
        case Left(message) => Left(message)
        case Right(stmt) => executeInsert(dbBytes, stmt)
      else if isKw(toks.head, "DELETE") then parseDelete(toks) match
        case Left(message) => Left(message)
        case Right(stmt) => executeDelete(dbBytes, stmt)
      else if isKw(toks.head, "UPDATE") then parseUpdate(toks) match
        case Left(message) => Left(message)
        case Right(stmt) => executeUpdate(dbBytes, stmt)
      else if isKw(toks.head, "DROP") then parseDropIndex(toks) match
        case Left(message) => Left(message)
        case Right(indexName) => executeDropIndex(dbBytes, indexName)
      else if isKw(toks.head, "CREATE") then
        if tkIsKw(toks.tail, "INDEX") then parseCreateIndex(toks) match
          case Left(message) => Left(message)
          case Right(stmt) => executeCreateIndex(dbBytes, sql, stmt)
        else parseCreate(toks) match
          case Left(message) => Left(message)
          case Right(tableName) => executeCreate(dbBytes, sql, tableName)
      else Left("executeMutation expects INSERT, DELETE, UPDATE, DROP INDEX, CREATE TABLE, or CREATE INDEX")

// ── Counted mutation (JDBC executeUpdate needs the affected-row count + last INSERT rowid) ──
// Same dispatch as executeMutation, but each statement also yields how many rows it changed and,
// for INSERT, the highest rowid assigned. CREATE/DROP → changes = 0. The counts are derived from a
// read pass over the affected table (the executors already act on exactly these rows): INSERT →
// #value-tuples, DELETE/UPDATE → #rows matching WHERE (matching sqlite's `changes()`), so the numbers
// agree with the mutation without threading a count through the large executor bodies.
case class MutationResult(image: ByteSlice, changes: Long, lastInsertRowid: Long)

// Long-valued list length, accumulated from a 0L seed so JS stays on BigInt (never mixes with a
// Number literal). Used for row counts.
def listLenLong(xs: List[Long]): Long =
  var n = 0L
  var r = xs
  while r.nonEmpty do
    n = n + 1L
    r = r.tail
  n

def valueRowsLenLong(xs: List[List[SqliteValue]]): Long =
  var n = 0L
  var r = xs
  while r.nonEmpty do
    n = n + 1L
    r = r.tail
  n

// Current rows + column names for a table (a read pass, used only to count affected rows).
def tableRowsForCount(dbBytes: ByteSlice, table: String): Either[String, (List[StorageRecord], List[String])] =
  tableContext(dbBytes, table) match
    case Left(message) => Left(message)
    case Right(ctx) =>
      openReadonlyRoot(ctx._1, ctx._2.toLong, RowidTableTree) match
        case Left(error) => Left(error.message)
        case Right(cursor) => collectRows(ctx._1, cursor) match
          case Left(error) => Left(error.message)
          case Right(rows) => Right((rows, ctx._3))

// #rows matching a DELETE/UPDATE WHERE (rows matched = sqlite `changes()`), from the pre-mutation image.
def matchedRowCount(dbBytes: ByteSlice, table: String, where: List[List[Condition]]): Either[String, Long] =
  tableRowsForCount(dbBytes, table) match
    case Left(message) => Left(message)
    case Right(rc) => Right(listLenLong(matchingRowids(rc._1, where, rc._2)))

// changes + lastInsertRowid for an INSERT. scljet assigns sequential rowids from maxRowid+1, so
// changes = #value-tuples and the last assigned rowid = maxRowid + changes.
def insertChangesRowid(dbBytes: ByteSlice, stmt: InsertStmt): Either[String, (Long, Long)] =
  if stmt.rows.isEmpty then Right((0L, 0L))
  else
    val nrows = valueRowsLenLong(stmt.rows)
    tableRowsForCount(dbBytes, stmt.table) match
      case Left(message) => Left(message)
      case Right(rc) => Right((nrows, longAdd(maxRowidOf(rc._1), nrows)))

def executeMutationCounted(dbBytes: ByteSlice, sql: String): Either[String, MutationResult] =
  executeMutationCountedParams(dbBytes, sql, Nil)

// tokenize → bindParams → resolveSubqueries, as one step producing the tokens to dispatch on.
def prepareMutationToks(dbBytes: ByteSlice, sql: String, params: List[SqliteValue]): Either[String, List[Token]] =
  tokenize(sql) match
    case Left(message) => Left(message)
    case Right(toks1) => bindParams(toks1, params) match
      case Left(message) => Left(message)
      case Right(toks0) => resolveSubqueries(dbBytes, toks0)

// Parameterized counted mutation. With `params = Nil` and no `?`, bindParams is identity, so
// executeMutationCounted delegates here.
def executeMutationCountedParams(dbBytes: ByteSlice, sql: String, params: List[SqliteValue]): Either[String, MutationResult] =
  prepareMutationToks(dbBytes, sql, params) match
    case Left(message) => Left(message)
    case Right(toks) =>
      if toks.isEmpty then Left("empty statement")
      else if isKw(toks.head, "INSERT") then parseInsert(toks) match
        case Left(message) => Left(message)
        case Right(stmt) => executeInsert(dbBytes, stmt) match
          case Left(message) => Left(message)
          case Right(image) => insertChangesRowid(dbBytes, stmt) match
            case Left(message) => Left(message)
            case Right(cr) => Right(MutationResult(image, cr._1, cr._2))
      else if isKw(toks.head, "DELETE") then parseDelete(toks) match
        case Left(message) => Left(message)
        case Right(stmt) => matchedRowCount(dbBytes, stmt.table, stmt.where) match
          case Left(message) => Left(message)
          case Right(n) => executeDelete(dbBytes, stmt) match
            case Left(message) => Left(message)
            case Right(image) => Right(MutationResult(image, n, 0L))
      else if isKw(toks.head, "UPDATE") then parseUpdate(toks) match
        case Left(message) => Left(message)
        case Right(stmt) => matchedRowCount(dbBytes, stmt.table, stmt.where) match
          case Left(message) => Left(message)
          case Right(n) => executeUpdate(dbBytes, stmt) match
            case Left(message) => Left(message)
            case Right(image) => Right(MutationResult(image, n, 0L))
      else if isKw(toks.head, "DROP") then parseDropIndex(toks) match
        case Left(message) => Left(message)
        case Right(indexName) => executeDropIndex(dbBytes, indexName) match
          case Left(message) => Left(message)
          case Right(image) => Right(MutationResult(image, 0L, 0L))
      else if isKw(toks.head, "CREATE") then
        if tkIsKw(toks.tail, "INDEX") then parseCreateIndex(toks) match
          case Left(message) => Left(message)
          case Right(stmt) => executeCreateIndex(dbBytes, sql, stmt) match
            case Left(message) => Left(message)
            case Right(image) => Right(MutationResult(image, 0L, 0L))
        else parseCreate(toks) match
          case Left(message) => Left(message)
          case Right(tableName) => executeCreate(dbBytes, sql, tableName) match
            case Left(message) => Left(message)
            case Right(image) => Right(MutationResult(image, 0L, 0L))
      else Left("executeMutationCounted expects INSERT, DELETE, UPDATE, DROP INDEX, CREATE TABLE, or CREATE INDEX")

// ── Rendering (sqlite3 CLI list format: `a|b|c` per row, NULL blank) ──

// A real is rendered like the sqlite3 CLI: an integer-valued real still shows a
// decimal (`35` → `35.0`); other values keep the shortest round-trip form (matches
// sqlite for up to ~15 significant digits — repeating decimals may differ).
def renderReal(x: Double): String =
  val s = x.toString
  var i = 0
  var hasDot = false
  while i < s.length do
    val c = s.charAt(i).toInt
    if c == 46 || c == 101 || c == 69 then hasDot = true
    i = i + 1
  if hasDot then s else s + ".0"

def renderValue(v: SqliteValue): String = v match
  case SqlNull => ""
  case SqlInteger(x) => x.toString
  case SqlReal(x) => renderReal(x)
  case SqlText(s) => s
  case SqlBlob(_) => ""

def renderRow(row: List[SqliteValue]): String =
  var r = row
  var s = ""
  var first = true
  while r.nonEmpty do
    s = if first then renderValue(r.head) else s + "|" + renderValue(r.head)
    first = false
    r = r.tail
  s

def renderRows(rows: List[List[SqliteValue]]): String =
  var r = rows
  var s = ""
  var first = true
  while r.nonEmpty do
    s = if first then renderRow(r.head) else s + "\n" + renderRow(r.head)
    first = false
    r = r.tail
  s
```
