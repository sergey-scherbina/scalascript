# `std.agent`

Generic agent loop for stateless OpenAI-compatible model gateways such as
rozum. The application owns prompts, tool handlers, validation, and session
state; the SDK only frames model calls and dispatches tool requests.

```scalascript
[httpPost, httpPostStream, Response](std/http.ssc)
[JsonValue, jsonValue, jStr, jNum, jBool, jField, jObj, jArr](std/json.ssc)

case class AgentEndpoint(baseUrl: String, authToken: String = "")

case class AgentEndpointPool(
  endpoints: List[AgentEndpoint],
  maxAttempts: Int = 3
)

case class RunOptions(
  temperature: Double = 0.0,
  maxSteps: Int = 8,
  maxTokens: Int = 4096,
  toolChoice: String = "auto"
)

case class ToolResult(contentJson: String, isError: Boolean = false)

trait AgentSchema[A]:
  def parametersJson: String
  def decode(argsJson: String): A

case class AgentSchemaInstance(parametersJson: String, decodeAny: String => Any) extends AgentSchema[Any]:
  def decode(argsJson: String): Any =
    decodeAny(argsJson)

object AgentSchema:
  def derived(m: Mirror): AgentSchema[Any] =
    if !m.isProduct then
      throw RuntimeException("std.agent AgentSchema supports product records only: " + m.label)
    val properties = agentSchemaProperties(m.elemLabels, m.elemTypes)
    val required = agentSchemaRequired(m.elemLabels, m.elemTypes)
    AgentSchemaInstance(objectSchema(properties, required), argsJson =>
      val args = jsonValue(argsJson)
      val values = agentSchemaDecodeFields(m.elemLabels, m.elemTypes, args)
      m.fromProduct(values)
    )

case class AgentTool(
  name: String,
  description: String,
  parametersJson: String,
  handler: String => ToolResult
)

case class ExecutedOp(
  tool: String,
  argsJson: String,
  resultJson: String,
  isError: Boolean
)

case class AgentResult(
  text: String,
  operations: List[ExecutedOp],
  transcriptJson: String,
  stop: String
)

case class AgentEvent(
  kind: String,
  text: String = "",
  tool: String = "",
  argsJson: String = "",
  resultJson: String = "",
  isError: Boolean = false,
  stop: String = ""
)

case class AgentStreamResult(
  result: AgentResult,
  events: List[AgentEvent]
)

case class PendingToolCall(
  index: Long,
  id: String,
  name: String,
  argsJson: String
)

case class StreamStep(
  text: String,
  toolCalls: List[PendingToolCall],
  finishReason: String,
  errorText: String,
  events: List[AgentEvent]
)

case class ToolDeltaStep(
  toolCalls: List[PendingToolCall],
  events: List[AgentEvent]
)

case class ToolDispatchStep(
  messages: List[String],
  operations: List[ExecutedOp],
  events: List[AgentEvent]
)

case class AgentHttpAttempt(
  status: Int,
  body: String,
  transportError: Boolean,
  errorText: String
)

case class AgentStreamAttempt(
  status: Int,
  transportError: Boolean,
  errorText: String,
  text: String,
  toolCalls: List[PendingToolCall],
  finishReason: String,
  streamError: String,
  events: List[AgentEvent]
)

def agentTool(name: String, description: String, parametersJson: String)
             (handler: String => ToolResult): AgentTool =
  AgentTool(name, description, parametersJson, handler)

def agentToolFor[A](name: String, description: String, schema: AgentSchema[A])
                   (handler: A => ToolResult): AgentTool =
  agentTool(name, description, schema.parametersJson) { argsJson =>
    handler(schema.decode(argsJson))
  }

def toolOk(contentJson: String): ToolResult =
  ToolResult(contentJson, false)

def toolError(message: String): ToolResult =
  ToolResult(jObj(List(jField("error", jStr(message)))), true)

def objectSchema(propertiesJson: String, required: List[String]): String =
  jObj(List(
    jField("type", jStr("object")),
    jField("properties", propertiesJson),
    jField("required", jArr(required.map(name => jStr(name))))
  ))

def agentSchemaProperties(labels: List[String], types: List[String]): String =
  jObj(agentSchemaPropertyFields(labels, types))

def agentSchemaPropertyFields(labels: List[String], types: List[String]): List[String] =
  (labels, types) match
    case (Nil, _) => List()
    case (_, Nil) => List()
    case (label :: labelRest, tpe :: typeRest) =>
      jField(label, agentJsonSchemaForType(label, tpe)) :: agentSchemaPropertyFields(labelRest, typeRest)

def agentSchemaRequired(labels: List[String], types: List[String]): List[String] =
  (labels, types) match
    case (Nil, _) => List()
    case (_, Nil) => List()
    case (label :: labelRest, tpe :: typeRest) =>
      val rest = agentSchemaRequired(labelRest, typeRest)
      if isAgentOptionType(tpe) then rest else label :: rest

def agentSchemaDecodeFields(labels: List[String], types: List[String], args: JsonValue): List[Any] =
  (labels, types) match
    case (Nil, _) => List()
    case (_, Nil) => List()
    case (label :: labelRest, tpe :: typeRest) =>
      agentDecodeValue(label, tpe, args.get(label)) :: agentSchemaDecodeFields(labelRest, typeRest, args)

def agentJsonSchemaForType(field: String, tpe: String): String =
  val clean = tpe.trim
  if clean == "String" then
    jObj(List(jField("type", jStr("string"))))
  else if clean == "Int" then
    jObj(List(jField("type", jStr("integer"))))
  else if clean == "Double" then
    jObj(List(jField("type", jStr("number"))))
  else if clean == "Boolean" then
    jObj(List(jField("type", jStr("boolean"))))
  else if isAgentListType(clean) then
    jObj(List(
      jField("type", jStr("array")),
      jField("items", agentJsonSchemaForType(field, agentInnerType(clean, "List[")))
    ))
  else if isAgentOptionType(clean) then
    jObj(List(jField("anyOf", jArr(List(
      agentJsonSchemaForType(field, agentInnerType(clean, "Option[")),
      jObj(List(jField("type", jStr("null"))))
    )))))
  else
    throw RuntimeException("std.agent AgentSchema unsupported field '" + field + "' type '" + clean + "'")

def agentDecodeValue(field: String, tpe: String, value: JsonValue): Any =
  val clean = tpe.trim
  if clean == "String" then
    value.asString
  else if clean == "Int" then
    value.asInt
  else if clean == "Double" then
    value.asDouble
  else if clean == "Boolean" then
    value.asBool
  else if isAgentListType(clean) then
    val inner = agentInnerType(clean, "List[")
    value.asList.map(v => agentDecodeValue(field, inner, v))
  else if isAgentOptionType(clean) then
    if value.isNull then
      None
    else
      Some(agentDecodeValue(field, agentInnerType(clean, "Option["), value))
  else
    throw RuntimeException("std.agent AgentSchema unsupported field '" + field + "' type '" + clean + "'")

def isAgentListType(tpe: String): Boolean =
  tpe.startsWith("List[") && tpe.endsWith("]")

def isAgentOptionType(tpe: String): Boolean =
  tpe.startsWith("Option[") && tpe.endsWith("]")

def agentInnerType(tpe: String, prefix: String): String =
  tpe.substring(prefix.length, tpe.length - 1).trim

def runAgent(endpoint: AgentEndpoint, model: String, system: String, user: String,
             tools: List[AgentTool], options: RunOptions = RunOptions()): AgentResult =
  runAgentPool(AgentEndpointPool(List(endpoint), 1), model, system, user, tools, options)

def runAgentPool(pool: AgentEndpointPool, model: String, system: String, user: String,
                 tools: List[AgentTool], options: RunOptions = RunOptions()): AgentResult =
  val initialMessages = List(systemMessage(system), userMessage(user))
  runAgentLoop(pool, model, tools, options, initialMessages, List(), 0, "")

def runAgentStream(endpoint: AgentEndpoint, model: String, system: String, user: String,
                   tools: List[AgentTool], options: RunOptions = RunOptions())
                  (onEvent: AgentEvent => Unit): AgentResult =
  runAgentStreamPool(AgentEndpointPool(List(endpoint), 1), model, system, user, tools, options)(onEvent)

def runAgentStreamPool(pool: AgentEndpointPool, model: String, system: String, user: String,
                       tools: List[AgentTool], options: RunOptions = RunOptions())
                      (onEvent: AgentEvent => Unit): AgentResult =
  val initialMessages = List(systemMessage(system), userMessage(user))
  runAgentStreamLoop(pool, model, tools, options, initialMessages, List(), 0, "", List(), onEvent).result

def collectAgentStream(endpoint: AgentEndpoint, model: String, system: String, user: String,
                       tools: List[AgentTool], options: RunOptions = RunOptions()): AgentStreamResult =
  collectAgentStreamPool(AgentEndpointPool(List(endpoint), 1), model, system, user, tools, options)

def collectAgentStreamPool(pool: AgentEndpointPool, model: String, system: String, user: String,
                           tools: List[AgentTool], options: RunOptions = RunOptions()): AgentStreamResult =
  runAgentStreamLoop(pool, model, tools, options,
    List(systemMessage(system), userMessage(user)), List(), 0, "", List(), event => ())

def runAgentLoop(pool: AgentEndpointPool, model: String, tools: List[AgentTool],
                 options: RunOptions, messages: List[String], ops: List[ExecutedOp],
                 step: Int, lastText: String): AgentResult =
  if step >= options.maxSteps then
    AgentResult(lastText, ops, jArr(messages), "MaxSteps")
  else
    val response = postChatCompletions(pool, requestBody(model, messages, tools, options))
    if response.transportError then
      AgentResult("rozum gateway transport failed: " + response.errorText, ops, jArr(messages), "Error")
    else if response.status < 200 || response.status >= 300 then
      AgentResult("rozum gateway HTTP " + response.status + ": " + response.body, ops, jArr(messages), "Error")
    else
      val root = jsonValue(response.body)
      val choice = root.get("choices").at(0)
      val message = choice.get("message")
      val finishReason = choice.get("finish_reason").asString
      val toolCallsJson = message.get("tool_calls")
      val calls = toolCallsJson.asList
      if finishReason == "tool_calls" || calls.length > 0 then
        val assistant = assistantToolCallsMessage(toolCallsJson)
        val next = appendToolResults(calls, tools, messages :+ assistant, ops)
        runAgentLoop(pool, model, tools, options, next._1, next._2, step + 1, lastText)
      else
        val text = message.get("content").asString
        AgentResult(text, ops, jArr(messages :+ assistantTextMessage(text)), "Done")

def runAgentStreamLoop(pool: AgentEndpointPool, model: String, tools: List[AgentTool],
                       options: RunOptions, messages: List[String], ops: List[ExecutedOp],
                       step: Int, lastText: String, events: List[AgentEvent],
                       onEvent: AgentEvent => Unit): AgentStreamResult =
  if step >= options.maxSteps then
    val nextEvents = emitEvent(events, AgentEvent("Stopped", stop = "MaxSteps"), onEvent)
    AgentStreamResult(AgentResult(lastText, ops, jArr(messages), "MaxSteps"), nextEvents)
  else
    val attempt = postChatCompletionsStream(
      pool,
      requestBodyWithStream(model, messages, tools, options, true),
      events,
      onEvent
    )
    try
      if attempt.transportError then
        val msg = "rozum gateway transport failed: " + attempt.errorText
        val errEvents = emitEvent(attempt.events, AgentEvent("Errored", text = msg), onEvent)
        val doneEvents = emitEvent(errEvents, AgentEvent("Stopped", stop = "Error"), onEvent)
        AgentStreamResult(AgentResult(msg, ops, jArr(messages), "Error"), doneEvents)
      else if attempt.status < 200 || attempt.status >= 300 then
        val msg = "rozum gateway HTTP " + attempt.status
        val errEvents = emitEvent(attempt.events, AgentEvent("Errored", text = msg), onEvent)
        val doneEvents = emitEvent(errEvents, AgentEvent("Stopped", stop = "Error"), onEvent)
        AgentStreamResult(AgentResult(msg, ops, jArr(messages), "Error"), doneEvents)
      else if attempt.streamError != "" then
        val doneEvents = emitEvent(attempt.events, AgentEvent("Stopped", stop = "Error"), onEvent)
        AgentStreamResult(AgentResult(attempt.streamError, ops, jArr(messages), "Error"), doneEvents)
      else if attempt.finishReason == "tool_calls" || attempt.toolCalls.length > 0 then
        val assistant = assistantPendingToolCallsMessage(attempt.toolCalls)
        val next = appendStreamingToolResults(attempt.toolCalls, tools, messages :+ assistant, ops, attempt.events, onEvent)
        val latestText = if attempt.text == "" then lastText else attempt.text
        runAgentStreamLoop(pool, model, tools, options, next.messages, next.operations,
          step + 1, latestText, next.events, onEvent)
      else
        val finalText = if attempt.text == "" then lastText else attempt.text
        val doneEvents = emitEvent(attempt.events, AgentEvent("Stopped", stop = "Done"), onEvent)
        AgentStreamResult(AgentResult(finalText, ops, jArr(messages :+ assistantTextMessage(finalText)), "Done"), doneEvents)
    catch case e: Throwable =>
      val msg = "rozum stream failed: " + e.getMessage
      val errEvents = emitEvent(attempt.events, AgentEvent("Errored", text = msg), onEvent)
      val doneEvents = emitEvent(errEvents, AgentEvent("Stopped", stop = "Error"), onEvent)
      AgentStreamResult(AgentResult(msg, ops, jArr(messages), "Error"), doneEvents)

def emitEvent(events: List[AgentEvent], event: AgentEvent, onEvent: AgentEvent => Unit): List[AgentEvent] =
  onEvent(event)
  events :+ event

def chatCompletionsUrl(endpoint: AgentEndpoint): String =
  endpoint.baseUrl + "/v1/chat/completions"

def poolAttemptLimit(pool: AgentEndpointPool): Int =
  val requested = if pool.maxAttempts < 1 then 1 else pool.maxAttempts
  val available = pool.endpoints.length
  if requested > available then available else requested

def postChatCompletions(pool: AgentEndpointPool, body: String): AgentHttpAttempt =
  postChatCompletionsFrom(pool.endpoints, poolAttemptLimit(pool), body)

def postChatCompletionsFrom(endpoints: List[AgentEndpoint], remaining: Int, body: String): AgentHttpAttempt =
  if remaining <= 0 then
    AgentHttpAttempt(0, "", true, "no rozum endpoints configured")
  else
    endpoints match
      case Nil =>
        AgentHttpAttempt(0, "", true, "no rozum endpoints configured")
      case endpoint :: rest =>
        val attempt = postChatCompletionsOnce(endpoint, body)
        if shouldRetryEndpoint(attempt.status, attempt.transportError) && remaining > 1 && rest.length > 0 then
          postChatCompletionsFrom(rest, remaining - 1, body)
        else
          attempt

def postChatCompletionsOnce(endpoint: AgentEndpoint, body: String): AgentHttpAttempt =
  try
    val response = httpPost(chatCompletionsUrl(endpoint), body, requestHeaders(endpoint))
    AgentHttpAttempt(response.status, response.body, false, "")
  catch case e: Throwable =>
    AgentHttpAttempt(0, "", true, e.getMessage)

def shouldRetryEndpoint(status: Int, transportError: Boolean): Boolean =
  transportError || status >= 500

def postChatCompletionsStream(pool: AgentEndpointPool, body: String, events: List[AgentEvent],
                              onEvent: AgentEvent => Unit): AgentStreamAttempt =
  postChatCompletionsStreamFrom(pool.endpoints, poolAttemptLimit(pool), body, events, onEvent)

def postChatCompletionsStreamFrom(endpoints: List[AgentEndpoint], remaining: Int, body: String,
                                  events: List[AgentEvent],
                                  onEvent: AgentEvent => Unit): AgentStreamAttempt =
  if remaining <= 0 then
    AgentStreamAttempt(0, true, "no rozum endpoints configured", "", List(), "", "", events)
  else
    endpoints match
      case Nil =>
        AgentStreamAttempt(0, true, "no rozum endpoints configured", "", List(), "", "", events)
      case endpoint :: rest =>
        val attempt = postChatCompletionsStreamOnce(endpoint, body, events, onEvent)
        if shouldRetryEndpoint(attempt.status, attempt.transportError) && remaining > 1 && rest.length > 0 then
          postChatCompletionsStreamFrom(rest, remaining - 1, body, events, onEvent)
        else
          attempt

def postChatCompletionsStreamOnce(endpoint: AgentEndpoint, body: String, events: List[AgentEvent],
                                  onEvent: AgentEvent => Unit): AgentStreamAttempt =
  var text = ""
  var pending = List[PendingToolCall]()
  var finishReason = ""
  var streamError = ""
  var streamEvents = events
  try
    val response = httpPostStream(
      chatCompletionsUrl(endpoint),
      body,
      streamRequestHeaders(endpoint)
    ) { line =>
      val parsed = handleStreamLine(line, pending, text, finishReason, streamError, streamEvents, onEvent)
      text = parsed.text
      pending = parsed.toolCalls
      streamEvents = parsed.events
      if parsed.finishReason != "" then finishReason = parsed.finishReason
      if parsed.errorText != "" then streamError = parsed.errorText
    }
    AgentStreamAttempt(response.status, false, "", text, pending, finishReason, streamError, streamEvents)
  catch case e: Throwable =>
    AgentStreamAttempt(0, true, e.getMessage, "", List(), "", "", events)

def requestHeaders(endpoint: AgentEndpoint): Map[String, String] =
  if endpoint.authToken == "" then
    Map("Content-Type" -> "application/json")
  else
    Map("Content-Type" -> "application/json", "Authorization" -> ("Bearer " + endpoint.authToken))

def streamRequestHeaders(endpoint: AgentEndpoint): Map[String, String] =
  if endpoint.authToken == "" then
    Map("Content-Type" -> "application/json", "Accept" -> "text/event-stream")
  else
    Map(
      "Content-Type" -> "application/json",
      "Accept" -> "text/event-stream",
      "Authorization" -> ("Bearer " + endpoint.authToken)
    )

def requestBody(model: String, messages: List[String], tools: List[AgentTool],
                options: RunOptions): String =
  requestBodyWithStream(model, messages, tools, options, false)

def requestBodyWithStream(model: String, messages: List[String], tools: List[AgentTool],
                          options: RunOptions, stream: Boolean): String =
  jObj(List(
    jField("model", jStr(model)),
    jField("messages", jArr(messages)),
    jField("tools", jArr(tools.map(t => toolRequestJson(t)))),
    jField("tool_choice", jStr(options.toolChoice)),
    jField("temperature", jNum(options.temperature.toString)),
    jField("max_tokens", jNum(options.maxTokens.toString)),
    jField("stream", jBool(stream))
  ))

def toolRequestJson(tool: AgentTool): String =
  jObj(List(
    jField("type", jStr("function")),
    jField("function", jObj(List(
      jField("name", jStr(tool.name)),
      jField("description", jStr(tool.description)),
      jField("parameters", tool.parametersJson)
    )))
  ))

def appendToolResults(calls: List[JsonValue], tools: List[AgentTool],
                      messages: List[String], ops: List[ExecutedOp]): (List[String], List[ExecutedOp]) =
  calls match
    case Nil => (messages, ops)
    case call :: rest =>
      val id = call.get("id").asString
      val fn = call.get("function")
      val name = fn.get("name").asString
      val args = normalizedArgs(fn.get("arguments").asString)
      val result = dispatchTool(tools, name, args)
      val msg = toolResultMessage(id, result)
      val op = ExecutedOp(name, args, result.contentJson, result.isError)
      appendToolResults(rest, tools, messages :+ msg, ops :+ op)

def appendStreamingToolResults(calls: List[PendingToolCall], tools: List[AgentTool],
                               messages: List[String], ops: List[ExecutedOp],
                               events: List[AgentEvent],
                               onEvent: AgentEvent => Unit): ToolDispatchStep =
  calls match
    case Nil => ToolDispatchStep(messages, ops, events)
    case call :: rest =>
      val args = normalizedArgs(call.argsJson)
      val result = dispatchTool(tools, call.name, args)
      val nextEvents = emitEvent(events, AgentEvent("ToolCallResult", tool = call.name,
        argsJson = args, resultJson = result.contentJson, isError = result.isError), onEvent)
      val msg = toolResultMessage(call.id, result)
      val op = ExecutedOp(call.name, args, result.contentJson, result.isError)
      appendStreamingToolResults(rest, tools, messages :+ msg, ops :+ op, nextEvents, onEvent)

def handleStreamLine(line: String, pending: List[PendingToolCall], text: String,
                     finishReason: String, streamError: String,
                     events: List[AgentEvent],
                     onEvent: AgentEvent => Unit): StreamStep =
  if !line.startsWith("data:") then
    StreamStep(text, pending, finishReason, streamError, events)
  else
    val data = line.substring(5).trim
    if data == "" || data == "[DONE]" then
      StreamStep(text, pending, finishReason, streamError, events)
    else
      val root = jsonValue(data)
      val errorMessage = root.get("error").get("message").asString
      if errorMessage != "" then
        val nextEvents = emitEvent(events, AgentEvent("Errored", text = errorMessage), onEvent)
        StreamStep(text, pending, finishReason, errorMessage, nextEvents)
      else
        val choice = root.get("choices").at(0)
        val delta = choice.get("delta")
        val content = delta.get("content").asString
        var nextText = text
        var nextEvents = events
        if content != "" then
          nextText = text + content
          nextEvents = emitEvent(events, AgentEvent("TextDelta", text = content), onEvent)
        val toolStep = applyToolCallDeltas(delta.get("tool_calls").asList, pending, nextEvents, onEvent)
        val finish = choice.get("finish_reason").asString
        val nextFinish = if finish != "" then finish else finishReason
        StreamStep(nextText, toolStep.toolCalls, nextFinish, streamError, toolStep.events)

def applyToolCallDeltas(deltas: List[JsonValue], pending: List[PendingToolCall],
                        events: List[AgentEvent],
                        onEvent: AgentEvent => Unit): ToolDeltaStep =
  deltas match
    case Nil => ToolDeltaStep(pending, events)
    case delta :: rest =>
      val next = applyToolCallDelta(delta, pending, events, onEvent)
      applyToolCallDeltas(rest, next.toolCalls, next.events, onEvent)

def applyToolCallDelta(delta: JsonValue, pending: List[PendingToolCall],
                       events: List[AgentEvent],
                       onEvent: AgentEvent => Unit): ToolDeltaStep =
  val index = delta.get("index").asInt
  val existing = pendingToolCall(pending, index)
  val fn = delta.get("function")
  val id = delta.get("id").asString
  val name = fn.get("name").asString
  val argsDelta = fn.get("arguments").asString
  val nextId = if id == "" then existing.id else id
  val nextName = if name == "" then existing.name else name
  val updated = PendingToolCall(index, nextId, nextName, existing.argsJson + argsDelta)
  val startedEvents =
    if existing.id == "" && existing.name == "" && (nextId != "" || nextName != "") then
      emitEvent(events, AgentEvent("ToolCallStarted", tool = nextName), onEvent)
    else
      events
  val deltaEvents =
    if argsDelta != "" then
      emitEvent(startedEvents, AgentEvent("ToolCallDelta", tool = nextName, argsJson = argsDelta), onEvent)
    else
      startedEvents
  ToolDeltaStep(upsertPendingToolCall(pending, updated), deltaEvents)

def pendingToolCall(calls: List[PendingToolCall], index: Long): PendingToolCall =
  calls.find(call => call.index == index) match
    case Some(call) => call
    case None => PendingToolCall(index, "", "", "")

def upsertPendingToolCall(calls: List[PendingToolCall], updated: PendingToolCall): List[PendingToolCall] =
  calls match
    case Nil => List(updated)
    case head :: tail =>
      if head.index == updated.index then updated :: tail
      else head :: upsertPendingToolCall(tail, updated)

def normalizedArgs(args: String): String =
  if args == "" then "{}" else args

def dispatchTool(tools: List[AgentTool], name: String, argsJson: String): ToolResult =
  tools.find(t => t.name == name) match
    case Some(tool) =>
      try tool.handler(argsJson)
      catch case e: Throwable =>
        toolError("tool '" + name + "' failed: " + e.getMessage)
    case None =>
      toolError("unknown tool: " + name)

def systemMessage(content: String): String =
  roleContentMessage("system", content)

def userMessage(content: String): String =
  roleContentMessage("user", content)

def assistantTextMessage(content: String): String =
  roleContentMessage("assistant", content)

def roleContentMessage(role: String, content: String): String =
  jObj(List(jField("role", jStr(role)), jField("content", jStr(content))))

def assistantToolCallsMessage(toolCalls: JsonValue): String =
  jObj(List(
    jField("role", jStr("assistant")),
    jField("tool_calls", toolCalls.raw)
  ))

def assistantPendingToolCallsMessage(toolCalls: List[PendingToolCall]): String =
  jObj(List(
    jField("role", jStr("assistant")),
    jField("tool_calls", jArr(toolCalls.map(call => pendingToolCallJson(call))))
  ))

def pendingToolCallJson(call: PendingToolCall): String =
  jObj(List(
    jField("id", jStr(call.id)),
    jField("type", jStr("function")),
    jField("function", jObj(List(
      jField("name", jStr(call.name)),
      jField("arguments", jStr(normalizedArgs(call.argsJson)))
    )))
  ))

def toolResultMessage(callId: String, result: ToolResult): String =
  jObj(List(
    jField("role", jStr("tool")),
    jField("tool_call_id", jStr(callId)),
    jField("content", jStr(result.contentJson))
  ))
```
