#!/usr/bin/env bash
# ssc-js — ScalaScript → JavaScript transpiler (development launcher)
# Transpiles .ssc files to JavaScript and optionally runs them via Node.js.
#
# Usage:
#   ssc-js file.ssc            # print JS to stdout
#   ssc-js file.ssc | node     # run in Node.js
#   ssc-js --run file.ssc      # transpile and run in one step (requires node)
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPILER="$(dirname "$SCRIPT_DIR")/compiler"

RUN=false
FILES=()
for arg in "$@"; do
  case "$arg" in
    --run) RUN=true ;;
    *)     FILES+=("$arg") ;;
  esac
done

if $RUN; then
  exec scala-cli run "$COMPILER" -- emit-js "${FILES[@]}" | node
else
  exec scala-cli run "$COMPILER" -- emit-js "${FILES[@]}"
fi
